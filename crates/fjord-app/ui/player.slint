// ── fjord-app · player.slint ─────────────────────────────────────────────────
//   TrackPanel            reusable panel for Sub/Audio/Video track selection; kb-y/changed scroll,
//                         optional "Off" row (has-off-row), hover rows, mouse-wheel via Flickable
//   video frame           mpv render output (AppState.video-frame Image)
//   skip-intro prompt     floating overlay shown during intro window
//   volume overlay        top-center toast; shows level bar + %; auto-hides after 1.5 s
//   Up Next banner        shown at credits_start or dur-30s; Play Now / Skip buttons
//   buffering overlay     centered pill shown when mpv stalls (paused-for-cache); shows % fill bar
//   controls bar          gradient fade bg; title+ends-at row; seek row with buffered layer,
//                         hover-expand bar/thumb, tooltip; transport buttons left | track buttons right
//   pause/play flash      84 px circle with ▶/⏸ icon; fades out 600 ms after pause toggle
//   stats overlay         video/audio codec, sync ratios, SPEED (A+V corrections), DROP (VO/decoder/mistimed), bitrate, cache
//   TrackPanel (×3)       subtitle (panel-id=1, has-off-row), audio (2), video (3)
//   cursor hider          full-size TouchArea; enabled when controls hidden; tracks cursor pos
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, TrackEntry } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, StatRow } from "widgets.slint";

// ── Reusable track-selection panel (Sub / Audio / Video) ─────────────────────
// Positioned above the controls bar; keyboard scroll via kb-y/changed pattern;
// mouse-wheel via native Flickable. has-off-row adds an "Off" entry at index 0.
component TrackPanel inherits Rectangle {
    in property <string>       title;
    in property <[TrackEntry]> tracks;
    in property <int>          current-id: -1;
    in property <bool>         has-off-row: false;
    // Container dimensions passed from the instantiation site (parent.height / parent.width).
    // Needed because Slint blocks `parent` access in component root-level property bindings.
    in property <length>       container-h;
    in property <length>       container-w;
    callback track-selected(int);

    height:        min(panel-list.preferred-height + 16px, container-h - 158px - 40px);
    y:             container-h - 158px - self.height - 8px;
    x:             container-w - self.width - 16px;
    width:         min(container-w - 32px, 400px);
    background:    #0e0e0eee;
    border-radius: Theme.radius-lg;
    clip:          true;

    property <length> kb-y: clamp(
        -(AppState.player-panel-cursor * 34px) + self.height / 2 - 17px,
        min(0px, self.height - panel-list.preferred-height),
        0px
    );
    changed kb-y => { panel-fl.viewport-y = kb-y; }

    panel-fl := Flickable {
        height:          parent.height;
        viewport-width:  parent.width;
        viewport-height: panel-list.preferred-height;

        panel-list := VerticalLayout {
            padding: 8px;
            spacing: 2px;

            Text {
                text:        root.title;
                color:       Theme.accent;
                font-size:   11px;
                font-weight: 700;
                height:      24px;
            }

            if root.has-off-row: Rectangle {
                height:        32px;
                border-radius: Theme.radius;
                background:    { let hov = off-ta.has-hover;
                                  AppState.player-panel-cursor == 0 ? Theme.surface-overlay
                                : root.current-id == 0              ? Theme.accent-muted
                                : hov                               ? Theme.surface
                                :                                      transparent };
                HorizontalLayout {
                    padding-left: 10px; padding-right: 10px;
                    alignment: center;
                    Text {
                        text:               "Off";
                        color:              root.current-id == 0 ? Theme.accent : Theme.text;
                        font-size:          12px;
                        vertical-alignment: center;
                    }
                }
                off-ta := TouchArea {
                    clicked => {
                        root.track-selected(0);
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                    }
                }
            }

            for t[i] in root.tracks: Rectangle {
                border-radius: Theme.radius;
                background:    { let hov = row-ta.has-hover;
                                  AppState.player-panel-cursor == i + (root.has-off-row ? 1 : 0) ? Theme.surface-overlay
                                : root.current-id == t.id                                         ? Theme.accent-muted
                                : hov                                                              ? Theme.surface
                                :                                                                    transparent };
                HorizontalLayout {
                    padding-top: 6px; padding-bottom: 6px; padding-left: 10px; padding-right: 10px;
                    Text {
                        text:               t.label;
                        color:              root.current-id == t.id ? Theme.accent : Theme.text;
                        font-size:          12px;
                        wrap:               word-wrap;
                        vertical-alignment: center;
                    }
                }
                row-ta := TouchArea {
                    clicked => {
                        root.track-selected(t.id);
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                    }
                }
            }
        }
    }
}

export component PlayerScreen inherits Rectangle {
    background: #000000;

    // ── pause/play flash state ────────────────────────────────────────────────
    property <float>  flash-opacity: 0.0;
    property <string> flash-icon:    "▶";
    property <bool>   _pause-mirror: AppState.is-paused;

    animate flash-opacity { duration: 600ms; easing: ease-out; }

    flash-timer := Timer {
        interval: 150ms;
        running:  false;
        triggered => {
            root.flash-opacity  = 0.0;
            self.running        = false;
        }
    }

    changed _pause-mirror => {
        if AppState.is-playing {
            root.flash-icon     = AppState.is-paused ? "⏸" : "▶";
            root.flash-opacity  = 1.0;
            flash-timer.running = true;
        }
    }

    // ── video frame ───────────────────────────────────────────────────────────
    Image {
        source:    AppState.video-frame;
        width:     parent.width;
        height:    parent.height;
        image-fit: contain;
    }

    TouchArea {
        width:        parent.width;
        height:       parent.height;
        mouse-cursor: AppState.controls-visible ? MouseCursor.default : MouseCursor.none;
        clicked        => { AppState.pause-play-toggle(); AppState.show-controls(); }
        double-clicked => { AppState.toggle-fullscreen(); }
        moved          => { AppState.show-controls(); }
        changed mouse-x => { AppState.player-cursor-x = self.mouse-x; AppState.show-controls(); }
        changed mouse-y => { AppState.player-cursor-y = self.mouse-y; AppState.show-controls(); }
    }

    // ── volume overlay ────────────────────────────────────────────────────────
    if AppState.show-volume-overlay: Rectangle {
        x:             (parent.width - self.width) / 2;
        y:             24px;
        width:         220px;
        height:        44px;
        border-radius: Theme.radius;
        background:    #0d0d0dcc;
        drop-shadow-blur:  10px;
        drop-shadow-color: #00000055;

        HorizontalLayout {
            padding-left:  14px;
            padding-right: 14px;
            padding-top:   0;
            padding-bottom: 0;
            spacing:       10px;
            alignment:     center;

            Text {
                text:               "Vol";
                color:              Theme.accent;
                font-size:          11px;
                font-weight:        700;
                vertical-alignment: center;
                width:              24px;
            }

            if !AppState.audio-passthrough-active: Rectangle {
                height:             6px;
                horizontal-stretch: 1;
                background:         #444444;
                border-radius:      3px;

                Rectangle {
                    x:             0;
                    width:         parent.width * AppState.volume-level / 100;
                    height:        parent.height;
                    background:    Theme.accent;
                    border-radius: 3px;
                }
            }

            if AppState.audio-passthrough-active: Text {
                text:               "passthrough";
                color:              Theme.text-subtle;
                font-size:          11px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            if !AppState.audio-passthrough-active: Text {
                text:               AppState.volume-level + "%";
                color:              #bbbbbb;
                font-size:          11px;
                vertical-alignment: center;
                width:              38px;
            }
        }
    }

    // ── skip-intro prompt ─────────────────────────────────────────────────────
    if AppState.show-skip-intro: Rectangle {
        x:             parent.width - 170px - 16px;
        y:             parent.height - 158px - 50px;
        width:         170px;
        height:        40px;
        border-radius: Theme.radius;
        background:    Theme.accent;
        drop-shadow-blur:  10px;
        drop-shadow-color: #00000055;

        TouchArea {
            clicked => { AppState.skip-intro(); }
        }
        Text {
            text:                 "Skip Intro →";
            color:                #ffffff;
            font-size:            14px;
            font-weight:          700;
            horizontal-alignment: center;
            vertical-alignment:   center;
        }
    }

    // ── Up Next banner ────────────────────────────────────────────────────────
    if AppState.show-next-ep-banner: Rectangle {
        x:             parent.width - self.width - 16px;
        y:             parent.height - 158px - self.height - 16px;
        width:         300px;
        height:        banner-inner.preferred-height;
        border-radius: Theme.radius-lg;
        background:    #0d0d0ddd;
        drop-shadow-blur:  12px;
        drop-shadow-color: #00000066;

        banner-inner := VerticalLayout {
            padding:   16px;
            spacing:   10px;

            HorizontalLayout {
                Text {
                    text:        "Up Next  ·  " + AppState.next-ep-secs + "s";
                    color:       Theme.accent;
                    font-size:   11px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }

            Text {
                text:      AppState.next-ep-title;
                color:     #ffffff;
                font-size: 13px;
                overflow:  elide;
            }

            HorizontalLayout {
                spacing: 8px;
                FjordButton {
                    text:  "Play Now";
                    clicked => { AppState.play-next-ep(); }
                }
                FjordButton {
                    text:  "Skip";
                    clicked => { AppState.cancel-auto-advance(); }
                }
            }
        }
    }

    // ── buffering overlay ─────────────────────────────────────────────────────
    if AppState.buffering-active: Rectangle {
        x:             (parent.width - self.width) / 2;
        y:             (parent.height - self.height) / 2;
        width:         180px;
        height:        56px;
        border-radius: Theme.radius-lg;
        background:    #0d0d0dcc;
        drop-shadow-blur:  10px;
        drop-shadow-color: #00000055;

        VerticalLayout {
            padding:   14px;
            spacing:   8px;
            alignment: center;

            Text {
                text:                 "Buffering  " + AppState.buffering-pct + "%";
                color:                Theme.text;
                font-size:            13px;
                horizontal-alignment: center;
            }

            Rectangle {
                height:        3px;
                background:    #444444;
                border-radius: 2px;
                property <float> fill: AppState.buffering-pct * 0.01;
                Rectangle {
                    x:             0;
                    width:         parent.width * parent.fill;
                    height:        parent.height;
                    background:    Theme.accent;
                    border-radius: 2px;
                }
            }
        }
    }

    // ── controls bar ──────────────────────────────────────────────────────────
    ctrl-bar := Rectangle {
        y:          parent.height - self.height;
        height:     158px;
        background: @linear-gradient(180deg, #00000000 0%, #000000bb 45%, #000000ee 100%);
        opacity:    AppState.controls-visible ? 1.0 : 0.0;
        animate opacity { duration: 300ms; }

        VerticalLayout {
            padding:   12px;
            spacing:   9px;
            alignment: center;

            // ── Title row: title left, "Ends at" right ────────────────────────
            HorizontalLayout {
                spacing: 12px;
                Text {
                    text:                 AppState.playing-title;
                    color:                #ffffff;
                    font-size:            13px;
                    overflow:             elide;
                    horizontal-stretch:   1;
                    vertical-alignment:   center;
                }
                if AppState.playback-ends-at != "": Text {
                    text:               "Ends " + AppState.playback-ends-at;
                    color:              #cccccc;
                    font-size:          12px;
                    vertical-alignment: center;
                }
            }

            // ── Seek row: current-time | track (with tooltip) | total ─────────
            HorizontalLayout {
                spacing: 8px;

                Text {
                    text:               AppState.playback-time;
                    color:              #cccccc;
                    font-size:          12px;
                    width:              54px;
                    vertical-alignment: center;
                }

                seek-track := Rectangle {
                    height:             20px;
                    horizontal-stretch: 1;

                    property <length> bar-h:   seek-ta.has-hover || seek-ta.pressed ? 8px : 4px;
                    property <length> thumb-s: seek-ta.has-hover || seek-ta.pressed ? 16px : 12px;
                    animate bar-h   { duration: 100ms; easing: ease-out; }
                    animate thumb-s { duration: 100ms; easing: ease-out; }

                    // Visual position during drag — updated every mouse-move; falls
                    // back to playback-pos when not pressed so the thumb tracks mpv.
                    property <float> drag-ratio: 0.0;
                    property <float> display-pos: seek-ta.pressed ? seek-track.drag-ratio : AppState.playback-pos;

                    // Visual track bar (expands on hover)
                    Rectangle {
                        y:             (parent.height - self.height) / 2;
                        height:        seek-track.bar-h;
                        background:    #444444;
                        border-radius: seek-track.bar-h / 2;

                        // Buffered layer
                        Rectangle {
                            x:             0;
                            width:         AppState.buffered-pos * parent.width;
                            height:        parent.height;
                            background:    #666666;
                            border-radius: seek-track.bar-h / 2;
                        }
                        // Played layer
                        Rectangle {
                            x:             0;
                            width:         seek-track.display-pos * parent.width;
                            height:        parent.height;
                            background:    Theme.accent;
                            border-radius: seek-track.bar-h / 2;
                        }
                    }

                    // Thumb knob (expands on hover)
                    Rectangle {
                        x:             seek-track.display-pos * seek-track.width - seek-track.thumb-s / 2;
                        y:             (parent.height - self.height) / 2;
                        width:         seek-track.thumb-s;
                        height:        seek-track.thumb-s;
                        border-radius: seek-track.thumb-s / 2;
                        background:    #ffffff;
                    }

                    // Hover time tooltip
                    if seek-ta.has-hover && AppState.seek-hover-time != "": Rectangle {
                        x:             clamp(seek-ta.mouse-x - 26px, 0px, seek-track.width - 52px);
                        y:             -30px;
                        width:         52px;
                        height:        22px;
                        background:    #0d0d0ddd;
                        border-radius: 4px;
                        Text {
                            text:                 AppState.seek-hover-time;
                            color:                #ffffff;
                            font-size:            11px;
                            horizontal-alignment: center;
                            vertical-alignment:   center;
                        }
                    }

                    seek-ta := TouchArea {
                        changed mouse-x => {
                            AppState.update-seek-hover(max(0, min(1, seek-ta.mouse-x / seek-track.width)));
                        }
                        clicked => {
                            AppState.seek-to(max(0, min(1, seek-ta.mouse-x / seek-track.width)));
                        }
                        moved => {
                            seek-track.drag-ratio = max(0, min(1, seek-ta.mouse-x / seek-track.width));
                            AppState.show-controls();
                            AppState.seek-to(seek-track.drag-ratio);
                        }
                        pointer-event(e) => {
                            if e.button == PointerEventButton.left && e.kind == PointerEventKind.up {
                                AppState.seek-committed(max(0, min(1, seek-ta.mouse-x / seek-track.width)));
                            }
                        }
                    }
                }

                Text {
                    text:                 AppState.playback-total;
                    color:                #888888;
                    font-size:            12px;
                    width:                54px;
                    horizontal-alignment: right;
                    vertical-alignment:   center;
                }
            }

            // ── Buttons row ──────────────────────────────────────────────────
            // Two overlaid full-width layouts: transport truly centered,
            // track/meta pinned to the right. Each gets width:parent.width so
            // alignment works against the full bar width, not content width.
            Rectangle {
                HorizontalLayout {
                    width:     parent.width;
                    alignment: center;
                    spacing:   8px;
                    FjordButton { text: "← Back";  width: 76px;  clicked => { AppState.minimize-player(); } }
                    FjordButton { text: "◀◀ 30s";  width: 80px;  clicked => { AppState.seek-backward-long(); } }
                    FjordButton {
                        text:  AppState.is-paused ? "▶ Play" : "⏸ Pause";
                        width: 80px;
                        clicked => { AppState.pause-play-toggle(); }
                    }
                    FjordButton { text: "30s ▶▶";  width: 80px;  clicked => { AppState.seek-forward-long(); } }
                    FjordButton { text: "■ Stop";   width: 72px;  danger: true; clicked => { AppState.stop-playback(); } }
                }
                HorizontalLayout {
                    width:     parent.width;
                    alignment: end;
                    spacing:   8px;
                    FjordButton {
                        text:  "Sub ▾";
                        width: 68px;
                        clicked => {
                            AppState.player-open-panel   = AppState.player-open-panel == 1 ? 0 : 1;
                            AppState.player-panel-cursor = 0;
                        }
                    }
                    FjordButton {
                        text:  "Audio ▾";
                        width: 76px;
                        clicked => {
                            AppState.player-open-panel   = AppState.player-open-panel == 2 ? 0 : 2;
                            AppState.player-panel-cursor = 0;
                        }
                    }
                    FjordButton {
                        text:  "Video ▾";
                        width: 76px;
                        clicked => {
                            AppState.player-open-panel   = AppState.player-open-panel == 3 ? 0 : 3;
                            AppState.player-panel-cursor = 0;
                        }
                    }
                    FjordButton {
                        text:  AppState.stats-visible ? "Hide Stats" : "Stats";
                        width: 82px;
                        clicked => { AppState.toggle-stats(); }
                    }
                }
            }
        }
    }

    // ── stats overlay ─────────────────────────────────────────────────────────
    if AppState.stats-visible: Rectangle {
        x:             parent.width - self.width - 16px;
        y:             16px;
        width:         420px;
        height:        stats-inner.preferred-height;
        background:    #0d0d0dcc;
        border-radius: Theme.radius;

        stats-inner := VerticalLayout {
            padding:   16px;
            spacing:   0px;

            Text {
                text:           "VIDEO";
                color:          Theme.accent;
                font-size:      10px;
                font-weight:    700;
                letter-spacing: 1.2px;
                height:         20px;
            }
            StatRow { label: "IN";    value: AppState.stat-vid-in;  }
            StatRow { label: "OUT";   value: AppState.stat-vid-out; }
            StatRow { label: "COLOR"; value: AppState.stat-color;   }
            StatRow { label: "HWDEC"; value: AppState.stat-hwdec;   }

            Rectangle { height: 12px; }

            Text {
                text:           "AUDIO";
                color:          Theme.accent;
                font-size:      10px;
                font-weight:    700;
                letter-spacing: 1.2px;
                height:         20px;
            }
            StatRow { label: "IN";  value: AppState.stat-aud-in;  }
            StatRow { label: "OUT"; value: AppState.stat-aud-out; }

            Rectangle { height: 12px; }

            Text {
                text:           "SYNC";
                color:          Theme.accent;
                font-size:      10px;
                font-weight:    700;
                letter-spacing: 1.2px;
                height:         20px;
            }
            StatRow { label: "DISPLAY"; value: AppState.stat-display; }
            StatRow { label: "VSYNC";   value: AppState.stat-vsync;   }
            StatRow { label: "A/V";     value: AppState.stat-avsync;  }
            StatRow { label: "SPEED";   value: AppState.stat-speed;   }
            StatRow { label: "DROP";    value: AppState.stat-drop;    }
            StatRow { label: "BITRATE"; value: AppState.stat-bitrate; }
            StatRow { label: "CACHE";   value: AppState.stat-cache;   }
        }
    }

    // ── subtitle track panel (S key) ─────────────────────────────────────────
    if AppState.player-open-panel == 1: TrackPanel {
        container-h: parent.height;
        container-w: parent.width;
        title:       "Subtitles";
        tracks:      AppState.sub-tracks;
        current-id:  AppState.current-sub-id;
        has-off-row: true;
        track-selected(id) => {
            AppState.select-sub(id);
            AppState.current-sub-id = id;
        }
    }

    // ── audio track panel (A key) ─────────────────────────────────────────────
    if AppState.player-open-panel == 2: TrackPanel {
        container-h: parent.height;
        container-w: parent.width;
        title:      "Audio";
        tracks:     AppState.audio-tracks;
        current-id: AppState.current-audio-id;
        track-selected(id) => {
            AppState.select-audio(id);
            AppState.current-audio-id = id;
        }
    }

    // ── video track panel (V key) ─────────────────────────────────────────────
    if AppState.player-open-panel == 3: TrackPanel {
        container-h: parent.height;
        container-w: parent.width;
        title:      "Video";
        tracks:     AppState.video-tracks;
        current-id: AppState.current-video-id;
        track-selected(id) => {
            AppState.select-video(id);
            AppState.current-video-id = id;
        }
    }

    // ── pause/play flash icon ─────────────────────────────────────────────────
    Rectangle {
        x:             (parent.width - self.width) / 2;
        y:             (parent.height - self.height) / 2;
        width:         84px;
        height:        84px;
        border-radius: 42px;
        background:    #00000088;
        opacity:       root.flash-opacity;
        Text {
            text:                 root.flash-icon;
            font-size:            34px;
            color:                #ffffff;
            horizontal-alignment: center;
            vertical-alignment:   center;
        }
    }

    // ── cursor hider ──────────────────────────────────────────────────────────
    TouchArea {
        width:        parent.width;
        height:       parent.height;
        enabled:      !AppState.controls-visible;
        mouse-cursor: MouseCursor.none;
        clicked         => { AppState.show-controls(); AppState.pause-play-toggle(); }
        changed mouse-x => { AppState.player-cursor-x = self.mouse-x; AppState.show-controls(); }
        changed mouse-y => { AppState.player-cursor-y = self.mouse-y; AppState.show-controls(); }
    }
}
