// ── fjord-app · player.slint ─────────────────────────────────────────────────
//   TrackPanel            reusable panel for Sub/Audio/Video/Chapter track selection; kb-y/changed scroll,
//                         optional "Off" row (has-off-row), hover rows, mouse-wheel via Flickable
//   video frame           mpv render output (AppState.video-frame Image)
//   skip-segment prompt   floating "Skip →" button for ask mode; Enter confirms
//   skip-timed prompt     two-button overlay for ask-timed mode: "Skip" + "Don't Skip" + countdown
//                         Left/Right toggle focus; Enter activates; Back/Esc dismisses
//   chapter OSD           top-left pill (y:24px); shows chapter name for ~2 s after , / . nav
//   delay OSD             top-left pill (y:68px); shows "Sub/Audio delay: ±N ms" for ~2 s after z/Z/x/X
//   Up Next banner        shown at credits_start or dur-30s; Play Now / Skip buttons; next-ep-ends-at "Ends HH:MM"
//   buffering overlay     centered pill; "Loading…" during initial load, "Buffering N%" + bar mid-stall;
//                         always rendered, animates opacity in/out (350ms fade) so it doesn't snap
//   controls bar          single bar: full (158px, controls-visible) or mini (52px, pause/seek).
//                         Full: gradient fade, title+ends-at row; seek row; buttons row.
//                         Mini: seek row only; "Ends at" moved inline after total time.
//                         Seek row: left-time (seek-bar-time during accumulation), buffered/played
//                         layers, chapter tick marks (2px), hover-expand bar/thumb, tooltip;
//                         display-pos = drag-ratio | seek-bar-pos (accumulation) | playback-pos.
//                         transport left | Ch ▾ (panel-id=4, conditional) | Sync ▾ (panel-id=5) |
//                         Sub ▾ (1) | Audio ▾ (2) | Video ▾ (3) | Stats right (full only).
//   pause/play flash      84 px circle with ▶/⏸ icon; fades out 600 ms after pause toggle
//   stats overlay         video/audio codec, sync ratios, SPEED (A+V corrections), DROP (VO/decoder/mistimed), bitrate, cache
//   TrackPanel (×4)       subtitle (panel-id=1, has-off-row), audio (2), video (3), chapters (4, no off-row)
//   sync panel (id=5)     custom panel: Sub −/+ | Audio −/+ with live delay display
//   cursor hider          full-size TouchArea; enabled when controls hidden; tracks cursor pos
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, TrackEntry } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, StatRow, LoadingSpinner, FadeInTrigger, PressPulse } from "widgets.slint";

// ── Reusable track-selection panel (Sub / Audio / Video) ─────────────────────
// Positioned above the controls bar; keyboard scroll via kb-y/changed pattern;
// mouse-wheel via native Flickable. has-off-row adds an "Off" entry at index 0.
component TrackPanel inherits Rectangle {
    in property <string>       title;
    in property <[TrackEntry]> tracks;
    in property <int>          current-id: -1;
    in property <bool>         has-off-row: false;
    // Container dimensions passed from the instantiation site (parent.height / parent.width).
    // Needed because Slint blocks `parent` access in component root-level property bindings.
    in property <length>       container-h;
    in property <length>       container-w;
    callback track-selected(int);

    height:        min(panel-list.preferred-height + 16px, container-h - 158px - 40px);
    y:             container-h - 158px - self.height - 8px;
    x:             container-w - self.width - 16px;
    width:         min(container-w - 32px, 400px);
    background:    #0e0e0eee;
    border-radius: Theme.radius-lg;
    clip:          true;

    property <length> kb-y: clamp(
        -(AppState.player-panel-cursor * 34px) + self.height / 2 - 17px,
        min(0px, self.height - panel-list.preferred-height),
        0px
    );
    changed kb-y => { panel-fl.viewport-y = kb-y; }

    panel-fl := Flickable {
        height:          parent.height;
        viewport-width:  parent.width;
        viewport-height: panel-list.preferred-height;

        panel-list := VerticalLayout {
            padding: 8px;
            spacing: 2px;

            Text {
                text:        root.title;
                color:       Theme.accent;
                font-size:   11px;
                font-weight: 700;
                height:      24px;
            }

            if root.has-off-row: Rectangle {
                height:        32px;
                border-radius: Theme.radius;
                background:    { let hov = off-ta.has-hover;
                                  AppState.player-panel-cursor == 0 ? Theme.surface-overlay
                                : root.current-id == 0              ? Theme.accent-muted
                                : hov                               ? Theme.surface
                                :                                      transparent };
                border-width:  (off-ta.pressed || off-pulse.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                off-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.player-panel-cursor == 0; }
                HorizontalLayout {
                    padding-left: 10px; padding-right: 10px;
                    alignment: center;
                    Text {
                        text:               "Off";
                        color:              root.current-id == 0 ? Theme.accent : Theme.text;
                        font-size:          12px;
                        vertical-alignment: center;
                    }
                }
                off-ta := TouchArea {
                    clicked => {
                        root.track-selected(0);
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                    }
                }
            }

            for t[i] in root.tracks: Rectangle {
                border-radius: Theme.radius;
                background:    { let hov = row-ta.has-hover;
                                  AppState.player-panel-cursor == i + (root.has-off-row ? 1 : 0) ? Theme.surface-overlay
                                : root.current-id == t.id                                         ? Theme.accent-muted
                                : hov                                                              ? Theme.surface
                                :                                                                    transparent };
                border-width:  (row-ta.pressed || row-pulse.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                row-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.player-panel-cursor == i + (root.has-off-row ? 1 : 0); }
                HorizontalLayout {
                    padding-top: 6px; padding-bottom: 6px; padding-left: 10px; padding-right: 10px;
                    Text {
                        text:               t.label;
                        color:              root.current-id == t.id ? Theme.accent : Theme.text;
                        font-size:          12px;
                        wrap:               word-wrap;
                        vertical-alignment: center;
                    }
                }
                row-ta := TouchArea {
                    clicked => {
                        root.track-selected(t.id);
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                    }
                }
            }
        }
    }
}

export component PlayerScreen inherits Rectangle {
    background: #000000;

    // ── pause/play flash state ────────────────────────────────────────────────
    property <float>  flash-opacity: 0.0;
    property <string> flash-icon:    "▶";
    property <bool>   _pause-mirror: AppState.is-paused;

    animate flash-opacity { duration: 600ms; easing: ease-out; }

    flash-timer := Timer {
        interval: 150ms;
        running:  false;
        triggered => {
            root.flash-opacity  = 0.0;
            self.running        = false;
        }
    }

    changed _pause-mirror => {
        if AppState.is-playing {
            root.flash-icon     = AppState.is-paused ? "⏸" : "▶";
            root.flash-opacity  = 1.0;
            flash-timer.running = true;
        }
    }

    // ── video frame ───────────────────────────────────────────────────────────
    Image {
        source:    AppState.video-frame;
        width:     parent.width;
        height:    parent.height;
        image-fit: contain;
    }

    TouchArea {
        width:        parent.width;
        height:       parent.height;
        mouse-cursor: AppState.controls-visible ? MouseCursor.default : MouseCursor.none;
        clicked        => { AppState.pause-play-toggle(); AppState.show-controls(); }
        double-clicked => { AppState.toggle-fullscreen(); }
        moved          => { AppState.show-controls(); }
        changed mouse-x => { AppState.player-cursor-x = self.mouse-x; AppState.show-controls(); }
        changed mouse-y => { AppState.player-cursor-y = self.mouse-y; AppState.show-controls(); }
    }

    // Volume overlay moved to a shared VolumeOverlay component (widgets.slint),
    // instantiated once at the MainWindow level so it also shows over the music
    // bar / Now Playing screen — not just the fullscreen player.

    // ── chapter name OSD (top-left, ~2 s after , / . navigation) ─────────────
    if AppState.chapter-osd-visible: Rectangle {
        x:             16px;
        y:             24px;
        width:         clamp(80px, ch-osd-label.preferred-width + 44px, 360px);
        height:        36px;
        border-radius: Theme.radius;
        background:    #0d0d0dcc;
        drop-shadow-blur:  10px;
        drop-shadow-color: #00000055;

        HorizontalLayout {
            padding-left:  12px;
            padding-right: 14px;
            spacing:       8px;
            alignment:     center;
            Text {
                text:               "▸";
                color:              Theme.accent;
                font-size:          11px;
                font-weight:        700;
                vertical-alignment: center;
                width:              12px;
            }
            ch-osd-label := Text {
                text:               AppState.chapter-osd-text;
                color:              #ffffff;
                font-size:          12px;
                vertical-alignment: center;
            }
        }
    }

    // ── sub / audio delay OSD pill ────────────────────────────────────────────
    if AppState.delay-osd-visible: Rectangle {
        x:             16px;
        y:             68px;
        width:         clamp(80px, delay-osd-label.preferred-width + 44px, 360px);
        height:        36px;
        border-radius: Theme.radius;
        background:    #0d0d0dcc;
        drop-shadow-blur:  10px;
        drop-shadow-color: #00000055;

        HorizontalLayout {
            padding-left:  12px;
            padding-right: 14px;
            spacing:       8px;
            alignment:     center;
            Text {
                text:               "⏱";
                color:              Theme.accent;
                font-size:          11px;
                font-weight:        700;
                vertical-alignment: center;
                width:              12px;
            }
            delay-osd-label := Text {
                text:               AppState.delay-osd-text;
                color:              #ffffff;
                font-size:          12px;
                vertical-alignment: center;
            }
        }
    }

    // ── skip segment prompt (Intro / Recap / Preview / Commercial) ───────────
    if AppState.show-skip-segment: Rectangle {
        x:             parent.width - 170px - 16px;
        y:             parent.height - 158px - 50px;
        width:         170px;
        height:        40px;
        border-radius: Theme.radius;
        border-width:  (skip-ta.pressed || skip-pulse.pulsing) ? 5px : 2px;
        border-color:  #ffffff55;
        background:    Theme.accent;
        drop-shadow-blur:  10px;
        drop-shadow-color: #00000055;
        opacity: skip-fade.fade-opacity;
        animate opacity { duration: 150ms; easing: ease-out; }
        skip-fade := FadeInTrigger { }
        animate border-width { duration: 90ms; easing: ease-out; }
        skip-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: true; }

        skip-ta := TouchArea {
            clicked => { AppState.skip-segment(); }
        }
        Text {
            text:                 AppState.skip-segment-label;
            color:                #ffffff;
            font-size:            14px;
            font-weight:          700;
            horizontal-alignment: center;
            vertical-alignment:   center;
        }
    }

    // ── skip timed prompt (ask-timed mode: "Skip" + "Don't Skip" + countdown) ─
    if AppState.show-skip-timed: Rectangle {
        x:             parent.width - timed-inner.preferred-width - 16px;
        y:             parent.height - 158px - timed-inner.preferred-height - 8px;
        width:         timed-inner.preferred-width;
        height:        timed-inner.preferred-height;
        border-radius: Theme.radius-lg;
        background:    #0d0d0ddd;
        drop-shadow-blur:  10px;
        drop-shadow-color: #00000055;
        opacity: timed-fade.fade-opacity;
        animate opacity { duration: 150ms; easing: ease-out; }
        timed-fade := FadeInTrigger { }

        timed-inner := VerticalLayout {
            padding: 12px;
            spacing: 8px;

            Text {
                text:        AppState.skip-timed-label + "  ·  " + AppState.skip-timed-secs + "s";
                color:       Theme.accent;
                font-size:   13px;
                font-weight: 700;
            }

            HorizontalLayout {
                spacing: 8px;
                FjordButton {
                    text:        "Skip";
                    kbd-focused: AppState.skip-timed-focused == 0;
                    clicked => { AppState.skip-segment(); }
                }
                FjordButton {
                    text:        "Don't Skip";
                    kbd-focused: AppState.skip-timed-focused == 1;
                    clicked => { AppState.dismiss-skip-timed(); }
                }
            }
        }
    }

    // ── Up Next banner ────────────────────────────────────────────────────────
    if AppState.show-next-ep-banner: Rectangle {
        x:             parent.width - self.width - 16px;
        y:             parent.height - 158px - self.height - 16px;
        width:         300px;
        height:        banner-inner.preferred-height;
        border-radius: Theme.radius-lg;
        background:    #0d0d0ddd;
        drop-shadow-blur:  12px;
        drop-shadow-color: #00000066;
        opacity: banner-fade.fade-opacity;
        animate opacity { duration: 150ms; easing: ease-out; }
        banner-fade := FadeInTrigger { }

        banner-inner := VerticalLayout {
            padding:   16px;
            spacing:   10px;

            HorizontalLayout {
                Text {
                    text:        "Up Next  ·  " + AppState.next-ep-secs + "s";
                    color:       Theme.accent;
                    font-size:   11px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                if AppState.next-ep-ends-at != "": Text {
                    text:               "Ends " + AppState.next-ep-ends-at;
                    color:              #cccccc;
                    font-size:          11px;
                    vertical-alignment: center;
                }
            }

            Text {
                text:      AppState.next-ep-title;
                color:     #ffffff;
                font-size: 13px;
                overflow:  elide;
            }

            HorizontalLayout {
                spacing: 8px;
                FjordButton {
                    text:        "Play Now";
                    kbd-focused: AppState.next-ep-banner-focused == 0;
                    clicked => { AppState.play-next-ep(); }
                }
                FjordButton {
                    text:        "Skip";
                    kbd-focused: AppState.next-ep-banner-focused == 1;
                    clicked => { AppState.cancel-auto-advance(); }
                }
            }
        }
    }

    // ── buffering overlay ─────────────────────────────────────────────────────
    // Always rendered; animates opacity in/out so it fades rather than snapping.
    // Shows "Loading…" (no bar) when pct=0 (initial HDD spin-up), "Buffering N%"
    // + fill bar when mpv is actually stalled mid-playback.
    Rectangle {
        x:             (parent.width - self.width) / 2;
        y:             (parent.height - self.height) / 2;
        width:         180px;
        height:        buf-inner.preferred-height;
        border-radius: Theme.radius-lg;
        background:    #0d0d0dcc;
        drop-shadow-blur:  10px;
        drop-shadow-color: #00000055;

        property <float> buf-opacity: AppState.buffering-active ? 1.0 : 0.0;
        animate buf-opacity { duration: 350ms; easing: ease-out; }
        opacity: self.buf-opacity;

        buf-inner := VerticalLayout {
            padding:   14px;
            spacing:   8px;
            alignment: center;

            if AppState.buffering-pct == 0: LoadingSpinner { }

            if AppState.buffering-pct > 0: Text {
                text:                 "Buffering  " + AppState.buffering-pct + "%";
                color:                Theme.text;
                font-size:            13px;
                horizontal-alignment: center;
            }

            if AppState.buffering-pct > 0: Rectangle {
                height:        3px;
                background:    #444444;
                border-radius: 2px;
                property <float> fill: AppState.buffering-pct * 0.01;
                Rectangle {
                    x:             0;
                    width:         parent.width * parent.fill;
                    height:        parent.height;
                    background:    Theme.accent;
                    border-radius: 2px;
                }
            }
        }
    }

    // ── controls bar ──────────────────────────────────────────────────────────
    ctrl-bar := Rectangle {
        y:          parent.height - self.height;
        // Collapses to 52 px in mini mode (pause / keyboard seek) — title + buttons hidden.
        height:     AppState.controls-visible ? 158px : 52px;
        background: @linear-gradient(180deg, #00000000 0%, #000000bb 45%, #000000ee 100%);
        // visible removes children from hit-testing when hidden; opacity alone keeps
        // TouchAreas active (Slint gotcha: opacity:0 ≠ non-interactive).
        visible:    AppState.controls-visible || AppState.pause-bar-visible || AppState.seek-osd-visible;
        opacity:    (AppState.controls-visible || AppState.pause-bar-visible || AppState.seek-osd-visible) ? 1.0 : 0.0;
        animate opacity { duration: 300ms; }

        VerticalLayout {
            padding:   12px;
            spacing:   9px;
            alignment: center;

            // ── Title row (full controls only) ───────────────────────────────
            if AppState.controls-visible: HorizontalLayout {
                spacing: 12px;
                Text {
                    text:                 AppState.playing-title;
                    color:                #ffffff;
                    font-size:            13px;
                    overflow:             elide;
                    horizontal-stretch:   1;
                    vertical-alignment:   center;
                }
                if AppState.playback-ends-at != "": Text {
                    text:               "Ends " + AppState.playback-ends-at;
                    color:              #cccccc;
                    font-size:          12px;
                    vertical-alignment: center;
                }
            }

            // ── Seek row: current-time | track (with tooltip) | total ─────────
            HorizontalLayout {
                spacing: 8px;

                Text {
                    // During seek accumulation show the target time; otherwise current position.
                    text:               AppState.seek-osd-visible ? AppState.seek-bar-time : AppState.playback-time;
                    color:              #cccccc;
                    font-size:          12px;
                    width:              54px;
                    vertical-alignment: center;
                }

                seek-track := Rectangle {
                    height:             20px;
                    horizontal-stretch: 1;

                    property <length> bar-h:   seek-ta.has-hover || seek-ta.pressed ? 8px : 4px;
                    property <length> thumb-s: seek-ta.has-hover || seek-ta.pressed ? 16px : 12px;
                    animate bar-h   { duration: 100ms; easing: ease-out; }
                    animate thumb-s { duration: 100ms; easing: ease-out; }

                    // Visual position during drag — updated every mouse-move; falls
                    // back to playback-pos when not pressed so the thumb tracks mpv.
                    property <float> drag-ratio:  0.0;
                    property <bool>  is-dragging: false;
                    // Use is-dragging (not pressed) so display-pos holds drag-ratio
                    // until the pointer-event(up) handler has run and the Rust seek-committed
                    // callback has already set playback-pos to the new position.
                    // During keyboard seek accumulation, show the target position.
                    property <float> display-pos: seek-track.is-dragging ? seek-track.drag-ratio
                        : AppState.seek-osd-visible ? AppState.seek-bar-pos
                        : AppState.playback-pos;

                    // Visual track bar (expands on hover)
                    Rectangle {
                        y:             (parent.height - self.height) / 2;
                        height:        seek-track.bar-h;
                        background:    #444444;
                        border-radius: seek-track.bar-h / 2;

                        // Buffered layer
                        Rectangle {
                            x:             0;
                            width:         AppState.buffered-pos * parent.width;
                            height:        parent.height;
                            background:    #666666;
                            border-radius: seek-track.bar-h / 2;
                        }
                        // Played layer
                        Rectangle {
                            x:             0;
                            width:         seek-track.display-pos * parent.width;
                            height:        parent.height;
                            background:    Theme.accent;
                            border-radius: seek-track.bar-h / 2;
                        }
                    }

                    // Chapter tick marks
                    for mark in AppState.chapter-marks: Rectangle {
                        x:             mark * seek-track.width - 1px;
                        y:             (parent.height - self.height) / 2;
                        width:         2px;
                        height:        parent.bar-h + 4px;
                        background:    #ffffff66;
                        border-radius: 1px;
                    }

                    // Thumb knob (expands on hover)
                    Rectangle {
                        x:             seek-track.display-pos * seek-track.width - seek-track.thumb-s / 2;
                        y:             (parent.height - self.height) / 2;
                        width:         seek-track.thumb-s;
                        height:        seek-track.thumb-s;
                        border-radius: seek-track.thumb-s / 2;
                        background:    #ffffff;
                    }

                    // Hover time tooltip
                    if seek-ta.has-hover && AppState.seek-hover-time != "": Rectangle {
                        x:             clamp(seek-ta.mouse-x - 26px, 0px, seek-track.width - 52px);
                        y:             -30px;
                        width:         52px;
                        height:        22px;
                        background:    #0d0d0ddd;
                        border-radius: 4px;
                        Text {
                            text:                 AppState.seek-hover-time;
                            color:                #ffffff;
                            font-size:            11px;
                            horizontal-alignment: center;
                            vertical-alignment:   center;
                        }
                    }

                    seek-ta := TouchArea {
                        changed mouse-x => {
                            AppState.update-seek-hover(max(0, min(1, seek-ta.mouse-x / seek-track.width)));
                        }
                        // During drag: update visual position and keep controls visible.
                        // On first move (is-dragging still false) call seek-drag-started so
                        // Rust pauses mpv — the video freezes during scrubbing.
                        moved => {
                            if !seek-track.is-dragging {
                                AppState.seek-drag-started();
                                AppState.seek-dragging = true;
                            }
                            seek-track.drag-ratio  = max(0, min(1, seek-ta.mouse-x / seek-track.width));
                            seek-track.is-dragging = true;
                            AppState.show-controls();
                        }
                        // pointer-event(up) is used instead of clicked so the drag always commits
                        // even when the pointer is released outside the seek-ta bounds (clicked only
                        // fires within bounds). Plain click (no drag): seek-to the clicked position.
                        pointer-event(event) => {
                            if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                                if seek-track.is-dragging {
                                    AppState.seek-committed(seek-track.drag-ratio);
                                } else {
                                    AppState.seek-to(max(0, min(1, seek-ta.mouse-x / seek-track.width)));
                                }
                                seek-track.is-dragging = false;
                                AppState.seek-dragging = false;
                            }
                        }
                    }
                }

                Text {
                    text:                 AppState.playback-total;
                    color:                #888888;
                    font-size:            12px;
                    width:                54px;
                    horizontal-alignment: right;
                    vertical-alignment:   center;
                }
                // "Ends at" in mini mode (title row is hidden, so show it here instead)
                if !AppState.controls-visible && AppState.playback-ends-at != "": Text {
                    text:               "Ends " + AppState.playback-ends-at;
                    color:              #aaaaaa;
                    font-size:          12px;
                    vertical-alignment: center;
                }
            }

            // ── Buttons row (full controls only) ─────────────────────────────
            // Two overlaid full-width layouts: transport truly centered,
            // track/meta pinned to the right. Each gets width:parent.width so
            // alignment works against the full bar width, not content width.
            if AppState.controls-visible: Rectangle {
                HorizontalLayout {
                    width:     parent.width;
                    alignment: center;
                    spacing:   8px;
                    FjordButton { text: "← Back";  width: 76px;  clicked => { AppState.minimize-player(); } }
                    FjordButton { text: "◀◀ 30s";  width: 80px;  clicked => { AppState.seek-backward-long(); } }
                    FjordButton {
                        text:  AppState.is-paused ? "▶ Play" : "⏸ Pause";
                        width: 80px;
                        clicked => { AppState.pause-play-toggle(); }
                    }
                    FjordButton { text: "30s ▶▶";  width: 80px;  clicked => { AppState.seek-forward-long(); } }
                    FjordButton { text: "■ Stop";   width: 72px;  danger: true; clicked => { AppState.stop-playback(); } }
                }
                HorizontalLayout {
                    width:     parent.width;
                    alignment: end;
                    spacing:   8px;
                    if AppState.chapter-entries.length > 0: FjordButton {
                        text:  "Ch ▾";
                        width: 60px;
                        clicked => {
                            AppState.player-open-panel   = AppState.player-open-panel == 4 ? 0 : 4;
                            AppState.player-panel-cursor = AppState.current-chapter.max(0);
                        }
                    }
                    FjordButton {
                        text:  "Sync ▾";
                        width: 70px;
                        clicked => {
                            AppState.player-open-panel = AppState.player-open-panel == 5 ? 0 : 5;
                        }
                    }
                    FjordButton {
                        text:  "Sub ▾";
                        width: 68px;
                        clicked => {
                            AppState.player-open-panel   = AppState.player-open-panel == 1 ? 0 : 1;
                            AppState.player-panel-cursor = 0;
                        }
                    }
                    FjordButton {
                        text:  "Audio ▾";
                        width: 76px;
                        clicked => {
                            AppState.player-open-panel   = AppState.player-open-panel == 2 ? 0 : 2;
                            AppState.player-panel-cursor = 0;
                        }
                    }
                    FjordButton {
                        text:  "Video ▾";
                        width: 76px;
                        clicked => {
                            AppState.player-open-panel   = AppState.player-open-panel == 3 ? 0 : 3;
                            AppState.player-panel-cursor = 0;
                        }
                    }
                    FjordButton {
                        text:  AppState.stats-visible ? "Hide Stats" : "Stats";
                        width: 82px;
                        clicked => { AppState.toggle-stats(); }
                    }
                }
            }
        }
    }

    // ── seek delta pill (centered, seek accumulation only) ───────────────────────
    // Shows accumulated seek amount (e.g. "+30s", "−1:30") in a centered pill
    // while keyboard seek is being accumulated. Hidden once the seek fires.
    if AppState.seek-osd-visible && !AppState.controls-visible: Rectangle {
        x:             (parent.width  - self.width)  / 2;
        y:             (parent.height - self.height) / 2;
        width:         max(delta-txt.preferred-width, target-txt.preferred-width) + 48px;
        height:        seek-pill-inner.preferred-height;
        border-radius: Theme.radius-lg;
        background:    #0d0d0dcc;
        drop-shadow-blur:  12px;
        drop-shadow-color: #00000066;

        seek-pill-inner := VerticalLayout {
            padding:   14px;
            spacing:   4px;
            alignment: center;

            delta-txt := Text {
                text:                 AppState.seek-delta-text;
                color:                #ffffff;
                font-size:            22px;
                font-weight:          700;
                horizontal-alignment: center;
            }
            target-txt := Text {
                text:                 "→  " + AppState.seek-bar-time;
                color:                #aaaaaa;
                font-size:            13px;
                horizontal-alignment: center;
            }
        }
    }

    // ── stats overlay ─────────────────────────────────────────────────────────
    if AppState.stats-visible: Rectangle {
        x:             parent.width - self.width - 16px;
        y:             16px;
        width:         420px;
        height:        stats-inner.preferred-height;
        background:    #0d0d0dcc;
        border-radius: Theme.radius;

        stats-inner := VerticalLayout {
            padding:   16px;
            spacing:   0px;

            Text {
                text:           "VIDEO";
                color:          Theme.accent;
                font-size:      10px;
                font-weight:    700;
                letter-spacing: 1.2px;
                height:         20px;
            }
            StatRow { label: "IN";    value: AppState.stat-vid-in;  }
            StatRow { label: "OUT";   value: AppState.stat-vid-out; }
            StatRow { label: "COLOR"; value: AppState.stat-color;   }
            StatRow { label: "HWDEC"; value: AppState.stat-hwdec;   }

            Rectangle { height: 12px; }

            Text {
                text:           "AUDIO";
                color:          Theme.accent;
                font-size:      10px;
                font-weight:    700;
                letter-spacing: 1.2px;
                height:         20px;
            }
            StatRow { label: "IN";  value: AppState.stat-aud-in;  }
            StatRow { label: "OUT"; value: AppState.stat-aud-out; }

            Rectangle { height: 12px; }

            Text {
                text:           "SYNC";
                color:          Theme.accent;
                font-size:      10px;
                font-weight:    700;
                letter-spacing: 1.2px;
                height:         20px;
            }
            StatRow { label: "DISPLAY"; value: AppState.stat-display; }
            StatRow { label: "VSYNC";   value: AppState.stat-vsync;   }
            StatRow { label: "A/V";     value: AppState.stat-avsync;  }
            StatRow { label: "SPEED";   value: AppState.stat-speed;   }
            StatRow { label: "DROP";    value: AppState.stat-drop;    }
            StatRow { label: "BITRATE"; value: AppState.stat-bitrate; }
            StatRow { label: "CACHE";   value: AppState.stat-cache;   }
        }
    }

    // ── subtitle track panel (S key) ─────────────────────────────────────────
    if AppState.player-open-panel == 1: TrackPanel {
        container-h: parent.height;
        container-w: parent.width;
        title:       "Subtitles";
        tracks:      AppState.sub-tracks;
        current-id:  AppState.current-sub-id;
        has-off-row: true;
        track-selected(id) => {
            AppState.select-sub(id);
            AppState.current-sub-id = id;
        }
    }

    // ── audio track panel (A key) ─────────────────────────────────────────────
    if AppState.player-open-panel == 2: TrackPanel {
        container-h: parent.height;
        container-w: parent.width;
        title:      "Audio";
        tracks:     AppState.audio-tracks;
        current-id: AppState.current-audio-id;
        track-selected(id) => {
            AppState.select-audio(id);
            AppState.current-audio-id = id;
        }
    }

    // ── video track panel (V key) ─────────────────────────────────────────────
    if AppState.player-open-panel == 3: TrackPanel {
        container-h: parent.height;
        container-w: parent.width;
        title:      "Video";
        tracks:     AppState.video-tracks;
        current-id: AppState.current-video-id;
        track-selected(id) => {
            AppState.select-video(id);
            AppState.current-video-id = id;
        }
    }

    // ── chapter panel (Ch ▾ button) ───────────────────────────────────────────
    if AppState.player-open-panel == 4: TrackPanel {
        container-h: parent.height;
        container-w: parent.width;
        title:       "Chapters";
        tracks:      AppState.chapter-entries;
        current-id:  AppState.current-chapter;
        track-selected(id) => {
            AppState.chapter-jump(id);
            AppState.player-open-panel   = 0;
            AppState.player-panel-cursor = 0;
        }
    }

    // ── sync panel (Sync ▾ button) — sub / audio delay +/- ───────────────────
    if AppState.player-open-panel == 5: Rectangle {
        y:             parent.height - 158px - self.height - 8px;
        x:             parent.width  - self.width - 16px;
        width:         min(parent.width - 32px, 300px);
        height:        sync-inner.preferred-height;
        background:    #0e0e0eee;
        border-radius: Theme.radius-lg;
        clip:          true;

        sync-inner := VerticalLayout {
            padding: 12px;
            spacing: 4px;

            Text {
                text:           "SYNC";
                color:          Theme.accent;
                font-size:      11px;
                font-weight:    700;
                letter-spacing: 1.2px;
                height:         24px;
            }

            // Sub delay row
            HorizontalLayout {
                height:  36px;
                spacing: 6px;
                alignment: center;
                Text {
                    text:               "Sub";
                    color:              Theme.text-subtle;
                    font-size:          12px;
                    vertical-alignment: center;
                    width:              34px;
                }
                FjordButton {
                    text:    "−100ms";
                    width:   72px;
                    clicked => { AppState.sub-delay-dec(); }
                }
                Text {
                    text:                 (AppState.sub-delay-ms >= 0 ? "+" : "") + AppState.sub-delay-ms + " ms";
                    color:                AppState.sub-delay-ms == 0 ? Theme.text-subtle : Theme.accent;
                    font-size:            12px;
                    font-weight:          700;
                    vertical-alignment:   center;
                    horizontal-alignment: center;
                    width:                72px;
                }
                FjordButton {
                    text:    "+100ms";
                    width:   72px;
                    clicked => { AppState.sub-delay-inc(); }
                }
            }

            // Audio delay row
            HorizontalLayout {
                height:  36px;
                spacing: 6px;
                alignment: center;
                Text {
                    text:               "Audio";
                    color:              Theme.text-subtle;
                    font-size:          12px;
                    vertical-alignment: center;
                    width:              34px;
                }
                FjordButton {
                    text:    "−100ms";
                    width:   72px;
                    clicked => { AppState.audio-delay-dec(); }
                }
                Text {
                    text:                 (AppState.audio-delay-ms >= 0 ? "+" : "") + AppState.audio-delay-ms + " ms";
                    color:                AppState.audio-delay-ms == 0 ? Theme.text-subtle : Theme.accent;
                    font-size:            12px;
                    font-weight:          700;
                    vertical-alignment:   center;
                    horizontal-alignment: center;
                    width:                72px;
                }
                FjordButton {
                    text:    "+100ms";
                    width:   72px;
                    clicked => { AppState.audio-delay-inc(); }
                }
            }
        }
    }

    // ── pause/play flash icon ─────────────────────────────────────────────────
    Rectangle {
        x:             (parent.width - self.width) / 2;
        y:             (parent.height - self.height) / 2;
        width:         84px;
        height:        84px;
        border-radius: 42px;
        background:    #00000088;
        opacity:       root.flash-opacity;
        Text {
            text:                 root.flash-icon;
            font-size:            34px;
            color:                #ffffff;
            horizontal-alignment: center;
            vertical-alignment:   center;
        }
    }

    // ── cursor hider ──────────────────────────────────────────────────────────
    // Also disabled while seek-track.is-dragging: if the controls-bar idle timer
    // fires mid-drag the cursor-hider would otherwise steal the mouse-up, calling
    // pause-play-toggle() and preventing seek-committed from firing on seek-ta.
    TouchArea {
        width:        parent.width;
        height:       parent.height;
        enabled:      !AppState.controls-visible && !AppState.pause-bar-visible && !AppState.seek-osd-visible && !seek-track.is-dragging;
        mouse-cursor: MouseCursor.none;
        clicked         => { AppState.show-controls(); AppState.pause-play-toggle(); }
        changed mouse-x => { AppState.player-cursor-x = self.mouse-x; AppState.show-controls(); }
        changed mouse-y => { AppState.player-cursor-y = self.mouse-y; AppState.show-controls(); }
    }
}
