// ── fjord-app · player.slint ─────────────────────────────────────────────────
//   video frame           mpv render output (AppState.video-frame Image)
//   skip-intro prompt     floating overlay shown during intro window
//   controls bar          progress track, timestamps, playback buttons, volume
//   stats overlay         video/audio codec, sync ratios, bitrate, cache
//   audio track panel     AppState.player-open-panel == 1
//   subtitle track panel  AppState.player-open-panel == 2
//   video track panel     AppState.player-open-panel == 3
//   cursor hider          full-size TouchArea; enabled when controls are hidden
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, TrackEntry } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, StatRow } from "widgets.slint";

export component PlayerScreen inherits Rectangle {
    background: #000000;

    // ── video frame ───────────────────────────────────────────────────────────
    Image {
        source:    AppState.video-frame;
        width:     parent.width;
        height:    parent.height;
        image-fit: contain;
    }

    TouchArea {
        width:        parent.width;
        height:       parent.height;
        mouse-cursor: AppState.controls-visible ? MouseCursor.default : MouseCursor.none;
        clicked => {
            AppState.pause-play-toggle();
            AppState.show-controls();
        }
        moved => { AppState.show-controls(); }
        changed mouse-x => { AppState.show-controls(); }
        changed mouse-y => { AppState.show-controls(); }
    }

    // ── skip-intro prompt ─────────────────────────────────────────────────────
    if AppState.show-skip-intro: Rectangle {
        x:             parent.width - 170px - 16px;
        y:             parent.height - 158px - 50px;
        width:         170px;
        height:        40px;
        border-radius: Theme.radius;
        background:    Theme.accent;
        drop-shadow-blur:  10px;
        drop-shadow-color: #00000055;

        TouchArea {
            clicked => { AppState.skip-intro(); }
        }
        Text {
            text:                 "Skip Intro →";
            color:                #ffffff;
            font-size:            14px;
            font-weight:          700;
            horizontal-alignment: center;
            vertical-alignment:   center;
        }
    }

    // ── controls bar ──────────────────────────────────────────────────────────
    ctrl-bar := Rectangle {
        y:          parent.height - self.height;
        height:     158px;
        background: #000000dd;
        opacity:    AppState.controls-visible ? 1.0 : 0.0;
        animate opacity { duration: 300ms; }

        VerticalLayout {
            padding:   12px;
            spacing:   9px;
            alignment: center;

            Text {
                text:                 AppState.playing-title;
                color:                #ffffff;
                font-size:            13px;
                overflow:             elide;
                horizontal-alignment: center;
            }

            HorizontalLayout {
                spacing: 10px;
                alignment: center;

                seek-track := Rectangle {
                    height:             6px;
                    horizontal-stretch: 1;
                    background:         #444444;
                    border-radius:      3px;

                    Rectangle {
                        x:             0;
                        width:         AppState.playback-pos * parent.width;
                        height:        parent.height;
                        background:    Theme.accent;
                        border-radius: 3px;
                    }
                    Rectangle {
                        x:             AppState.playback-pos * parent.width - 7px;
                        y:             -5px;
                        width:         14px;
                        height:        14px;
                        border-radius: 7px;
                        background:    #ffffff;
                    }
                    seek-ta := TouchArea {
                        clicked => {
                            AppState.seek-to(max(0, min(1, seek-ta.mouse-x / seek-track.width)));
                        }
                        moved => {
                            if seek-ta.pressed {
                                AppState.seek-to(max(0, min(1, seek-ta.mouse-x / seek-track.width)));
                            }
                        }
                    }
                }

                Text {
                    text:      AppState.playback-time + " / " + AppState.playback-total;
                    color:     #bbbbbb;
                    font-size: 12px;
                    width:     108px;
                }
            }

            HorizontalLayout {
                alignment: center;
                spacing:   8px;

                FjordButton { text: "← Back";  width: 76px;  clicked => { AppState.minimize-player(); } }
                FjordButton { text: "◀◀ 30s";  width: 80px;  clicked => { AppState.seek-backward-long(); } }
                FjordButton {
                    text:  AppState.is-paused ? "▶ Play" : "⏸ Pause";
                    width: 80px;
                    clicked => { AppState.pause-play-toggle(); }
                }
                FjordButton { text: "30s ▶▶";  width: 80px;  clicked => { AppState.seek-forward-long(); } }
                FjordButton { text: "■ Stop";   width: 72px;  danger: true; clicked => { AppState.stop-playback(); } }

                FjordButton {
                    text:  "Sub ▾";
                    width: 68px;
                    clicked => {
                        AppState.player-open-panel   = AppState.player-open-panel == 1 ? 0 : 1;
                        AppState.player-panel-cursor = 0;
                    }
                }
                FjordButton {
                    text:  "Audio ▾";
                    width: 76px;
                    clicked => {
                        AppState.player-open-panel   = AppState.player-open-panel == 2 ? 0 : 2;
                        AppState.player-panel-cursor = 0;
                    }
                }
                FjordButton {
                    text:  "Video ▾";
                    width: 76px;
                    clicked => {
                        AppState.player-open-panel   = AppState.player-open-panel == 3 ? 0 : 3;
                        AppState.player-panel-cursor = 0;
                    }
                }
                FjordButton {
                    text:  AppState.stats-visible ? "Hide Stats" : "Stats";
                    width: 82px;
                    clicked => { AppState.toggle-stats(); }
                }
            }
        }
    }

    // ── stats overlay ─────────────────────────────────────────────────────────
    if AppState.stats-visible: Rectangle {
        x:             parent.width - self.width - 16px;
        y:             16px;
        width:         420px;
        height:        stats-inner.preferred-height;
        background:    #0d0d0dcc;
        border-radius: Theme.radius;

        stats-inner := VerticalLayout {
            padding:   16px;
            spacing:   0px;

            Text {
                text:        "Playback Stats";
                color:       Theme.accent;
                font-size:   12px;
                font-weight: 700;
                height:      22px;
            }
            Rectangle { height: 1px; background: #2a2a2a; }
            Rectangle { height: 8px; }

            StatRow { label: "VID IN";   value: AppState.stat-vid-in;  }
            StatRow { label: "VID OUT";  value: AppState.stat-vid-out; }
            StatRow { label: "COLOR";    value: AppState.stat-color;   }
            StatRow { label: "HWDEC";    value: AppState.stat-hwdec;   }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: #1f1f1f; }
            Rectangle { height: 6px; }

            StatRow { label: "AUD IN";   value: AppState.stat-aud-in;  }
            StatRow { label: "AUD OUT";  value: AppState.stat-aud-out; }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: #1f1f1f; }
            Rectangle { height: 6px; }

            StatRow { label: "DISPLAY";  value: AppState.stat-display; }
            StatRow { label: "VSYNC";    value: AppState.stat-vsync;   }
            StatRow { label: "A/V";      value: AppState.stat-avsync;  }
            StatRow { label: "DROP";     value: AppState.stat-drop;    }
            StatRow { label: "BITRATE";  value: AppState.stat-bitrate; }
            StatRow { label: "CACHE";    value: AppState.stat-cache;   }
        }
    }

    // ── audio track panel ─────────────────────────────────────────────────────
    if AppState.player-open-panel == 1: Rectangle {
        y:             parent.height - ctrl-bar.height - sub-panel-inner.preferred-height - 24px;
        x:             parent.width - self.width - 16px;
        width:         220px;
        height:        sub-panel-inner.preferred-height + 16px;
        background:    #0e0e0eee;
        border-radius: Theme.radius-lg;

        sub-panel-inner := VerticalLayout {
            padding: 8px;
            spacing: 2px;

            Text {
                text:        "Subtitles";
                color:       Theme.accent;
                font-size:   11px;
                font-weight: 700;
                height:      24px;
            }

            Rectangle {
                height:        32px;
                border-radius: Theme.radius;
                background:    AppState.player-panel-cursor == 0
                               ? Theme.surface-overlay
                               : (AppState.current-sub-id == 0 ? Theme.accent-muted : transparent);
                HorizontalLayout {
                    padding-left: 10px; padding-right: 10px;
                    alignment: center;
                    Text {
                        text:               "Off";
                        color:              AppState.current-sub-id == 0 ? Theme.accent : Theme.text;
                        font-size:          12px;
                        vertical-alignment: center;
                    }
                }
                TouchArea {
                    clicked => {
                        AppState.select-sub(0);
                        AppState.current-sub-id      = 0;
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                    }
                }
            }

            for t[i] in AppState.sub-tracks: Rectangle {
                height:        32px;
                border-radius: Theme.radius;
                background:    AppState.player-panel-cursor == i + 1
                               ? Theme.surface-overlay
                               : (AppState.current-sub-id == t.id ? Theme.accent-muted : transparent);
                HorizontalLayout {
                    padding-left: 10px; padding-right: 10px;
                    alignment: center;
                    Text {
                        text:               t.label;
                        color:              AppState.current-sub-id == t.id ? Theme.accent : Theme.text;
                        font-size:          12px;
                        overflow:           elide;
                        vertical-alignment: center;
                    }
                }
                TouchArea {
                    clicked => {
                        AppState.select-sub(t.id);
                        AppState.current-sub-id      = t.id;
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                    }
                }
            }
        }
    }

    // ── subtitle track panel ──────────────────────────────────────────────────
    if AppState.player-open-panel == 2: Rectangle {
        y:             parent.height - ctrl-bar.height - aud-panel-inner.preferred-height - 24px;
        x:             parent.width - self.width - 16px;
        width:         220px;
        height:        aud-panel-inner.preferred-height + 16px;
        background:    #0e0e0eee;
        border-radius: Theme.radius-lg;

        aud-panel-inner := VerticalLayout {
            padding: 8px;
            spacing: 2px;

            Text {
                text:        "Audio";
                color:       Theme.accent;
                font-size:   11px;
                font-weight: 700;
                height:      24px;
            }

            for t[i] in AppState.audio-tracks: Rectangle {
                height:        32px;
                border-radius: Theme.radius;
                background:    AppState.player-panel-cursor == i
                               ? Theme.surface-overlay
                               : (AppState.current-audio-id == t.id ? Theme.accent-muted : transparent);
                HorizontalLayout {
                    padding-left: 10px; padding-right: 10px;
                    alignment: center;
                    Text {
                        text:               t.label;
                        color:              AppState.current-audio-id == t.id ? Theme.accent : Theme.text;
                        font-size:          12px;
                        overflow:           elide;
                        vertical-alignment: center;
                    }
                }
                TouchArea {
                    clicked => {
                        AppState.select-audio(t.id);
                        AppState.current-audio-id    = t.id;
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                    }
                }
            }
        }
    }

    // ── video track panel ─────────────────────────────────────────────────────
    if AppState.player-open-panel == 3: Rectangle {
        y:             parent.height - ctrl-bar.height - vid-panel-inner.preferred-height - 24px;
        x:             parent.width - self.width - 16px;
        width:         220px;
        height:        vid-panel-inner.preferred-height + 16px;
        background:    #0e0e0eee;
        border-radius: Theme.radius-lg;

        vid-panel-inner := VerticalLayout {
            padding: 8px;
            spacing: 2px;

            Text {
                text:        "Video";
                color:       Theme.accent;
                font-size:   11px;
                font-weight: 700;
                height:      24px;
            }

            for t[i] in AppState.video-tracks: Rectangle {
                height:        32px;
                border-radius: Theme.radius;
                background:    AppState.player-panel-cursor == i
                               ? Theme.surface-overlay
                               : (AppState.current-video-id == t.id ? Theme.accent-muted : transparent);
                HorizontalLayout {
                    padding-left: 10px; padding-right: 10px;
                    alignment: center;
                    Text {
                        text:               t.label;
                        color:              AppState.current-video-id == t.id ? Theme.accent : Theme.text;
                        font-size:          12px;
                        overflow:           elide;
                        vertical-alignment: center;
                    }
                }
                TouchArea {
                    clicked => {
                        AppState.select-video(t.id);
                        AppState.current-video-id    = t.id;
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                    }
                }
            }
        }
    }

    // ── cursor hider ──────────────────────────────────────────────────────────
    TouchArea {
        width:        parent.width;
        height:       parent.height;
        enabled:      !AppState.controls-visible;
        mouse-cursor: MouseCursor.none;
        clicked         => { AppState.show-controls(); AppState.pause-play-toggle(); }
        changed mouse-x => { AppState.show-controls(); }
        changed mouse-y => { AppState.show-controls(); }
    }
}
