// ── fjord-app · widgets.slint ────────────────────────────────────────────────
//   FjordButton        accent / danger push button; kbd-focused draws white border ring
//   IconCircleButton   38px circle button; gray when inactive, accent when active; ♥/✓ icons
//   NavItem            sidebar navigation row (icon + label + active indicator)
//   BrowseItem         single row in the browse / search list
//   MediaCard          poster card used in horizontal scroll rows and library grid; clicked + right-clicked callbacks; badges: ✓ played, count pill, ♥ favourite; animated white-tint hover overlay on top of poster image
//   LoadingSpinner     animated ring shown while content loads
//   StatRow            label + value row inside the stats overlay
//   ToggleSwitch       pill-shaped on/off toggle; checked <=> + toggled callback
//   SectionHeader      accent label + accent hairline to the right (settings section dividers)
//   SettingsDropdown   compact dropdown that sizes to current text; popup right-aligns with trigger
//   SettingsRow        standard settings row: title + subtitle left, @children right, focus highlight + hover
//                      row-index must match the PLY_* / GEN_* constant in settings.rs
//                      section defaults to 1 (Player); pass section: 0 for General rows
//   BackdropHero       full-width 300 px backdrop image with bottom-to-bg fade gradient
//   PosterBlock        160×240 poster with rounded corners; placeholder when no image; badges: ✓ played, progress bar, unplayed count pill
//   MetaLine           year · runtime · rating + optional ★ community rating
//   CastRow            Flickable row of cast cards: portrait photo + name + role; focused-idx border ring;
//                      hover overlay; viewport-x tracks focused-idx for keyboard scroll
//   StorylineSection   collapsible overview block: "Storyline ▶" header; 3-line preview collapsed,
//                      full text expanded; click anywhere on header to toggle
//   MiniPlayerBar      full-width bottom bar; 108px in mode 3 (!video-behind-ui): live video + title + buttons;
//                      56px compact bar in mode 2 (video-behind-ui): NOW PLAYING + title + buttons (no thumbnail);
//                      float-card-focused (-1=none, 0=Resume, 1=Stop)
//   MusicPlayerBar     full-width bottom bar 72px; shown when is-audio-playing; three zones:
//                      left: album art 60×60 + title + artist (click → open-album);
//                      centre: ⏸/▶ pause/play · ⏹ stop · progress bar · elapsed / total;
//                      right: ♥ favourite (placeholder for Phase 50 controls)
//   ToastNotification  bottom-center error pill; message: string; auto-dismissed by Timer in main.slint
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, CardItem, CastMember } from "theme.slint";
import { AppState } from "app_state.slint";

// ── Accent button ─────────────────────────────────────────────────────────────
export component FjordButton inherits Rectangle {
    in property <string> text;
    in property <bool>   enabled:     true;
    in property <bool>   danger:      false;
    in property <bool>   kbd-focused: false;
    callback clicked;

    height:        38px;
    border-radius: Theme.radius;
    border-width:  kbd-focused ? 2px : 0px;
    border-color:  #ffffff99;
    background: !enabled      ? Theme.surface-raised
              : ta.has-hover  ? (danger ? #c53030 : Theme.accent-hover)
              :                  (danger ? Theme.error : Theme.accent);

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
    Text {
        text:                 root.text;
        color:                root.enabled ? #ffffff : Theme.text-subtle;
        font-size:            14px;
        font-weight:          600;
        horizontal-alignment: center;
        vertical-alignment:   center;
    }
}

// ── Circle icon button (♥ fav / ✓ watched) ───────────────────────────────────
export component IconCircleButton inherits Rectangle {
    in property <string> icon;
    in property <bool>   active:      false;
    in property <bool>   kbd-focused: false;
    callback clicked;

    width:         38px;
    height:        38px;
    border-radius: 19px;
    border-width:  kbd-focused ? 2px : 0px;
    border-color:  #ffffff99;
    background: active       ? Theme.accent
              : ta.has-hover ? Theme.surface-overlay
              :                Theme.surface-raised;

    Text {
        x:                    0;
        y:                    0;
        width:                parent.width;
        height:               parent.height;
        text:                 root.icon;
        color:                #ffffff;
        font-size:            20px;
        font-weight:          600;
        horizontal-alignment: center;
        vertical-alignment:   center;
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

// ── Sidebar nav row ───────────────────────────────────────────────────────────
export component NavItem inherits Rectangle {
    in property <string> label;
    in property <bool>   active: false;
    in property <bool>   kbd-focused: false;
    callback clicked;
    callback double-clicked;

    height: 40px;
    border-radius: Theme.radius;
    background: active && kbd-focused ? Theme.accent
              : active                ? Theme.accent-muted
              : ta.has-hover          ? Theme.surface-raised
              :                         #00000000;

    ta := TouchArea {
        clicked        => { root.clicked(); }
        double-clicked => { root.double-clicked(); }
    }

    HorizontalLayout {
        padding-left: 14px;
        spacing:      10px;
        alignment:    start;

        Rectangle {
            width: 6px;
            Rectangle {
                width:         6px;
                height:        6px;
                border-radius: 3px;
                y:             (parent.height - self.height) / 2;
                background:    active ? Theme.accent : Theme.text-subtle;
            }
        }
        Text {
            text:               label;
            color:              active ? Theme.text : Theme.text-muted;
            font-size:          14px;
            font-weight:        active ? 600 : 400;
            vertical-alignment: center;
        }
    }
}

// ── Browse-screen list row ────────────────────────────────────────────────────
export component BrowseItem inherits Rectangle {
    in property <string> text;
    in property <bool>   selected: false;
    callback clicked;
    callback activated;
    callback right-clicked;

    height: 42px;
    border-radius: Theme.radius;
    background: { let hov = ta.has-hover; selected ? Theme.accent-muted : (hov ? Theme.surface-raised : #00000000) };

    ta := TouchArea {
        clicked        => { root.clicked(); }
        double-clicked => { root.activated(); }
        pointer-event(e) => {
            if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                root.right-clicked();
            }
        }
    }
    HorizontalLayout {
        padding-left:  10px;
        padding-right: 12px;
        spacing:        8px;
        alignment:      start;

        Rectangle {
            width:         3px;
            height:        20px;
            y:             (parent.height - self.height) / 2;
            border-radius: 1.5px;
            background:    selected ? Theme.accent : #00000000;
        }
        Text {
            text:               root.text;
            color:              selected ? Theme.text : Theme.text-muted;
            font-size:          14px;
            overflow:           elide;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

// ── Poster card (used inside horizontal scroll rows) ──────────────────────────
export component MediaCard inherits Rectangle {
    in property <CardItem> item;
    in property <bool>     focused: false;
    callback clicked;
    callback right-clicked;

    width:          140px;
    height:         224px;
    border-radius:  Theme.radius;
    border-width:   focused ? 2px : 0px;
    border-color:   Theme.accent;
    background:     #00000000;

    VerticalLayout {
        spacing: 6px;

        poster-rect := Rectangle {
            height:        root.height - 54px;
            border-radius: Theme.radius;
            background:    Theme.surface-raised;
            clip:          true;

            if item.has-poster: Image {
                source:    item.poster;
                width:     parent.width;
                height:    parent.height;
                image-fit: cover;
            }

            if !item.has-poster: Text {
                text:                 item.title;
                color:                Theme.text-muted;
                font-size:            11px;
                wrap:                 word-wrap;
                horizontal-alignment: center;
                vertical-alignment:   center;
                x:                    6px;
                width:                parent.width - 12px;
            }

            // In-progress bar at bottom of poster
            if item.resume-pct > 0 && !item.has-played: Rectangle {
                y:          parent.height - 3px;
                height:     3px;
                background: Theme.surface-overlay;
                Rectangle {
                    x:          0;
                    width:      parent.width * item.resume-pct;
                    height:     parent.height;
                    background: Theme.accent;
                }
            }

            // Favourite heart badge
            if item.is-favorite: Rectangle {
                x:             4px;
                y:             4px;
                width:         24px;
                height:        24px;
                border-radius: 12px;
                background:    Theme.accent;
                Text {
                    text:                 "❤";
                    color:                #ffffff;
                    font-size:            14px;
                    font-weight:          900;
                    horizontal-alignment: center;
                    vertical-alignment:   center;
                }
            }

            // Watched checkmark badge
            if item.has-played: Rectangle {
                x:             parent.width - 28px;
                y:             4px;
                width:         24px;
                height:        24px;
                border-radius: 12px;
                background:    Theme.accent;
                Text {
                    text:                 "✓";
                    color:                #ffffff;
                    font-size:            18px;
                    font-weight:          900;
                    horizontal-alignment: center;
                    vertical-alignment:   center;
                }
            }

            // Unseen episode count badge (series)
            if item.unplayed-count > 0 && !item.has-played: Rectangle {
                x:             parent.width - 28px;
                y:             4px;
                width:         24px;
                height:        24px;
                border-radius: 12px;
                background:    Theme.accent;
                Text {
                    text:                 "\{item.unplayed-count}";
                    color:                #ffffff;
                    font-size:            11px;
                    font-weight:          900;
                    horizontal-alignment: center;
                    vertical-alignment:   center;
                }
            }

            // Hover highlight — on top of image and badges so it is visible even
            // when a poster image fills the rectangle.
            Rectangle {
                background: #ffffff1a;
                opacity:    ta.has-hover ? 1.0 : 0.0;
                animate opacity { duration: 120ms; easing: ease; }
            }
        }

        VerticalLayout {
            spacing: 2px;

            Text {
                text:      item.title;
                color:     Theme.text;
                font-size: 12px;
                overflow:  elide;
                height:    30px;
                wrap:      word-wrap;
            }
            if item.year > 0: Text {
                text:      "\{item.year}";
                color:     Theme.text-muted;
                font-size: 10px;
            }
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
        pointer-event(e) => {
            if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                root.right-clicked();
            }
        }
    }
}

// ── Loading spinner ───────────────────────────────────────────────────────────
export component LoadingSpinner inherits Rectangle {
    height: 20px;

    property <int> step: 0;

    Timer {
        interval: 260ms;
        running:  true;
        triggered() => { step = step + 1 >= 3 ? 0 : step + 1; }
    }

    HorizontalLayout {
        alignment: center;
        spacing:   16px;
        height:    100%;

        for i in [0, 1, 2]: Rectangle {
            width:         20px;
            height:        20px;
            border-radius: 10px;
            background:    Theme.accent;
            opacity:       step == i ? 1.0 : 0.15;
            animate opacity { duration: 180ms; easing: ease-in-out; }
        }
    }
}

// ── Pill toggle switch ────────────────────────────────────────────────────────
export component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled;

    width:  52px;
    height: 28px;

    Rectangle {
        border-radius: parent.height / 2;
        background:    root.checked ? Theme.accent : Theme.surface-raised;
        border-width:  1.5px;
        border-color:  root.checked ? Theme.accent : Theme.border;
        animate background { duration: 140ms; easing: ease; }

        Rectangle {
            width:         22px;
            height:        22px;
            border-radius: 11px;
            background:    #ffffff;
            y:             (parent.height - self.height) / 2;
            x:             root.checked ? parent.width - self.width - 3px : 3px;
            animate x { duration: 140ms; easing: ease-in-out; }
            drop-shadow-blur:  4px;
            drop-shadow-color: #00000040;
        }
    }

    TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }
}

// ── Settings section divider (accent label + hairline) ────────────────────────
export component SectionHeader inherits Rectangle {
    in property <string> text;
    height: 28px;

    HorizontalLayout {
        spacing: 10px;
        alignment: start;
        Text {
            text:               root.text;
            color:              Theme.accent;
            font-size:          11px;
            font-weight:        700;
            vertical-alignment: center;
        }
        Rectangle {
            horizontal-stretch: 1;
            Rectangle {
                width:      parent.width;
                height:     1px;
                y:          (parent.height - 1px) / 2;
                background: Theme.accent;
                opacity:    0.3;
            }
        }
    }
}

// ── Settings dropdown (auto-sizes to current value; popup right-aligns) ───────
export component SettingsDropdown inherits Rectangle {
    in property <[string]> model;
    in-out property <string> current-value;
    callback selected(string);

    property <string> display-value: root.current-value != "" ? root.current-value : "(none)";
    // Cap popup height for long lists; Flickable handles overflow.
    property <length> pop-h: min(root.model.length * 32px + 8px, 320px);

    // Width tracks rendered text; capped so long descriptions don't overflow the settings row.
    width:         min(max(80px, val.preferred-width + chevron.preferred-width + 24px), 280px);
    height:        34px;
    border-radius: 6px;
    background:    ta.has-hover ? Theme.surface-overlay : Theme.surface-raised;
    border-width:  1px;
    border-color:  Theme.border;

    HorizontalLayout {
        padding-left:  10px;
        padding-right: 8px;
        spacing:        6px;
        alignment:      start;
        val := Text {
            text:               root.display-value;
            color:              Theme.text;
            font-size:          13px;
            vertical-alignment: center;
            overflow:           elide;
        }
        chevron := Text {
            text:               "▾";
            color:              Theme.text-muted;
            font-size:          10px;
            vertical-alignment: center;
        }
    }

    ta := TouchArea { clicked => { popup.show(); } }

    popup := PopupWindow {
        // Width grows to fit the widest item; right edge stays flush with the trigger.
        x:      root.width - self.width;
        y:      root.height + 2px;
        width:  min(max(root.width, items-layout.preferred-width + 8px), 700px);
        height: root.pop-h;

        Rectangle {
            background:        Theme.surface-raised;
            border-radius:     6px;
            border-width:      1px;
            border-color:      Theme.border;
            drop-shadow-blur:  8px;
            drop-shadow-color: #00000060;
            clip:              true;

            Flickable {
                viewport-height: root.model.length * 32px + 8px;
                items-layout := VerticalLayout {
                    padding: 4px;
                    for opt in root.model: Rectangle {
                        height:          32px;
                        border-radius:   4px;
                        preferred-width: opt-text.preferred-width + 20px;
                        background:      opt-ta.has-hover ? Theme.accent-muted : transparent;
                        opt-text := Text {
                            x:                  10px;
                            text:               opt != "" ? opt : "(none)";
                            color:              opt == root.current-value ? Theme.accent : Theme.text;
                            font-size:          13px;
                            font-weight:        opt == root.current-value ? 600 : 400;
                            vertical-alignment: center;
                            overflow:           elide;
                        }
                        opt-ta := TouchArea {
                            clicked => {
                                root.current-value = opt;
                                root.selected(opt);
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

// ── Settings content row ──────────────────────────────────────────────────────
// Standard two-column row: title+subtitle on the left, @children on the right.
// TouchArea (lower z) lets ToggleSwitch / SettingsDropdown children receive their
// own clicks while still tracking hover for the row highlight.
export component SettingsRow inherits Rectangle {
    in property <int>    row-index;
    in property <int>    section:  1;
    in property <string> title;
    in property <string> subtitle;
    in property <bool>   indent:   false;

    border-radius: Theme.radius;
    background: {
        let hov = ta.has-hover;
        AppState.settings-focused == row-index
            ? Theme.accent-muted
            : (hov ? Theme.surface : transparent)
    };

    ta := TouchArea {
        clicked => {
            AppState.settings-section = root.section;
            AppState.settings-focused = root.row-index;
        }
    }

    HorizontalLayout {
        padding-top:    12px;
        padding-bottom: 12px;
        padding-right:  12px;
        padding-left:   root.indent ? 28px : 12px;
        spacing: Theme.sp;
        alignment: space-between;
        VerticalLayout {
            spacing:            3px;
            horizontal-stretch: 1;
            Text { text: root.title;    color: Theme.text;       font-size: 14px; }
            Text { text: root.subtitle; color: Theme.text-muted; font-size: 12px; overflow: elide; }
        }
        @children
    }
}

// ── Detail page shared atoms ──────────────────────────────────────────────────

export component BackdropHero inherits Rectangle {
    in property <image> source;
    height: 300px;
    clip:   true;
    Image {
        source:    root.source;
        width:     parent.width;
        height:    parent.height;
        image-fit: cover;
    }
    Rectangle {
        background: @linear-gradient(180deg, transparent 20%, Theme.bg 100%);
    }
}

export component PosterBlock inherits Rectangle {
    in property <image> source;
    in property <bool>  has-image:      false;
    in property <bool>  has-played:     false;
    in property <float> resume-pct:     0.0;
    in property <int>   unplayed-count: 0;
    width:         160px;
    height:        240px;
    border-radius: Theme.radius;
    clip:          true;
    background:    Theme.surface-raised;
    if has-image: Image {
        source:    root.source;
        width:     parent.width;
        height:    parent.height;
        image-fit: cover;
    }
    // progress bar (resume)
    if root.resume-pct > 0.0 && !root.has-played: Rectangle {
        x: 0; y: parent.height - 4px;
        width:      parent.width * root.resume-pct;
        height:     4px;
        background: Theme.accent;
    }
    // ✓ played badge (top-right)
    if root.has-played: Rectangle {
        x: parent.width - 28px; y: 6px;
        width: 22px; height: 22px;
        border-radius: 11px;
        background: Theme.accent;
        Text { text: "✓"; color: white; font-size: 11px; font-weight: 700;
               horizontal-alignment: center; vertical-alignment: center;
               width: parent.width; height: parent.height; }
    }
    // unplayed-count pill (top-right, when no played badge)
    if root.unplayed-count > 0 && !root.has-played: Rectangle {
        x: parent.width - 28px; y: 6px;
        width: 22px; height: 22px;
        border-radius: 11px;
        background: Theme.accent;
        Text { text: root.unplayed-count; color: white; font-size: 11px; font-weight: 700;
               horizontal-alignment: center; vertical-alignment: center;
               width: parent.width; height: parent.height; }
    }
}

export component MetaLine inherits HorizontalLayout {
    in property <string> meta;
    in property <string> rating-label;
    spacing:   16px;
    alignment: start;
    Text {
        text:      root.meta;
        color:     Theme.text-muted;
        font-size: 14px;
    }
    if root.rating-label != "": Text {
        text:      root.rating-label;
        color:     #f5c518;
        font-size: 14px;
    }
}

export component CastRow inherits VerticalLayout {
    in property <[CastMember]> cast;
    in property <int>          focused-idx: -1;
    callback item-selected(/* idx */ int);
    spacing: 12px;

    // kb-x lives on CastRow (root), not on fl itself.
    // A property on a Flickable that reads self.width / self.viewport-width creates
    // a dependency cycle → "Recursion detected" panic (Slint gotcha). Reading
    // fl.width from the parent element is safe (no self-reference).
    property <length> kb-x: root.focused-idx <= 0 ? 0px
              : clamp(
                    -(root.focused-idx * 116px + 50px - fl.width / 2),
                    min(0px, fl.width - hbox.preferred-width),
                    0px
                );
    changed kb-x => { fl.viewport-x = kb-x; }

    Text { text: "Cast & Crew"; color: Theme.text; font-size: 16px; font-weight: 700; }

    // Flickable so keyboard navigation (viewport-x tracks focused-idx) scrolls the row.
    // Card stride = 100px width + 16px spacing = 116px.
    // kb-x drives viewport-x via changed callback; mouse-wheel scroll works natively.
    fl := Flickable {
        height:         162px;
        viewport-width: hbox.preferred-width;
        animate viewport-x { duration: 150ms; easing: ease-out; }

        hbox := HorizontalLayout {
            spacing:   16px;
            alignment: start;

            for c[i] in root.cast: VerticalLayout {
                width:   100px;
                spacing: 4px;

                // Single Rectangle with clip + border: Slint renders border on top of children
                // so the focus ring is always visible even when the photo fills the area.
                Rectangle {
                    height:        120px;
                    border-radius: Theme.radius;
                    border-width:  root.focused-idx == i ? 2px : 0px;
                    border-color:  Theme.accent;
                    background:    Theme.surface-raised;
                    clip:          true;

                    if c.has-photo: Image {
                        source:    c.photo;
                        width:     parent.width;
                        height:    parent.height;
                        image-fit: cover;
                    }

                    // Hover overlay — read has-hover before ternary to keep binding alive
                    Rectangle {
                        background: { let h = ta.has-hover; h ? #ffffff18 : transparent; }
                    }

                    ta := TouchArea {
                        clicked => { root.item-selected(i); }
                    }
                }

                Text { text: c.name; color: Theme.text;       font-size: 12px; font-weight: 600; overflow: elide; }
                Text { text: c.role; color: Theme.text-muted; font-size: 11px; overflow: elide; }
            }
        }
    }
}

// ── Collapsible storyline section ─────────────────────────────────────────────
export component StorylineSection inherits VerticalLayout {
    in property    <string> text;
    in-out property <bool>  expanded:    false;
    in property    <bool>   kbd-focused: false;

    hdr := Rectangle {
        height:        44px;
        background:    ta.has-hover ? Theme.surface : transparent;
        border-width:  root.kbd-focused ? 2px : 0px;
        border-color:  #ffffff99;
        border-radius: Theme.radius;

        HorizontalLayout {
            x: 0; y: 0; width: parent.width; height: parent.height;
            padding-left:  48px;
            padding-right: 48px;
            spacing:       8px;
            alignment:     start;
            Text {
                text:               "Overview";
                color:              Theme.text;
                font-size:          15px;
                font-weight:        600;
                vertical-alignment: center;
            }
            Text {
                text:               expanded ? "▼" : "▶";
                color:              Theme.text-muted;
                font-size:          13px;
                vertical-alignment: center;
            }
        }

        ta := TouchArea { clicked => { expanded = !expanded; } }
    }

    VerticalLayout {
        padding-left:   48px;
        padding-right:  48px;
        padding-bottom: 20px;

        // Single clipping Rectangle whose height animates between collapsed (66px)
        // and fully expanded (txt.preferred-height).  preferred-height is the text's
        // natural wrapped height at the given width — it doesn't feed into any layout
        // cycle because it reads the text content, not any allocated dimension.
        Rectangle {
            clip:   true;
            height: root.expanded ? max(txt.preferred-height, 66px) : 66px;
            animate height { duration: 200ms; easing: ease-in-out; }

            txt := Text {
                x:         0;
                y:         0;
                text:      root.text;
                color:     #cccccc;
                font-size: 15px;
                wrap:      word-wrap;
                width:     min(root.width - 96px, 640px);
            }
        }
    }
}

// ── Stats overlay row ─────────────────────────────────────────────────────────
export component StatRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    HorizontalLayout {
        padding-top:    2px;
        padding-bottom: 2px;
        spacing:        10px;
        Text {
            text:               label;
            color:              #555555;
            font-size:          11px;
            font-weight:        700;
            width:              60px;
            vertical-alignment: top;
        }
        Text {
            text:               value;
            color:              #cccccc;
            font-size:          11px;
            wrap:               word-wrap;
            horizontal-stretch: 1;
        }
    }
}

// ── Mini-player bar ───────────────────────────────────────────────────────────
// Full-width bar docked at the top by MainWindow (y=0, width=parent.width).
// Mode 3 (!video-behind-ui): 108px — live video (192×108, 16:9) + title + Resume/Stop.
// Mode 2 (video-behind-ui):   56px — compact bar (no thumbnail; video fills window) + title + Resume/Stop.
// float-card-focused: -1=not focused, 0=Resume, 1=Stop. Up from sidebar nav=0 to focus.
export component MiniPlayerBar inherits Rectangle {
    height:     AppState.video-behind-ui ? 56px : 108px;
    background: Theme.surface-raised;

    // Focus ring
    if AppState.float-card-focused >= 0: Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        border-width:  2px;
        border-color:  Theme.accent;
        border-radius: 0px;
        background:    transparent;
    }

    // ── Mode 3: live video + info ─────────────────────────────────────────────
    if !AppState.video-behind-ui: HorizontalLayout {
        Rectangle {
            width:      192px;
            background: #000000;
            clip:       true;
            Image {
                source:    AppState.video-frame;
                width:     parent.width;
                height:    parent.height;
                image-fit: contain;
            }
        }
        VerticalLayout {
            padding:   12px;
            spacing:   5px;
            alignment: center;
            Text { text: "NOW PLAYING"; color: Theme.accent; font-size: 9px; font-weight: 700; }
            Text { text: AppState.playing-title; color: Theme.text; font-size: 13px; overflow: elide; }
            HorizontalLayout {
                spacing: 6px; alignment: start;
                FjordButton {
                    text: "▶  Resume"; height: 28px; width: 120px;
                    kbd-focused: AppState.float-card-focused == 0;
                    clicked => { AppState.float-card-focused = -1; AppState.resume-player(); }
                }
                FjordButton {
                    text: "■  Stop"; height: 28px; width: 80px; danger: true;
                    kbd-focused: AppState.float-card-focused == 1;
                    clicked => { AppState.float-card-focused = -1; AppState.stop-playback(); }
                }
            }
        }
    }

    // ── Mode 2: compact 56px bar (video fills window; no thumbnail needed) ────
    if AppState.video-behind-ui: HorizontalLayout {
        padding: 12px; spacing: 8px;
        VerticalLayout {
            alignment: center; spacing: 3px; horizontal-stretch: 1;
            Text { text: "NOW PLAYING"; color: Theme.accent; font-size: 9px; font-weight: 700; }
            Text { text: AppState.playing-title; color: Theme.text; font-size: 13px; overflow: elide; }
        }
        HorizontalLayout {
            spacing: 6px; alignment: end;
            FjordButton {
                text: "▶  Resume"; height: 28px; width: 120px;
                kbd-focused: AppState.float-card-focused == 0;
                clicked => { AppState.float-card-focused = -1; AppState.resume-player(); }
            }
            FjordButton {
                text: "■  Stop"; height: 28px; width: 80px; danger: true;
                kbd-focused: AppState.float-card-focused == 1;
                clicked => { AppState.float-card-focused = -1; AppState.stop-playback(); }
            }
        }
    }
}

// ── Music player bar ──────────────────────────────────────────────────────────
export component MusicPlayerBar inherits Rectangle {
    height:     72px;
    background: Theme.surface-raised;
    border-color: Theme.border;
    border-width: 0px;

    // Top border line
    Rectangle {
        y: 0; height: 1px;
        background: Theme.border;
    }

    HorizontalLayout {
        padding:   0px;
        spacing:   0px;

        // ── Left zone: album art + title + artist ─────────────────────────────
        ta-left := TouchArea {
            width:   240px;
            mouse-cursor: MouseCursor.pointer;
            clicked => { AppState.music-bar-open-album(); }

            HorizontalLayout {
                padding:  8px;
                spacing:  10px;
                alignment: center;

                // Album art 60×60
                Rectangle {
                    width:         56px;
                    height:        56px;
                    border-radius: Theme.radius;
                    background:    Theme.surface-overlay;
                    clip:          true;
                    if AppState.music-bar-has-art: Image {
                        width:     parent.width;
                        height:    parent.height;
                        image-fit: cover;
                        source:    AppState.music-bar-art;
                    }
                    if !AppState.music-bar-has-art: Text {
                        text:                 "♫";
                        color:                Theme.text-subtle;
                        font-size:            24px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }

                VerticalLayout {
                    alignment:          center;
                    spacing:            3px;
                    horizontal-stretch: 1;
                    Text {
                        text:        AppState.music-bar-title;
                        color:       Theme.text;
                        font-size:   13px;
                        font-weight: 600;
                        overflow:    elide;
                    }
                    Text {
                        text:      AppState.music-bar-artist;
                        color:     Theme.text-muted;
                        font-size: 12px;
                        overflow:  elide;
                    }
                }
            }
        }

        // ── Centre zone: transport + progress + time ──────────────────────────
        VerticalLayout {
            horizontal-stretch: 1;
            padding-top:     8px;
            padding-bottom:  8px;
            spacing:         4px;
            alignment:       center;

            // Transport buttons
            HorizontalLayout {
                alignment: center;
                spacing:   16px;

                // Play / Pause
                ta-pp := TouchArea {
                    width:  36px; height: 36px;
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { AppState.music-bar-play-pause(); }
                    Rectangle {
                        width:  parent.width; height: parent.height;
                        border-radius: 18px;
                        background: ta-pp.has-hover ? Theme.surface-overlay : transparent;
                        Text {
                            text:                 AppState.music-bar-paused ? "▶" : "⏸";
                            color:                Theme.text;
                            font-size:            16px;
                            vertical-alignment:   center;
                            horizontal-alignment: center;
                            width:                parent.width;
                            height:               parent.height;
                        }
                    }
                }

                // Stop
                ta-stop := TouchArea {
                    width:  36px; height: 36px;
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { AppState.music-bar-stop(); }
                    Rectangle {
                        width:  parent.width; height: parent.height;
                        border-radius: 18px;
                        background: ta-stop.has-hover ? Theme.surface-overlay : transparent;
                        Text {
                            text:                 "⏹";
                            color:                Theme.text-muted;
                            font-size:            14px;
                            vertical-alignment:   center;
                            horizontal-alignment: center;
                            width:                parent.width;
                            height:               parent.height;
                        }
                    }
                }
            }

            // Progress bar + time
            HorizontalLayout {
                spacing:   8px;
                alignment: center;

                Text {
                    text:      AppState.music-bar-elapsed;
                    color:     Theme.text-muted;
                    font-size: 11px;
                    width:     36px;
                    horizontal-alignment: right;
                    vertical-alignment:   center;
                }

                // Seek bar
                progress-ta := TouchArea {
                    horizontal-stretch: 1;
                    height: 16px;
                    mouse-cursor: MouseCursor.pointer;
                    clicked => {
                        // Phase 50 will wire proper seek; for now no-op
                    }
                    Rectangle {
                        x:             0;
                        width:         parent.width;
                        y:             (parent.height - 3px) / 2;
                        height:        3px;
                        border-radius: 1.5px;
                        background:    Theme.surface-overlay;

                        // Filled portion
                        Rectangle {
                            x:             0;
                            width:         parent.width * AppState.music-bar-pos;
                            height:        parent.height;
                            border-radius: parent.border-radius;
                            background:    Theme.accent;
                        }
                    }
                }

                Text {
                    text:      AppState.music-bar-total;
                    color:     Theme.text-muted;
                    font-size: 11px;
                    width:     36px;
                    horizontal-alignment: left;
                    vertical-alignment:   center;
                }
            }
        }

        // ── Right zone: placeholder for Phase 50 (shuffle/repeat/♥/queue) ─────
        Rectangle {
            width: 200px;
            // Empty for Phase 49; Phase 50 adds shuffle/repeat/♥/queue controls
        }
    }
}

// ── Toast notification ────────────────────────────────────────────────────────
export component ToastNotification inherits Rectangle {
    in property <string> message;

    height: max(44px, txt.preferred-height + 22px);

    border-radius: Theme.radius-lg;
    background:    #101012f0;
    border-width:  1px;
    border-color:  Theme.border-strong;
    drop-shadow-blur:     14px;
    drop-shadow-color:    #00000077;
    drop-shadow-offset-y: 4px;
    clip: true;

    // Left accent stripe
    Rectangle {
        x: 0; y: 0;
        width:      4px;
        height:     parent.height;
        background: Theme.error;
    }

    txt := Text {
        x:      18px;
        y:      0;
        width:  parent.width - 26px;
        height: parent.height;
        text:               root.message;
        color:              Theme.text;
        font-size:          13px;
        wrap:               word-wrap;
        vertical-alignment: center;
    }
}
