// ── fjord-app · widgets.slint ────────────────────────────────────────────────
//   FjordButton        accent / danger push button; kbd-focused draws white border ring;
//                      optional icon-left/icon-right (font-family hard-pinned to Noto Sans
//                      Symbols2, kept separate from `text` so the label itself stays on
//                      whichever font Settings → UI → Text font has selected)
//   IconCircleButton   38px circle button; gray when inactive, accent when active; ♥︎/✓︎ icons
//                      (also reused for the now_playing.slint transport row); font-family
//                      hard-pinned per-icon (Adwaita Sans for ♥︎/✓︎, Noto Sans Symbols2 for the
//                      rest) regardless of Settings → UI → Text font
//   NavItem            sidebar navigation row (icon + label + active indicator)
//   BrowseItem         single row in the browse / search list
//   FadeInTrigger      non-visual helper: drop into any element with opacity:0 + animate opacity
//                      already declared to fade it in on creation (Timer-based, not init =>);
//                      its own 16ms kick-tick is NOT scaled by settings-animation-speed (it's a
//                      one-shot "next frame" trick, not a perceptible duration) — the animate
//                      opacity block it triggers IS scaled; used only by player.slint's 3
//                      skip-segment overlays and MediaCard's poster fade-in now (main.slint's
//                      29 screen/overlay sites moved to FadeGate, below)
//   FadeGate           non-visual helper: symmetric fade in/out, unlike FadeInTrigger's fade-in
//                      only — owns the mount/unmount decision itself (`show` in, `mounted`/
//                      `fade-opacity` out) so `if gate.mounted: Element { opacity: gate.fade-opacity; }`
//                      keeps the element alive through its own fade-out instead of Slint's `if`
//                      destroying it the instant the raw condition flips false; unmount-timer's
//                      interval matches the consumer's own `animate opacity` duration (150ms *
//                      settings-animation-speed, floored at 16ms) so unmount lands right as the
//                      fade-out finishes — all 29 main.slint screen/overlay sites use this now
//   PressPulse         non-visual helper: keyboard half of the universal press/click animation;
//                      trigger: AppState.kb-activate-pulse, active: <focus expr> => pulsing: bool
//                      (110ms self-resetting); pair with border-width + ta.pressed for mouse —
//                      border-only by design so pressing never resizes/brightens/bolds text.
//                      The 110ms hold is NOT scaled by settings-animation-speed (deliberately —
//                      it's how long the flash is held, not how it eases); the border-width
//                      animate at each of its ~50 call sites IS scaled
//   MediaCard          poster card used in horizontal scroll rows and library grid; clicked + right-clicked callbacks; badges: ✓︎ played, count pill, ♥︎ favourite; animated white-tint hover overlay on top of poster image; poster image fades in via FadeInTrigger; title/subtitle are uncapped wrap:word-wrap Text (always show the full title/episode name, no elide) — poster-rect reads the text block's preferred-height and shrinks to make room instead of the text ever overflowing the card, see the vertical-alignment:bottom Slint gotcha in CLAUDE.md
//   LoadingSpinner     animated ring shown while content loads; dot-cycle Timer interval
//                      (base 260ms, floored at 16ms) AND each dot's opacity animate both scale
//                      with settings-animation-speed — unlike PressPulse/FadeInTrigger's Timers,
//                      this one directly choreographs the animation's own rhythm rather than
//                      holding a state for something else to ease, so it's scaled too
//   StatRow            label + value row inside the stats overlay
//   ToggleSwitch       pill-shaped on/off toggle; checked <=> + toggled callback
//   SectionHeader      accent label + accent hairline to the right (settings section dividers)
//   SettingsDropdown   compact dropdown that sizes to current text; popup right-aligns with trigger
//   SettingsRow        standard settings row: title + subtitle left, @children right, focus highlight + hover
//                      row-index must match the PLY_* / GEN_* constant in settings.rs
//                      section defaults to 1 (Player); pass section: 0 for General rows
//   BackdropHero       full-width 300 px backdrop image with bottom-to-bg fade gradient
//   PosterBlock        160×240 poster with rounded corners; placeholder when no image; badges: ✓︎ played, progress bar, unplayed count pill
//   MetaLine           year · runtime · rating + optional ★ community rating
//   CastRow            Flickable row of cast cards: portrait photo + name + role; focused-idx border ring;
//                      hover overlay; viewport-x tracks focused-idx for keyboard scroll
//   StorylineSection   collapsible overview block: "Storyline ▶︎" header; 3-line preview collapsed,
//                      full text expanded; click anywhere on header to toggle
//   MiniPlayerBar      full-width bottom bar; 108px in mode 3 (!video-behind-ui): live video + title + buttons;
//                      56px compact bar in mode 2 (video-behind-ui): NOW PLAYING + title + buttons (no thumbnail);
//                      float-card-focused (-1=none, 0=Resume, 1=Stop)
//   MusicPlayerBar     full-width bottom bar 72px; shown when is-audio-playing; three zones:
//                      left: album art 60×60 + title + artist (click → open-album);
//                      centre: ⏸︎/▶︎ pause/play · ⏹︎ stop · progress bar · elapsed / total;
//                      right: ⏮︎Prev/⏭︎Next/⇌︎Shuffle/↺︎Repeat/⋮︎Queue/♪︎Lyrics (slots 4-9)
//   QueuePanel         right-side overlay panel 400px wide; header "Queue N of M" + Clear All;
//                      scrollable playlist rows: 40×40 art thumbnail + index · title · artist; current item accented;
//   LyricsView         full-width overlay panel; Flickable list of LyricEntry lines;
//                      active line highlighted in accent; auto-scrolls to active line via kb-y binding
//   ToastNotification  bottom-center error pill; message: string; auto-dismissed by Timer in main.slint
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, CardItem, CastMember, QueueEntry, LyricEntry } from "theme.slint";
import { AppState } from "app_state.slint";

// Non-visual helper: instantiate as a NAMED child (e.g. `pulse := PressPulse {
// trigger: AppState.kb-activate-pulse; active: root.kbd-focused; }`) and bind
// the host element's `border-width: (ta.pressed || pulse.pulsing) ? 4px :
// (kbd-focused ? 2px : 0px);` + `animate border-width {...}` to it — this is
// the keyboard half of the universal press/click animation (mouse gets it for
// free via TouchArea.pressed, which needs no Rust involvement). Deliberately
// border-only, not a scale/opacity change — pressing never resizes, brightens,
// or bolds the widget's own text, only a border appears/thickens (user
// feedback: a scale-based version made text look like it was growing/getting
// bolder on press, which read as gimmicky). `trigger` is bumped once by
// keys.rs::handle_key() on every Enter press; every mounted PressPulse in the
// tree sees the same bump but only plays the pulse if ITS OWN `active` input
// (the widget's pre-existing focus/selection expression) is true at that
// moment, so no per-widget identity/addressing scheme is needed. `pulsing`
// self-resets after one Timer interval — same one-shot-Timer idiom as
// FadeInTrigger below, just re-triggerable instead of fire-once. Declared
// before FjordButton (Slint requires an element be declared before use within
// the same file) since FjordButton is the first consumer.
export component PressPulse {
    in property <int>  trigger;
    in property <bool> active: true;
    out property <bool> pulsing: false;

    changed trigger => {
        if root.active {
            root.pulsing = true;
            // Force a genuine stop-then-restart rather than just `= true` —
            // Slint's Timer.running is dirty-checked like any property, so
            // writing `true` when it's ALREADY true (a second trigger landing
            // within the same 110ms window, e.g. rapid double-Enter) is a
            // no-op and doesn't restart the countdown; the originally
            // scheduled `triggered` still fires ~110ms after the FIRST press,
            // cutting the second press's flash short. Both writes below are
            // real value transitions, so both are always processed.
            reset-timer.running = false;
            reset-timer.running = true;
        }
    }
    reset-timer := Timer {
        interval: 110ms;
        running:  false;
        triggered => {
            root.pulsing = false;
            self.running = false;
        }
    }
}

// ── Accent button ─────────────────────────────────────────────────────────────
export component FjordButton inherits Rectangle {
    in property <string> text;
    // Optional icon glyph(s) rendered as their own Text (pinned to the
    // bundled Noto Sans Symbols2, same as every other icon in the app,
    // regardless of Settings → UI → Text font) so callers with a combined
    // icon+label ("▶︎ Play", "■︎ Stop") don't force the LABEL word through
    // Noto too — Noto Sans Symbols2 has zero Latin-alphabet coverage, so a
    // single Text mixing both would leave the word falling through to an
    // uncontrolled system fallback. icon-left/icon-right cover prefix
    // ("▶︎ Play") and suffix ("30s ▶︎▶︎") layouts; both default empty, so a
    // plain `text`-only button (the common case) is unaffected.
    in property <string> icon-left:  "";
    in property <string> icon-right: "";
    in property <bool>   enabled:     true;
    in property <bool>   danger:      false;
    in property <bool>   kbd-focused: false;
    callback clicked;

    height:        38px;
    border-radius: Theme.radius;
    border-width:  (ta.pressed || pulse.pulsing) ? 4px : (kbd-focused ? 2px : 0px);
    border-color:  #ffffff99;
    background: !enabled      ? Theme.surface-raised
              : ta.has-hover  ? (danger ? #c53030 : Theme.accent-hover)
              :                  (danger ? Theme.error : Theme.accent);
    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: root.kbd-focused; }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        alignment: center;
        spacing:   6px;
        if root.icon-left != "": Text {
            text:               root.icon-left;
            color:              root.enabled ? #ffffff : Theme.text-subtle;
            font-size:          14px;
            font-weight:        600;
            font-family:        "Noto Sans Symbols 2";
            vertical-alignment: center;
        }
        if root.text != "": Text {
            text:               root.text;
            color:              root.enabled ? #ffffff : Theme.text-subtle;
            font-size:          14px;
            font-weight:        600;
            vertical-alignment: center;
        }
        if root.icon-right != "": Text {
            text:               root.icon-right;
            color:              root.enabled ? #ffffff : Theme.text-subtle;
            font-size:          14px;
            font-weight:        600;
            font-family:        "Noto Sans Symbols 2";
            vertical-alignment: center;
        }
    }
}

// ── Circle icon button (♥︎ fav / ✓︎ watched) ───────────────────────────────────
export component IconCircleButton inherits Rectangle {
    in property <string> icon;
    in property <bool>   active:      false;
    in property <bool>   kbd-focused: false;
    callback clicked;

    width:         38px;
    height:        38px;
    border-radius: 19px;
    border-width:  (ta.pressed || pulse.pulsing) ? 4px : (kbd-focused ? 2px : 0px);
    border-color:  #ffffff99;
    background: active       ? Theme.accent
              : ta.has-hover ? Theme.surface-overlay
              :                Theme.surface-raised;
    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: root.kbd-focused; }

    Text {
        x:                    0;
        y:                    0;
        width:                parent.width;
        height:               parent.height;
        text:                 root.icon;
        color:                #ffffff;
        font-size:            20px;
        font-weight:          600;
        // Hard-pinned regardless of Settings → UI → Text font: ♥/✓ always
        // render via Adwaita Sans specifically (the deliberately-chosen
        // style for those two), every other icon this component shows
        // (the now_playing.slint transport row: ⏮︎▶︎⏸︎⏭︎⇌︎↺︎🔉︎🔊︎) always
        // via the bundled Noto Sans Symbols2 fallback font. Several
        // candidate text fonts turned out to have their own competing
        // glyphs for common icons like these — pinning explicitly means
        // icon appearance never depends on which text font is active.
        font-family:          (root.icon == "❤︎" || root.icon == "✓︎") ? "Adwaita Sans" : "Noto Sans Symbols 2";
        horizontal-alignment: center;
        vertical-alignment:   center;
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

// ── Sidebar nav row ───────────────────────────────────────────────────────────
export component NavItem inherits Rectangle {
    in property <string> label;
    in property <bool>   active: false;
    callback clicked;
    callback double-clicked;

    height: 40px;
    border-radius: Theme.radius;
    // Single "selected" state — no separate extra-bright tier for "the
    // sidebar literally has keyboard focus right now" vs. "this is just the
    // active section". That two-tier version (bright accent + sidebar-kb-
    // active vs. muted accent) made Browse All and Settings look
    // inconsistent with Home/TV/Movies/Collections/Music: those two open a
    // separate AppMode (Browse/Settings) the instant the sidebar cursor
    // lands on them, so they immediately showed the muted tier while the
    // other five — which all share AppMode::Dashboard regardless of which
    // one is selected — stayed bright while merely being cursor-highlighted.
    // User feedback: the single-state look (already how Browse/Settings/Quit
    // effectively read) is cleaner — apply it uniformly to all sidebar items.
    background: active         ? Theme.accent-muted
              : ta.has-hover    ? Theme.surface-raised
              :                   #00000000;
    animate background { duration: 140ms * AppState.settings-animation-speed; easing: ease; }
    border-width:  (ta.pressed || pulse.pulsing) ? 3px : 0px;
    border-color:  Theme.accent;
    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: root.active && AppState.sidebar-kb-active; }

    ta := TouchArea {
        clicked        => { root.clicked(); }
        double-clicked => { root.double-clicked(); }
    }

    HorizontalLayout {
        padding-left: 14px;
        spacing:      10px;
        alignment:    start;

        Rectangle {
            width: 6px;
            Rectangle {
                width:         6px;
                height:        6px;
                border-radius: 3px;
                y:             (parent.height - self.height) / 2;
                background:    active ? Theme.accent : Theme.text-subtle;
            }
        }
        Text {
            text:               label;
            color:              active ? Theme.text : Theme.text-muted;
            font-size:          14px;
            font-weight:        active ? 600 : 400;
            vertical-alignment: center;
        }
    }
}

// ── Browse-screen list row ────────────────────────────────────────────────────
export component BrowseItem inherits Rectangle {
    in property <string> text;
    in property <bool>   selected: false;
    callback clicked;
    callback activated;
    callback right-clicked;

    height: 42px;
    border-radius: Theme.radius;
    background: { let hov = ta.has-hover; selected ? Theme.accent-muted : (hov ? Theme.surface-raised : #00000000) };
    border-width:  (ta.pressed || pulse.pulsing) ? 3px : 0px;
    border-color:  Theme.accent;
    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: root.selected; }

    ta := TouchArea {
        clicked        => { root.clicked(); }
        double-clicked => { root.activated(); }
        pointer-event(e) => {
            if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                root.right-clicked();
            }
        }
    }
    HorizontalLayout {
        padding-left:  10px;
        padding-right: 12px;
        spacing:        8px;
        alignment:      start;

        Rectangle {
            width:         3px;
            height:        20px;
            y:             (parent.height - self.height) / 2;
            border-radius: 1.5px;
            background:    selected ? Theme.accent : #00000000;
        }
        Text {
            text:               root.text;
            color:              selected ? Theme.text : Theme.text-muted;
            font-size:          14px;
            overflow:           elide;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

// Non-visual helper: instantiate as a NAMED child (e.g. `fade := FadeInTrigger {}`)
// and bind the host element's `opacity: fade.fade-opacity;` + `animate opacity {...}`
// to fade it in shortly after creation. Exposes fade-opacity as an out property
// rather than writing `parent.opacity` directly — `parent` from inside the Timer
// refers to FadeInTrigger itself (its immediate parent), not the host two levels
// up, so a direct `parent.opacity` write silently no-ops on the host and leaves it
// stuck invisible. Uses a Timer rather than `init =>` because the opacity write
// needs to land on a genuinely later event-loop tick — writing it in the same tick
// as the initial `opacity: 0` binding would just coalesce into a single value with
// nothing for `animate` to transition from. Used for entrance fades on `if`-gated
// elements (destroyed/recreated on every toggle, unlike an always-mounted element
// whose opacity binding can just react to a condition changing).
export component FadeInTrigger {
    out property <float> fade-opacity: 0;
    Timer {
        interval: 16ms;
        running:  true;
        triggered => {
            fade-opacity = 1;
            self.running = false;
        }
    }
}

// FadeGate: symmetric fade in/out. FadeInTrigger only handles the entrance —
// the consumer's own `if condition: Element {...}` still destroys the
// element the instant `condition` goes false, so nothing ever fades out.
// FadeGate owns the mount decision itself: declare it as an always-present
// sibling (`gate := FadeGate { show: <condition>; }`), then gate the `if` on
// `gate.mounted` (not the raw condition) and bind `opacity: gate.fade-opacity;`.
// `mounted` stays true for one fade-out's worth of time after `show` goes
// false, so the element is still there to actually play that fade before
// `if gate.mounted` unmounts it. The consumer still declares its own
// `animate opacity {...}` block, same as with FadeInTrigger.
export component FadeGate {
    in property <bool> show: false;
    out property <bool> mounted: false;
    out property <float> fade-opacity: 0;

    init => {
        root.mounted = root.show;
        if root.show {
            kick-timer.running = true;
        }
    }

    changed show => {
        if root.show {
            unmount-timer.running = false;
            root.mounted = true;
            kick-timer.running = true;
        } else {
            // Cancel a still-pending kick-timer — without this, a show
            // true→false transition landing before the 16ms kick fires
            // leaves it armed; it still fires later (unconditionally
            // setting fade-opacity back to 1), flashing the element back
            // to full opacity on top of whatever replaced it, right until
            // unmount-timer catches up. Real bug: show-login defaults to
            // true before the saved-session check flips it to
            // show-connecting, all before the event loop even starts, so
            // this fired on every single cold start with a saved session.
            kick-timer.running = false;
            root.fade-opacity = 0;
            unmount-timer.running = true;
        }
    }

    // Bumps opacity 0→1 a frame after mounting, same trick as FadeInTrigger,
    // so the consumer's `animate opacity` has a real transition to interpolate.
    kick-timer := Timer {
        interval: 16ms;
        running:  false;
        triggered => {
            root.fade-opacity = 1;
            self.running = false;
        }
    }

    // Keeps `mounted` true for exactly as long as the fade-out animation
    // takes, so `if gate.mounted` doesn't destroy the element mid-fade.
    unmount-timer := Timer {
        interval: max(16ms, 150ms * AppState.settings-animation-speed);
        running:  false;
        triggered => {
            root.mounted = false;
            self.running = false;
        }
    }
}

// ── Poster card (used inside horizontal scroll rows) ──────────────────────────
export component MediaCard inherits Rectangle {
    in property <CardItem> item;
    in property <bool>     focused: false;
    callback clicked;
    callback right-clicked;

    width:          140px;
    height:         224px;
    border-radius:  Theme.radius;
    background:     #00000000;
    pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: root.focused; }

    // Inset 3px on every side so the focus/press ring (flush with root,
    // declared last below) has a clear gutter to sit in — content used to
    // extend flush to root's own edges, so the ring's stroke visibly bit
    // into the poster image and the title text's first line. The inset is
    // `padding: 3px` (a native layout property), NOT explicit x/y/width/height
    // geometry bindings on this VerticalLayout: a previous version bound
    // `width: root.width - 6px; height: root.height - 6px;` here and it
    // caused a REAL "Recursion detected" panic on the HTPC (properties.rs:583,
    // fjord.log r716) — LibraryGrid instantiates MediaCard WITHOUT an explicit
    // height, so root.height there is assigned by the row HorizontalLayout's
    // layout cache, and an explicit-geometry binding on a child LAYOUT element
    // that reads root.height feeds back into the very constraint computation
    // that produces root.height → cycle. (An outset ring — root ± constant on
    // the ring Rectangle — crashed the same way earlier on the dev machine;
    // see the "root.width ± constant" gotcha in CLAUDE.md.) SectionRow passes
    // height explicitly, which is why dashboards never crashed — the library
    // grid is the vulnerable instantiation. `padding` is resolved inside the
    // layout's own cache with no external geometry binding, so no cycle.
    VerticalLayout {
        padding: 3px;
        spacing: 6px;

        poster-rect := Rectangle {
            // Reserve exactly what the title+subtitle block below actually
            // needs (text-col.preferred-height, which grows with however
            // many lines a long title/subtitle wraps to — no cap, the whole
            // title is always shown) rather than a fixed budget that assumed
            // 2 lines each. max(0px, ...) keeps this well-defined (never
            // negative) even for a pathologically long title on a short
            // card: the poster just shrinks, all the way to invisible in
            // the extreme case, rather than the text overflowing past the
            // card's own bounds into whatever is below it. Reads root.height
            // (the month-stable pattern), NOT parent.height — parent is the
            // padded VerticalLayout whose height participates in layout-info
            // computation (see the recursion note above). text-col is a
            // sibling, not an ancestor, so reading its preferred-height here
            // does not create the same kind of cycle.
            height:        max(0px, root.height - 12px - text-col.preferred-height);
            border-radius: Theme.radius;
            background:    Theme.surface-raised;
            clip:          true;

            if item.has-poster: Image {
                source:    item.poster;
                width:     parent.width;
                height:    parent.height;
                image-fit: cover;
                opacity:   poster-fade.fade-opacity;
                animate opacity { duration: 200ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                poster-fade := FadeInTrigger { }
            }

            if !item.has-poster: Text {
                text:                 item.title;
                color:                Theme.text-muted;
                font-size:            11px;
                wrap:                 word-wrap;
                horizontal-alignment: center;
                vertical-alignment:   center;
                x:                    6px;
                width:                parent.width - 12px;
            }

            // In-progress bar at bottom of poster
            if item.resume-pct > 0 && !item.has-played: Rectangle {
                y:          parent.height - 3px;
                height:     3px;
                background: Theme.surface-overlay;
                Rectangle {
                    x:          0;
                    width:      parent.width * item.resume-pct;
                    height:     parent.height;
                    background: Theme.accent;
                }
            }

            // Favourite heart badge
            if item.is-favorite: Rectangle {
                x:             4px;
                y:             4px;
                width:         24px;
                height:        24px;
                border-radius: 12px;
                background:    Theme.accent;
                Text {
                    text:                 "❤︎";
                    font-family:          "Adwaita Sans";
                    color:                #ffffff;
                    font-size:            14px;
                    font-weight:          900;
                    horizontal-alignment: center;
                    vertical-alignment:   center;
                }
            }

            // Watched checkmark badge
            if item.has-played: Rectangle {
                x:             parent.width - 28px;
                y:             4px;
                width:         24px;
                height:        24px;
                border-radius: 12px;
                background:    Theme.accent;
                Text {
                    text:                 "✓︎";
                    font-family:          "Adwaita Sans";
                    color:                #ffffff;
                    font-size:            18px;
                    font-weight:          900;
                    horizontal-alignment: center;
                    vertical-alignment:   center;
                }
            }

            // Unseen episode count badge (series)
            if item.unplayed-count > 0 && !item.has-played: Rectangle {
                x:             parent.width - 28px;
                y:             4px;
                width:         24px;
                height:        24px;
                border-radius: 12px;
                background:    Theme.accent;
                Text {
                    text:                 "\{item.unplayed-count}";
                    color:                #ffffff;
                    font-size:            11px;
                    font-weight:          900;
                    horizontal-alignment: center;
                    vertical-alignment:   center;
                }
            }

            // Hover highlight — on top of image and badges so it is visible even
            // when a poster image fills the rectangle.
            Rectangle {
                background: #ffffff1a;
                opacity:    ta.has-hover ? 1.0 : 0.0;
                animate opacity { duration: 120ms * AppState.settings-animation-speed; easing: ease; }
            }
        }

        // No fixed/capped height on either Text below — both are left to
        // their natural wrap:word-wrap size, so a long title or episode name
        // is always shown in full rather than being elided after N lines.
        // poster-rect above reads this layout's preferred-height to shrink
        // and make room, so nothing here needs to know its own budget.
        // (Earlier attempts capped the title at 2 lines via a fixed height +
        // vertical-alignment:bottom to keep it flush with the subtitle; that
        // hit a real Slint 1.16.1 bug where bottom-alignment mis-measures
        // text height as soon as wrap:word-wrap produces 2+ lines, leaving a
        // stray gap — confirmed via a standalone repro. Top-aligned,
        // uncapped Text sidesteps it entirely instead of working around it.)
        text-col := VerticalLayout {
            spacing: 2px;

            Text {
                text:      item.title;
                color:     Theme.text;
                font-size: 12px;
                wrap:      word-wrap;
            }
            if item.subtitle != "": Text {
                text:      item.subtitle;
                color:     Theme.text-muted;
                font-size: 10px;
                wrap:      word-wrap;
            }
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
        pointer-event(e) => {
            if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                root.right-clicked();
            }
        }
    }

    // Focus/press ring — a dedicated, last-declared, transparent overlay
    // rather than a border-width on root itself. root's border sits behind
    // the poster image (poster-rect is a separately nested Rectangle flush
    // to root's edges, not the same Rectangle as the border), so it could
    // paint underneath the image depending on compositing order. Declaring
    // this Rectangle last guarantees it paints on top of everything above,
    // the same fix already used for MiniPlayerBar's focus ring.
    // A 3px-outset version of THIS Rectangle (extending beyond root's own
    // bounds so the ring wouldn't overlap the poster/title edge pixels) was
    // tried and reverted: it triggered a live "Recursion detected" Slint
    // panic during mouse-hover geometry evaluation, and separately got
    // visibly clipped by the surrounding Flickable's own viewport edge for
    // edge-of-row cards, since scrollable containers don't reserve margin for
    // content that intentionally overflows an item's own bounds. This
    // Rectangle stays flush with root (the known-stable configuration); the
    // clear gutter instead comes from insetting the *content* 3px inward
    // (the VerticalLayout above), so the ring has room to sit in without
    // touching the poster or title while never leaving root's own bounds.
    Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        border-radius: Theme.radius;
        border-width:  (ta.pressed || pulse.pulsing) ? 4px : (focused ? 2px : 0px);
        border-color:  Theme.accent;
        background:    transparent;
        animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    }
}

// ── Loading spinner ───────────────────────────────────────────────────────────
export component LoadingSpinner inherits Rectangle {
    height: 20px;

    property <int> step: 0;

    Timer {
        // Floored at 16ms (~1 frame, same floor FadeInTrigger's own kick-tick
        // uses) rather than letting this go to a literal 0ms at
        // animation-speed=0 — unlike an `animate` block's duration (where 0ms
        // just means "jump instantly, no re-firing"), a Timer with interval
        // 0ms would re-fire continuously and spin the CPU.
        interval: max(16ms, 260ms * AppState.settings-animation-speed);
        running:  true;
        triggered() => { step = step + 1 >= 3 ? 0 : step + 1; }
    }

    HorizontalLayout {
        alignment: center;
        spacing:   16px;
        height:    100%;

        for i in [0, 1, 2]: Rectangle {
            width:         20px;
            height:        20px;
            border-radius: 10px;
            background:    Theme.accent;
            opacity:       step == i ? 1.0 : 0.15;
            animate opacity { duration: 180ms * AppState.settings-animation-speed; easing: ease-in-out; }
        }
    }
}

// ── Pill toggle switch ────────────────────────────────────────────────────────
export component ToggleSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled;

    width:  52px;
    height: 28px;

    Rectangle {
        border-radius: parent.height / 2;
        background:    root.checked ? Theme.accent : Theme.surface-raised;
        border-width:  ta.pressed ? 3px : 1.5px;
        border-color:  root.checked ? Theme.accent : Theme.border;
        animate background { duration: 140ms * AppState.settings-animation-speed; easing: ease; }
        animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }

        Rectangle {
            width:         22px;
            height:        22px;
            border-radius: 11px;
            background:    #ffffff;
            y:             (parent.height - self.height) / 2;
            x:             root.checked ? parent.width - self.width - 3px : 3px;
            animate x { duration: 140ms * AppState.settings-animation-speed; easing: ease-in-out; }
            drop-shadow-blur:  4px;
            drop-shadow-color: #00000040;
        }
    }

    ta := TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }
}

// ── Settings section divider (accent label + hairline) ────────────────────────
export component SectionHeader inherits Rectangle {
    in property <string> text;
    height: 28px;

    HorizontalLayout {
        spacing: 10px;
        alignment: start;
        Text {
            text:               root.text;
            color:              Theme.accent;
            font-size:          11px;
            font-weight:        700;
            vertical-alignment: center;
        }
        Rectangle {
            horizontal-stretch: 1;
            Rectangle {
                width:      parent.width;
                height:     1px;
                y:          (parent.height - 1px) / 2;
                background: Theme.accent;
                opacity:    0.3;
            }
        }
    }
}

// ── Settings dropdown (auto-sizes to current value; popup right-aligns) ───────
export component SettingsDropdown inherits Rectangle {
    in property <[string]> model;
    in-out property <string> current-value;
    callback selected(string);

    property <string> display-value: root.current-value != "" ? root.current-value : "(none)";
    // Cap popup height for long lists; Flickable handles overflow.
    property <length> pop-h: min(root.model.length * 32px + 8px, 320px);

    // Width tracks rendered text; capped so long descriptions don't overflow the settings row.
    width:         min(max(80px, val.preferred-width + chevron.preferred-width + 24px), 280px);
    height:        34px;
    border-radius: 6px;
    background:    ta.has-hover ? Theme.surface-overlay : Theme.surface-raised;
    border-width:  ta.pressed ? 3px : 1px;
    border-color:  ta.pressed ? Theme.accent : Theme.border;
    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }

    HorizontalLayout {
        padding-left:  10px;
        padding-right: 8px;
        spacing:        6px;
        alignment:      start;
        val := Text {
            text:               root.display-value;
            color:              Theme.text;
            font-size:          13px;
            vertical-alignment: center;
            overflow:           elide;
        }
        chevron := Text {
            text:               "▾︎";
            font-family:          "Noto Sans Symbols 2";
            color:              Theme.text-muted;
            font-size:          10px;
            vertical-alignment: center;
        }
    }

    ta := TouchArea { clicked => { popup.show(); } }

    popup := PopupWindow {
        // Width grows to fit the widest item; right edge stays flush with the trigger.
        x:      root.width - self.width;
        y:      root.height + 2px;
        width:  min(max(root.width, items-layout.preferred-width + 8px), 700px);
        height: root.pop-h;

        Rectangle {
            background:        Theme.surface-raised;
            border-radius:     6px;
            border-width:      1px;
            border-color:      Theme.border;
            drop-shadow-blur:  8px;
            drop-shadow-color: #00000060;
            clip:              true;

            Flickable {
                viewport-height: root.model.length * 32px + 8px;
                items-layout := VerticalLayout {
                    padding: 4px;
                    for opt in root.model: Rectangle {
                        height:          32px;
                        border-radius:   4px;
                        preferred-width: opt-text.preferred-width + 20px;
                        background:      opt-ta.has-hover ? Theme.accent-muted : transparent;
                        opt-text := Text {
                            x:                  10px;
                            text:               opt != "" ? opt : "(none)";
                            color:              opt == root.current-value ? Theme.accent : Theme.text;
                            font-size:          13px;
                            font-weight:        opt == root.current-value ? 600 : 400;
                            vertical-alignment: center;
                            overflow:           elide;
                        }
                        opt-ta := TouchArea {
                            clicked => {
                                root.current-value = opt;
                                root.selected(opt);
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

// ── Settings content row ──────────────────────────────────────────────────────
// Standard two-column row: title+subtitle on the left, @children on the right.
// TouchArea (lower z) lets ToggleSwitch / SettingsDropdown children receive their
// own clicks while still tracking hover for the row highlight.
export component SettingsRow inherits Rectangle {
    in property <int>    row-index;
    in property <int>    section:  1;
    in property <string> title;
    in property <string> subtitle;
    in property <bool>   indent:   false;

    border-radius: Theme.radius;
    background: {
        let hov = ta.has-hover;
        AppState.settings-focused == row-index
            ? Theme.accent-muted
            : (hov ? Theme.surface : transparent)
    };
    border-width:  (ta.pressed || pulse.pulsing) ? 3px : 0px;
    border-color:  Theme.accent;
    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.settings-focused == root.row-index; }

    ta := TouchArea {
        clicked => {
            AppState.settings-section = root.section;
            AppState.settings-focused = root.row-index;
        }
    }

    HorizontalLayout {
        padding-top:    12px;
        padding-bottom: 12px;
        padding-right:  12px;
        padding-left:   root.indent ? 28px : 12px;
        spacing: Theme.sp;
        alignment: space-between;
        VerticalLayout {
            spacing:            3px;
            horizontal-stretch: 1;
            Text { text: root.title;    color: Theme.text;       font-size: 14px; }
            Text { text: root.subtitle; color: Theme.text-muted; font-size: 12px; overflow: elide; }
        }
        @children
    }
}

// ── Detail page shared atoms ──────────────────────────────────────────────────

export component BackdropHero inherits Rectangle {
    in property <image> source;
    height: 300px;
    clip:   true;
    Image {
        source:    root.source;
        width:     parent.width;
        height:    parent.height;
        image-fit: cover;
    }
    Rectangle {
        background: @linear-gradient(180deg, transparent 20%, Theme.bg 100%);
    }
}

export component PosterBlock inherits Rectangle {
    in property <image> source;
    in property <bool>  has-image:      false;
    in property <bool>  has-played:     false;
    in property <float> resume-pct:     0.0;
    in property <int>   unplayed-count: 0;
    width:         160px;
    height:        240px;
    border-radius: Theme.radius;
    clip:          true;
    background:    Theme.surface-raised;
    if has-image: Image {
        source:    root.source;
        width:     parent.width;
        height:    parent.height;
        image-fit: cover;
    }
    // progress bar (resume)
    if root.resume-pct > 0.0 && !root.has-played: Rectangle {
        x: 0; y: parent.height - 4px;
        width:      parent.width * root.resume-pct;
        height:     4px;
        background: Theme.accent;
    }
    // ✓︎ played badge (top-right)
    if root.has-played: Rectangle {
        x: parent.width - 28px; y: 6px;
        width: 22px; height: 22px;
        border-radius: 11px;
        background: Theme.accent;
        Text { text: "✓︎"; font-family: "Adwaita Sans"; color: white; font-size: 11px; font-weight: 700;
               horizontal-alignment: center; vertical-alignment: center;
               width: parent.width; height: parent.height; }
    }
    // unplayed-count pill (top-right, when no played badge)
    if root.unplayed-count > 0 && !root.has-played: Rectangle {
        x: parent.width - 28px; y: 6px;
        width: 22px; height: 22px;
        border-radius: 11px;
        background: Theme.accent;
        Text { text: root.unplayed-count; color: white; font-size: 11px; font-weight: 700;
               horizontal-alignment: center; vertical-alignment: center;
               width: parent.width; height: parent.height; }
    }
}

export component MetaLine inherits HorizontalLayout {
    in property <string> meta;
    in property <string> rating-label;
    spacing:   16px;
    alignment: start;
    Text {
        text:      root.meta;
        color:     Theme.text-muted;
        font-size: 14px;
    }
    if root.rating-label != "": Text {
        text:      root.rating-label;
        color:     #f5c518;
        font-size: 14px;
    }
}

export component CastRow inherits VerticalLayout {
    in property <[CastMember]> cast;
    in property <int>          focused-idx: -1;
    callback item-selected(/* idx */ int);
    spacing: 12px;

    // kb-x lives on CastRow (root), not on fl itself.
    // A property on a Flickable that reads self.width / self.viewport-width creates
    // a dependency cycle → "Recursion detected" panic (Slint gotcha). Reading
    // fl.width from the parent element is safe (no self-reference).
    property <length> kb-x: root.focused-idx <= 0 ? 0px
              : clamp(
                    -(root.focused-idx * 116px + 50px - fl.width / 2),
                    min(0px, fl.width - hbox.preferred-width),
                    0px
                );
    changed kb-x => { fl.viewport-x = kb-x; }

    Text { text: "Cast & Crew"; color: Theme.text; font-size: 16px; font-weight: 700; }

    // Flickable so keyboard navigation (viewport-x tracks focused-idx) scrolls the row.
    // Card stride = 100px width + 16px spacing = 116px.
    // kb-x drives viewport-x via changed callback; mouse-wheel scroll works natively.
    fl := Flickable {
        height:         162px;
        viewport-width: hbox.preferred-width;
        animate viewport-x { duration: 150ms * AppState.settings-scroll-speed; easing: ease-out-expo; }

        hbox := HorizontalLayout {
            spacing:   16px;
            alignment: start;

            for c[i] in root.cast: VerticalLayout {
                width:   100px;
                spacing: 4px;

                // Single Rectangle with clip + border: Slint renders border on top of children
                // so the focus ring is always visible even when the photo fills the area.
                Rectangle {
                    height:        120px;
                    border-radius: Theme.radius;
                    border-width:  (ta.pressed || cast-pulse.pulsing) ? 4px : (root.focused-idx == i ? 2px : 0px);
                    border-color:  Theme.accent;
                    background:    Theme.surface-raised;
                    clip:          true;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    cast-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: root.focused-idx == i; }

                    if c.has-photo: Image {
                        source:    c.photo;
                        width:     parent.width;
                        height:    parent.height;
                        image-fit: cover;
                    }

                    // Hover overlay — read has-hover before ternary to keep binding alive
                    Rectangle {
                        background: { let h = ta.has-hover; h ? #ffffff18 : transparent; }
                    }

                    ta := TouchArea {
                        clicked => { root.item-selected(i); }
                    }
                }

                Text { text: c.name; color: Theme.text;       font-size: 12px; font-weight: 600; overflow: elide; }
                Text { text: c.role; color: Theme.text-muted; font-size: 11px; overflow: elide; }
            }
        }
    }
}

// ── Collapsible storyline section ─────────────────────────────────────────────
export component StorylineSection inherits VerticalLayout {
    in property    <string> text;
    in-out property <bool>  expanded:    false;
    in property    <bool>   kbd-focused: false;

    hdr := Rectangle {
        height:        44px;
        background:    ta.has-hover ? Theme.surface : transparent;
        border-width:  (ta.pressed || story-pulse.pulsing) ? 4px : (root.kbd-focused ? 2px : 0px);
        border-color:  #ffffff99;
        border-radius: Theme.radius;
        animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
        story-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: root.kbd-focused; }

        HorizontalLayout {
            x: 0; y: 0; width: parent.width; height: parent.height;
            padding-left:  48px;
            padding-right: 48px;
            spacing:       8px;
            alignment:     start;
            Text {
                text:               "Overview";
                color:              Theme.text;
                font-size:          15px;
                font-weight:        600;
                vertical-alignment: center;
            }
            Text {
                text:               expanded ? "▼︎" : "▶︎";
                font-family:          "Noto Sans Symbols 2";
                color:              Theme.text-muted;
                font-size:          13px;
                vertical-alignment: center;
            }
        }

        ta := TouchArea { clicked => { expanded = !expanded; } }
    }

    VerticalLayout {
        padding-left:   48px;
        padding-right:  48px;
        padding-bottom: 20px;

        // Single clipping Rectangle whose height animates between collapsed (66px)
        // and fully expanded (txt.preferred-height).  preferred-height is the text's
        // natural wrapped height at the given width — it doesn't feed into any layout
        // cycle because it reads the text content, not any allocated dimension.
        Rectangle {
            clip:   true;
            height: root.expanded ? max(txt.preferred-height, 66px) : 66px;
            animate height { duration: 200ms * AppState.settings-animation-speed; easing: ease-in-out; }

            txt := Text {
                x:         0;
                y:         0;
                text:      root.text;
                color:     #cccccc;
                font-size: 15px;
                wrap:      word-wrap;
                width:     min(root.width - 96px, 640px);
            }
        }
    }
}

// ── Stats overlay row ─────────────────────────────────────────────────────────
export component StatRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    HorizontalLayout {
        padding-top:    2px;
        padding-bottom: 2px;
        spacing:        10px;
        Text {
            text:               label;
            color:              #555555;
            font-size:          11px;
            font-weight:        700;
            width:              60px;
            vertical-alignment: top;
        }
        Text {
            text:               value;
            color:              #cccccc;
            font-size:          11px;
            wrap:               word-wrap;
            horizontal-stretch: 1;
        }
    }
}

// ── Mini-player bar ───────────────────────────────────────────────────────────
// Full-width bar docked at the top by MainWindow (y=0, width=parent.width).
// Mode 3 (!video-behind-ui): 108px — live video (192×108, 16:9) + title + Resume/Stop.
// Mode 2 (video-behind-ui):   56px — compact bar (no thumbnail; video fills window) + title + Resume/Stop.
// float-card-focused: -1=not focused, 0=Resume, 1=Stop. Up from sidebar nav=0 to focus.
export component MiniPlayerBar inherits Rectangle {
    height:     AppState.video-behind-ui ? 56px : 108px;
    background: Theme.surface-raised;

    // Focus ring
    if AppState.float-card-focused >= 0: Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        border-width:  2px;
        border-color:  Theme.accent;
        border-radius: 0px;
        background:    transparent;
    }

    // ── Mode 3: live video + info ─────────────────────────────────────────────
    if !AppState.video-behind-ui: HorizontalLayout {
        Rectangle {
            width:      192px;
            background: #000000;
            clip:       true;
            Image {
                source:    AppState.video-frame;
                width:     parent.width;
                height:    parent.height;
                image-fit: contain;
            }
        }
        VerticalLayout {
            padding:   12px;
            spacing:   5px;
            alignment: center;
            Text { text: "NOW PLAYING"; color: Theme.accent; font-size: 9px; font-weight: 700; }
            Text { text: AppState.playing-title; color: Theme.text; font-size: 13px; overflow: elide; }
            HorizontalLayout {
                spacing: 6px; alignment: start;
                FjordButton {
                    icon-left: "▶︎"; text: "Resume"; height: 28px; width: 120px;
                    kbd-focused: AppState.float-card-focused == 0;
                    clicked => { AppState.float-card-focused = -1; AppState.resume-player(); }
                }
                FjordButton {
                    icon-left: "■︎"; text: "Stop"; height: 28px; width: 80px; danger: true;
                    kbd-focused: AppState.float-card-focused == 1;
                    clicked => { AppState.float-card-focused = -1; AppState.stop-playback(); }
                }
            }
        }
    }

    // ── Mode 2: compact 56px bar (video fills window; no thumbnail needed) ────
    if AppState.video-behind-ui: HorizontalLayout {
        padding: 12px; spacing: 8px;
        VerticalLayout {
            alignment: center; spacing: 3px; horizontal-stretch: 1;
            Text { text: "NOW PLAYING"; color: Theme.accent; font-size: 9px; font-weight: 700; }
            Text { text: AppState.playing-title; color: Theme.text; font-size: 13px; overflow: elide; }
        }
        HorizontalLayout {
            spacing: 6px; alignment: end;
            FjordButton {
                icon-left: "▶︎"; text: "Resume"; height: 28px; width: 120px;
                kbd-focused: AppState.float-card-focused == 0;
                clicked => { AppState.float-card-focused = -1; AppState.resume-player(); }
            }
            FjordButton {
                icon-left: "■︎"; text: "Stop"; height: 28px; width: 80px; danger: true;
                kbd-focused: AppState.float-card-focused == 1;
                clicked => { AppState.float-card-focused = -1; AppState.stop-playback(); }
            }
        }
    }
}

// ── Music player bar ──────────────────────────────────────────────────────────
export component MusicPlayerBar inherits Rectangle {
    height:     72px;
    background: Theme.surface-raised;
    border-color: Theme.border;
    border-width: 0px;

    // Top border line
    Rectangle {
        y: 0; height: 1px;
        background: Theme.border;
    }

    HorizontalLayout {
        padding:   0px;
        spacing:   0px;

        // ── Left zone: album art + title + artist ─────────────────────────────
        ta-left := TouchArea {
            width:   240px;
            mouse-cursor: MouseCursor.pointer;
            // Opens the fullscreen Now Playing screen — "Open Album" moved
            // inside it (Phase 66).
            clicked => { AppState.open-now-playing(); }

            Rectangle {
                border-radius: Theme.radius;
                border-width:  (ta-left.pressed || left-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 0 ? 2px : 0px);
                border-color:  Theme.accent;
                background:    ta-left.has-hover ? Theme.surface-overlay : transparent;
                animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                left-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 0; }

            HorizontalLayout {
                padding:  8px;
                spacing:  10px;
                alignment: center;

                // Album art 60×60
                Rectangle {
                    width:         56px;
                    height:        56px;
                    border-radius: Theme.radius;
                    background:    Theme.surface-overlay;
                    clip:          true;
                    if AppState.music-bar-has-art: Image {
                        width:     parent.width;
                        height:    parent.height;
                        image-fit: cover;
                        source:    AppState.music-bar-art;
                    }
                    if !AppState.music-bar-has-art: Text {
                        text:                 "♫";
                        font-family:          "Noto Sans Symbols 2";
                        color:                Theme.text-subtle;
                        font-size:            24px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }

                VerticalLayout {
                    alignment:          center;
                    spacing:            3px;
                    horizontal-stretch: 1;
                    Text {
                        text:        AppState.music-bar-title;
                        color:       Theme.text;
                        font-size:   13px;
                        font-weight: 600;
                        overflow:    elide;
                    }
                    Text {
                        text:      AppState.music-bar-artist;
                        color:     Theme.text-muted;
                        font-size: 12px;
                        overflow:  elide;
                    }
                }
            }
            } // Rectangle (focus border)
        }

        // ── Centre zone: transport + progress + time ──────────────────────────
        VerticalLayout {
            horizontal-stretch: 1;
            padding-top:     8px;
            padding-bottom:  8px;
            spacing:         4px;
            alignment:       center;

            // Transport buttons
            HorizontalLayout {
                alignment: center;
                spacing:   16px;

                // Play / Pause
                ta-pp := TouchArea {
                    width:  36px; height: 36px;
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { AppState.music-bar-play-pause(); }
                    Rectangle {
                        width:  parent.width; height: parent.height;
                        border-radius: 18px;
                        border-width:  (ta-pp.pressed || pp-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 1 ? 2px : 0px);
                        border-color:  Theme.accent;
                        background: ta-pp.has-hover ? Theme.surface-overlay : transparent;
                        animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                        pp-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 1; }
                        Text {
                            text:                 AppState.music-bar-paused ? "▶︎" : "⏸︎";
                            font-family:          "Noto Sans Symbols 2";
                            color:                Theme.text;
                            font-size:            16px;
                            vertical-alignment:   center;
                            horizontal-alignment: center;
                            width:                parent.width;
                            height:               parent.height;
                        }
                    }
                }

                // Stop
                ta-stop := TouchArea {
                    width:  36px; height: 36px;
                    mouse-cursor: MouseCursor.pointer;
                    clicked => { AppState.music-bar-stop(); }
                    Rectangle {
                        width:  parent.width; height: parent.height;
                        border-radius: 18px;
                        border-width:  (ta-stop.pressed || stop-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 2 ? 2px : 0px);
                        border-color:  Theme.accent;
                        background: ta-stop.has-hover ? Theme.surface-overlay : transparent;
                        animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                        stop-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 2; }
                        Text {
                            text:                 "⏹︎";
                            font-family:          "Noto Sans Symbols 2";
                            color:                Theme.text-muted;
                            font-size:            14px;
                            vertical-alignment:   center;
                            horizontal-alignment: center;
                            width:                parent.width;
                            height:               parent.height;
                        }
                    }
                }
            }

            // Progress bar + time
            HorizontalLayout {
                spacing:   8px;

                Text {
                    text:      AppState.music-bar-elapsed;
                    color:     Theme.text-muted;
                    font-size: 11px;
                    width:     36px;
                    horizontal-alignment: right;
                    vertical-alignment:   center;
                }

                // Seek bar
                progress-ta := TouchArea {
                    horizontal-stretch: 1;
                    height: 16px;
                    mouse-cursor: MouseCursor.pointer;
                    clicked => {
                        AppState.music-bar-seek(self.mouse-x / self.width);
                    }
                    // Track — thicker + brighter when keyboard-focused (slot 3)
                    property <bool> tl-focused: AppState.music-bar-focused == 3;
                    Rectangle {
                        x:             0;
                        width:         parent.width;
                        y:             (parent.height - (parent.tl-focused ? 5px : 3px)) / 2;
                        height:        parent.tl-focused ? 5px : 3px;
                        border-radius: parent.tl-focused ? 2.5px : 1.5px;
                        background:    parent.tl-focused ? Theme.accent-muted : Theme.surface-overlay;

                        // Filled portion
                        Rectangle {
                            x:             0;
                            width:         parent.width * AppState.music-bar-pos;
                            height:        parent.height;
                            border-radius: parent.border-radius;
                            background:    Theme.accent;
                        }
                    }
                }

                Text {
                    text:      AppState.music-bar-total;
                    color:     Theme.text-muted;
                    font-size: 11px;
                    width:     36px;
                    horizontal-alignment: left;
                    vertical-alignment:   center;
                }
            }
        }

        // ── Right zone: ⏮︎Prev/⏭︎Next/⇌︎Shuffle/↺︎Repeat/⋮︎Queue/♪︎Lyrics(cond.)/🔉︎/🔊︎ ──
        // Width sized for the worst case (8 × 36px icons + 7 × 8px gaps = 344px);
        // was a stale 240px left over from the original 6-icon set — the two
        // volume buttons overflowed past the window edge and got clipped.
        HorizontalLayout {
            width:     344px;
            alignment: center;
            spacing:   8px;

            // ⏮︎ Prev (slot 4)
            ta-prev := TouchArea {
                width: 36px; height: 36px;
                mouse-cursor: MouseCursor.pointer;
                clicked => { AppState.queue-prev-track(); }
                Rectangle {
                    border-radius: 18px;
                    border-width:  (ta-prev.pressed || prev-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 4 ? 2px : 0px);
                    border-color:  Theme.accent;
                    background:    ta-prev.has-hover ? Theme.surface-overlay : transparent;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    prev-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 4; }
                    Text {
                        text:                 "⏮︎";
                        font-family:          "Noto Sans Symbols 2";
                        color:                Theme.text-muted;
                        font-size:            14px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }
            }

            // ⏭︎ Next (slot 5)
            ta-next := TouchArea {
                width: 36px; height: 36px;
                mouse-cursor: MouseCursor.pointer;
                clicked => { AppState.queue-next-track(); }
                Rectangle {
                    border-radius: 18px;
                    border-width:  (ta-next.pressed || next-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 5 ? 2px : 0px);
                    border-color:  Theme.accent;
                    background:    ta-next.has-hover ? Theme.surface-overlay : transparent;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    next-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 5; }
                    Text {
                        text:                 "⏭︎";
                        font-family:          "Noto Sans Symbols 2";
                        color:                Theme.text-muted;
                        font-size:            14px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }
            }

            // ⇌︎ Shuffle (slot 6)
            ta-shuffle := TouchArea {
                width: 36px; height: 36px;
                mouse-cursor: MouseCursor.pointer;
                clicked => { AppState.toggle-shuffle(); }
                Rectangle {
                    border-radius: 18px;
                    border-width:  (ta-shuffle.pressed || shuffle-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 6 ? 2px : 0px);
                    border-color:  Theme.accent;
                    background:    (ta-shuffle.has-hover || AppState.queue-shuffle) ? Theme.surface-overlay : transparent;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    shuffle-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 6; }
                    Text {
                        text:                 "⇌︎";
                        font-family:          "Noto Sans Symbols 2";
                        color:                AppState.queue-shuffle ? Theme.accent : Theme.text-muted;
                        font-size:            14px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }
            }

            // ↺︎ Repeat (slot 7): Off(muted) / All(accent) / One(accent + superscript¹)
            ta-repeat := TouchArea {
                width: 36px; height: 36px;
                mouse-cursor: MouseCursor.pointer;
                clicked => { AppState.cycle-repeat(); }
                Rectangle {
                    border-radius: 18px;
                    border-width:  (ta-repeat.pressed || repeat-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 7 ? 2px : 0px);
                    border-color:  Theme.accent;
                    background:    (ta-repeat.has-hover || AppState.queue-repeat-mode > 0) ? Theme.surface-overlay : transparent;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    repeat-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 7; }
                    Text {
                        text:                 AppState.queue-repeat-mode == 2 ? "↺︎¹" : "↺︎";
                        font-family:          "Noto Sans Symbols 2";
                        color:                AppState.queue-repeat-mode > 0 ? Theme.accent : Theme.text-muted;
                        font-size:            14px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }
            }

            // ⋮︎ Queue (slot 8): opens queue panel
            ta-queue-btn := TouchArea {
                width: 36px; height: 36px;
                mouse-cursor: MouseCursor.pointer;
                clicked => { AppState.open-queue-panel(); }
                Rectangle {
                    border-radius: 18px;
                    border-width:  (ta-queue-btn.pressed || queue-btn-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 8 ? 2px : 0px);
                    border-color:  Theme.accent;
                    background:    (ta-queue-btn.has-hover || AppState.show-queue-panel) ? Theme.surface-overlay : transparent;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    queue-btn-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 8; }
                    Text {
                        text:                 "⋮︎";
                        font-family:          "Noto Sans Symbols 2";
                        color:                AppState.show-queue-panel ? Theme.accent : Theme.text-muted;
                        font-size:            18px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }
            }

            // ♪︎ Lyrics (slot 9): toggle lyrics overlay; only shown when lyrics available
            if AppState.lyrics-available: ta-lyrics-btn := TouchArea {
                width: 36px; height: 36px;
                mouse-cursor: MouseCursor.pointer;
                clicked => { AppState.toggle-lyrics(); }
                Rectangle {
                    border-radius: 18px;
                    border-width:  (ta-lyrics-btn.pressed || lyrics-btn-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 9 ? 2px : 0px);
                    border-color:  Theme.accent;
                    background:    (ta-lyrics-btn.has-hover || AppState.show-lyrics) ? Theme.surface-overlay : transparent;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    lyrics-btn-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 9; }
                    Text {
                        text:                 "♪︎";
                        font-family:          "Noto Sans Symbols 2";
                        color:                AppState.show-lyrics ? Theme.accent : Theme.text-muted;
                        font-size:            16px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }
            }

            // 🔉︎ Volume Down (slot 10) / 🔊︎ Volume Up (slot 11): always shown.
            ta-vol-down := TouchArea {
                width: 36px; height: 36px;
                mouse-cursor: MouseCursor.pointer;
                clicked => { AppState.volume-down(); }
                Rectangle {
                    border-radius: 18px;
                    border-width:  (ta-vol-down.pressed || vol-down-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 10 ? 2px : 0px);
                    border-color:  Theme.accent;
                    background:    ta-vol-down.has-hover ? Theme.surface-overlay : transparent;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    vol-down-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 10; }
                    Text {
                        text:                 "🔉︎";
                        color:                Theme.text-muted;
                        font-size:            15px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }
            }
            ta-vol-up := TouchArea {
                width: 36px; height: 36px;
                mouse-cursor: MouseCursor.pointer;
                clicked => { AppState.volume-up(); }
                Rectangle {
                    border-radius: 18px;
                    border-width:  (ta-vol-up.pressed || vol-up-pulse.pulsing) ? 4px : (AppState.music-bar-focused == 11 ? 2px : 0px);
                    border-color:  Theme.accent;
                    background:    ta-vol-up.has-hover ? Theme.surface-overlay : transparent;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    vol-up-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.music-bar-focused == 11; }
                    Text {
                        text:                 "🔊︎";
                        color:                Theme.text-muted;
                        font-size:            15px;
                        vertical-alignment:   center;
                        horizontal-alignment: center;
                        width:                parent.width;
                        height:               parent.height;
                    }
                }
            }
        }
    }
}

// ── Queue panel ───────────────────────────────────────────────────────────────
// Right-side overlay: header "Queue N of M" + "Clear All" + scrollable playlist.
// Current item rendered with accent background and bold title.
// Keyboard: Up/Down navigate, Enter = jump to item, Delete/Back = close.
export component QueuePanel inherits Rectangle {
    // Dim overlay behind the panel
    background: #00000088;

    TouchArea {
        // Click outside the panel closes it
        width: parent.width - 400px; height: parent.height;
        x: 0; y: 0;
        clicked => { AppState.show-queue-panel = false; }
    }

    // Panel body
    panel := Rectangle {
        x:             parent.width - 400px;
        y:             0;
        width:         400px;
        height:        parent.height;
        background:    Theme.surface;
        border-width:  1px;
        border-color:  Theme.border;
        clip:          true;

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // ── Header ────────────────────────────────────────────────────────
            header := Rectangle {
                height:     56px;
                background: Theme.surface-raised;
                border-width:  0px;

                HorizontalLayout {
                    padding-left:  16px;
                    padding-right: 12px;
                    alignment:     space-between;
                    spacing:       0px;

                    Text {
                        text: {
                            let n = AppState.queue-items.length;
                            let c = AppState.queue-panel-cursor;
                            "Queue — " + (max(c, 0) + 1) + " of " + n
                        }
                        color:             Theme.text;
                        font-size:         15px;
                        font-weight:       600;
                        vertical-alignment: center;
                        height: parent.height;
                    }

                    ta-clear := TouchArea {
                        width: 72px; height: parent.height;
                        mouse-cursor: MouseCursor.pointer;
                        clicked => { AppState.queue-clear(); }
                        Text {
                            // Keyboard focus: Up from the top row lands here (cursor -1)
                            text:                 "Clear All";
                            color:                { let hov = ta-clear.has-hover;
                                                    AppState.queue-panel-cursor == -1 ? Theme.accent
                                                    : hov ? Theme.accent : Theme.text-muted };
                            font-size:            13px;
                            font-weight:          AppState.queue-panel-cursor == -1 ? 700 : 400;
                            vertical-alignment:   center;
                            horizontal-alignment: right;
                            width:                parent.width;
                            height:               parent.height;
                        }
                        // Press feedback: underline only, text itself untouched.
                        Rectangle {
                            x: 0; y: parent.height - 3px;
                            width:      parent.width;
                            height:     (ta-clear.pressed || clear-pulse.pulsing) ? 3px : 0px;
                            background: Theme.accent;
                            animate height { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                        }
                        clear-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.queue-panel-cursor == -1; }
                    }
                }

                // Bottom border
                Rectangle {
                    x: 0; y: parent.height - 1px;
                    width: parent.width; height: 1px;
                    background: Theme.border;
                }
            }

            // ── Scrollable list ───────────────────────────────────────────────
            list-area := Rectangle {
                height: parent.height - header.height;
                clip:   true;

                fl := Flickable {
                    width:           parent.width;
                    height:          parent.height;
                    viewport-height: max(parent.height, list.preferred-height);

                    property <length> kb-y: clamp(
                        -(AppState.queue-panel-cursor * 56px) + parent.height / 2 - 28px,
                        min(0px, parent.height - list.preferred-height),
                        0px
                    );
                    changed kb-y => { fl.viewport-y = kb-y; }

                    list := VerticalLayout {
                        alignment: start;
                        spacing:   0px;
                        padding:   0px;

                        for entry[i] in AppState.queue-items: row-ta := TouchArea {
                            height: 56px;
                            mouse-cursor: MouseCursor.pointer;
                            double-clicked => { AppState.queue-jump(entry.index); }
                            clicked => { AppState.queue-panel-cursor = i; }

                            Rectangle {
                                height: parent.height;
                                background: entry.is-current ? #ffffff14
                                          : i == AppState.queue-panel-cursor ? Theme.surface-overlay
                                          : row-ta.has-hover ? #ffffff08
                                          : transparent;
                                border-width:  (row-ta.pressed || row-pulse.pulsing) ? 3px : 0px;
                                border-color:  Theme.accent;
                                animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                                row-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: i == AppState.queue-panel-cursor; }

                                HorizontalLayout {
                                    padding-left:  10px;
                                    padding-right: 12px;
                                    spacing:       10px;
                                    alignment:     center;

                                    // Album art thumbnail (40×40)
                                    Rectangle {
                                        width:         40px;
                                        height:        40px;
                                        border-radius: Theme.radius;
                                        background:    Theme.surface-overlay;
                                        clip:          true;
                                        if entry.has-poster: Image {
                                            width:     parent.width;
                                            height:    parent.height;
                                            image-fit: cover;
                                            source:    entry.poster;
                                        }
                                        if !entry.has-poster: Text {
                                            text:                 "♫";
                                            font-family:          "Noto Sans Symbols 2";
                                            color:                Theme.text-subtle;
                                            font-size:            18px;
                                            vertical-alignment:   center;
                                            horizontal-alignment: center;
                                            width:                parent.width;
                                            height:               parent.height;
                                        }
                                    }

                                    // Index number
                                    Text {
                                        text:               i + 1;
                                        color:              entry.is-current ? Theme.accent : Theme.text-muted;
                                        font-size:          12px;
                                        horizontal-alignment: right;
                                        vertical-alignment:   center;
                                        width:              22px;
                                    }

                                    // Title + artist column
                                    VerticalLayout {
                                        alignment:          center;
                                        spacing:            2px;
                                        horizontal-stretch: 1;

                                        Text {
                                            text:       entry.title;
                                            color:      entry.is-current ? Theme.accent : Theme.text;
                                            font-size:  14px;
                                            font-weight: entry.is-current ? 700 : 400;
                                            overflow:   elide;
                                        }

                                        if entry.artist != "" || entry.is-queued: Text {
                                            text:      entry.is-queued
                                                       ? (entry.artist == "" ? "Queued" : entry.artist + "  ·  Queued")
                                                       : entry.artist;
                                            color:     entry.is-queued ? Theme.text-subtle : Theme.text-muted;
                                            font-size: 12px;
                                            overflow:  elide;
                                        }
                                    }
                                }

                                // Bottom separator (skip last row)
                                if i < AppState.queue-items.length - 1: Rectangle {
                                    x: 10px; y: parent.height - 1px;
                                    width: parent.width - 20px; height: 1px;
                                    background: Theme.border;
                                }

                                // Focused-row left accent stripe
                                if i == AppState.queue-panel-cursor: Rectangle {
                                    x: 0; y: 0;
                                    width: 3px; height: parent.height;
                                    background: Theme.accent;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// ── Lyrics view ───────────────────────────────────────────────────────────────
// Full-width overlay that shows synced or unsynced lyrics.
// Active line (lyrics-active-idx) is highlighted in accent; the view auto-scrolls
// to keep it centred via the kb-y binding pattern.
export component LyricsView inherits Rectangle {
    background: #000000cc;

    // Click backdrop to dismiss
    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { AppState.toggle-lyrics(); }
    }

    // Panel: full window width minus fixed side padding (was capped at a
    // narrow fixed 600px, which left large empty margins on typical HTPC
    // displays). No upper cap — each line is short and horizontally centred
    // within the column rather than flowing to fill it, so there's no
    // paragraph-readability reason to additionally cap the column itself on
    // wide screens.
    panel := Rectangle {
        x:          80px;
        y:          0;
        width:      parent.width - 160px;
        height:     parent.height;
        background: transparent;

        // kb-y + changed-handler (not a direct viewport-y binding) keeps
        // native mouse-wheel scroll working alongside the auto-follow.
        fl := Flickable {
            width:           parent.width;
            height:          parent.height;
            viewport-height: max(parent.height, lyric-list.preferred-height);

            property <length> kb-y: clamp(
                -(AppState.lyrics-active-idx * 76px) + parent.height / 2 - 38px,
                min(0px, parent.height - lyric-list.preferred-height),
                0px
            );
            changed kb-y => { fl.viewport-y = kb-y; }
            animate viewport-y { duration: 450ms * AppState.settings-scroll-speed; easing: ease-in-out; }

            lyric-list := VerticalLayout {
                alignment: start;
                spacing:   0px;
                padding:   32px;

                // min-height (not a fixed height) lets a long line wrap to 2+ lines
                // instead of being elided with "…" — Text's un-set height then
                // reports its real wrapped size upward, and the TouchArea (having
                // no height of its own) takes that size, floored at 76px so short
                // lines keep the usual single-line row rhythm. `sizer` is an
                // invisible probe always measured at the ACTIVE font/weight, so a
                // row that would need 2 lines once highlighted reserves that
                // height up front — without this, a line sitting at 1 line while
                // small would suddenly grow the whole list by a row's height the
                // instant it activates, on top of the font-size jump.
                for line[i] in AppState.lyrics-lines: TouchArea {
                    min-height: max(76px, sizer.preferred-height);
                    clicked => { AppState.toggle-lyrics(); }
                    sizer := Text {
                        visible:    false;
                        height:     0px;
                        text:       line.text;
                        font-size:  40px;
                        font-weight: 700;
                        width:      parent.width;
                        wrap:       word-wrap;
                    }
                    Text {
                        text:               line.text;
                        color:              i == AppState.lyrics-active-idx ? Theme.accent
                                          : i == AppState.lyrics-active-idx + 1 || i == AppState.lyrics-active-idx - 1
                                            ? Theme.text-muted
                                          : Theme.text-subtle;
                        font-size:          i == AppState.lyrics-active-idx ? 40px : 24px;
                        font-weight:        i == AppState.lyrics-active-idx ? 700 : 400;
                        horizontal-alignment: center;
                        width:              parent.width;
                        // Can't bind height: parent.height here — parent (the
                        // TouchArea) derives ITS height from `sizer`, not from
                        // this Text, so that's not a cycle, but this Text's own
                        // natural (unset) height is what lets a short line stay
                        // short instead of stretching to fill the reserved row;
                        // centre it manually within that taller row instead.
                        y:                  (parent.height - self.height) / 2;
                        wrap:               word-wrap;
                        animate color, font-size { duration: 350ms * AppState.settings-animation-speed; easing: ease-in-out; }
                    }
                }
            }
        }
    }
}

// ── Volume overlay ───────────────────────────────────────────────────────────
// Top-center toast; shows level bar + %; auto-hides after 1.5 s (Rust-driven).
// Was inline in player.slint (fullscreen video only) — shared here so the new
// music-bar / Now Playing volume buttons get the same feedback.
export component VolumeOverlay inherits Rectangle {
    width:         220px;
    height:        44px;
    border-radius: Theme.radius;
    background:    #0d0d0dcc;
    drop-shadow-blur:  10px;
    drop-shadow-color: #00000055;

    HorizontalLayout {
        padding-left:  14px;
        padding-right: 14px;
        padding-top:   0;
        padding-bottom: 0;
        spacing:       10px;
        alignment:     center;

        Text {
            text:               "Vol";
            color:              Theme.accent;
            font-size:          11px;
            font-weight:        700;
            vertical-alignment: center;
            width:              24px;
        }

        if !AppState.audio-passthrough-active: Rectangle {
            height:             6px;
            horizontal-stretch: 1;
            background:         #444444;
            border-radius:      3px;

            Rectangle {
                x:             0;
                width:         parent.width * AppState.volume-level / 100;
                height:        parent.height;
                background:    Theme.accent;
                border-radius: 3px;
            }
        }

        if AppState.audio-passthrough-active: Text {
            text:               "passthrough";
            color:              Theme.text-subtle;
            font-size:          11px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }

        if !AppState.audio-passthrough-active: Text {
            text:               AppState.volume-level + "%";
            color:              #bbbbbb;
            font-size:          11px;
            vertical-alignment: center;
            width:              38px;
        }
    }
}

// ── Toast notification ────────────────────────────────────────────────────────
export component ToastNotification inherits Rectangle {
    in property <string> message;

    height: max(44px, txt.preferred-height + 22px);

    border-radius: Theme.radius-lg;
    background:    #101012f0;
    border-width:  1px;
    border-color:  Theme.border-strong;
    drop-shadow-blur:     14px;
    drop-shadow-color:    #00000077;
    drop-shadow-offset-y: 4px;
    clip: true;

    // Left accent stripe
    Rectangle {
        x: 0; y: 0;
        width:      4px;
        height:     parent.height;
        background: Theme.error;
    }

    txt := Text {
        x:      18px;
        y:      0;
        width:  parent.width - 26px;
        height: parent.height;
        text:               root.message;
        color:              Theme.text;
        font-size:          13px;
        wrap:               word-wrap;
        vertical-alignment: center;
    }
}
