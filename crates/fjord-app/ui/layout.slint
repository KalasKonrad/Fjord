// ── fjord-app · layout.slint ─────────────────────────────────────────────────
//   AppShell  sidebar (NavItems: Home/Movies/TV Shows/Browse All/Settings/Quit + mini-player card) + content area slot
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, NavItem } from "widgets.slint";

export component AppShell inherits HorizontalLayout {
    opacity: AppState.video-behind-ui ? 0.88 : 1.0;
    spacing: 0px;

    Rectangle {
        width:      Theme.sidebar-width;
        background: Theme.sidebar-bg;

        VerticalLayout {
            padding:     Theme.sp;
            padding-top: Theme.sp-lg;
            spacing:     3px;

            Rectangle {
                height: 48px;
                VerticalLayout {
                    alignment: center;
                    spacing:   2px;
                    Text { text: "Fjord";    color: Theme.accent;      font-size: 20px; font-weight: 700; }
                    Text { text: "Jellyfin"; color: Theme.text-subtle; font-size: 11px; }
                }
            }

            Rectangle { height: Theme.sp; }

            NavItem {
                label: "Home";
                active: AppState.active-nav == 0;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 0;
                    AppState.nav-selected(0);
                    AppState.focused-section = -1;
                }
            }
            NavItem {
                label: "Movies";
                active: AppState.active-nav == 1;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 1;
                    AppState.nav-selected(1);
                    AppState.focused-section = -1;
                }
                double-clicked => {
                    AppState.active-nav       = 1;
                    AppState.nav-selected(1);
                    AppState.show-browse      = false;
                    AppState.show-library     = true;
                    AppState.library-focused  = 0;
                    AppState.focused-section  = -1;
                    AppState.library-search-clear();
                }
            }
            NavItem {
                label: "TV Shows";
                active: AppState.active-nav == 2;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 2;
                    AppState.nav-selected(2);
                    AppState.focused-section = -1;
                }
                double-clicked => {
                    AppState.active-nav       = 2;
                    AppState.nav-selected(2);
                    AppState.show-browse      = false;
                    AppState.show-library     = true;
                    AppState.library-focused  = 0;
                    AppState.focused-section  = -1;
                    AppState.library-search-clear();
                }
            }
            NavItem {
                label: "Browse All";
                active: AppState.active-nav == 3;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-library    = false;
                    AppState.show-browse     = true;
                    AppState.active-nav      = 3;
                    AppState.nav-selected(3);
                    AppState.focused-section = -1;
                    AppState.browse-search-clear();
                }
            }

            Rectangle { vertical-stretch: 1; }

            if AppState.has-background-player: Rectangle {
                height:        AppState.video-behind-ui ? 74px : 148px;
                background:    Theme.surface-raised;
                border-radius: Theme.radius;
                clip:          true;

                VerticalLayout {
                    spacing: 0px;

                    if !AppState.video-behind-ui: Rectangle {
                        height:     80px;
                        background: #000000;
                        clip:       true;
                        Image {
                            source:    AppState.video-frame;
                            width:     parent.width;
                            height:    parent.height;
                            image-fit: contain;
                        }
                    }

                    VerticalLayout {
                        padding:   8px;
                        spacing:   4px;
                        alignment: center;

                        Text {
                            text:        "NOW PLAYING";
                            color:       Theme.accent;
                            font-size:   9px;
                            font-weight: 700;
                        }
                        Text {
                            text:      AppState.playing-title;
                            color:     Theme.text;
                            font-size: 12px;
                            overflow:  elide;
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            FjordButton {
                                text:               "▶  Resume";
                                height:             28px;
                                horizontal-stretch: 1;
                                clicked => { AppState.resume-player(); }
                            }
                            FjordButton {
                                text:   "■";
                                height: 28px;
                                width:  28px;
                                danger: true;
                                clicked => { AppState.stop-playback(); }
                            }
                        }
                    }
                }
            }

            Rectangle { height: 4px; }

            NavItem {
                label: "Settings";
                active: AppState.active-nav == 10;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-browse  = false;
                    AppState.show-library = false;
                    AppState.active-nav   = 10;
                    AppState.nav-selected(10);
                    AppState.focused-section   = -1;
                }
            }

            Rectangle {
                height:        36px;
                border-radius: Theme.radius;
                background: (AppState.active-nav == 11 && AppState.focused-section < 0) || ta-quit.has-hover ? #3a1a1a : #00000000;
                ta-quit := TouchArea {
                    clicked => { AppState.quit(); }
                }
                HorizontalLayout {
                    padding-left: 14px;
                    spacing:      10px;
                    alignment:    start;
                    Rectangle {
                        width: 6px;
                        Rectangle {
                            width: 6px; height: 6px; border-radius: 3px;
                            y: (parent.height - self.height) / 2;
                            background: Theme.error;
                        }
                    }
                    Text {
                        text:               "Quit";
                        color:              Theme.error;
                        font-size:          14px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    Rectangle { width: 1px; background: Theme.border; }

    @children
}
