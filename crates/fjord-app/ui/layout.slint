// ── fjord-app · layout.slint ─────────────────────────────────────────────────
//   AppShell  sidebar (NavItems: Home/TV Shows/Movies/Collections/Music/Browse All/Settings/Quit
//             + mini-player card) + content area slot
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, NavItem } from "widgets.slint";

export component AppShell inherits HorizontalLayout {
    spacing: 0px;

    Rectangle {
        width:      Theme.sidebar-width;
        background: Theme.sidebar-bg;

        VerticalLayout {
            padding:     Theme.sp;
            padding-top: Theme.sp-lg;
            spacing:     3px;

            Rectangle {
                height: 48px;
                HorizontalLayout {
                    alignment: center;
                    spacing:   8px;
                    Image {
                        width:  40px;
                        height: 40px;
                        source: AppState.app-logo-idx == 1  ? @image-url("../../../assets/fjord_01.svg") :
                                AppState.app-logo-idx == 2  ? @image-url("../../../assets/fjord_02.svg") :
                                AppState.app-logo-idx == 4  ? @image-url("../../../assets/fjord_04.svg") :
                                AppState.app-logo-idx == 5  ? @image-url("../../../assets/fjord_05.svg") :
                                AppState.app-logo-idx == 9  ? @image-url("../../../assets/fjord_09.svg") :
                                                              @image-url("../../../assets/fjord_10.svg");
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing:   2px;
                        Text { text: "Fjord";    color: Theme.accent;      font-size: 20px; font-weight: 700; }
                        Text { text: "Jellyfin"; color: Theme.text-subtle; font-size: 11px; }
                    }
                }
            }

            Rectangle { height: Theme.sp; }

            NavItem {
                label: "Home";
                active: AppState.active-nav == 0;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 0;
                    AppState.nav-selected(0);
                    AppState.focused-section = -1;
                }
            }
            NavItem {
                label: "TV Shows";
                active: AppState.active-nav == 1;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 1;
                    AppState.nav-selected(1);
                    AppState.focused-section = -1;
                }
                double-clicked => {
                    AppState.active-nav       = 1;
                    AppState.nav-selected(1);
                    AppState.show-browse      = false;
                    AppState.show-library     = true;
                    AppState.library-focused  = 0;
                    AppState.focused-section  = -1;
                    AppState.library-search-clear();
                }
            }
            NavItem {
                label: "Movies";
                active: AppState.active-nav == 2;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 2;
                    AppState.nav-selected(2);
                    AppState.focused-section = -1;
                }
                double-clicked => {
                    AppState.active-nav       = 2;
                    AppState.nav-selected(2);
                    AppState.show-browse      = false;
                    AppState.show-library     = true;
                    AppState.library-focused  = 0;
                    AppState.focused-section  = -1;
                    AppState.library-search-clear();
                }
            }
            NavItem {
                label: "Collections";
                active: AppState.active-nav == 3;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 3;
                    AppState.nav-selected(3);
                    AppState.focused-section = -1;
                }
                double-clicked => {
                    AppState.active-nav       = 3;
                    AppState.nav-selected(3);
                    AppState.show-browse      = false;
                    AppState.show-library     = true;
                    AppState.library-focused  = 0;
                    AppState.focused-section  = -1;
                    AppState.library-search-clear();
                }
            }
            // Music — nav=4, placeholder (not yet implemented)
            Rectangle {
                height:        36px;
                border-radius: Theme.radius;
                background: AppState.active-nav == 4 && AppState.focused-section < 0 ? Theme.surface : #00000000;
                TouchArea {
                    clicked => {
                        AppState.show-browse     = false;
                        AppState.show-library    = false;
                        AppState.active-nav      = 4;
                        AppState.nav-selected(4);
                        AppState.focused-section = -1;
                    }
                }
                HorizontalLayout {
                    padding-left: 14px;
                    spacing:      10px;
                    alignment:    start;
                    Rectangle {
                        width: 6px;
                        Rectangle {
                            width: 6px; height: 6px; border-radius: 3px;
                            y: (parent.height - self.height) / 2;
                            background: Theme.text-subtle;
                        }
                    }
                    Text {
                        text:               "Music";
                        color:              Theme.text-subtle;
                        font-size:          14px;
                        vertical-alignment: center;
                    }
                }
            }
            NavItem {
                label: "Browse All";
                active: AppState.active-nav == 5;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-library    = false;
                    AppState.show-browse     = true;
                    AppState.active-nav      = 5;
                    AppState.nav-selected(5);
                    AppState.focused-section = -1;
                    AppState.browse-search-clear();
                }
            }

            Rectangle { vertical-stretch: 1; }

            Rectangle { height: 4px; }

            NavItem {
                label: "Settings";
                active: AppState.active-nav == 10;
                kbd-focused: AppState.focused-section < 0;
                clicked => {
                    AppState.show-browse  = false;
                    AppState.show-library = false;
                    AppState.active-nav   = 10;
                    AppState.nav-selected(10);
                    AppState.focused-section   = -1;
                }
            }

            Rectangle {
                height:        36px;
                border-radius: Theme.radius;
                background: (AppState.active-nav == 11 && AppState.focused-section < 0) || ta-quit.has-hover ? #3a1a1a : #00000000;
                ta-quit := TouchArea {
                    clicked => { AppState.quit(); }
                }
                HorizontalLayout {
                    padding-left: 14px;
                    spacing:      10px;
                    alignment:    start;
                    Rectangle {
                        width: 6px;
                        Rectangle {
                            width: 6px; height: 6px; border-radius: 3px;
                            y: (parent.height - self.height) / 2;
                            background: Theme.error;
                        }
                    }
                    Text {
                        text:               "Quit";
                        color:              Theme.error;
                        font-size:          14px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    Rectangle { width: 1px; background: Theme.border; }

    @children
}
