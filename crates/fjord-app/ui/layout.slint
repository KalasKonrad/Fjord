// ── fjord-app · layout.slint ─────────────────────────────────────────────────
//   AppShell  sidebar (NavItems: Home/TV Shows/Movies/Collections/Music(nav=4)/Browse All/Settings/Quit
//             + mini-player card) + content area slot
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, NavItem, PressPulse } from "widgets.slint";

export component AppShell inherits HorizontalLayout {
    spacing: 0px;

    Rectangle {
        width:      Theme.sidebar-width;
        background: Theme.sidebar-bg;

        VerticalLayout {
            padding:     Theme.sp;
            padding-top: Theme.sp-lg;
            spacing:     3px;

            Rectangle {
                height: 48px;
                HorizontalLayout {
                    alignment: center;
                    spacing:   8px;
                    Image {
                        width:  40px;
                        height: 40px;
                        source: AppState.app-logo-idx == 1  ? @image-url("../../../assets/fjord_01.svg") :
                                AppState.app-logo-idx == 2  ? @image-url("../../../assets/fjord_02.svg") :
                                AppState.app-logo-idx == 4  ? @image-url("../../../assets/fjord_04.svg") :
                                AppState.app-logo-idx == 5  ? @image-url("../../../assets/fjord_05.svg") :
                                AppState.app-logo-idx == 9  ? @image-url("../../../assets/fjord_09.svg") :
                                                              @image-url("../../../assets/fjord_10.svg");
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing:   2px;
                        Text { text: "FJORD";    color: Theme.accent;      font-size: 20px; font-weight: 700; }
                        Text { text: "Jellyfin"; color: Theme.text-subtle; font-size: 11px; }
                    }
                }
            }

            Rectangle { height: Theme.sp; }

            NavItem {
                label: "Home";
                active: AppState.active-nav == 0;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 0;
                    AppState.nav-selected(0);
                    AppState.focused-section = -1;
                }
            }
            NavItem {
                label: "TV Shows";
                active: AppState.active-nav == 1;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 1;
                    AppState.nav-selected(1);
                    AppState.focused-section = -1;
                }
                double-clicked => {
                    AppState.active-nav            = 1;
                    AppState.nav-selected(1);
                    AppState.show-browse           = false;
                    AppState.library-focused       = 0;
                    AppState.library-focused-row   = 0;
                    AppState.focused-section       = -1;
                    AppState.library-search-clear();
                    AppState.open-library(1);
                    AppState.show-library          = true;
                }
            }
            NavItem {
                label: "Movies";
                active: AppState.active-nav == 2;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 2;
                    AppState.nav-selected(2);
                    AppState.focused-section = -1;
                }
                double-clicked => {
                    AppState.active-nav            = 2;
                    AppState.nav-selected(2);
                    AppState.show-browse           = false;
                    AppState.library-focused       = 0;
                    AppState.library-focused-row   = 0;
                    AppState.focused-section       = -1;
                    AppState.library-search-clear();
                    AppState.open-library(2);
                    AppState.show-library          = true;
                }
            }
            NavItem {
                label: "Collections";
                active: AppState.active-nav == 3;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 3;
                    AppState.nav-selected(3);
                    AppState.focused-section = -1;
                }
                double-clicked => {
                    AppState.active-nav            = 3;
                    AppState.nav-selected(3);
                    AppState.show-browse           = false;
                    AppState.library-focused       = 0;
                    AppState.library-focused-row   = 0;
                    AppState.focused-section       = -1;
                    AppState.library-search-clear();
                    AppState.open-library(3);
                    AppState.show-library          = true;
                }
            }
            NavItem {
                label: "Music";
                active: AppState.active-nav == 4;
                clicked => {
                    AppState.show-browse     = false;
                    AppState.show-library    = false;
                    AppState.active-nav      = 4;
                    AppState.nav-selected(4);
                    AppState.focused-section = -1;
                }
                double-clicked => {
                    AppState.active-nav            = 4;
                    AppState.nav-selected(4);
                    AppState.show-browse           = false;
                    AppState.library-focused       = 0;
                    AppState.library-focused-row   = 0;
                    AppState.focused-section       = -1;
                    AppState.library-search-clear();
                    AppState.open-library(4);
                    AppState.show-library          = true;
                }
            }
            NavItem {
                label: "Browse All";
                active: AppState.active-nav == 5;
                clicked => {
                    AppState.show-library    = false;
                    AppState.show-browse     = true;
                    AppState.active-nav      = 5;
                    AppState.nav-selected(5);
                    AppState.focused-section = -1;
                    AppState.browse-search-clear();
                }
            }

            Rectangle { vertical-stretch: 1; }

            Rectangle { height: 4px; }

            NavItem {
                label: "Settings";
                active: AppState.active-nav == 10;
                clicked => {
                    AppState.show-browse  = false;
                    AppState.show-library = false;
                    AppState.active-nav   = 10;
                    AppState.nav-selected(10);
                    AppState.focused-section   = -1;
                }
            }

            Rectangle {
                height:        36px;
                border-radius: Theme.radius;
                background: (AppState.active-nav == 11 && AppState.sidebar-kb-active) || ta-quit.has-hover ? #3a1a1a : #00000000;
                border-width:  (ta-quit.pressed || quit-pulse.pulsing) ? 3px : 0px;
                border-color:  Theme.error;
                animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                // Same scoping fix as NavItem (widgets.slint): active-nav==11 &&
                // focused-section<0 alone stays stale/true while deep in
                // Library/Browse/Settings/Detail/etc, so it can't gate the
                // background OR the pulse on its own — sidebar-kb-active narrows
                // both to genuine Dashboard-sidebar focus. (The background binding
                // was originally missed when this fix was applied to the pulse
                // below — found in a later review: arrow to Quit, then open any
                // overlay via mouse without touching active-nav/focused-section,
                // and the row stayed lit red the whole time the overlay was open.)
                quit-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.active-nav == 11 && AppState.sidebar-kb-active; }
                ta-quit := TouchArea {
                    clicked => { AppState.quit(); }
                }
                HorizontalLayout {
                    padding-left: 14px;
                    spacing:      10px;
                    alignment:    start;
                    Rectangle {
                        width: 6px;
                        Rectangle {
                            width: 6px; height: 6px; border-radius: 3px;
                            y: (parent.height - self.height) / 2;
                            background: Theme.error;
                        }
                    }
                    Text {
                        text:               "Quit";
                        color:              Theme.error;
                        font-size:          14px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    Rectangle { width: 1px; background: Theme.border; }

    @children
}
