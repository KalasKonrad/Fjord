// ── fjord-app · detail.slint ─────────────────────────────────────────────────
//   DetailPage  header block: backdrop image covers poster+title area (image-fit cover,
//               dark gradient overlay); semi-transparent overlay makes text readable;
//               muted text uses #cccccc when backdrop present for legibility.
//               Play / Resume / "Series →" buttons; ♥︎ fav IconCircleButton (gray=not fav,
//               blue=fav) · ✓︎ watched IconCircleButton; "Ends HH:MM" text below buttons.
//               Title column's inner block is a plain Rectangle fixed at height:240px
//               (matching PosterBlock) holding two independently-positioned children —
//               title/meta/tagline/etc. at its top, the button row pinned via an explicit
//               y: parent.height - 38px — so neither's position depends on the other's size
//               (2026-07-18; corrected same day from an earlier vertical-stretch:1-spacer
//               version that didn't reliably hold up live). "Ends" stays outside this block
//               as a normal next-in-flow sibling.
//               CastRow (on plain bg below header block); collection SectionRow;
//               "More Like This" SectionRow; scrollable overview.
//               button focus: detail-focused-btn (-1=Back, 0=Play, 1=Resume, 2=Series, 3=Fav, 4=Watched)
//               cast focus: detail-cast-focused (Right past last btn enters; Left from 0 exits)
//   Page is shown only after initial metadata+poster+backdrop have loaded (see detail.rs
//   spawn_main) — app-content-loading overlay on previous screen during fetch.
//   Back while background player is minimized clears playback-from-detail so stop won't
//   re-open detail; mini card / video-behind-ui remains active in the sidebar.
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, CastMember } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, IconCircleButton, PosterBlock, MetaLine, CastRow, StorylineSection } from "widgets.slint";
import { SectionRow } from "home.slint";

export component DetailPage inherits Rectangle {
    background: Theme.bg;
    property <length> kb-y: clamp(-AppState.detail-scroll,
                                  min(0px, self.height - detail-content.preferred-height), 0px);
    changed kb-y => { detail-fl.viewport-y = kb-y; }

    detail-fl := Flickable {
        width:           parent.width;
        height:          parent.height;
        viewport-height: detail-content.preferred-height;
        viewport-width:  self.width;
        animate viewport-y { duration: 200ms * AppState.settings-scroll-speed; easing: ease-in-out; }

        detail-content := VerticalLayout {

            // ── Header: backdrop image fills entire poster+text block ─────────
            Rectangle {
                background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

                // Backdrop image — fills this Rectangle; height driven by inner layout
                if AppState.detail-has-backdrop: Image {
                    x: 0; y: 0;
                    width:     parent.width;
                    height:    parent.height;
                    image-fit: cover;
                    source:    AppState.detail-backdrop;
                }
                // Overlay — darkens backdrop so text remains readable
                if AppState.detail-has-backdrop: Rectangle {
                    x: 0; y: 0;
                    width:      parent.width;
                    height:     parent.height;
                    background: @linear-gradient(180deg, #00000080 0%, #000000cc 100%);
                }

                VerticalLayout {
                HorizontalLayout {
                    padding-left:   48px;
                    padding-right:  48px;
                    padding-top:    68px;
                    padding-bottom: 24px;
                    spacing:        32px;
                    alignment:      start;

                    if AppState.detail-has-poster: PosterBlock {
                        source:         AppState.detail-poster;
                        has-image:      true;
                        has-played:     AppState.detail-has-played;
                        resume-pct:     AppState.detail-resume-pct;
                    }

                    VerticalLayout {
                        spacing:   8px;
                        alignment: start;

                        // Real bug, live-reported 2026-07-18: the earlier
                        // height:240px + vertical-stretch:1 spacer version
                        // of this fix didn't reliably land the button row
                        // at a fixed position — the flex/stretch math
                        // doesn't hold up the way a first read of Slint's
                        // layout model suggests once optional-line count
                        // varies. Replaced with a deterministic version:
                        // a plain (non-Layout) Rectangle fixed at 240px
                        // (matching PosterBlock) holding two INDEPENDENTLY
                        // positioned children — the title/meta stack at
                        // its top (y:0, sized to its own content, free to
                        // grow or shrink) and the button row pinned via an
                        // explicit `y: parent.height - 38px` (both
                        // FjordButton and IconCircleButton are a fixed
                        // 38px tall, confirmed in widgets.slint, so this
                        // is a hard constant, not a guess). Neither
                        // child's position depends on the other's size at
                        // all, which is what actually guarantees the fixed
                        // Y — the previous version's bug was exactly that
                        // the button row's position WAS still derived from
                        // the text stack's height via the spacer.
                        Rectangle {
                            height: 240px;

                            VerticalLayout {
                                x: 0; y: 0;
                                width:     parent.width;
                                spacing:   8px;
                                alignment: start;

                                Text {
                                    text:        AppState.detail-title;
                                    color:       Theme.text;
                                    font-size:   28px;
                                    font-weight: 700;
                                    wrap:        word-wrap;
                                }

                                if AppState.detail-tagline != "": Text {
                                    text:        AppState.detail-tagline;
                                    color:       AppState.detail-has-backdrop ? #ffffff : Theme.text-muted;
                                    font-size:   15px;
                                    font-italic: true;
                                    wrap:        word-wrap;
                                }

                                if AppState.detail-series-label != "": Text {
                                    text:      AppState.detail-series-label;
                                    color:     Theme.accent;
                                    font-size: 14px;
                                }

                                MetaLine {
                                    meta:         AppState.detail-meta;
                                    rating-label: AppState.detail-rating-label;
                                }

                                if AppState.detail-genres != "": Text {
                                    text:      AppState.detail-genres;
                                    color:     AppState.detail-has-backdrop ? #ffffff : Theme.text-muted;
                                    font-size: 13px;
                                }

                                if AppState.detail-studio != "": Text {
                                    text:      AppState.detail-studio;
                                    color:     AppState.detail-has-backdrop ? #ffffff : Theme.text-muted;
                                    font-size: 13px;
                                }
                            }

                            HorizontalLayout {
                                x: 0;
                                y: parent.height - 38px;
                                spacing:   12px;
                                alignment: start;
                                FjordButton {
                                    icon-left:   "▶︎";
                                    text:        "Play";
                                    width:       110px;
                                    kbd-focused: AppState.detail-focused-btn == 0 && AppState.detail-cast-focused < 0;
                                    clicked => { AppState.play-detail(); }
                                }
                                if AppState.detail-can-resume: FjordButton {
                                    text:        "⏩︎  " + AppState.detail-resume-label;
                                    kbd-focused: AppState.detail-focused-btn == 1 && AppState.detail-cast-focused < 0;
                                    clicked => { AppState.resume-detail(); }
                                }
                                if AppState.detail-series-id != "": FjordButton {
                                    text:        "Series →";
                                    width:       100px;
                                    kbd-focused: AppState.detail-focused-btn == 2 && AppState.detail-cast-focused < 0;
                                    clicked => {
                                        AppState.detail-scroll      = 0px;
                                        AppState.detail-focused-btn = 0;
                                        AppState.close-detail();
                                        AppState.open-series(AppState.detail-series-id);
                                    }
                                }
                                // ♥︎ favourite — gray when not fav, accent when fav
                                IconCircleButton {
                                    icon:        "❤︎";
                                    active:      AppState.detail-is-favorite;
                                    kbd-focused: AppState.detail-focused-btn == 3 && AppState.detail-cast-focused < 0;
                                    clicked => { AppState.toggle-detail-fav(); }
                                }
                                // ✓︎ watched — gray when not watched, accent when watched
                                IconCircleButton {
                                    icon:        "✓︎";
                                    active:      AppState.detail-has-played;
                                    kbd-focused: AppState.detail-focused-btn == 4 && AppState.detail-cast-focused < 0;
                                    clicked => { AppState.toggle-detail-played(); }
                                }
                            }
                        }

                        // Ends HH:MM — shown below the action buttons
                        if AppState.detail-ends-at != "": Text {
                            text:      "Ends " + AppState.detail-ends-at;
                            color:     AppState.detail-has-backdrop ? #eeeeee : Theme.text-muted;
                            font-size: 13px;
                        }
                    }
                }
                if AppState.detail-overview != "": StorylineSection {
                    text:        AppState.detail-overview;
                    expanded <=> AppState.detail-overview-expanded;
                    kbd-focused: AppState.detail-focused-btn == 5 && AppState.detail-focused-row == 0;
                }
                }
            }

            if AppState.detail-cast.length > 0: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 24px;

                Rectangle { height: 1px; background: Theme.border; }
                Rectangle { height: 12px; }

                CastRow {
                    cast:        AppState.detail-cast;
                    focused-idx: AppState.detail-cast-focused;
                    item-selected(idx) => {
                        AppState.open-person(AppState.detail-cast[idx].id, AppState.detail-cast[idx].name);
                    }
                }
            }

            if AppState.detail-collection.length > 0: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 40px;

                Rectangle { height: 1px; background: Theme.border; }

                SectionRow {
                    section-title:   AppState.detail-collection-title;
                    items:           AppState.detail-collection;
                    section-focused: AppState.detail-focused-row == 2;
                    focused-card:    AppState.detail-collection-focused;
                    item-play(id, itype) => { AppState.open-detail(id, itype); }
                    item-context(id, played, fav, rpct, itype, sid) => {
                        AppState.open-context-menu(id, played, fav, rpct, itype, sid);
                    }
                }
            }

            if AppState.detail-similar.length > 0: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 40px;

                Rectangle { height: 1px; background: Theme.border; }

                SectionRow {
                    section-title:   "More Like This";
                    items:           AppState.detail-similar;
                    section-focused: AppState.detail-focused-row == 3;
                    focused-card:    AppState.detail-similar-focused;
                    item-play(id, itype) => { AppState.open-detail(id, itype); }
                    item-context(id, played, fav, rpct, itype, sid) => {
                        AppState.open-context-menu(id, played, fav, rpct, itype, sid);
                    }
                }
            }
        }
    }

    FjordButton {
        x:           16px;
        y:           16px;
        text:        "← Back";
        width:       88px;
        kbd-focused: AppState.detail-focused-btn == -1 && AppState.detail-cast-focused < 0;
        clicked => {
            AppState.detail-scroll              = 0px;
            AppState.detail-focused-btn         = 0;
            AppState.detail-focused-row         = 0;
            AppState.detail-cast-focused        = -1;
            AppState.detail-collection-focused  = -1;
            AppState.detail-similar-focused     = -1;
            if AppState.has-background-player {
                AppState.playback-from-detail = false;
            }
            AppState.close-detail();
        }
    }
}
