// ── fjord-app · detail.slint ─────────────────────────────────────────────────
//   DetailPage  backdrop, poster, title, metadata, scrollable overview, cast row,
//               play / resume buttons with kbd-focused highlight ring;
//               scroll via AppState.detail-scroll (kbd) or mouse-wheel (native Flickable);
//               button focus via detail-focused-btn; kb-y/changed for keyboard scroll
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, CastMember } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton } from "widgets.slint";

export component DetailPage inherits Rectangle {
    background: Theme.bg;
    property <length> kb-y: clamp(-AppState.detail-scroll,
                                  min(0px, self.height - detail-content.preferred-height), 0px);
    changed kb-y => { detail-fl.viewport-y = kb-y; }

    detail-fl := Flickable {
        width:           parent.width;
        height:          parent.height;
        viewport-height: detail-content.preferred-height;

        detail-content := VerticalLayout {

            if AppState.detail-has-backdrop: Rectangle {
                height: 300px;
                clip:   true;
                Image {
                    source:    AppState.detail-backdrop;
                    width:     parent.width;
                    height:    parent.height;
                    image-fit: cover;
                }
                Rectangle {
                    background: @linear-gradient(180deg, transparent 20%, Theme.bg 100%);
                }
            }

            HorizontalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-top:    AppState.detail-has-backdrop ? 0px : 48px;
                padding-bottom: 24px;
                spacing:        32px;
                alignment:      start;

                if AppState.detail-has-poster: Image {
                    source:    AppState.detail-poster;
                    width:     160px;
                    height:    240px;
                    image-fit: cover;
                }

                VerticalLayout {
                    spacing:   8px;
                    alignment: start;

                    Text {
                        text:        AppState.detail-title;
                        color:       Theme.text;
                        font-size:   28px;
                        font-weight: 700;
                        wrap:        word-wrap;
                    }

                    if AppState.detail-series-label != "": Text {
                        text:      AppState.detail-series-label;
                        color:     Theme.accent;
                        font-size: 14px;
                    }

                    HorizontalLayout {
                        spacing:   16px;
                        alignment: start;
                        Text { text: AppState.detail-meta;         color: Theme.text-muted; font-size: 14px; }
                        if AppState.detail-rating-label != "": Text { text: AppState.detail-rating-label; color: #f5c518; font-size: 14px; }
                    }

                    if AppState.detail-genres != "": Text {
                        text:      AppState.detail-genres;
                        color:     Theme.text-muted;
                        font-size: 13px;
                    }

                    Rectangle { height: 12px; }

                    if AppState.detail-overview != "": Text {
                        text:      AppState.detail-overview;
                        color:     Theme.text;
                        font-size: 14px;
                        wrap:      word-wrap;
                        max-width: 640px;
                    }

                    Rectangle { height: 20px; }

                    HorizontalLayout {
                        spacing:   12px;
                        alignment: start;
                        if AppState.detail-loading: Text {
                            text:               "Loading…";
                            color:              Theme.text-muted;
                            font-size:          14px;
                            vertical-alignment: center;
                        }
                        if !AppState.detail-loading: FjordButton {
                            text:        "▶  Play";
                            width:       110px;
                            kbd-focused: AppState.detail-focused-btn == 0;
                            clicked => { AppState.play-detail(); }
                        }
                        if !AppState.detail-loading && AppState.detail-can-resume: FjordButton {
                            text:        "⏩  " + AppState.detail-resume-label;
                            kbd-focused: AppState.detail-focused-btn == 1;
                            clicked => { AppState.resume-detail(); }
                        }
                    }
                }
            }

            if AppState.detail-cast.length > 0: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 40px;
                spacing:        12px;

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "Cast"; color: Theme.text; font-size: 16px; font-weight: 700; }

                HorizontalLayout {
                    spacing:   24px;
                    alignment: start;
                    for c in AppState.detail-cast: VerticalLayout {
                        width:   120px;
                        spacing: 2px;
                        Text { text: c.name; color: Theme.text;       font-size: 13px; font-weight: 600; overflow: elide; }
                        Text { text: c.role; color: Theme.text-muted; font-size: 12px; overflow: elide; }
                    }
                }
            }
        }
    }

    FjordButton {
        x:       16px;
        y:       16px;
        text:    "← Back";
        width:   88px;
        clicked => { AppState.detail-scroll = 0px; AppState.detail-focused-btn = 0; AppState.close-detail(); }
    }
}
