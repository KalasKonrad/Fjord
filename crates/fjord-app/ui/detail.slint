// ── fjord-app · detail.slint ─────────────────────────────────────────────────
//   DetailPage  BackdropHero + PosterBlock + MetaLine + CastRow atoms; tagline (italic);
//               studio line; scrollable overview; CastRow with portraits (crew: Director/Writer, then cast);
//               collection SectionRow (BoxSet siblings, title = BoxSet name);
//               "More Like This" SectionRow (similar items); play / resume / "Series →" buttons
//               with kbd-focused highlight ring; "Series →" visible only for Episodes;
//               scroll via AppState.detail-scroll (kbd) or mouse-wheel (native Flickable);
//               button focus: detail-focused-btn (0=Play 1=Resume 2=Series);
//               cast focus: detail-cast-focused (Right past last btn enters; Left from 0 exits)
//   Inline bg-player mode (detail-bg-player = true):
//               Backspace during detail-page playback shows video inline instead of sidebar
//               mini-card. If settings-video-behind is false: video frame replaces poster slot
//               (160×240). If true: video frame replaces BackdropHero (full-width 300px).
//               Buttons change to "▶ Resume" (→ fullscreen) and "⏹ Stop".
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, CastMember } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, BackdropHero, PosterBlock, MetaLine, CastRow } from "widgets.slint";
import { SectionRow } from "home.slint";

export component DetailPage inherits Rectangle {
    background: Theme.bg;
    property <length> kb-y: clamp(-AppState.detail-scroll,
                                  min(0px, self.height - detail-content.preferred-height), 0px);
    changed kb-y => { detail-fl.viewport-y = kb-y; }

    detail-fl := Flickable {
        width:           parent.width;
        height:          parent.height;
        viewport-height: detail-content.preferred-height;

        detail-content := VerticalLayout {

            // Hero slot: video frame when any background player is active + hero-mode;
            // otherwise the normal backdrop image.
            if AppState.has-background-player && AppState.video-behind-ui: Rectangle {
                height: 300px;
                clip:   true;
                background: #000;
                Image {
                    source:    AppState.video-frame;
                    width:     parent.width;
                    height:    parent.height;
                    image-fit: contain;
                }
                Rectangle {
                    background: @linear-gradient(180deg, transparent 20%, Theme.bg 100%);
                }
            }
            if AppState.detail-has-backdrop && !(AppState.has-background-player && AppState.video-behind-ui): BackdropHero {
                source: AppState.detail-backdrop;
            }

            HorizontalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-top:    (AppState.detail-has-backdrop || (AppState.detail-bg-player && AppState.settings-video-behind)) ? 0px : 48px;
                padding-bottom: 24px;
                spacing:        32px;
                alignment:      start;

                // Poster slot: video frame when any background player is active (poster-mode);
                // otherwise the normal poster image.
                // Hero-mode: show poster alongside the hero video.
                if AppState.has-background-player && !AppState.video-behind-ui: Rectangle {
                    width:         160px;
                    height:        240px;
                    border-radius: Theme.radius;
                    clip:          true;
                    background:    #000;
                    Image {
                        source:    AppState.video-frame;
                        width:     parent.width;
                        height:    parent.height;
                        image-fit: contain;
                    }
                }
                if AppState.detail-has-poster && !AppState.has-background-player: PosterBlock {
                    source:    AppState.detail-poster;
                    has-image: true;
                }
                if AppState.detail-has-poster && AppState.has-background-player && AppState.video-behind-ui: PosterBlock {
                    source:    AppState.detail-poster;
                    has-image: true;
                }

                VerticalLayout {
                    spacing:   8px;
                    alignment: start;

                    Text {
                        text:        AppState.detail-title;
                        color:       Theme.text;
                        font-size:   28px;
                        font-weight: 700;
                        wrap:        word-wrap;
                    }

                    if AppState.detail-tagline != "": Text {
                        text:        AppState.detail-tagline;
                        color:       Theme.text-muted;
                        font-size:   15px;
                        font-italic: true;
                        wrap:        word-wrap;
                    }

                    if AppState.detail-series-label != "": Text {
                        text:      AppState.detail-series-label;
                        color:     Theme.accent;
                        font-size: 14px;
                    }

                    MetaLine {
                        meta:         AppState.detail-meta;
                        rating-label: AppState.detail-rating-label;
                    }

                    if AppState.detail-genres != "": Text {
                        text:      AppState.detail-genres;
                        color:     Theme.text-muted;
                        font-size: 13px;
                    }

                    if AppState.detail-studio != "": Text {
                        text:      AppState.detail-studio;
                        color:     Theme.text-muted;
                        font-size: 13px;
                    }

                    Rectangle { height: 12px; }

                    if AppState.detail-overview != "": Text {
                        text:      AppState.detail-overview;
                        color:     Theme.text;
                        font-size: 14px;
                        wrap:      word-wrap;
                        max-width: 640px;
                    }

                    Rectangle { height: 20px; }

                    HorizontalLayout {
                        spacing:   12px;
                        alignment: start;
                        if AppState.detail-loading: Text {
                            text:               "Loading…";
                            color:              Theme.text-muted;
                            font-size:          14px;
                            vertical-alignment: center;
                        }
                        // Background player active: Resume → fullscreen, Stop → end playback
                        if !AppState.detail-loading && AppState.has-background-player: FjordButton {
                            text:        "▶  Resume";
                            width:       110px;
                            kbd-focused: AppState.detail-focused-btn == 0 && AppState.detail-cast-focused < 0;
                            clicked => { AppState.resume-player(); }
                        }
                        if !AppState.detail-loading && AppState.has-background-player: FjordButton {
                            text:        "⏹  Stop";
                            width:       90px;
                            kbd-focused: AppState.detail-focused-btn == 1 && AppState.detail-cast-focused < 0;
                            clicked => { AppState.stop-playback(); }
                        }
                        // Normal mode: Play, Resume, Series
                        if !AppState.detail-loading && !AppState.has-background-player: FjordButton {
                            text:        "▶  Play";
                            width:       110px;
                            kbd-focused: AppState.detail-focused-btn == 0 && AppState.detail-cast-focused < 0;
                            clicked => { AppState.play-detail(); }
                        }
                        if !AppState.detail-loading && !AppState.has-background-player && AppState.detail-can-resume: FjordButton {
                            text:        "⏩  " + AppState.detail-resume-label;
                            kbd-focused: AppState.detail-focused-btn == 1 && AppState.detail-cast-focused < 0;
                            clicked => { AppState.resume-detail(); }
                        }
                        if !AppState.detail-loading && !AppState.has-background-player && AppState.detail-series-id != "": FjordButton {
                            text:        "Series →";
                            width:       100px;
                            kbd-focused: AppState.detail-focused-btn == 2 && AppState.detail-cast-focused < 0;
                            clicked => {
                                AppState.detail-scroll      = 0px;
                                AppState.detail-focused-btn = 0;
                                AppState.close-detail();
                                AppState.open-series(AppState.detail-series-id);
                            }
                        }
                    }
                }
            }

            if AppState.detail-cast.length > 0: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 24px;

                Rectangle { height: 1px; background: Theme.border; }
                Rectangle { height: 12px; }

                CastRow {
                    cast:        AppState.detail-cast;
                    focused-idx: AppState.detail-cast-focused;
                }
            }

            if AppState.detail-collection.length > 0: VerticalLayout {
                padding-bottom: 40px;

                Rectangle { height: 1px; background: Theme.border; }

                SectionRow {
                    section-title:  AppState.detail-collection-title;
                    items:          AppState.detail-collection;
                    section-focused: AppState.detail-focused-row == 2;
                    focused-card:   AppState.detail-collection-focused;
                    item-play(id, itype) => { AppState.open-detail(id, itype); }
                    item-context(id, played, fav, rpct, itype, sid) => {
                        AppState.open-context-menu(id, played, fav, rpct, itype, sid);
                    }
                }
            }

            if AppState.detail-similar.length > 0: VerticalLayout {
                padding-bottom: 40px;

                Rectangle { height: 1px; background: Theme.border; }

                SectionRow {
                    section-title:  "More Like This";
                    items:          AppState.detail-similar;
                    section-focused: AppState.detail-focused-row == 3;
                    focused-card:   AppState.detail-similar-focused;
                    item-play(id, itype) => { AppState.open-detail(id, itype); }
                    item-context(id, played, fav, rpct, itype, sid) => {
                        AppState.open-context-menu(id, played, fav, rpct, itype, sid);
                    }
                }
            }
        }
    }

    FjordButton {
        x:       16px;
        y:       16px;
        text:    "← Back";
        width:   88px;
        clicked => {
            AppState.detail-scroll              = 0px;
            AppState.detail-focused-btn         = 0;
            AppState.detail-focused-row         = 0;
            AppState.detail-cast-focused        = -1;
            AppState.detail-collection-focused  = -1;
            AppState.detail-similar-focused     = -1;
            if AppState.has-background-player {
                AppState.detail-bg-player     = false;
                AppState.playback-from-detail = false;
            }
            AppState.close-detail();
        }
    }
}
