// ── fjord-app · series.slint ─────────────────────────────────────────────────
//   SeriesScreen  scrollable page: header block (backdrop image covers poster+title area,
//                 dark gradient overlay) · ♥ fav IconCircleButton · ✓ watched IconCircleButton ·
//                 poster badges (played/unplayed-count) · season tabs (accent bottom border
//                 when focused) · episode SectionRow · CastRow · More Like This SectionRow
//   Keyboard scroll: 0-height anchor Rectangles (next-up-anchor, seasons-anchor,
//                 ep-anchor, cast-anchor, similar-anchor) track section Y positions;
//                 kb-y property on fl maps focused section → viewport-y target;
//                 changed kb-y => { self.viewport-y = kb-y; } keeps mouse-wheel
//                 native while keyboard nav auto-scrolls.
//   Season tabs kb-x: uses root.width (NOT self.width) to avoid "Recursion detected"
//                 crash — self.width inside a conditional Rectangle comes from the
//                 content layout cache, which is already being evaluated when the
//                 ChangeTracker initialises.
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, SeasonEntry, CardItem } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, IconCircleButton, MetaLine, CastRow, PosterBlock, StorylineSection } from "widgets.slint";
import { SectionRow } from "home.slint";

export component SeriesScreen inherits Rectangle {
    background: Theme.bg;

    fl := Flickable {
        width:           parent.width;
        height:          parent.height;
        viewport-height: content.preferred-height;

        // Keyboard scroll — positions anchored by 0-height sibling Rectangles in
        // the VerticalLayout.  Mouse-wheel still works natively because viewport-y
        // is NOT bound to an expression; only changed kb-y assigns it.
        property <length> kb-y:
            AppState.series-similar-focused >= 0 ?
                clamp(root.height / 2 - similar-anchor.y, min(0px, root.height - content.preferred-height), 0px) :
            AppState.series-cast-focused >= 0 ?
                clamp(root.height / 2 - cast-anchor.y, min(0px, root.height - content.preferred-height), 0px) :
            AppState.series-focused-btn >= 0 ?
                0px :  // header buttons: scroll to top
            !AppState.series-in-season-row && !AppState.series-next-up-focused ?
                clamp(root.height / 3 - ep-anchor.y, min(0px, root.height - content.preferred-height), 0px) :
            AppState.series-in-season-row ?
                clamp(root.height / 2 - seasons-anchor.y, min(0px, root.height - content.preferred-height), 0px) :
            // series-next-up-focused: show near top
            clamp(root.height / 3 - next-up-anchor.y, min(0px, root.height - content.preferred-height), 0px);

        changed kb-y => { self.viewport-y = kb-y; }

        content := VerticalLayout {

            // ── Header: backdrop image covers poster+title block ──────────────
            Rectangle {
                background: Theme.bg;

                // Backdrop image — fills this Rectangle; height driven by inner layout
                if AppState.series-has-backdrop: Image {
                    x: 0; y: 0;
                    width:     parent.width;
                    height:    parent.height;
                    image-fit: cover;
                    source:    AppState.series-backdrop;
                }
                // Overlay — darkens backdrop so text remains readable
                if AppState.series-has-backdrop: Rectangle {
                    x: 0; y: 0;
                    width:      parent.width;
                    height:     parent.height;
                    background: @linear-gradient(180deg, #00000060 0%, #000000a0 100%);
                }

                HorizontalLayout {
                    padding-left:   48px;
                    padding-right:  48px;
                    padding-top:    68px;
                    padding-bottom: 20px;
                    spacing:        28px;
                    alignment:      start;

                    if AppState.series-has-poster: PosterBlock {
                        source:         AppState.series-poster;
                        has-image:      true;
                        has-played:     AppState.series-has-played;
                        unplayed-count: AppState.series-unplayed-count;
                        width:          130px;
                        height:         195px;
                    }

                    VerticalLayout {
                        spacing:            8px;
                        alignment:          start;
                        horizontal-stretch: 1;

                        Text {
                            text:        AppState.series-title;
                            color:       Theme.text;
                            font-size:   28px;
                            font-weight: 700;
                            wrap:        no-wrap;
                            overflow:    elide;
                        }

                        if AppState.series-tagline != "": Text {
                            text:        AppState.series-tagline;
                            color:       AppState.series-has-backdrop ? #cccccc : Theme.text-muted;
                            font-size:   15px;
                            font-italic: true;
                            wrap:        word-wrap;
                        }

                        if AppState.series-meta != "": MetaLine {
                            meta:         AppState.series-meta;
                            rating-label: AppState.series-rating-label;
                        }

                        if AppState.series-genres != "": Text {
                            text:      AppState.series-genres;
                            color:     AppState.series-has-backdrop ? #cccccc : Theme.text-muted;
                            font-size: 13px;
                            wrap:      word-wrap;
                        }

                        if AppState.series-studio != "": Text {
                            text:      AppState.series-studio;
                            color:     AppState.series-has-backdrop ? #cccccc : Theme.text-muted;
                            font-size: 13px;
                        }


                        HorizontalLayout {
                            spacing:   12px;
                            alignment: start;
                            // ♥ favourite — gray when not fav, accent when fav
                            IconCircleButton {
                                icon:        "❤";
                                active:      AppState.series-is-favorite;
                                kbd-focused: AppState.series-focused-btn == 1;
                                clicked => { AppState.toggle-series-fav(); }
                            }
                            // ✓ watched — gray when not watched, accent when watched
                            IconCircleButton {
                                icon:        "✓";
                                active:      AppState.series-has-played;
                                kbd-focused: AppState.series-focused-btn == 2;
                                clicked => { AppState.toggle-series-played(); }
                            }
                        }
                    }
                }
            }

            if AppState.series-overview != "": StorylineSection {
                text: AppState.series-overview;
            }

            // ── Next Up anchor (scroll target) ────────────────────────────────
            next-up-anchor := Rectangle { height: 0px; }

            // ── Next Up ───────────────────────────────────────────────────────
            if AppState.series-has-next-up: VerticalLayout {
                padding-left:  48px;
                padding-right: 48px;
                Rectangle { height: 1px; background: Theme.border; }
                SectionRow {
                    section-title:   AppState.series-next-up-section-title;
                    items:           AppState.series-next-up-cards;
                    section-focused: AppState.series-next-up-focused;
                    focused-card:    0;
                    item-play(id, _) => { AppState.play-series-episode(id); }
                    item-context(id, played, fav, rpct, itype, sid) => {
                        AppState.open-context-menu(id, played, fav, rpct, itype, sid);
                    }
                }
            }

            // ── Season tabs anchor (scroll target) ────────────────────────────
            seasons-anchor := Rectangle { height: 0px; }

            // ── Season tabs ───────────────────────────────────────────────────
            if AppState.series-seasons.length > 0: Rectangle {
                height:     44px;
                background: AppState.series-in-season-row ? Theme.surface-raised : #00000000;

                // kb-x lives on the outer Rectangle (not on season-fl) to avoid the Slint
                // self-reference gotcha: a property binding on a Flickable that reads
                // self.width / self.viewport-width always evaluates the clamp (no ternary
                // short-circuit), registering a dependency that triggers re-evaluation during
                // layout → "Recursion detected" panic.
                //
                // Additionally: self.width (this conditional Rectangle) is allocated by the
                // content VerticalLayout's layout cache.  When fl.kb-y's ChangeTracker
                // initialises it reads anchor.y → triggers the content layout cache
                // → ensure_updated() on this conditional → user_init reads kb-x
                // → self.width reads the content layout cache (currently being evaluated)
                // → "Recursion detected".  Using root.width (set by the outer parent,
                // never derived from this component's internal layout cache) breaks the
                // cycle.  Both values are always equal because the Rectangle fills the
                // full screen width.
                property <length> kb-x: clamp(
                    root.width / 2 - 98px - AppState.series-season-idx * 108px,
                    min(0px, root.width - season-tabs.preferred-width - 48px),
                    0px
                );
                changed kb-x => { season-fl.viewport-x = kb-x; }

                Rectangle { y: parent.height - 2px; height: 2px; background: AppState.series-in-season-row ? Theme.accent : Theme.border; }

                season-fl := Flickable {
                    width:          parent.width;
                    viewport-width: season-tabs.preferred-width + 48px;
                    animate viewport-x { duration: 150ms; easing: ease-out; }

                    season-tabs := HorizontalLayout {
                        padding-left:  48px;
                        padding-right: 48px;
                        spacing:       8px;
                        alignment:     start;

                        for s[i] in AppState.series-seasons: Rectangle {
                            width:         max(80px, lbl.preferred-width + 24px);
                            height:        32px;
                            y:             6px;
                            border-radius: Theme.radius;
                            background:    i == AppState.series-season-idx ? Theme.accent : Theme.surface;

                            lbl := Text {
                                text:                 s.name;
                                color:                i == AppState.series-season-idx ? #ffffff : Theme.text-muted;
                                font-size:            13px;
                                font-weight:          i == AppState.series-season-idx ? 700 : 400;
                                horizontal-alignment: center;
                                vertical-alignment:   center;
                            }

                            TouchArea {
                                clicked => {
                                    AppState.series-season-idx    = i;
                                    AppState.series-select-season(i);
                                    AppState.series-focused-ep    = 0;
                                    AppState.series-in-season-row = false;
                                }
                                double-clicked => {
                                    AppState.series-season-idx = i;
                                    AppState.open-season-detail(s.id, AppState.series-id);
                                }
                            }
                        }
                    }
                }
            }

            // ── Episode anchor (scroll target) ────────────────────────────────
            ep-anchor := Rectangle { height: 0px; }

            // ── Loading indicator ─────────────────────────────────────────────
            if AppState.series-loading && AppState.series-episode-cards.length == 0: Rectangle {
                height: 60px;
                Text {
                    text:                 "Loading episodes…";
                    color:                Theme.text-muted;
                    font-size:            14px;
                    horizontal-alignment: center;
                    vertical-alignment:   center;
                }
            }

            // ── Episode horizontal row ────────────────────────────────────────
            if AppState.series-episode-cards.length > 0: VerticalLayout {
                padding-left:  48px;
                padding-right: 48px;
                SectionRow {
                    section-title:   "Episodes";
                    items:           AppState.series-episode-cards;
                    section-focused: !AppState.series-in-season-row
                                     && !AppState.series-next-up-focused
                                     && AppState.series-cast-focused < 0
                                     && AppState.series-similar-focused < 0;
                    focused-card:    AppState.series-focused-ep;
                    item-play(id, _) => { AppState.play-series-episode(id); }
                    item-context(id, played, fav, rpct, itype, sid) => {
                        AppState.open-context-menu(id, played, fav, rpct, itype, sid);
                    }
                }
            }

            // ── Cast anchor (scroll target) ───────────────────────────────────
            cast-anchor := Rectangle { height: 0px; }

            // ── Cast & Crew ───────────────────────────────────────────────────
            if AppState.series-cast.length > 0: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-top:    4px;
                padding-bottom: 24px;

                Rectangle { height: 1px; background: Theme.border; }
                Rectangle { height: 12px; }

                CastRow {
                    cast:        AppState.series-cast;
                    focused-idx: AppState.series-cast-focused;
                }
            }

            // ── Similar anchor (scroll target) ────────────────────────────────
            similar-anchor := Rectangle { height: 0px; }

            // ── More Like This ────────────────────────────────────────────────
            if AppState.series-similar.length > 0: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 40px;

                Rectangle { height: 1px; background: Theme.border; }

                SectionRow {
                    section-title:   "More Like This";
                    items:           AppState.series-similar;
                    section-focused: AppState.series-similar-focused >= 0;
                    focused-card:    AppState.series-similar-focused;
                    item-play(id, itype) => { AppState.open-detail(id, itype); }
                    item-context(id, played, fav, rpct, itype, sid) => {
                        AppState.open-context-menu(id, played, fav, rpct, itype, sid);
                    }
                }
            }
        }
    }

    FjordButton {
        x:           16px;
        y:           16px;
        text:        "← Back";
        width:       88px;
        kbd-focused: AppState.series-focused-btn == 0;
        clicked => { AppState.close-series(); }
    }
}
