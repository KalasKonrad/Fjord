import { Theme, SeasonEntry, EpisodeEntry } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton } from "widgets.slint";

export component SeriesScreen inherits Rectangle {
    background: Theme.bg;

    VerticalLayout {

        if AppState.series-has-backdrop: Rectangle {
            height: 260px;
            clip:   true;
            Image {
                source:    AppState.series-backdrop;
                width:     parent.width;
                height:    parent.height;
                image-fit: cover;
            }
            Rectangle {
                background: @linear-gradient(180deg, transparent 20%, Theme.bg 100%);
            }
        }

        HorizontalLayout {
            padding-left:   48px;
            padding-right:  48px;
            padding-top:    AppState.series-has-backdrop ? 0px : 36px;
            padding-bottom: 16px;
            spacing:        28px;
            alignment:      start;

            if AppState.series-has-poster: Image {
                source:    AppState.series-poster;
                width:     130px;
                height:    195px;
                image-fit: cover;
            }

            VerticalLayout {
                spacing:            8px;
                alignment:          start;
                horizontal-stretch: 1;

                Text {
                    text:        AppState.series-title;
                    color:       Theme.text;
                    font-size:   28px;
                    font-weight: 700;
                    wrap:        no-wrap;
                    overflow:    elide;
                }

                if AppState.series-overview != "": Text {
                    text:      AppState.series-overview;
                    color:     Theme.text-muted;
                    font-size: 13px;
                    wrap:      word-wrap;
                    overflow:  elide;
                }
            }
        }

        if AppState.series-seasons.length > 0: Rectangle {
            height:     44px;
            background: AppState.series-in-season-row ? Theme.surface-raised : #00000000;

            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }

            season-fl := Flickable {
                width:          parent.width;
                viewport-width: season-tabs.preferred-width + 48px;
                viewport-x: clamp(
                    season-fl.width / 2 - 98px - AppState.series-season-idx * 108px,
                    min(0px, season-fl.width - self.viewport-width),
                    0px
                );
                animate viewport-x { duration: 150ms; easing: ease-out; }
                season-tabs := HorizontalLayout {
                    padding-left:  48px;
                    padding-right: 48px;
                    spacing:       8px;
                    alignment:     start;

                    for s[i] in AppState.series-seasons: Rectangle {
                        width:         max(80px, lbl.preferred-width + 24px);
                        height:        32px;
                        y:             6px;
                        border-radius: Theme.radius;
                        background:    i == AppState.series-season-idx ? Theme.accent : Theme.surface;

                        lbl := Text {
                            text:                 s.name;
                            color:                i == AppState.series-season-idx ? #ffffff : Theme.text-muted;
                            font-size:            13px;
                            font-weight:          i == AppState.series-season-idx ? 700 : 400;
                            horizontal-alignment: center;
                            vertical-alignment:   center;
                        }

                        TouchArea {
                            clicked => {
                                AppState.series-season-idx    = i;
                                AppState.series-select-season(i);
                                AppState.series-focused-ep    = 0;
                                AppState.series-in-season-row = false;
                            }
                        }
                    }
                }
            }
        }

        if AppState.series-loading && AppState.series-episodes.length == 0: Rectangle {
            height: 60px;
            Text {
                text:                 "Loading episodes…";
                color:                Theme.text-muted;
                font-size:            14px;
                horizontal-alignment: center;
                vertical-alignment:   center;
            }
        }

        ep-fl := Flickable {
            vertical-stretch:   1;
            viewport-width:     ep-fl.width;
            viewport-height:    max(ep-fl.height, AppState.series-episodes.length * 72px);
            viewport-y: AppState.series-focused-ep <= 0 ? 0px
                      : clamp(
                            -(AppState.series-focused-ep * 72px + 36px - ep-fl.height / 2),
                            min(0px, ep-fl.height - AppState.series-episodes.length * 72px),
                            0px
                        );
            animate viewport-y { duration: 150ms; easing: ease-out; }

            VerticalLayout {
            for ep[i] in AppState.series-episodes: Rectangle {
                height:     72px;
                background: i == AppState.series-focused-ep && !AppState.series-in-season-row
                          ? Theme.surface-raised : #00000000;

                HorizontalLayout {
                    spacing:   0px;
                    alignment: start;

                    Rectangle {
                        width:      3px;
                        height:     parent.height;
                        background: i == AppState.series-focused-ep && !AppState.series-in-season-row
                                  ? Theme.accent : #00000000;
                    }

                    HorizontalLayout {
                    padding-left:  13px;
                    padding-right: 16px;
                    spacing:       12px;
                    alignment:     start;

                    Rectangle {
                        width:         120px;
                        height:        68px;
                        y:             2px;
                        border-radius: Theme.radius;
                        background:    Theme.surface;
                        clip:          true;

                        if ep.has-thumb: Image {
                            source:    ep.thumb;
                            width:     parent.width;
                            height:    parent.height;
                            image-fit: cover;
                        }

                        if ep.has-played: Rectangle {
                            background: #00000099;
                            Text {
                                text:                 "✓";
                                color:                Theme.accent;
                                font-size:            20px;
                                horizontal-alignment: center;
                                vertical-alignment:   center;
                            }
                        }
                    }

                    VerticalLayout {
                        spacing:          3px;
                        alignment:        center;
                        vertical-stretch: 1;

                        HorizontalLayout {
                            spacing:   8px;
                            alignment: start;

                            Text {
                                text:        "S\{ep.season-num < 10 ? "0" : ""}\{ep.season-num}E\{ep.ep-num < 10 ? "0" : ""}\{ep.ep-num}";
                                color:       Theme.accent;
                                font-size:   12px;
                                font-weight: 600;
                            }
                            Text {
                                text:      ep.runtime;
                                color:     Theme.text-muted;
                                font-size: 12px;
                            }
                        }

                        Text {
                            text:        ep.title;
                            color:       Theme.text;
                            font-size:   14px;
                            font-weight: 500;
                            overflow:    elide;
                        }

                        if ep.overview != "": Text {
                            text:      ep.overview;
                            color:     Theme.text-muted;
                            font-size: 12px;
                            overflow:  elide;
                        }

                        if ep.resume-pct > 0: Rectangle {
                            height:        3px;
                            border-radius: 1.5px;
                            background:    Theme.surface-overlay;
                            max-width:     300px;

                            Rectangle {
                                x:             0;
                                width:         parent.width * ep.resume-pct;
                                height:        parent.height;
                                border-radius: parent.border-radius;
                                background:    Theme.accent;
                            }
                        }
                    }

                    TouchArea {
                        clicked => { AppState.play-series-episode(ep.id); }
                    }
                    }
                }
            }
            }
        }
    }

    FjordButton {
        x:       16px;
        y:       16px;
        text:    "← Back";
        width:   88px;
        clicked => { AppState.close-series(); }
    }
}
