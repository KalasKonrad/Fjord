import { Theme, TrackEntry, CastMember, SeasonEntry, CardItem, KeyBindingEntry } from "theme.slint";
import { StandardListView } from "std-widgets.slint";

// ── fjord-app · app_state.slint ──────────────────────────────────────────────
//   Screen routing        show-login, show-detail, show-series, show-library, app-content-loading, etc.
//   Toast notification    toast-message: string, toast-visible: bool (auto-dismissed after 4 s)
//   Navigation state      active-nav, focused-section, focused-card, settings-focused, settings-section, float-card-focused
//   Server info           server-url, server-name, server-version
//   Library grid          library-cols, library-query, library-header-focused, library-sort (0-4),
//                         library-filter-unwatched, library-filter-favorites, library-sort-focused,
//                         library-sort-cursor, library-back-focused, library-alpha-offsets (27 ints A-Z+#),
//                         library-has-filters (false for Collections — hides Unwatched/Favorites toggles)
//   Browse list           media-items, current-item, browse-query, browse-header-focused
//   Dashboard data        continue-watching, next-up, recently-added, etc.
//   Auto-advance          show-next-ep-banner, next-ep-title, next-ep-ends-at, next-ep-secs
//   Volume overlay        show-volume-overlay, volume-level, audio-passthrough-active (transient ~1.5 s)
//   Segment skip          show-skip-segment, skip-segment-label (Intro Skipper: ask mode)
//                         show-skip-timed, skip-timed-label/secs/focused (ask-timed mode: 2-btn + countdown)
//   Player state          is-playing, is-paused, video-frame, playback-ends-at, seek-hover-time,
//                         buffering-active/pct, buffered-pos, playback-total-secs, track panels,
//                         seek-dragging (true while seek bar is held; blocks PausePlay from keyboard)
//                         chapter-marks ([float] 0-1), chapter-osd-visible/text, chapter-prev/next callbacks,
//                         chapter-entries ([TrackEntry]), current-chapter, chapter-jump (Chapters panel)
//                         delay-osd-visible/text (sub/audio delay OSD ~2 s), sub/audio-delay-ms (Sync panel),
//                         sub/audio-delay-inc/dec callbacks
//   Detail page           detail-id, detail-item-type, detail-resume-secs, detail-title, detail-tagline,
//                         detail-studio, detail-is-favorite, detail-has-played, detail-focused-row,
//                         detail-cast-focused, detail-collection-focused, detail-similar-focused,
//                         detail-series-id, detail-scroll, detail-focused-btn, detail-ends-at,
//                         detail-cast, detail-similar, detail-collection-title, detail-collection, etc.
//   Series state          series-id, seasons, episode-cards (horizontal SectionRow), poster, backdrop,
//                         tagline, studio, is-favorite, meta/genres/rating-label, next-up card (+ section-title with ends-at), cast, similar
//   Season detail state   show-season, season-id/title/overview/meta, poster/backdrop, cast, focused-ep
//   Person detail state   show-person, person-id/name/bio, portrait, filmography, film-focused, in-film-row
//   Context menu          show-context-menu, context-menu-* state, context-menu-focused
//   Settings state        hwdec, interpolation, audio-spdif, sub-lang, skip-*-mode/secs, etc.
//   Key binding editor    keybinding-normal/player rows, keybinding-focused, keybinding-rebinding
//   Nav helpers           section-len, find-first/next/prev-section, section-card-id
//   Callbacks — auth      do-login, sign-out, quit, toggle-fullscreen
//   Callbacks — browse    nav-selected, filter-changed, browse-search-*, library-search-*
//   Callbacks — play      item-play, play/resume-detail, open-detail/series
//   Callbacks — player    pause-play-toggle, seek-*, volume-*, mute, select-*, stop
//   Callbacks — context   open-context-menu, context-mark-played, context-toggle-fav, context-play-from-start
//   Callbacks — misc      show-controls, cancel-auto-advance, play-next-ep, close-detail/series, refocus
//   Callbacks — keys      handle-key (main dispatch), keybinding-reset-defaults
// ─────────────────────────────────────────────────────────────────────────────
export global AppState {
    // ── Screen routing ────────────────────────────────────────────────────────
    in-out property <bool> show-login:            true;
    in-out property <bool> show-browse:           false;
    in-out property <bool> show-library:          false;
    in-out property <bool> show-series:           false;
    in-out property <bool> show-detail:           false;
    in-out property <bool> is-playing:            false;
    in-out property <bool> has-background-player: false;
    in-out property <bool> video-behind-ui:       false;
    in-out property <bool>  app-content-loading:   false;  // true while fetching detail/series before showing screen
    in-out property <float> app-loading-progress:  0.0;   // 0.0→1.0 while app-content-loading; drives the progress bar

    // ── Toast notification ────────────────────────────────────────────────────
    in-out property <string> toast-message: "";
    in-out property <bool>   toast-visible:  false;

    // ── Navigation state ──────────────────────────────────────────────────────
    in-out property <int>    active-nav:         0;
    in-out property <int>    focused-section:   -1;
    in-out property <int>    focused-card:       0;
    in-out property <int>    float-card-focused: -1;  // -1=not focused, 0=Resume, 1=Stop; floating mini-player
    in     property <string> server-url:       "";
    in     property <string> server-name:      "";
    in     property <string> server-version:   "";
    in-out property <int>    settings-focused: -1;   // -1 = left pane focus, ≥0 = right-pane row
    in-out property <int>    settings-section: -1;   // -1 = sidebar, 0 = General, 1 = Player
    in-out property <bool>     settings-dropdown-open:   false;  // a dropdown popup is keyboard-open
    in-out property <int>      settings-dropdown-cursor: -1;     // focused item index inside open popup
    in-out property <[string]> settings-dropdown-model:  [];     // display strings for the open dropdown
    in-out property <string>   settings-dropdown-display: "";    // display string of current value (accent highlight)

    // ── Library grid state ────────────────────────────────────────────────────
    in-out property <bool>       library-header-focused:    false;
    in-out property <int>        library-focused:           0;
    in-out property <[CardItem]> library-display:           [];
    in-out property <string>     library-query:             "";
    in-out property <int>        library-cols:              6;   // written by MainWindow on resize
    // sort: 0=Name A–Z  1=Name Z–A  2=Year ↓  3=Year ↑  4=Random
    in-out property <int>        library-sort:              0;
    in-out property <bool>       library-filter-unwatched:  false;
    in-out property <bool>       library-filter-favorites:  false;
    in-out property <bool>       library-sort-focused:      false;
    in-out property <int>        library-sort-cursor:       0;
    in-out property <bool>       library-back-focused:      false;
    // 27 flat item indices (A=0..Z=25, #=26); -1 means no items for that letter
    in-out property <[int]>      library-alpha-offsets:     [];
    // false for Collections library (hides Unwatched/Favorites filter toggles)
    in-out property <bool>       library-has-filters:       true;
    in-out property <length>     dash-cw:                140px; // written by MainWindow on resize
    in-out property <length>     dash-ch:                224px; // written by MainWindow on resize

    // ── Browse list state ─────────────────────────────────────────────────────
    in     property <string>                 status:        "";
    in     property <[StandardListViewItem]> media-items:   [];
    in-out property <int>                    current-item:  -1;
    in-out property <string>                 browse-query:  ""; // tracks keyboard search text
    in-out property <bool>                   browse-header-focused: false;

    // ── Home / dashboard data rows ────────────────────────────────────────────
    in property <[CardItem]> continue-watching:        [];
    in property <[CardItem]> next-up:                  [];
    in property <[CardItem]> recently-added:           [];
    in property <[CardItem]> continue-watching-movies: [];
    in property <[CardItem]> recently-added-movies:    [];
    in property <[CardItem]> not-watched-movies:       [];
    in property <[CardItem]> continue-watching-tv:     [];
    in property <[CardItem]> recently-added-tv:        [];
    in property <[CardItem]> not-watched-tv:           [];
    in property <[CardItem]> all-movies:               [];
    in property <[CardItem]> all-series:               [];
    in property <[CardItem]> all-collections:          [];

    // ── Up Next banner (shown during credits / last 30 s) ────────────────────
    in-out property <bool>   show-next-ep-banner:    false;
    in-out property <string> next-ep-title:           "";
    in-out property <string> next-ep-ends-at:         "";  // "HH:MM" wall-clock end of next episode
    in-out property <int>    next-ep-secs:             30;
    in-out property <int>    next-ep-banner-focused:   0;  // 0=Play Now, 1=Skip

    // ── Volume overlay (transient, ~1.5 s) ───────────────────────────────────
    in-out property <bool> show-volume-overlay:      false;
    in-out property <int>  volume-level:             100;
    in-out property <bool> audio-passthrough-active: false; // true when iec61937 passthrough detected

    // ── Segment skip prompts (Intro Skipper: Intro / Recap / Preview / Commercial) ──
    // ask mode:      single "Skip →" button
    in-out property <bool>   show-skip-segment:  false;
    in-out property <string> skip-segment-label: "Skip Intro →";
    // ask-timed mode: two-button overlay ("Skip" + "Don't Skip") with countdown
    in-out property <bool>   show-skip-timed:    false;
    in-out property <string> skip-timed-label:   "Skip Intro →";
    in-out property <int>    skip-timed-secs:    8;
    in-out property <int>    skip-timed-focused: 0;  // 0=Skip, 1=Don't Skip
    callback dismiss-skip-timed;

    // ── Player state ──────────────────────────────────────────────────────────
    in     property <image>  video-frame;
    in-out property <int>    app-logo-idx:         1;    // 1-10, randomised at startup
    in-out property <bool>   is-paused:            false;
    in-out property <string> playing-title:         "";
    in-out property <bool>   stats-visible:         false;
    in-out property <float>  playback-pos:           0;
    in-out property <string> playback-time:          "0:00";
    in-out property <string> playback-total:         "0:00";
    in-out property <float>  playback-total-secs:    0.0;   // total duration in seconds; used by seek-hover time calc
    in-out property <string> playback-ends-at:       "";
    in-out property <string> seek-hover-time:        "";    // formatted time at hover position on the seek bar
    in-out property <bool>   buffering-active:       false; // true when mpv is stalled waiting for cache
    in-out property <int>    buffering-pct:          0;     // cache-buffering-state 0-100
    in-out property <float>  buffered-pos:           0.0;  // demuxer cache end as fraction 0-1; shown on seek bar
    callback update-seek-hover(float);                      // hover fraction 0-1 → Rust formats and sets seek-hover-time
    in-out property <bool>   controls-visible:       true;
    in-out property <bool>   pause-bar-visible:      false; // minimal bar shown on keyboard pause; cleared on resume
    in-out property <bool>   seek-osd-visible:       false; // seek accumulation active; minimal bar uses seek-bar-* values
    in-out property <float>  seek-bar-pos:           0.0;   // target seek position (0-1); used by minimal bar thumb when seek-osd-visible
    in-out property <string> seek-bar-time:          "";    // target seek time string; used by minimal bar left-time when seek-osd-visible
    in-out property <string> seek-delta-text:        "";    // formatted seek delta e.g. "+30s" or "-1:30"; shown in centered pill
    in-out property <bool>   seek-dragging:          false; // true while seek bar button is held; blocks PausePlay
    in-out property <length> player-cursor-x:        0;   // last cursor position in player coords
    in-out property <length> player-cursor-y:        0;
    in-out property <int>    player-open-panel:      0;
    in-out property <int>    player-panel-cursor:    0;

    in-out property <[TrackEntry]> sub-tracks;
    in-out property <[TrackEntry]> audio-tracks;
    in-out property <[TrackEntry]> video-tracks;
    in-out property <int>          current-sub-id:   0;
    in-out property <int>          current-audio-id: 1;
    in-out property <int>          current-video-id: 1;

    // ── Chapter navigation ────────────────────────────────────────────────────
    in-out property <[float]>      chapter-marks:      [];   // normalised 0-1 seek bar positions for each chapter
    in-out property <bool>         chapter-osd-visible: false;
    in-out property <string>       chapter-osd-text:    "";   // "Chapter N" or chapter title; shown for ~2 s
    in-out property <[TrackEntry]> chapter-entries:    [];    // id=index, label="M:SS · Title"; populated when chapters load
    in-out property <int>          current-chapter:    -1;   // index of active chapter (-1 = none loaded)
    callback chapter-prev();
    callback chapter-next();
    callback chapter-jump(int);   // seek to chapter by index; called from Chapters panel click or kbd Enter

    // ── Sub / audio delay OSD + Sync panel ───────────────────────────────────
    in-out property <bool>   delay-osd-visible: false;
    in-out property <string> delay-osd-text:    "";   // "Sub delay: +200 ms" / "Audio delay: −100 ms"; shown for ~2 s
    in-out property <int>    sub-delay-ms:      0;    // live sub-delay in ms; shown in Sync panel
    in-out property <int>    audio-delay-ms:    0;    // live audio-delay in ms; shown in Sync panel
    callback sub-delay-inc();    // z  (+100 ms)
    callback sub-delay-dec();    // Z  (−100 ms)
    callback audio-delay-inc();  // x  (+100 ms)
    callback audio-delay-dec();  // X  (−100 ms)

    in property <string> stat-vid-in:   "—";
    in property <string> stat-vid-out:  "—";
    in property <string> stat-color:    "—";
    in property <string> stat-hwdec:    "—";
    in property <string> stat-aud-in:   "—";
    in property <string> stat-aud-out:  "—";
    in property <string> stat-display:  "—";
    in property <string> stat-vsync:    "—";
    in property <string> stat-avsync:   "—";
    in property <string> stat-speed:    "—";
    in property <string> stat-drop:     "—";
    in property <string> stat-bitrate:  "—";
    in property <string> stat-cache:    "—";

    // ── Detail page state ─────────────────────────────────────────────────────
    in-out property <string>       detail-id:            "";
    in-out property <string>       detail-item-type:    "";    // item type cached from fetch (Movie, Episode, etc.)
    in-out property <float>        detail-resume-secs:   0;    // resume position in seconds (cached from fetch)
    in-out property <bool>         detail-loading:       false;
    in-out property <int>          detail-focused-btn:      0;    // 0=Play 1=Resume 2=Series 3=Fav 4=Watched 5=Overview
    in-out property <bool>         detail-overview-expanded: false;
    in-out property <string>       detail-title:        "";
    in-out property <string>       detail-tagline:      "";    // first tagline or ""
    in-out property <string>       detail-studio:       "";    // first studio name or ""
    in-out property <string>       detail-series-label: "";
    in-out property <string>       detail-series-id:    "";    // series ID when detail item is an Episode; "" otherwise
    in-out property <string>       detail-meta:         "";
    in-out property <string>       detail-genres:       "";
    in-out property <string>       detail-overview:     "";
    in-out property <string>       detail-rating-label: "";
    in-out property <image>        detail-poster;
    in-out property <bool>         detail-has-poster:   false;
    in-out property <image>        detail-backdrop;
    in-out property <bool>         detail-has-backdrop: false;
    in-out property <bool>         detail-can-resume:   false;
    in-out property <string>       detail-resume-label: "";
    in-out property <string>       detail-ends-at:      "";  // "HH:MM" wall-clock time playback ends; shown below buttons
    in-out property <bool>         detail-is-favorite:  false;
    in-out property <bool>         detail-has-played:   false;
    in-out property <float>        detail-resume-pct:   0.0;
    in-out property <[CastMember]> detail-cast;
    in-out property <int>          detail-focused-row:        0;   // 0=buttons 1=cast 2=collection 3=similar
    in-out property <int>          detail-cast-focused:      -1;   // -1=none; ≥0=focused card in cast row
    in-out property <[CardItem]>   detail-similar:           [];   // "More Like This" poster row
    in-out property <int>          detail-similar-focused:   -1;   // focused card in "More Like This" row
    in-out property <string>       detail-collection-title:  "";   // BoxSet name when movie is in a collection
    in-out property <[CardItem]>   detail-collection:        [];   // "Part of [collection]" poster row
    in-out property <int>          detail-collection-focused: -1;  // focused card in collection row
    in-out property <length>       detail-scroll:       0px;
    in-out property <bool>         playback-from-detail: false;   // set by start_playback when play came from detail page; reset_playback_ui restores detail on stop
    in-out property <bool>         playback-from-series: false;   // set by on_play_series_episode; reset_playback_ui restores series screen on stop
    in-out property <bool>         playback-from-season: false;   // set alongside playback-from-series when season detail was also open

    // ── Series drill-down state ───────────────────────────────────────────────
    in-out property <string>           series-id:                "";
    in-out property <bool>             series-loading:           true;
    in-out property <string>           series-title:             "";
    in-out property <string>           series-overview:          "";
    in-out property <string>           series-tagline:           "";
    in-out property <string>           series-studio:            "";
    in-out property <string>           series-meta:              "";  // "2023 · TV-MA · 3 Seasons · 24 Episodes"
    in-out property <string>           series-genres:            "";  // "Drama, Crime"
    in-out property <string>           series-rating-label:      "";  // "★ 8.9"
    in-out property <bool>             series-is-favorite:       false;
    in-out property <bool>             series-has-played:        false;
    in-out property <int>              series-unplayed-count:    0;
    in-out property <image>            series-poster;
    in-out property <bool>             series-has-poster:        false;
    in-out property <image>            series-backdrop;
    in-out property <bool>             series-has-backdrop:      false;
    in-out property <[SeasonEntry]>    series-seasons;
    in-out property <[CardItem]>       series-episode-cards:     [];  // horizontal episode row
    in-out property <int>              series-season-idx:        0;
    in-out property <int>              series-focused-ep:        0;
    in-out property <bool>             series-in-season-row:     false;
    // Next Up (single next unwatched episode for this series)
    in-out property <bool>             series-next-up-focused:   false;  // true when keyboard focus is on the Next Up row
    in-out property <bool>             series-has-next-up:       false;
    in-out property <string>           series-next-up-id:            "";
    in-out property <string>           series-next-up-section-title: "Next Up";  // "Next Up" or "Next Up  ·  Ends HH:MM"
    in-out property <float>            series-next-up-resume-pct: 0;
    in-out property <bool>             series-next-up-has-played: false;
    in-out property <[CardItem]>       series-next-up-cards:     [];
    // Cast & Crew
    in-out property <[CastMember]>     series-cast:              [];
    in-out property <int>              series-cast-focused:      -1;
    // More Like This
    in-out property <[CardItem]>       series-similar:           [];
    in-out property <int>              series-similar-focused:   -1;
    // Header button focus: -1=not focused, 0=Back, 1=♥ fav, 2=✓ Watched, 3=Overview
    in-out property <int>              series-focused-btn:        -1;
    in-out property <bool>             series-overview-expanded:  false;

    // ── Season detail state ───────────────────────────────────────────────────
    in-out property <bool>         show-season:         false;
    in-out property <string>       season-id:           "";
    in-out property <string>       season-title:        "";
    in-out property <string>       season-overview:     "";
    in-out property <string>       season-meta:         "";
    in-out property <image>        season-poster;
    in-out property <bool>         season-has-poster:   false;
    in-out property <image>        season-backdrop;
    in-out property <bool>         season-has-backdrop: false;
    in-out property <[CastMember]> season-cast:         [];
    in-out property <int>          season-cast-focused:    -1;
    in-out property <int>          season-focused-ep:      0;
    // header button focus: -1=not focused, 0=Back, 1=♥ fav, 2=✓ watched, 3=Overview
    in-out property <int>          season-focused-btn:        -1;
    in-out property <bool>         season-overview-expanded:  false;
    in-out property <bool>         season-is-favorite:        false;
    in-out property <bool>         season-has-played:         false;
    in-out property <bool>         season-loading:         false;
    callback toggle-season-fav();
    callback toggle-season-played();

    // ── Person detail state ───────────────────────────────────────────────────
    in-out property <bool>       show-person:         false;
    in-out property <string>     person-id:           "";
    in-out property <string>     person-name:         "";
    in-out property <string>     person-bio:          "";
    in-out property <image>      person-portrait;
    in-out property <bool>       person-has-portrait: false;
    in-out property <[CardItem]> person-filmography:  [];
    in-out property <int>        person-film-focused: 0;
    in-out property <bool>       person-in-film-row:  false;

    // ── Collection screen state ───────────────────────────────────────────────
    in-out property <bool>       show-collection:         false;
    in-out property <string>     collection-id:           "";
    in-out property <string>     collection-title:        "";
    in-out property <image>      collection-poster;
    in-out property <bool>       collection-has-poster:   false;
    in-out property <image>      collection-backdrop;
    in-out property <bool>       collection-has-backdrop: false;
    in-out property <[CardItem]> collection-items:        [];
    in-out property <int>        collection-focused:      0;
    in-out property <bool>       collection-back-focused: false;
    in-out property <int>        collection-open-gen:     0;    // incremented on every open; stale closures abort

    // ── Context menu state ────────────────────────────────────────────────────
    in-out property <bool>   show-context-menu:        false;
    in-out property <string> context-menu-item-id:     "";
    in-out property <string> context-menu-item-type:   "";
    in-out property <string> context-menu-series-id:   "";   // series ID when item is an Episode; "" otherwise
    in-out property <bool>   context-menu-has-played:  false;
    in-out property <bool>   context-menu-is-favorite: false;
    in-out property <float>  context-menu-resume-pct:  0;
    in-out property <int>    context-menu-focused:     0;   // 0=Resume (if resume-pct>0 && !played) 1=Play from Start 2=Mark Played 3=Favourite 4=View Details

    // ── Key binding editor state ──────────────────────────────────────────────
    in-out property <[KeyBindingEntry]> keybinding-normal: [];
    in-out property <[KeyBindingEntry]> keybinding-player: [];
    in-out property <int>  keybinding-focused:   -1;
    in-out property <bool> keybinding-rebinding: false;

    // ── Settings state ────────────────────────────────────────────────────────
    in-out property <bool>   settings-launch-fullscreen:    false;
    in-out property <bool>   settings-audio-spdif:          false;
    in-out property <bool>   settings-spdif-ac3:            true;
    in-out property <bool>   settings-spdif-eac3:           true;
    in-out property <bool>   settings-spdif-dts:            true;
    in-out property <bool>   settings-spdif-dts-hd:         true;
    in-out property <bool>   settings-spdif-truehd:         true;
    in-out property <string> settings-hwdec:                "auto";
    in-out property <string> settings-vf:                   "";
    in-out property <string> settings-video-sync:           "audio";
    in-out property <bool>   settings-opengl-early-flush:   false;
    in-out property <bool>   settings-video-latency-hacks:  false;
    in-out property <bool>   settings-interpolation:        false;
    in-out property <string> settings-tscale:               "oversample";
    in-out property <string> settings-tone-mapping:         "auto";
    in-out property <bool>   settings-target-colorspace-hint: false;
    in-out property <string> settings-deinterlace:          "no";
    in-out property <int>    settings-cache-mb:             0;
    in-out property <bool>   settings-video-behind:         false;
    in-out property <bool>   settings-sub-enabled:          true;
    in-out property <string> settings-sub-lang:             "";
    in-out property <string> settings-sub-lang2:            "";
    in-out property <string> settings-sub-type:             "";
    in-out property <string>   settings-audio-lang:           "";
    in-out property <string>   settings-audio-device:          "";
    in-out property <string>   settings-audio-device-desc:     "";
    in-out property <[string]> settings-audio-device-display:  [];
    in-out property <bool>     settings-device-is-pipewire:    true;  // auto = pipewire by default
    in-out property <bool>     settings-alsa-irq-scheduling:   false;
    callback audio-device-selected(string);

    // ── Intro Skipper skip modes ("always-skip"|"ask"|"ask-timed"|"never-skip") ──
    in-out property <string> settings-skip-intro-mode:      "ask";
    in-out property <int>    settings-skip-intro-secs:       8;
    in-out property <string> settings-skip-recap-mode:      "ask";
    in-out property <int>    settings-skip-recap-secs:       8;
    in-out property <string> settings-skip-preview-mode:    "ask";
    in-out property <int>    settings-skip-preview-secs:     8;
    in-out property <string> settings-skip-commercial-mode: "ask";
    in-out property <int>    settings-skip-commercial-secs:  8;
    // Credits mode: "always-skip"|"ask"|"never-skip" (no ask-timed — banner has its own countdown)
    in-out property <string> settings-skip-credits-mode:    "ask";
    in-out property <int>    settings-skip-credits-secs:    30;

    // ── Nav helper pure functions (used by MainWindow keyboard handler) ──────────
    public pure function section-len(s: int) -> int {
        if active-nav == 0 {
            s == 0 ? continue-watching.length :
            s == 1 ? next-up.length :
            s == 2 ? recently-added.length :
                     recently-added-movies.length
        } else if active-nav == 1 {
            // TV Shows dashboard
            s == 0 ? continue-watching-tv.length :
            s == 1 ? next-up.length :
            s == 2 ? recently-added-tv.length :
                     not-watched-tv.length
        } else if active-nav == 2 {
            // Movies dashboard
            s == 0 ? continue-watching-movies.length :
            s == 1 ? 0 :
            s == 2 ? recently-added-movies.length :
                     not-watched-movies.length
        } else {
            0
        }
    }

    public pure function find-first-section() -> int {
        if section-len(0) > 0 { return 0; }
        if section-len(1) > 0 { return 1; }
        if section-len(2) > 0 { return 2; }
        if section-len(3) > 0 { return 3; }
        return 0;
    }

    public pure function find-next-section(from: int) -> int {
        if from + 1 <= 3 && section-len(from + 1) > 0 { return from + 1; }
        if from + 2 <= 3 && section-len(from + 2) > 0 { return from + 2; }
        if from + 3 <= 3 && section-len(from + 3) > 0 { return from + 3; }
        return from;
    }

    public pure function find-prev-section(from: int) -> int {
        if from - 1 >= 0 && section-len(from - 1) > 0 { return from - 1; }
        if from - 2 >= 0 && section-len(from - 2) > 0 { return from - 2; }
        if from - 3 >= 0 && section-len(from - 3) > 0 { return from - 3; }
        return -1;
    }

    public pure function section-card-id(s: int, c: int) -> string {
        if active-nav == 0 {
            s == 0 ? continue-watching[c].id :
            s == 1 ? next-up[c].id :
            s == 2 ? recently-added[c].id :
                     recently-added-movies[c].id
        } else if active-nav == 1 {
            // TV Shows
            s == 0 ? continue-watching-tv[c].id :
            s == 1 ? next-up[c].id :
            s == 2 ? recently-added-tv[c].id :
                     not-watched-tv[c].id
        } else if active-nav == 2 {
            // Movies
            s == 0 ? continue-watching-movies[c].id :
            s == 2 ? recently-added-movies[c].id :
                     not-watched-movies[c].id
        } else {
            ""
        }
    }

    public pure function section-card-item(s: int, c: int) -> CardItem {
        if active-nav == 0 {
            s == 0 ? continue-watching[c] :
            s == 1 ? next-up[c] :
            s == 2 ? recently-added[c] :
                     recently-added-movies[c]
        } else if active-nav == 1 {
            // TV Shows
            s == 0 ? continue-watching-tv[c] :
            s == 1 ? next-up[c] :
            s == 2 ? recently-added-tv[c] :
                     not-watched-tv[c]
        } else if active-nav == 2 {
            // Movies
            s == 0 ? continue-watching-movies[c] :
            s == 2 ? recently-added-movies[c] :
                     not-watched-movies[c]
        } else {
            { id: "", title: "", year: 0, item_type: "", poster: @image-url(""),
              has_played: false, resume_pct: 0, unplayed_count: 0, is_favorite: false, series_id: "" }
        }
    }

    // ── Callbacks — auth / nav ────────────────────────────────────────────────
    callback do-login(string, string, string);
    callback sign-out;
    callback nav-selected(int);
    callback toggle-fullscreen;
    callback quit;
    callback refocus; // re-grab keyboard focus after mouse interaction steals it

    // ── Callbacks — browse / library ──────────────────────────────────────────
    callback play-item(int);
    callback filter-changed(string);
    callback browse-search-append(string);
    callback browse-search-backspace();
    callback browse-search-clear();
    callback library-search-append(string);
    callback library-search-backspace();
    callback library-search-clear();
    callback open-library(int);
    callback library-sort-apply(int, bool, bool);  // sort-idx, filter-unwatched, filter-favorites
    callback library-jump-to-letter(int);          // 0=A..25=Z, 26=#

    // ── Callbacks — item play / detail / series ───────────────────────────────
    callback item-play(string);
    callback open-detail(/* id */ string, /* item-type */ string);
    callback play-detail;
    callback resume-detail;
    callback close-detail;
    callback open-collection(/* id */ string, /* title */ string);
    callback open-series(string);
    callback series-select-season(int);
    callback play-series-episode(string);
    callback close-series;
    callback open-season-detail(/* season-id */ string, /* series-id */ string);
    callback close-season-detail();
    callback open-person(/* id */ string, /* name */ string);
    callback close-person;
    callback toggle-detail-fav;
    callback toggle-detail-played;
    callback toggle-series-fav;
    callback toggle-series-played;

    // ── Callbacks — player controls ───────────────────────────────────────────
    callback pause-play-toggle;
    callback seek-backward;
    callback seek-forward;
    callback seek-backward-long;
    callback seek-forward-long;
    callback seek-acc(float);   // keyboard seek accumulation: +secs=forward, -secs=backward; debounced
    callback stop-playback;
    callback seek-to(float);
    callback seek-drag-started();                               // first mouse-move of a drag; Rust pauses mpv during scrub
    callback seek-committed(float);                             // fires on mouse-up after drag; seeks + resumes mpv
    callback select-sub(int);
    callback select-audio(int);
    callback select-video(int);
    callback commit-panel-selection;
    callback mute-toggle;
    callback volume-up;
    callback volume-down;
    callback show-controls;
    callback toggle-stats;
    callback minimize-player;
    callback resume-player;

    // ── Callbacks — context menu ──────────────────────────────────────────────
    callback open-context-menu(string, bool, bool, float, string, string); // id, played, fav, resume-pct, item-type, series-id
    callback open-context-menu-browse(int);                              // browse list index → Rust resolves
    callback open-context-menu-series-ep(string, bool, bool, float, string); // ep id, played, fav, resume-pct, series-id
    callback context-mark-played(string, bool);       // id, currently-played → Rust toggles
    callback context-toggle-fav(string, bool);        // id, currently-favorite → Rust toggles
    callback context-play-from-start(string);

    // ── Callbacks — misc overlays ─────────────────────────────────────────────
    callback cancel-auto-advance;
    callback play-next-ep;
    callback skip-segment;
    callback settings-changed;
    callback dropdown-pick; // mouse click on keyboard overlay item; cursor already set

    // ── Key dispatch ──────────────────────────────────────────────────────────
    // Called by the FocusScope key-pressed handler; Rust returns true → accept,
    // false → reject.  Replaces the 670-line Slint keyboard handler.
    callback handle-key(/* text */ string, /* shift */ bool, /* ctrl */ bool, /* repeat */ bool) -> bool;

    // Resets keybindings to compiled-in defaults and saves to keybindings.json.
    callback keybinding-reset-defaults();
}
