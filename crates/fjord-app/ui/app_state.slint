// ── fjord-app · app_state.slint ──────────────────────────────────────────────
//   Screen routing        show-login, show-detail, show-series, show-library, show-album, show-artist, app-content-loading, etc.
//                         show-connecting/show-offline (startup connectivity gate, checked before
//                         show-login) + retry-connection callback (OfflineScreen's Retry button)
//   Toast notification    toast-message: string, toast-visible: bool (auto-dismissed after 4 s)
//   Navigation state      active-nav, focused-section, focused-card, settings-focused, settings-section, float-card-focused
//   Server info           server-url, server-name, server-version, client-version (Fjord's own build, set once at startup)
//   Library grid          library-cols, library-query, library-header-focused, library-sort (0-4),
//                         library-filter-unwatched, library-filter-favorites, library-sort-focused,
//                         library-sort-cursor, library-back-focused, library-scrubber-focused,
//                         library-scrubber-cursor (0=#, 1=A..26=Z, tracks scroll + keyboard),
//                         library-alpha-offsets (27 ints A-Z+#),
//                         library-has-filters (false for Collections/Music — hides Unwatched/Favorites toggles)
//                         library-music-view (0=Artists 1=Albums 2=Playlists, Music only)
//   Browse list           media-items, current-item, browse-query, browse-header-focused
//   Dashboard data        continue-watching, next-up, recently-added, recently-added-albums, recently-played-albums, etc.
//   Auto-advance          show-next-ep-banner, next-ep-title, next-ep-ends-at, next-ep-secs
//   Volume overlay        show-volume-overlay, volume-level, audio-passthrough-active (transient ~1.5 s)
//   Segment skip          show-skip-segment, skip-segment-label (Intro Skipper: ask mode)
//                         show-skip-timed, skip-timed-label/secs/focused (ask-timed mode: 2-btn + countdown)
//   Player state          is-playing, is-paused, playing-artist,
//                         video-frame, playback-ends-at,
//   Music bar             is-audio-playing, music-bar-title/artist/album-id/art/has-art/pos/elapsed/total/paused,
//                         music-bar-play-pause, music-bar-stop, music-bar-open-album, play-album-all
//   Now Playing            show-now-playing, now-playing-in-strip/-ctrl-focused/-strip-focused, open-now-playing
//                         seek-hover-time, buffering-active/pct, buffered-pos, playback-total-secs, track panels,
//                         seek-dragging (true while seek bar is held; blocks PausePlay from keyboard)
//                         chapter-marks ([float] 0-1), chapter-osd-visible/text, chapter-prev/next callbacks,
//                         chapter-entries ([TrackEntry]), current-chapter, chapter-jump (Chapters panel)
//                         delay-osd-visible/text (sub/audio delay OSD ~2 s), sub/audio-delay-ms (Sync panel),
//                         sub/audio-delay-inc/dec callbacks
//   Detail page           detail-id, detail-item-type, detail-resume-secs, detail-title, detail-tagline,
//                         detail-studio, detail-is-favorite, detail-has-played, detail-focused-row,
//                         detail-cast-focused, detail-collection-focused, detail-similar-focused,
//                         detail-series-id, detail-scroll, detail-focused-btn, detail-ends-at,
//                         detail-cast, detail-similar, detail-collection-title, detail-collection, etc.
//   Series state          series-id, seasons, episode-cards (horizontal SectionRow), poster, backdrop,
//                         tagline, studio, is-favorite, meta/genres/rating-label, next-up card (+ section-title with ends-at), cast, similar
//   Season detail state   show-season, season-id/title/overview/meta, poster/backdrop, cast, focused-ep
//   Person detail state   show-person, person-id/name/bio, portrait, filmography, film-focused, in-film-row
//   Album detail state    show-album, album-id/title/artist/meta/overview, poster, tracks ([TrackItem]),
//                         album-focused-track, album-back-focused, album-is-favorite, album-has-played, album-open-gen, album-btn-focused,
//                         album-overview-expanded (collapsible bio section)
//   Artist detail state   show-artist, artist-id/title/overview/meta, portrait, albums ([CardItem]),
//                         artist-focused, artist-back-focused, artist-open-gen,
//                         artist-is-favorite, artist-btn-focused (-1=none,0=▶︎,1=♥︎),
//                         artist-overview-expanded (collapsible bio); play-artist-all, toggle-artist-fav
//   Seerr integration      settings-seerr-enabled, seerr-connected/-label, open-connect-seerr, seerr-disconnect;
//                         settings-streaming-region-desc/-display, streaming-region-selected (Settings →
//                         Integrations → Streaming Region, only shown while connected — dynamic dropdown,
//                         same shape as settings-font-family-*); settings-trailer-quality (Settings →
//                         Integrations → Trailer Quality, same visibility gate, but a plain static
//                         dropdown); yt-dlp-available (gates Watch Trailer button visibility);
//                         request-detail-trailer-url/-btn-focused, play-trailer (Watch Trailer button
//                         on RequestDetailScreen — Discover only, see CLAUDE.md);
//                         ConnectSeerrScreen: show-connect-seerr, connect-seerr-method (0-3), connect-seerr-error/busy,
//                         connect-seerr-qc-code/-secret/-polling (Quick Connect), connect-seerr-api-key/-jellyfin/-local/
//                         -quickconnect-start/-poll callbacks (discover.rs/seerr_auth.rs)
//   Discover screen        discover-query, discover-searching, discover-results ([CardItem]),
//                         discover-focused/-focused-row, discover-header-focused, discover-search-*,
//                         open-discover-item(media-type, tmdb-id) (redirects to the real Jellyfin
//                         item via detail::open_detail when a local library match exists, instead
//                         of the Seerr request-detail flow); landing rows (query==""):
//                         discover-trending/-popular-movies/-popular-tv/-upcoming-movies/-upcoming-tv/
//                         -requested ([CardItem]), discover-landing-card (column within focused-section 0-5)
//   Request detail state   show-request-detail, request-detail-media-type/-tmdb-id/-title/-meta/-overview,
//                         request-detail-rating ("★ 7.9", empty = no badge), request-detail-overview-expanded,
//                         request-detail-poster/-backdrop, request-detail-status ("" | requested | processing |
//                         partial | available), request-detail-cast ([CastMember]) + -focused-cast,
//                         request-detail-seasons ([SeasonItem], TV only) + -focused-season,
//                         request-detail-back-focused, request-detail-zone (0=button row,1=storyline,2=cast —
//                         vertical flow on the main page only; quality/profile/tags/seasons live in the
//                         Request Options modal below), request-detail-want-4k,
//                         request-detail-tags ([TagItem], Radarr/Sonarr default-server tags) + -focused-tag,
//                         request-detail-profiles ([ProfileItem], quality profiles on that same server,
//                         row 0 a synthetic "Default" entry) + -focused-profile + -selected-profile-id
//                         (radio, 0=Default); request-detail-tags-alt/-profiles-alt/-selected-profile-id-alt
//                         (the other quality tier, pre-fetched — request-detail-set-quality swaps these in
//                         instead of re-fetching on toggle), request-detail-open-gen, request-detail-requesting,
//                         request-detail-toggle-season/-tag/-request,
//                         open-request-options (Request button -> modal instead of inlining every picker on
//                         the page); show-request-options, request-options-zone (0=Quality row,1=Profile row,
//                         2=tags row,3=seasons row,4=confirm row — same skip-absent-zones idiom as
//                         request-detail-zone), request-options-confirm-focused (0=Cancel,1=Request)
//   Context menu          show-context-menu, context-menu-* state, context-menu-focused
//   Settings state        hwdec, interpolation, audio-spdif, sub-lang, skip-*-mode/secs, etc.
//   Key binding editor    keybinding-normal/player rows, keybinding-focused, keybinding-rebinding
//   Nav helpers           section-len, find-first/next/prev-section, section-card-id
//   Callbacks — auth      do-login, sign-out, quit, toggle-fullscreen
//   Callbacks — browse    nav-selected, filter-changed, browse-search-*, library-search-*
//   Callbacks — play      item-play, play/resume-detail, open-detail/series, open-album, play-album-track
//   Callbacks — player    pause-play-toggle, seek-*, volume-*, mute, select-*, stop
//   Queue                 queue-count, queue-repeat-mode, queue-shuffle, playlist callbacks; show-queue-panel, queue-items, queue-panel-cursor;
//                         open-queue-panel (mouse entry point — refresh + focus grab, mirrors the 'q' key, CR11-6)
//   Lyrics                show-lyrics, lyrics-available, lyrics-lines ([LyricEntry]), lyrics-active-idx, toggle-lyrics
//   Callbacks — context   open-context-menu, context-mark-played, context-toggle-fav, context-play-from-start
//   Callbacks — misc      show-controls, cancel-auto-advance, play-next-ep, close-detail/series, close-album, close-artist, refocus
//   Callbacks — keys      handle-key (main dispatch), keybinding-reset-defaults
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, TrackEntry, TrackItem, CastMember, SeasonEntry, CardItem, KeyBindingEntry, QueueEntry, LyricEntry, SeasonItem, TagItem, ProfileItem, StreamingProvider } from "theme.slint";
import { StandardListView } from "std-widgets.slint";

export global AppState {
    // ── Screen routing ────────────────────────────────────────────────────────
    in-out property <bool> show-login:            true;
    // Startup connectivity gate (checked before show-login): show-connecting while
    // the saved-session auth probe is in flight; show-offline if it fails to reach
    // the server at all (as opposed to a definite 401, which routes to show-login).
    in-out property <bool> show-connecting:       false;
    in-out property <bool> show-offline:          false;
    // 0=Retry 1=Change Server 2=Quit — a permanent failure (server decommissioned,
    // wrong saved URL) needs a way out besides retrying forever.
    in-out property <int>  offline-focused:       0;
    callback retry-connection();
    in-out property <bool> show-browse:           false;
    in-out property <bool> show-library:          false;
    in-out property <bool> show-series:           false;
    in-out property <bool> show-detail:           false;
    in-out property <bool> is-playing:            false;
    in-out property <bool> has-background-player: false;
    in-out property <bool> video-behind-ui:       false;
    in-out property <bool>  app-content-loading:   false;  // true while fetching detail/series before showing screen
    in-out property <float> app-loading-progress:  0.0;   // 0.0→1.0 while app-content-loading; drives the progress bar

    // ── Toast notification ────────────────────────────────────────────────────
    in-out property <string> toast-message: "";
    in-out property <bool>   toast-visible:  false;

    // ── Press animation ────────────────────────────────────────────────────────
    // Bumped once by keys.rs::handle_key() on every Enter press; every mounted
    // widgets.slint::PressPulse instance reacts if its own focus/selection
    // expression is currently true, playing a brief border-flash "press" cue.
    // Mouse press feedback needs no Rust involvement (TouchArea.pressed).
    in-out property <int>    kb-activate-pulse: 0;
    // True only under the same condition keys.rs::active_mode() calls
    // AppMode::Dashboard, plus focused-section < 0 — the one narrow condition
    // under which the sidebar is genuinely the thing holding focus. Used by
    // both the press-pulse gate above and NavItem's own background highlight
    // (widgets.slint) in place of the old per-instance `kbd-focused` prop
    // (`focused-section < 0` alone, identically bound on every sidebar row),
    // which stayed stale/true while deep in Library/Browse/Settings/Detail/
    // etc since those modes never touch focused-section — the active sidebar
    // tab used to stay fully lit (and, once the press-pulse existed, kept
    // pulsing) long after focus had moved elsewhere. Deliberately a **pure
    // Slint expression**, not a value Rust pushes on keypress: an earlier
    // version was only recomputed inside keys::handle_key(), so it went stale
    // again the moment a screen change was triggered by the *mouse* instead
    // of the keyboard (e.g. clicking into the library grid) — a plain
    // expression mirroring active_mode()'s own conditions off the same
    // AppState flags is correct-by-construction for every input method at
    // once, since those flags are set identically regardless of how they
    // were triggered. The trade-off is duplicating active_mode()'s condition
    // list here; if a new screen/overlay is ever added to that Rust function,
    // this expression needs the matching branch added too.
    out property <bool> sidebar-kb-active:
        !show-context-menu
        && !show-queue-panel
        && !(show-now-playing && is-audio-playing)
        && !(show-person     && !is-playing)
        && !(show-detail     && !is-playing)
        && !(show-season     && !is-playing)
        && !(show-series     && !is-playing)
        && !(show-artist     && !is-playing)
        && !(show-collection && !is-playing)
        && !(show-album      && !is-playing)
        && !(show-request-detail && !is-playing)
        && !is-playing
        && !show-library
        && !show-browse
        && active-nav != 10
        && focused-section < 0;
        // Discover (active-nav==6) deliberately does NOT get its own
        // exclusion here, unlike Settings (10) — Discover now replicates
        // dispatch_dashboard's focused-section sidebar/content contract
        // itself (discover::handle_key), so focused-section < 0 alone
        // correctly means "sidebar focused" there too, same as Home/Movies/TV.

    // ── Navigation state ──────────────────────────────────────────────────────
    in-out property <int>    active-nav:         0;
    in-out property <int>    focused-section:   -1;
    in-out property <int>    focused-card:       0;
    in-out property <int>    float-card-focused: -1;  // -1=not focused, 0=Resume, 1=Stop; floating mini-player
    in     property <string> server-url:       "";
    in     property <string> server-name:      "";
    in     property <string> server-version:   "";
    in     property <string> client-version:   "";  // Fjord's own build id, set once at startup
    in-out property <int>    settings-focused: -1;   // -1 = left pane focus, ≥0 = right-pane row
    in-out property <int>    settings-section: -1;   // -1 = sidebar, 0 = General, 1 = Player
    in-out property <bool>     settings-dropdown-open:   false;  // a dropdown popup is keyboard-open
    in-out property <int>      settings-dropdown-cursor: -1;     // focused item index inside open popup
    in-out property <[string]> settings-dropdown-model:  [];     // display strings for the open dropdown
    in-out property <string>   settings-dropdown-display: "";    // display string of current value (accent highlight)

    // ── Library grid state ────────────────────────────────────────────────────
    in-out property <bool>       library-header-focused:    false;
    in-out property <int>        library-focused:           0;
    in-out property <[CardItem]> library-display:           [];
    in-out property <string>     library-query:             "";
    in-out property <int>        library-cols:              6;   // written by MainWindow on resize
    // sort: 0=Name A–Z  1=Name Z–A  2=Year ↓  3=Year ↑  4=Random
    in-out property <int>        library-sort:              0;
    in-out property <bool>       library-filter-unwatched:  false;
    in-out property <bool>       library-filter-favorites:  false;
    in-out property <bool>       library-sort-focused:      false;
    in-out property <int>        library-sort-cursor:       0;
    in-out property <bool>       library-back-focused:      false;
    in-out property <int>        library-focused-row:       0;     // row that drives vertical scroll; only updated on Up/Down
    in-out property <bool>       library-scrubber-focused:  false;
    in-out property <int>        library-scrubber-cursor:   0;
    // 27 flat item indices (A=0..Z=25, #=26); -1 means no items for that letter
    in-out property <[int]>      library-alpha-offsets:     [];
    // false for Collections library (hides Unwatched/Favorites filter toggles)
    in-out property <bool>       library-has-filters:       true;
    // Music library view: 0=Artists  1=Albums
    in-out property <int>        library-music-view:        0;
    in-out property <length>     dash-cw:                140px; // written by MainWindow on resize
    in-out property <length>     dash-ch:                224px; // written by MainWindow on resize

    // ── Browse list state ─────────────────────────────────────────────────────
    in     property <string>                 status:        "";
    in     property <[StandardListViewItem]> media-items:   [];
    in-out property <int>                    current-item:  -1;
    in-out property <string>                 browse-query:  ""; // tracks keyboard search text
    in-out property <bool>                   browse-header-focused: false;

    // ── Home / dashboard data rows ────────────────────────────────────────────
    in property <[CardItem]> continue-watching:        [];
    in property <[CardItem]> next-up:                  [];
    in property <[CardItem]> recently-added:           [];
    in property <[CardItem]> continue-watching-movies: [];
    in property <[CardItem]> recently-added-movies:    [];
    in property <[CardItem]> not-watched-movies:       [];
    in property <[CardItem]> continue-watching-tv:        [];
    in property <[CardItem]> recently-added-tv:           [];
    in property <[CardItem]> not-watched-tv:              [];
    in property <[CardItem]> recently-added-collections:  [];
    in property <[CardItem]> unwatched-collections:       [];
    in property <[CardItem]> recently-added-albums:       [];
    in property <[CardItem]> recently-played-albums:      [];
    in property <[CardItem]> favorite-movies:             [];
    in property <[CardItem]> favorite-series:             [];
    in property <[CardItem]> favorite-albums:             [];
    in property <[CardItem]> all-movies:               [];
    in property <[CardItem]> all-series:               [];
    in property <[CardItem]> all-collections:          [];
    in property <[CardItem]> all-artists:              [];
    in property <[CardItem]> all-albums:               [];
    in property <[CardItem]> all-playlists:            [];
    in property <[CardItem]> music-playlists:          [];   // Music dashboard "Playlists" row (section 3)

    // ── Up Next banner (shown during credits / last 30 s) ────────────────────
    in-out property <bool>   show-next-ep-banner:    false;
    in-out property <string> next-ep-title:           "";
    in-out property <string> next-ep-ends-at:         "";  // "HH:MM" wall-clock end of next episode
    in-out property <int>    next-ep-secs:             30;
    in-out property <int>    next-ep-banner-focused:   0;  // 0=Play Now, 1=Skip

    // ── Volume overlay (transient, ~1.5 s) ───────────────────────────────────
    in-out property <bool> show-volume-overlay:      false;
    in-out property <int>  volume-level:             100;
    in-out property <bool> audio-passthrough-active: false; // true when iec61937 passthrough detected

    // ── Segment skip prompts (Intro Skipper: Intro / Recap / Preview / Commercial) ──
    // ask mode:      single "Skip →" button
    in-out property <bool>   show-skip-segment:  false;
    in-out property <string> skip-segment-label: "Skip Intro →";
    // ask-timed mode: two-button overlay ("Skip" + "Don't Skip") with countdown
    in-out property <bool>   show-skip-timed:    false;
    in-out property <string> skip-timed-label:   "Skip Intro →";
    in-out property <int>    skip-timed-secs:    8;
    in-out property <int>    skip-timed-focused: 0;  // 0=Skip, 1=Don't Skip
    callback dismiss-skip-timed;

    // ── Player state ──────────────────────────────────────────────────────────
    in     property <image>  video-frame;
    in-out property <string> playing-artist:        "";   // artist name shown in controls bar for audio tracks

    // ── Music player bar ──────────────────────────────────────────────────────
    in-out property <bool>   is-audio-playing:    false; // music bar active (audio-only playback)
    in-out property <string> music-bar-title:     "";
    in-out property <string> music-bar-artist:    "";
    in-out property <string> music-bar-album-id:  "";   // for album art fetch + open-album nav
    in-out property <image>  music-bar-art;
    in-out property <bool>   music-bar-has-art:   false;
    in-out property <float>  music-bar-pos:       0;    // 0–1 playback position
    in-out property <string> music-bar-elapsed:   "0:00";
    in-out property <string> music-bar-total:     "0:00";
    in-out property <bool>   music-bar-paused:    false;
    // -1=none 0=art/title 1=⏸︎/▶︎ 2=⏹︎ 3=timeline 4=⏮︎Prev 5=⏭︎Next 6=⇌︎Shuffle 7=↺︎Repeat 8=⋮︎Queue 9=♪︎Lyrics
    in-out property <int>    music-bar-focused:   -1;
    callback music-bar-play-pause();
    callback music-bar-stop();
    callback music-bar-open-album();
    callback music-bar-seek(ratio: float);
    callback music-bar-seek-rel(secs: float); // relative seek in seconds (±10)

    // ── Now Playing (fullscreen music screen) ─────────────────────────────────
    in-out property <bool> show-now-playing:          false;
    in-out property <bool> now-playing-back-focused:   false; // top-left Back button focused
    in-out property <bool> now-playing-in-strip:       false; // false=transport row, true=up-next strip
    in-out property <int>  now-playing-ctrl-focused:   2;     // 0=Album 1=Prev 2=Play/Pause 3=Next 4=Shuffle 5=Repeat 6=VolDown 7=VolUp
    in-out property <int>  now-playing-strip-focused:  0;     // index into queue-items
    callback open-now-playing(); // Rust resets focus state then sets show-now-playing=true
    callback play-album-all();

    in-out property <int>    app-logo-idx:         1;    // 1-10, randomised at startup
    in-out property <bool>   is-paused:            false;
    in-out property <string> playing-title:         "";
    in-out property <bool>   stats-visible:         false;
    in-out property <float>  playback-pos:           0;
    in-out property <string> playback-time:          "0:00";
    in-out property <string> playback-total:         "0:00";
    in-out property <float>  playback-total-secs:    0.0;   // total duration in seconds; used by seek-hover time calc
    in-out property <string> playback-ends-at:       "";
    in-out property <string> seek-hover-time:        "";    // formatted time at hover position on the seek bar
    in-out property <bool>   buffering-active:       false; // true when mpv is stalled waiting for cache
    in-out property <int>    buffering-pct:          0;     // cache-buffering-state 0-100
    in-out property <float>  buffered-pos:           0.0;  // demuxer cache end as fraction 0-1; shown on seek bar
    callback update-seek-hover(float);                      // hover fraction 0-1 → Rust formats and sets seek-hover-time
    in-out property <bool>   controls-visible:       true;
    in-out property <bool>   pause-bar-visible:      false; // minimal bar shown on keyboard pause; cleared on resume
    in-out property <bool>   seek-osd-visible:       false; // seek accumulation active; minimal bar uses seek-bar-* values
    in-out property <float>  seek-bar-pos:           0.0;   // target seek position (0-1); used by minimal bar thumb when seek-osd-visible
    in-out property <string> seek-bar-time:          "";    // target seek time string; used by minimal bar left-time when seek-osd-visible
    in-out property <string> seek-delta-text:        "";    // formatted seek delta e.g. "+30s" or "-1:30"; shown in centered pill
    in-out property <bool>   seek-dragging:          false; // true while seek bar button is held; blocks PausePlay
    in-out property <length> player-cursor-x:        0;   // last cursor position in player coords
    in-out property <length> player-cursor-y:        0;
    in-out property <int>    player-open-panel:      0;
    in-out property <int>    player-panel-cursor:    0;

    in-out property <[TrackEntry]> sub-tracks;
    in-out property <[TrackEntry]> audio-tracks;
    in-out property <[TrackEntry]> video-tracks;
    in-out property <int>          current-sub-id:   0;
    in-out property <int>          current-audio-id: 1;
    in-out property <int>          current-video-id: 1;

    // ── Chapter navigation ────────────────────────────────────────────────────
    in-out property <[float]>      chapter-marks:      [];   // normalised 0-1 seek bar positions for each chapter
    in-out property <bool>         chapter-osd-visible: false;
    in-out property <string>       chapter-osd-text:    "";   // "Chapter N" or chapter title; shown for ~2 s
    in-out property <[TrackEntry]> chapter-entries:    [];    // id=index, label="M:SS · Title"; populated when chapters load
    in-out property <int>          current-chapter:    -1;   // index of active chapter (-1 = none loaded)
    callback chapter-prev();
    callback chapter-next();
    callback chapter-jump(int);   // seek to chapter by index; called from Chapters panel click or kbd Enter

    // ── Sub / audio delay OSD + Sync panel ───────────────────────────────────
    in-out property <bool>   delay-osd-visible: false;
    in-out property <string> delay-osd-text:    "";   // "Sub delay: +200 ms" / "Audio delay: −100 ms"; shown for ~2 s
    in-out property <int>    sub-delay-ms:      0;    // live sub-delay in ms; shown in Sync panel
    in-out property <int>    audio-delay-ms:    0;    // live audio-delay in ms; shown in Sync panel
    callback sub-delay-inc();    // z  (+100 ms)
    callback sub-delay-dec();    // Z  (−100 ms)
    callback audio-delay-inc();  // x  (+100 ms)
    callback audio-delay-dec();  // X  (−100 ms)

    in property <string> stat-vid-in:   "—";
    in property <string> stat-vid-out:  "—";
    in property <string> stat-color:    "—";
    in property <string> stat-hwdec:    "—";
    in property <string> stat-aud-in:   "—";
    in property <string> stat-aud-out:  "—";
    in property <string> stat-display:  "—";
    in property <string> stat-vsync:    "—";
    in property <string> stat-avsync:   "—";
    in property <string> stat-speed:    "—";
    in property <string> stat-drop:     "—";
    in property <string> stat-bitrate:  "—";
    in property <string> stat-cache:    "—";

    // ── Detail page state ─────────────────────────────────────────────────────
    in-out property <string>       detail-id:            "";
    in-out property <string>       detail-item-type:    "";    // item type cached from fetch (Movie, Episode, etc.)
    in-out property <float>        detail-resume-secs:   0;    // resume position in seconds (cached from fetch)
    in-out property <bool>         detail-loading:       false;
    in-out property <int>          detail-focused-btn:      0;    // 0=Play 1=Resume 2=Series 3=Fav 4=Watched 5=Overview
    in-out property <bool>         detail-overview-expanded: false;
    in-out property <string>       detail-title:        "";
    in-out property <string>       detail-tagline:      "";    // first tagline or ""
    in-out property <string>       detail-studio:       "";    // first studio name or ""
    in-out property <string>       detail-series-label: "";
    in-out property <string>       detail-series-id:    "";    // series ID when detail item is an Episode; "" otherwise
    in-out property <string>       detail-meta:         "";
    in-out property <string>       detail-genres:       "";
    in-out property <string>       detail-overview:     "";
    in-out property <string>       detail-rating-label: "";
    in-out property <image>        detail-poster;
    in-out property <bool>         detail-has-poster:   false;
    in-out property <image>        detail-backdrop;
    in-out property <bool>         detail-has-backdrop: false;
    in-out property <bool>         detail-can-resume:   false;
    in-out property <string>       detail-resume-label: "";
    in-out property <string>       detail-ends-at:      "";  // "HH:MM" wall-clock time playback ends; shown below buttons
    in-out property <bool>         detail-is-favorite:  false;
    in-out property <bool>         detail-has-played:   false;
    in-out property <float>        detail-resume-pct:   0.0;
    in-out property <[CastMember]> detail-cast;
    in-out property <int>          detail-focused-row:        0;   // 0=buttons 1=cast 2=collection 3=similar
    in-out property <int>          detail-cast-focused:      -1;   // -1=none; ≥0=focused card in cast row
    in-out property <[CardItem]>   detail-similar:           [];   // "More Like This" poster row
    in-out property <int>          detail-similar-focused:   -1;   // focused card in "More Like This" row
    in-out property <string>       detail-collection-title:  "";   // BoxSet name when movie is in a collection
    in-out property <[CardItem]>   detail-collection:        [];   // "Part of [collection]" poster row
    in-out property <int>          detail-collection-focused: -1;  // focused card in collection row
    in-out property <length>       detail-scroll:       0px;
    in-out property <bool>         playback-from-detail: false;   // set by start_playback when play came from detail page; reset_playback_ui restores detail on stop
    in-out property <bool>         playback-from-series: false;   // set by on_play_series_episode; reset_playback_ui restores series screen on stop
    in-out property <bool>         playback-from-season: false;   // set alongside playback-from-series when season detail was also open

    // ── Series drill-down state ───────────────────────────────────────────────
    in-out property <string>           series-id:                "";
    in-out property <bool>             series-loading:           true;
    in-out property <string>           series-title:             "";
    in-out property <string>           series-overview:          "";
    in-out property <string>           series-tagline:           "";
    in-out property <string>           series-studio:            "";
    in-out property <string>           series-meta:              "";  // "2023 · TV-MA · 3 Seasons · 24 Episodes"
    in-out property <string>           series-genres:            "";  // "Drama, Crime"
    in-out property <string>           series-rating-label:      "";  // "★ 8.9"
    in-out property <bool>             series-is-favorite:       false;
    in-out property <bool>             series-has-played:        false;
    in-out property <int>              series-unplayed-count:    0;
    in-out property <image>            series-poster;
    in-out property <bool>             series-has-poster:        false;
    in-out property <image>            series-backdrop;
    in-out property <bool>             series-has-backdrop:      false;
    in-out property <[SeasonEntry]>    series-seasons;
    in-out property <[CardItem]>       series-episode-cards:     [];  // horizontal episode row
    in-out property <int>              series-season-idx:        0;
    in-out property <int>              series-focused-ep:        0;
    in-out property <bool>             series-in-season-row:     false;
    // Next Up (single next unwatched episode for this series)
    in-out property <bool>             series-next-up-focused:   false;  // true when keyboard focus is on the Next Up row
    in-out property <bool>             series-has-next-up:       false;
    in-out property <string>           series-next-up-id:            "";
    in-out property <string>           series-next-up-section-title: "Next Up";  // "Next Up" or "Next Up  ·  Ends HH:MM"
    in-out property <float>            series-next-up-resume-pct: 0;
    in-out property <bool>             series-next-up-has-played: false;
    in-out property <[CardItem]>       series-next-up-cards:     [];
    // Cast & Crew
    in-out property <[CastMember]>     series-cast:              [];
    in-out property <int>              series-cast-focused:      -1;
    // More Like This
    in-out property <[CardItem]>       series-similar:           [];
    in-out property <int>              series-similar-focused:   -1;
    // Header button focus: -1=not focused, 0=Back, 1=♥︎ fav, 2=✓︎ Watched, 3=Overview
    in-out property <int>              series-focused-btn:        -1;
    in-out property <bool>             series-overview-expanded:  false;

    // ── Season detail state ───────────────────────────────────────────────────
    in-out property <bool>         show-season:         false;
    in-out property <string>       season-id:           "";
    in-out property <string>       season-title:        "";
    in-out property <string>       season-overview:     "";
    in-out property <string>       season-meta:         "";
    in-out property <image>        season-poster;
    in-out property <bool>         season-has-poster:   false;
    in-out property <image>        season-backdrop;
    in-out property <bool>         season-has-backdrop: false;
    in-out property <[CastMember]> season-cast:         [];
    in-out property <int>          season-cast-focused:    -1;
    in-out property <int>          season-focused-ep:      0;
    // header button focus: -1=not focused, 0=Back, 1=♥︎ fav, 2=✓︎ watched, 3=Overview
    in-out property <int>          season-focused-btn:        -1;
    in-out property <bool>         season-overview-expanded:  false;
    in-out property <bool>         season-is-favorite:        false;
    in-out property <bool>         season-has-played:         false;
    in-out property <bool>         season-loading:         false;
    callback toggle-season-fav();
    callback toggle-season-played();

    // ── Person detail state ───────────────────────────────────────────────────
    in-out property <bool>       show-person:         false;
    in-out property <string>     person-id:           "";
    in-out property <string>     person-name:         "";
    in-out property <string>     person-bio:          "";
    in-out property <image>      person-portrait;
    in-out property <bool>       person-has-portrait: false;
    in-out property <[CardItem]> person-filmography:  [];
    in-out property <int>        person-film-focused: 0;
    in-out property <bool>       person-in-film-row:  false;

    // ── Collection screen state ───────────────────────────────────────────────
    in-out property <bool>       show-collection:         false;
    in-out property <string>     collection-id:           "";
    in-out property <string>     collection-title:        "";
    in-out property <image>      collection-poster;
    in-out property <bool>       collection-has-poster:   false;
    in-out property <image>      collection-backdrop;
    in-out property <bool>       collection-has-backdrop: false;
    in-out property <[CardItem]> collection-items:        [];
    in-out property <int>        collection-focused:      0;
    in-out property <bool>       collection-back-focused: false;
    in-out property <int>        collection-open-gen:     0;    // incremented on every open; stale closures abort
    in-out property <string>     collection-overview:     "";
    in-out property <bool>       collection-is-favorite:  false;
    in-out property <bool>       collection-has-played:   false;
    in-out property <int>        collection-btn-focused:  -1;   // -1=none, 0=♥︎, 1=✓︎

    // ── Album detail state ────────────────────────────────────────────────────
    in-out property <bool>        show-album:          false;
    in-out property <string>      album-id:            "";
    in-out property <string>      album-title:         "";
    in-out property <string>      album-artist:        "";
    in-out property <string>      album-meta:          "";   // "2020 · 12 tracks · 45:23"
    in-out property <string>      album-overview:      "";
    in-out property <image>       album-poster;
    in-out property <bool>        album-has-poster:    false;
    in-out property <[TrackItem]> album-tracks:        [];
    in-out property <int>         album-focused-track: 0;
    in-out property <bool>        album-back-focused:  false;
    in-out property <bool>        album-is-favorite:   false;
    in-out property <bool>        album-has-played:    false;
    in-out property <int>         album-open-gen:      0;   // stale-request guard
    in-out property <bool>   album-is-playlist:    false; // AlbumScreen shows a playlist: pos numbering, ✕︎ remove, Delete key
    in-out property <int>         album-btn-focused:   -1;  // -1=none, 0=♥︎, 1=✓︎
    in-out property <bool>        album-overview-expanded: false;

    // ── Artist screen state ───────────────────────────────────────────────────
    in-out property <bool>       show-artist:         false;
    in-out property <string>     artist-id:           "";
    in-out property <string>     artist-title:        "";
    in-out property <string>     artist-overview:     "";
    in-out property <string>     artist-meta:         "";   // "5 albums"
    in-out property <image>      artist-portrait;
    in-out property <bool>       artist-has-portrait: false;
    in-out property <[CardItem]> artist-albums:       [];
    in-out property <int>        artist-focused:      0;
    in-out property <bool>       artist-back-focused: false;
    in-out property <int>        artist-open-gen:     0;   // stale-request guard
    in-out property <bool>       artist-is-favorite:  false;
    in-out property <int>        artist-btn-focused:  -1;  // -1=none, 0=▶︎ Play All, 1=♥︎
    in-out property <bool>       artist-overview-expanded: false;

    callback toggle-artist-fav;
    callback play-artist-all;

    // ── Discover screen state (Seerr search + results grid, discover.rs) ─────
    // No show-discover flag — this screen is driven by active-nav == 6
    // directly, same pattern as the Home/Movies/TV dashboards, not a
    // separate boolean overlay flag.
    in-out property <string>     discover-query:          "";
    in-out property <bool>       discover-searching:       false;
    in-out property <[CardItem]> discover-results:         [];
    in-out property <int>        discover-focused:         0;
    in-out property <int>        discover-focused-row:     0;      // scroll anchor, mirrors library-focused-row
    in-out property <bool>       discover-header-focused:  false;  // search field focused, mirrors browse-header-focused
    callback discover-search-append(string);
    callback discover-search-backspace();
    callback discover-search-clear();
    // Fired when keyboard Down reaches the last row of discover-results —
    // fetches the next search-results page and appends it, if one exists.
    // Seerr/TMDB search commonly has far more than one page for a common
    // word; Fjord only ever fetched page 1 until this existed, capping
    // results well below what Seerr's own web UI shows for the same query.
    // No-ops quietly when there's no next page / one's already in flight /
    // there's no active search — see discover.rs::spawn_discover_search_more.
    callback discover-load-more();
    callback open-discover-item(string, string);   // media-type ("movie"|"tv"), tmdb-id (as string)

    // ── Discover landing rows (shown when discover-query == "") ──────────────
    // Fetched once per session (guarded in FjordState) when nav first lands
    // on Discover with a connection active. Fixed set of 5, always in this
    // order — focused-section (shared, same property Home/Movies/TV use)
    // picks which row, 0-4; discover-landing-card is the column within it
    // (a separate property from discover-focused, which is the FLAT grid's
    // row-major index used only when a search query is active — the two
    // views are mutually exclusive so there's no real overlap, but the index
    // math is different enough to need its own property).
    in-out property <[CardItem]> discover-trending:         [];
    in-out property <[CardItem]> discover-popular-movies:   [];
    in-out property <[CardItem]> discover-popular-tv:       [];
    in-out property <[CardItem]> discover-upcoming-movies:  [];
    in-out property <[CardItem]> discover-upcoming-tv:      [];
    // Requests still on the way — not declined, not already available/
    // deleted (fjord_seerr::SeerrClient::requested_not_available). Unlike
    // the other 5 rows, each card's poster/title comes from a per-item
    // detail fetch, not directly from the row's own listing endpoint (GET
    // /request carries only a tmdbId) — same CardItem shape either way.
    in-out property <[CardItem]> discover-requested:        [];
    in-out property <int>        discover-landing-card:     0;

    // ── Request detail screen state (Seerr movie/TV detail + Request, discover.rs) ──
    in-out property <bool>          show-request-detail:          false;
    in-out property <string>        request-detail-media-type:    "";  // "movie" | "tv"
    in-out property <int>           request-detail-tmdb-id:       0;
    in-out property <string>        request-detail-title:         "";
    in-out property <string>        request-detail-meta:          "";  // year · genres
    in-out property <string>        request-detail-overview:      "";
    in-out property <bool>          request-detail-overview-expanded: false;
    // "★ 7.9" (TMDB voteAverage, one decimal) or "" when absent/zero — fed
    // straight into MetaLine.rating-label, same as DetailPage's own
    // Jellyfin-community-rating badge.
    in-out property <string>        request-detail-rating:        "";
    // ── Metadata panel (Status/dates/language/countries/network/streaming) ──
    // Purely-display, read-only content — no keyboard zone of its own
    // (reached by scrolling the page's existing Flickable, same as MetaLine's
    // genre/tagline text elsewhere in the app). request-detail-production-
    // status is TMDB's own production-status string ("Returning Series",
    // "Ended", "Released", ...) — deliberately a DIFFERENT property from
    // request-detail-status above, which is Seerr's own request/availability
    // state; conflating the two would silently break the Request button's
    // existing "" vs requested/processing/partial/available logic.
    in-out property <string>        request-detail-production-status: "";
    in-out property <string>        request-detail-date-label:    "";  // "Release Date" | "First Air Date"
    in-out property <string>        request-detail-date-value:    "";  // "July 14, 2026"; "" if unknown
    in-out property <string>        request-detail-next-air-date: "";  // TV only; "" if none/unknown
    in-out property <string>        request-detail-original-language: "";  // display name, e.g. "English"
    // Multi-line "🇺🇸 United States\n🇬🇧 United Kingdom" — a plain Text with
    // wrap:word-wrap respects embedded \n as real line breaks (same
    // mechanism StorylineSection relies on), so this doesn't need a
    // separate list model just to stack a handful of country names.
    in-out property <string>        request-detail-production-countries: "";
    in-out property <string>        request-detail-network:       "";  // TV only; joined "Apple TV, BBC"
    in-out property <[StreamingProvider]> request-detail-providers: [];  // flatrate only, resolved region
    in-out property <image>         request-detail-poster;
    in-out property <bool>          request-detail-has-poster:    false;
    in-out property <image>         request-detail-backdrop;
    in-out property <bool>          request-detail-has-backdrop:  false;
    // "" (requestable, Request button shown) | "requested" | "processing" |
    // "partial" (still requestable) | "available" — mirrors CardItem.availability
    in-out property <string>        request-detail-status:        "";
    // Watch Trailer (Discover only — see CLAUDE.md's Seerr integration
    // section). "" = no trailer found in MovieDetails/TvDetails.
    // relatedVideos, button hidden. Independent of request-detail-status —
    // watching a trailer makes sense even for an already-requested/
    // available item, so it's a third sibling in the button row, not nested
    // inside either the Request-button or status-pill branch.
    in-out property <string>        request-detail-trailer-url:   "";
    // Button row focus: 0=Request, 1=Trailer — only meaningful within zone
    // 0, and only ever reaches 1 when a trailer button actually exists.
    // Every site that changes this (keyboard zone entry, either button's
    // own `clicked` handler) must keep it in sync — see the mouse/keyboard
    // focus desync bug class documented in CLAUDE.md's Seerr integration
    // section (Phase 142's zone-numbering fix) this mirrors.
    in-out property <int>           request-detail-btn-focused:   0;
    // Cast + crew (director/writer/top-billed actors), same take(2)/take(3)/
    // take(12) cap as DetailPage's Jellyfin cast. item-selected is a no-op —
    // there's no TMDB-person detail screen to open — but the row stays
    // keyboard-focusable (Left/Right scroll) for consistency.
    in-out property <[CastMember]>  request-detail-cast:          [];
    in-out property <int>           request-detail-focused-cast:  -1;
    in-out property <[SeasonItem]>  request-detail-seasons:       [];  // TV only, empty for movies
    in-out property <int>           request-detail-focused-season: 0;
    in-out property <bool>          request-detail-back-focused:  true;
    // Vertical flow below the back button: 0=button row (Request/4K),
    // 1=storyline (collapsible overview, only if overview non-empty),
    // 2=cast row (only if any), 3=tags row (only if any), 4=seasons row
    // (TV only, only if any). Up/Down step to the nearest zone that exists
    // for the current item — discover.rs owns that "which zones exist" list.
    // Replaced the earlier two-bool (in-tags/in-seasons) model once a third
    // and fourth optional zone (storyline, cast) made one flag per zone
    // stop scaling.
    in-out property <int>           request-detail-zone:          0;
    in-out property <int>           request-detail-open-gen:      0;     // stale-async-response guard
    in-out property <bool>          request-detail-requesting:    false;
    // want-4k maps to POST /request's `is4k` field — the only quality/
    // resolution knob Seerr's API exposes; there's no discrete HDR request
    // flag (that's a Radarr/Sonarr quality-profile concern, configured
    // server-side, not something a request itself specifies). Toggled from
    // the Request Options modal below, not inline on the page.
    in-out property <bool>          request-detail-want-4k:       false;
    // Radarr (movie) / Sonarr (tv) tags on the default server — best-effort,
    // silently empty if the server has none configured or the fetch fails
    // (some Seerr accounts may not have permission to read /service/*; a tag
    // picker not appearing shouldn't block the request flow either way).
    in-out property <[TagItem]>     request-detail-tags:          [];
    in-out property <int>           request-detail-focused-tag:   0;
    // Quality profiles on the same default server, same best-effort-empty
    // rules as tags. Radio-select via selected-profile-id (0 = row 0 =
    // synthetic "Default" entry, meaning "don't send profileId at all" —
    // real Radarr/Sonarr profile ids are never 0) rather than a per-row
    // bool, since exactly one (or none) can be chosen, not several.
    in-out property <[ProfileItem]> request-detail-profiles:            [];
    in-out property <int>           request-detail-focused-profile:     0;
    in-out property <int>           request-detail-selected-profile-id: 0;
    // Tags/profiles/selection for the *other* quality tier — both tiers are
    // fetched up front (SeerrClient::available_request_options_both_tiers)
    // so toggling Quality in the Request Options modal swaps these in
    // instantly (request-detail-set-quality below) rather than re-fetching
    // live, which would need its own loading state and risk a race on rapid
    // toggling. Selections (t.selected / this id) travel with whichever set
    // they belong to, so switching tiers and back preserves what was picked.
    in-out property <[TagItem]>     request-detail-tags-alt:                [];
    in-out property <[ProfileItem]> request-detail-profiles-alt:            [];
    in-out property <int>           request-detail-selected-profile-id-alt: 0;
    // Slint click handlers call this instead of setting want-4k directly,
    // so the tier swap above happens for mouse input too, not just keyboard
    // (handle_key_request_options calls the same Rust helper directly).
    callback request-detail-set-quality(bool);
    callback request-detail-toggle-season(int);
    callback request-detail-toggle-tag(int);
    callback request-detail-request;
    // Watch Trailer — see request-detail-trailer-url's own doc comment.
    // Registered in main.rs (not discover.rs), since it needs VideoState,
    // which discover::wire_discover doesn't receive — see CLAUDE.md's Seerr
    // integration section for why.
    callback play-trailer();

    // ── Request Options modal (quality/profile/tags/seasons — opened from
    // the Request button instead of showing all four inline on the page) ──
    callback open-request-options();
    in-out property <bool>          show-request-options:               false;
    // 0=Quality row (2K/4K, always), 1=Profile row (if any configured),
    // 2=tags row (if any), 3=seasons row (if any, TV only), 4=confirm row
    // (Cancel/Request, always) — same skip-absent-zones navigation idiom as
    // request-detail-zone, but a separate numbering scheme (owned by
    // existing_option_zones()/handle_key_request_options in discover.rs)
    // since it's a different, independent vertical flow inside the modal.
    in-out property <int>           request-options-zone:               0;
    in-out property <int>           request-options-confirm-focused:    1; // 0=Cancel, 1=Request

    // ── Context menu state ────────────────────────────────────────────────────
    in-out property <bool>   show-context-menu:        false;
    in-out property <string> context-menu-item-id:     "";
    in-out property <string> context-menu-title:       "";   // display name — set by every open site; queue rows use it
    in-out property <string> context-menu-item-type:   "";
    in-out property <string> context-menu-series-id:   "";   // series ID when item is an Episode; "" otherwise
    in-out property <bool>   context-menu-has-played:  false;
    in-out property <bool>   context-menu-is-favorite: false;
    in-out property <float>  context-menu-resume-pct:  0;

    // ── Add-to-playlist picker (opened from context-menu row 7, music items) ──
    in-out property <bool>       show-playlist-picker:   false;
    in-out property <[CardItem]> playlist-picker-items:  [];   // existing playlists (id, title, subtitle="N tracks")
    in-out property <int>        playlist-picker-cursor: 0;    // 0 = "+ New playlist…", 1..N = items[cursor-1]
    in-out property <bool>       playlist-picker-naming: false; // typing a new playlist name
    in-out property <string>     playlist-picker-name:   "";
    in-out property <int>    context-menu-focused:     0;   // 0=Resume (if resume-pct>0 && !played) 1=Play from Start 2=Mark Played 3=Favourite 4=View Details

    // ── Key binding editor state ──────────────────────────────────────────────
    in-out property <[KeyBindingEntry]> keybinding-normal: [];
    in-out property <[KeyBindingEntry]> keybinding-player: [];
    in-out property <int>  keybinding-focused:   -1;
    in-out property <bool> keybinding-rebinding: false;

    // ── Settings state ────────────────────────────────────────────────────────
    in-out property <bool>   settings-launch-fullscreen:    false;
    in-out property <bool>   settings-audio-spdif:          false;
    in-out property <bool>   settings-spdif-ac3:            true;
    in-out property <bool>   settings-spdif-eac3:           true;
    in-out property <bool>   settings-spdif-dts:            true;
    in-out property <bool>   settings-spdif-dts-hd:         true;
    in-out property <bool>   settings-spdif-truehd:         true;
    in-out property <string> settings-hwdec:                "auto";
    in-out property <string> settings-vf:                   "";
    in-out property <string> settings-video-sync:           "audio";
    in-out property <bool>   settings-opengl-early-flush:   false;
    in-out property <bool>   settings-video-latency-hacks:  false;
    in-out property <bool>   settings-interpolation:        false;
    in-out property <string> settings-tscale:               "oversample";
    in-out property <string> settings-tone-mapping:         "auto";
    in-out property <bool>   settings-target-colorspace-hint: false;
    in-out property <string> settings-deinterlace:          "no";
    in-out property <int>    settings-cache-mb:             0;
    in-out property <bool>   settings-video-behind:         false;
    in-out property <string> settings-log-level:            "info"; // applies on next launch, not live

    // ── Library prewarm progress (Phase 104) ──────────────────────────────────
    in-out property <bool>   prewarm-metadata-running: false;
    in-out property <int>    prewarm-metadata-total:   0;
    in-out property <int>    prewarm-metadata-done:    0;
    in-out property <string> prewarm-metadata-summary: "";
    in-out property <bool>   prewarm-image-running:    false;
    in-out property <int>    prewarm-image-total:      0;
    in-out property <int>    prewarm-image-done:       0;
    in-out property <string> prewarm-image-summary:    "";
    in-out property <bool>   settings-sub-enabled:          true;
    in-out property <string> settings-sub-lang:             "";
    in-out property <string> settings-sub-lang2:            "";
    in-out property <string> settings-sub-type:             "";
    in-out property <int>    settings-sub-scale-pct:          100;
    in-out property <int>    settings-sub-pos-pct:            100;
    in-out property <bool>   settings-sub-respect-ass-styling: true;
    in-out property <string> settings-sub-color:              "";
    in-out property <bool>   settings-sub-background:         false;
    in-out property <string>   settings-audio-lang:           "";
    in-out property <string>   settings-audio-device:          "";
    in-out property <string>   settings-audio-device-desc:     "";
    in-out property <string>   settings-audio-channels:        "auto-safe"; // mpv --audio-channels
    in-out property <bool>     settings-gapless-audio:         true; // preload next track into same mpv instance
    in-out property <bool>     settings-now-playing-auto-open: true; // pop the fullscreen Now Playing screen after ~30s idle
    in-out property <string>   settings-passthrough-device:      ""; // video output while SPDIF on ("" = same as audio output)
    in-out property <string>   settings-passthrough-device-desc: "";
    in-out property <[string]> settings-audio-device-display:  [];
    in-out property <bool>     settings-device-is-pipewire:    true;  // auto = pipewire by default
    in-out property <bool>     settings-alsa-irq-scheduling:   false;
    callback audio-device-selected(string);
    callback passthrough-device-selected(string);

    // ── Intro Skipper skip modes ("always-skip"|"ask"|"ask-timed"|"never-skip") ──
    in-out property <string> settings-skip-intro-mode:      "ask";
    in-out property <int>    settings-skip-intro-secs:       8;
    in-out property <string> settings-skip-recap-mode:      "ask";
    in-out property <int>    settings-skip-recap-secs:       8;
    in-out property <string> settings-skip-preview-mode:    "ask";
    in-out property <int>    settings-skip-preview-secs:     8;
    in-out property <string> settings-skip-commercial-mode: "ask";
    in-out property <int>    settings-skip-commercial-secs:  8;
    // Credits mode: "always-skip"|"ask"|"never-skip" (no ask-timed — banner has its own countdown)
    in-out property <string> settings-skip-credits-mode:    "ask";
    in-out property <int>    settings-skip-credits-secs:    30;

    // ── Player seek step (Settings → Player → Seeking) ───────────────────────
    in-out property <int>    settings-seek-step-secs:       10;
    in-out property <int>    settings-seek-step-long-secs:  30;

    // ── UI animation speed (Settings → UI) — ratios (1.0 = 100%, hand-tuned
    // durations unchanged), not raw percentages, so every animate block can
    // multiply its duration directly without a /100 at each of ~119 sites.
    in-out property <int>    settings-scroll-speed-pct:     100;
    in-out property <int>    settings-animation-speed-pct:  100;
    in     property <float>  settings-scroll-speed:         1.0;
    in     property <float>  settings-animation-speed:      1.0;

    // ── Text font (Settings → UI) — same dynamic-dropdown shape as the audio
    // device rows above, fetched via fc-list instead of mpv. settings-font-family
    // is the actual value MainWindow.font-family binds to ("Inter" | "" | any
    // other installed family name); settings-font-family-desc is its human-
    // readable label; settings-font-family-display is the dropdown's list.
    in-out property <string>   settings-font-family:          "Inter";
    in-out property <string>   settings-font-family-desc:     "Inter (Fjord default)";
    in-out property <[string]> settings-font-family-display:  [];
    callback font-family-selected(string);

    // ── Seerr integration (Settings → Integrations, discover.rs/seerr_auth.rs) ──
    // settings-seerr-enabled is the persisted toggle; seerr-connected +
    // seerr-connected-label are live state pushed by Rust whenever the
    // connection changes (login, disconnect, a 401 re-auth reset) — not
    // derived from settings-seerr-enabled, since "enabled" and "connected"
    // are independent (enabling doesn't connect, and a 401 can disconnect
    // without touching the enabled toggle).
    in-out property <bool>   settings-seerr-enabled: false;
    in-out property <bool>   seerr-connected:        false;
    in-out property <string> seerr-connected-label:  "Not connected";
    // Fetched async (GET /status, unauthenticated) after every successful
    // connect and again at startup if already connected — mirrors how
    // server-name/server-version are fetched fresh each session rather than
    // persisted, since it's cheap and this way it's never stale.
    in-out property <string> seerr-version:        "";
    callback open-connect-seerr;
    callback seerr-disconnect;

    // Streaming Region (Settings → Integrations, only shown when
    // seerr-connected) — same dynamic-dropdown shape as settings-font-
    // family-display above, just fetched from Seerr (GET /watchproviders/
    // regions) instead of fc-list, and only once a connection exists rather
    // than always-available at startup. settings-streaming-region-desc is
    // the current selection's display string ("Sweden (SE)"); the actual
    // ISO code lives server-side in the connected user's own Seerr
    // settings, not mirrored into a Fjord Config field — see
    // discover.rs::resolve_streaming_region, which reads it fresh (then
    // caches it) rather than trusting a locally persisted copy that could
    // drift from what's actually set on the account.
    in-out property <string>   settings-streaming-region-desc:    "";
    in-out property <[string]> settings-streaming-region-display: [];
    callback streaming-region-selected(string);

    // Trailer Quality (Settings → Integrations, only shown when
    // seerr-connected, same gate as Streaming Region) — a plain **static**
    // dropdown (unlike Streaming Region/Text font/Audio device above): the
    // option list ("Best"/"1080p"/"720p"/"480p") is fixed at compile time,
    // no async fetch needed, so this uses the generic dropdown_model/
    // current_value_str/apply_dropdown_selection path in settings.rs — same
    // shape as e.g. the Seeking rows, not a special-cased dynamic one.
    // Caps mpv's ytdl-format for Watch Trailer playback (main.rs::
    // trailer_ytdl_format); "1080p" is the default (Config.trailer_quality) —
    // display-ready values stored directly, same idiom as settings-sub-color.
    in-out property <string> settings-trailer-quality: "1080p";

    // Whether `yt-dlp` was found on PATH at startup (main.rs::
    // detect_yt_dlp) — gates the Watch Trailer button's visibility
    // alongside request-detail-trailer-url being non-empty. A pure local-
    // machine fact, independent of seerr-enabled/seerr-connected.
    in-out property <bool> yt-dlp-available: false;

    // ── ConnectSeerrScreen (connect_seerr.slint / seerr_auth.rs) ────────────
    // method: 0=API key, 1=Jellyfin login, 2=Quick Connect, 3=Local account.
    // qc-* is Quick Connect's own sub-state (code shown to the user, secret
    // threaded back on each poll tick, polling bool gates the Timer).
    in-out property <bool>   show-connect-seerr:       false;
    in-out property <int>    connect-seerr-method:     0;
    in-out property <string> connect-seerr-error:      "";
    in-out property <bool>   connect-seerr-busy:       false;
    in-out property <string> connect-seerr-qc-code:    "";
    in-out property <string> connect-seerr-qc-secret:  "";
    in-out property <bool>   connect-seerr-qc-polling: false;
    callback connect-seerr-api-key(string, string);              // url, key
    callback connect-seerr-jellyfin(string, string, string);     // url, username, password
    callback connect-seerr-local(string, string, string);        // url, email, password
    callback connect-seerr-quickconnect-start(string);           // url
    callback connect-seerr-quickconnect-poll(string, string);    // url, secret

    // ── Nav helper pure functions (used by MainWindow keyboard handler) ──────────
    public pure function section-len(s: int) -> int {
        if active-nav == 0 {
            s == 0 ? continue-watching.length :
            s == 1 ? next-up.length :
            s == 2 ? recently-added.length :
            s == 3 ? recently-added-movies.length :
                     recently-added-albums.length
        } else if active-nav == 1 {
            // TV Shows dashboard
            s == 0 ? continue-watching-tv.length :
            s == 1 ? next-up.length :
            s == 2 ? recently-added-tv.length :
            s == 3 ? not-watched-tv.length :
                     favorite-series.length
        } else if active-nav == 2 {
            // Movies dashboard
            s == 0 ? continue-watching-movies.length :
            s == 1 ? 0 :
            s == 2 ? recently-added-movies.length :
            s == 3 ? not-watched-movies.length :
                     favorite-movies.length
        } else if active-nav == 3 {
            // Collections dashboard
            s == 0 ? recently-added-collections.length :
            s == 1 ? unwatched-collections.length :
                     0
        } else if active-nav == 4 {
            // Music dashboard
            s == 0 ? recently-added-albums.length :
            s == 1 ? recently-played-albums.length :
            s == 2 ? favorite-albums.length :
            s == 3 ? music-playlists.length :
                     0
        } else {
            0
        }
    }

    public pure function find-first-section() -> int {
        if section-len(0) > 0 { return 0; }
        if section-len(1) > 0 { return 1; }
        if section-len(2) > 0 { return 2; }
        if section-len(3) > 0 { return 3; }
        if section-len(4) > 0 { return 4; }
        return 0;
    }

    public pure function find-next-section(from: int) -> int {
        if from + 1 <= 4 && section-len(from + 1) > 0 { return from + 1; }
        if from + 2 <= 4 && section-len(from + 2) > 0 { return from + 2; }
        if from + 3 <= 4 && section-len(from + 3) > 0 { return from + 3; }
        if from + 4 <= 4 && section-len(from + 4) > 0 { return from + 4; }
        return from;
    }

    public pure function find-prev-section(from: int) -> int {
        if from - 1 >= 0 && section-len(from - 1) > 0 { return from - 1; }
        if from - 2 >= 0 && section-len(from - 2) > 0 { return from - 2; }
        if from - 3 >= 0 && section-len(from - 3) > 0 { return from - 3; }
        if from - 4 >= 0 && section-len(from - 4) > 0 { return from - 4; }
        return -1;
    }

    public pure function section-card-id(s: int, c: int) -> string {
        if active-nav == 0 {
            s == 0 ? continue-watching[c].id :
            s == 1 ? next-up[c].id :
            s == 2 ? recently-added[c].id :
            s == 3 ? recently-added-movies[c].id :
                     recently-added-albums[c].id
        } else if active-nav == 1 {
            // TV Shows
            s == 0 ? continue-watching-tv[c].id :
            s == 1 ? next-up[c].id :
            s == 2 ? recently-added-tv[c].id :
            s == 3 ? not-watched-tv[c].id :
                     favorite-series[c].id
        } else if active-nav == 2 {
            // Movies
            s == 0 ? continue-watching-movies[c].id :
            s == 2 ? recently-added-movies[c].id :
            s == 3 ? not-watched-movies[c].id :
                     favorite-movies[c].id
        } else if active-nav == 3 {
            // Collections dashboard
            s == 0 ? recently-added-collections[c].id :
                     unwatched-collections[c].id
        } else if active-nav == 4 {
            // Music dashboard
            s == 0 ? recently-added-albums[c].id :
            s == 1 ? recently-played-albums[c].id :
            s == 2 ? favorite-albums[c].id :
                     music-playlists[c].id
        } else {
            ""
        }
    }

    public pure function section-card-item(s: int, c: int) -> CardItem {
        if active-nav == 0 {
            s == 0 ? continue-watching[c] :
            s == 1 ? next-up[c] :
            s == 2 ? recently-added[c] :
            s == 3 ? recently-added-movies[c] :
                     recently-added-albums[c]
        } else if active-nav == 1 {
            // TV Shows
            s == 0 ? continue-watching-tv[c] :
            s == 1 ? next-up[c] :
            s == 2 ? recently-added-tv[c] :
            s == 3 ? not-watched-tv[c] :
                     favorite-series[c]
        } else if active-nav == 2 {
            // Movies
            s == 0 ? continue-watching-movies[c] :
            s == 2 ? recently-added-movies[c] :
            s == 3 ? not-watched-movies[c] :
                     favorite-movies[c]
        } else if active-nav == 3 {
            // Collections dashboard
            s == 0 ? recently-added-collections[c] :
                     unwatched-collections[c]
        } else if active-nav == 4 {
            // Music dashboard
            s == 0 ? recently-added-albums[c] :
            s == 1 ? recently-played-albums[c] :
            s == 2 ? favorite-albums[c] :
                     music-playlists[c]
        } else {
            { id: "", title: "", year: 0, item_type: "", poster: @image-url(""),
              has_played: false, resume_pct: 0, unplayed_count: 0, is_favorite: false, series_id: "" }
        }
    }

    // ── Callbacks — auth / nav ────────────────────────────────────────────────
    callback do-login(string, string, string);
    callback sign-out;
    callback prewarm-metadata;
    callback prewarm-images;
    callback nav-selected(int);
    callback toggle-fullscreen;
    callback quit;
    callback refocus; // re-grab keyboard focus after mouse interaction steals it

    // ── Callbacks — browse / library ──────────────────────────────────────────
    callback play-item(int);
    callback filter-changed(string);
    callback browse-search-append(string);
    callback browse-search-backspace();
    callback browse-search-clear();
    callback library-search-append(string);
    callback library-search-backspace();
    callback library-search-clear();
    callback open-library(int);
    callback library-sort-apply(int, bool, bool);  // sort-idx, filter-unwatched, filter-favorites
    callback library-jump-to-letter(int);          // 0=A..25=Z, 26=#
    callback library-grid-scrolled(int);           // top-card index → update scrubber cursor
    callback library-music-view-changed(int);      // 0=Artists 1=Albums 2=Playlists
    callback playlist-remove-entry(int);           // track row index → remove entry from open playlist
    callback open-playlist-picker();               // context-menu "Add to Playlist" → Rust populates + shows picker
    callback playlist-picker-select(int);          // picker items index → add target item to that playlist
    callback playlist-picker-create();             // create playlist named playlist-picker-name with target item

    // ── Callbacks — item play / detail / series ───────────────────────────────
    callback item-play(string);
    callback open-detail(/* id */ string, /* item-type */ string);
    callback play-detail;
    callback resume-detail;
    callback close-detail;
    callback open-collection(/* id */ string, /* title */ string);
    callback open-album(/* id */ string, /* title */ string);
    callback play-album-track(/* track-id */ string);
    callback close-album;
    callback toggle-album-fav;
    callback toggle-album-played;
    callback open-artist(/* id */ string, /* title */ string);
    callback close-artist;
    callback open-series(string);
    callback series-select-season(int);
    callback play-series-episode(string);
    callback close-series;
    callback open-season-detail(/* season-id */ string, /* series-id */ string);
    callback close-season-detail();
    callback open-person(/* id */ string, /* name */ string);
    callback close-person;
    callback toggle-detail-fav;
    callback toggle-detail-played;
    callback toggle-series-fav;
    callback toggle-series-played;
    callback toggle-collection-fav;
    callback toggle-collection-played;

    // ── Callbacks — player controls ───────────────────────────────────────────
    callback pause-play-toggle;
    callback seek-backward;
    callback seek-forward;
    callback seek-backward-long;
    callback seek-forward-long;
    callback seek-acc(float);   // keyboard seek accumulation: +secs=forward, -secs=backward; debounced
    callback stop-playback;
    callback seek-to(float);
    callback seek-drag-started();                               // first mouse-move of a drag; Rust pauses mpv during scrub
    callback seek-committed(float);                             // fires on mouse-up after drag; seeks + resumes mpv
    callback select-sub(int);
    callback select-audio(int);
    callback select-video(int);
    callback commit-panel-selection;
    callback mute-toggle;
    callback volume-up;
    callback volume-down;
    callback show-controls;
    callback toggle-stats;
    callback minimize-player;
    callback resume-player;

    // ── Queue ─────────────────────────────────────────────────────────────────
    in-out property <int>          queue-count:       0;     // upcoming: playlist tracks after current + queued items (set by push_queue_display)
    in-out property <int>          queue-repeat-mode: 0;     // 0=Off 1=All 2=One
    in-out property <bool>         queue-shuffle:     false; // shuffle active
    in-out property <bool>         show-queue-panel:  false; // queue panel overlay visible
    in-out property <int>          queue-panel-cursor: 0;    // focused row in queue panel
    in-out property <[QueueEntry]> queue-items:        [];   // Rust pushes after every mutation
    callback queue-add-item();               // add focused context-menu item to back of queue
    callback queue-play-next-item();         // insert after current in playlist / front of queue
    callback queue-prev-track();             // prev track (or restart if pos ≥ 2 s)
    callback queue-next-track();             // next track (respects shuffle/repeat)
    callback toggle-shuffle();               // flip shuffle on/off; re-seeds shuffle-order
    callback cycle-repeat();                 // cycle Off → All → One → Off
    callback queue-jump(int);               // jump to playlist index → start_playback
    callback queue-remove(int);             // splice item from playlist
    callback queue-clear();                 // clear playlist + queue
    callback refresh-queue-display();       // Rust rebuilds queue-items from VideoState
    callback open-queue-panel();            // mouse entry point (music-bar ⋮︎): refresh + focus grab, mirrors 'q'

    // ── Lyrics (Phase 52) ─────────────────────────────────────────────────────
    in-out property <bool>          show-lyrics:      false; // lyrics overlay visible
    in-out property <bool>          lyrics-available: false; // server returned lyric data
    in-out property <[LyricEntry]>  lyrics-lines:     [];   // populated by Rust from get_lyrics
    in-out property <int>           lyrics-active-idx: -1;  // currently-playing line (-1 = none)
    callback toggle-lyrics();                               // 9/♪︎ button or L key

    // ── Callbacks — context menu ──────────────────────────────────────────────
    callback open-context-menu(string, bool, bool, float, string, string); // id, played, fav, resume-pct, item-type, series-id
    callback open-context-menu-browse(int);                              // browse list index → Rust resolves
    callback open-context-menu-series-ep(string, bool, bool, float, string); // ep id, played, fav, resume-pct, series-id
    callback context-mark-played(string, bool);       // id, currently-played → Rust toggles
    callback context-toggle-fav(string, bool);        // id, currently-favorite → Rust toggles
    callback context-play-from-start(string);

    // ── Callbacks — misc overlays ─────────────────────────────────────────────
    callback cancel-auto-advance;
    callback play-next-ep;
    callback skip-segment;
    callback settings-changed;
    callback dropdown-pick; // mouse click on keyboard overlay item; cursor already set

    // ── Key dispatch ──────────────────────────────────────────────────────────
    // Called by the FocusScope key-pressed handler; Rust returns true → accept,
    // false → reject.  Replaces the 670-line Slint keyboard handler.
    callback handle-key(/* text */ string, /* shift */ bool, /* ctrl */ bool, /* repeat */ bool) -> bool;

    // Resets keybindings to compiled-in defaults and saves to keybindings.json.
    callback keybinding-reset-defaults();
}
