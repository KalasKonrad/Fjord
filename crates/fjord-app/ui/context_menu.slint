// ── fjord-app · context_menu.slint ───────────────────────────────────────────
//   ContextMenu     overlay: Resume (if resume-pct > 0), Play from Start,
//                            Play Next, Add to Queue,
//                            Mark Played/Unplayed, Favourite/Unfavourite, View Details,
//                            Add to Playlist (row 7, Audio/MusicAlbum only)
//                   triggered by C key or right-click on any card
//                   keyboard: Up/Down loop; Enter confirms; Esc closes
//   PlaylistPicker  add-to-playlist modal: ＋ New playlist… (name input) + playlist list;
//                   cursor 0 = new row, 1..N = items; keyboard in keys.rs handle_playlist_picker
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { PressPulse } from "widgets.slint";

export component ContextMenu inherits Rectangle {
    background: #00000088;

    // Close on backdrop click
    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { AppState.show-context-menu = false; }
    }

    // Menu box — centred
    Rectangle {
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        width:         240px;
        height:        menu-layout.preferred-height + 16px;
        border-radius: Theme.radius-lg;
        background:    Theme.surface-raised;
        border-width:  1px;
        border-color:  Theme.border-strong;
        drop-shadow-blur:     20px;
        drop-shadow-color:    #000000aa;
        drop-shadow-offset-y: 6px;

        // Stop backdrop click from propagating through the box
        TouchArea { width: parent.width; height: parent.height; }

        menu-layout := VerticalLayout {
            x: 0; y: 8px;
            width: parent.width;
            spacing: 2px;
            padding-left:  8px;
            padding-right: 8px;

            // Row 0 — Resume (only when there is a saved position)
            if AppState.context-menu-resume-pct > 0 && !AppState.context-menu-has-played: Rectangle {
                height: 44px;
                border-radius: Theme.radius;
                background: AppState.context-menu-focused == 0 ? Theme.accent-muted : transparent;
                border-width:  (ta0.pressed || pulse0.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                pulse0 := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.context-menu-focused == 0; }
                HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 10px;
                    alignment: start;
                    Text {
                        text: "⏵";
                        color: AppState.context-menu-focused == 0 ? Theme.accent : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center; width: 18px;
                    }
                    Text {
                        text: "Resume";
                        color: AppState.context-menu-focused == 0 ? Theme.text : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center;
                    }
                }
                ta0 := TouchArea {
                    clicked => {
                        AppState.item-play(AppState.context-menu-item-id);
                        AppState.show-context-menu = false;
                    }
                    pointer-event(e) => {
                        if e.kind == PointerEventKind.move { AppState.context-menu-focused = 0; }
                    }
                }
            }

            // Row 1 — Play from Start
            Rectangle {
                height: 44px;
                border-radius: Theme.radius;
                background: AppState.context-menu-focused == 1 ? Theme.accent-muted : transparent;
                border-width:  (ta1.pressed || pulse1.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                pulse1 := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.context-menu-focused == 1; }
                HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 10px;
                    alignment: start;
                    Text {
                        text: "▶";
                        color: AppState.context-menu-focused == 1 ? Theme.accent : Theme.text-muted;
                        font-size: 12px; vertical-alignment: center; width: 18px;
                    }
                    Text {
                        text: "Play from Start";
                        color: AppState.context-menu-focused == 1 ? Theme.text : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center;
                    }
                }
                ta1 := TouchArea {
                    clicked => {
                        AppState.context-play-from-start(AppState.context-menu-item-id);
                        AppState.show-context-menu = false;
                    }
                    pointer-event(e) => {
                        if e.kind == PointerEventKind.move { AppState.context-menu-focused = 1; }
                    }
                }
            }

            // Row 2 — Play Next (insert at front of queue)
            Rectangle {
                height: 44px;
                border-radius: Theme.radius;
                background: AppState.context-menu-focused == 2 ? Theme.accent-muted : transparent;
                border-width:  (ta2.pressed || pulse2.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                pulse2 := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.context-menu-focused == 2; }
                HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 10px;
                    alignment: start;
                    Text {
                        text: "⏭";
                        color: AppState.context-menu-focused == 2 ? Theme.accent : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center; width: 18px;
                    }
                    Text {
                        text: "Play Next";
                        color: AppState.context-menu-focused == 2 ? Theme.text : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center;
                    }
                }
                ta2 := TouchArea {
                    clicked => {
                        AppState.queue-play-next-item();
                        AppState.show-context-menu = false;
                    }
                    pointer-event(e) => {
                        if e.kind == PointerEventKind.move { AppState.context-menu-focused = 2; }
                    }
                }
            }

            // Row 3 — Add to Queue (append to back)
            Rectangle {
                height: 44px;
                border-radius: Theme.radius;
                background: AppState.context-menu-focused == 3 ? Theme.accent-muted : transparent;
                border-width:  (ta3.pressed || pulse3.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                pulse3 := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.context-menu-focused == 3; }
                HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 10px;
                    alignment: start;
                    Text {
                        text: "＋";
                        color: AppState.context-menu-focused == 3 ? Theme.accent : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center; width: 18px;
                    }
                    Text {
                        text: "Add to Queue";
                        color: AppState.context-menu-focused == 3 ? Theme.text : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center;
                    }
                }
                ta3 := TouchArea {
                    clicked => {
                        AppState.queue-add-item();
                        AppState.show-context-menu = false;
                    }
                    pointer-event(e) => {
                        if e.kind == PointerEventKind.move { AppState.context-menu-focused = 3; }
                    }
                }
            }

            // Row 4 — Mark Played / Unplayed
            Rectangle {
                height: 44px;
                border-radius: Theme.radius;
                background: AppState.context-menu-focused == 4 ? Theme.accent-muted : transparent;
                border-width:  (ta4.pressed || pulse4.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                pulse4 := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.context-menu-focused == 4; }
                HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 10px;
                    alignment: start;
                    Text {
                        text: AppState.context-menu-has-played ? "✓" : "○";
                        color: AppState.context-menu-focused == 4 ? Theme.accent : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center; width: 18px;
                    }
                    Text {
                        text: AppState.context-menu-has-played ? "Mark as Unplayed" : "Mark as Played";
                        color: AppState.context-menu-focused == 4 ? Theme.text : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center;
                    }
                }
                ta4 := TouchArea {
                    clicked => {
                        AppState.context-mark-played(AppState.context-menu-item-id, AppState.context-menu-has-played);
                        AppState.show-context-menu = false;
                    }
                    pointer-event(e) => {
                        if e.kind == PointerEventKind.move { AppState.context-menu-focused = 4; }
                    }
                }
            }

            // Row 5 — Favourite / Unfavourite
            Rectangle {
                height: 44px;
                border-radius: Theme.radius;
                background: AppState.context-menu-focused == 5 ? Theme.accent-muted : transparent;
                border-width:  (ta5.pressed || pulse5.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                pulse5 := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.context-menu-focused == 5; }
                HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 10px;
                    alignment: start;
                    Text {
                        text: AppState.context-menu-is-favorite ? "♥" : "♡";
                        color: AppState.context-menu-focused == 5 ? Theme.accent : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center; width: 18px;
                    }
                    Text {
                        text: AppState.context-menu-is-favorite ? "Remove from Favourites" : "Add to Favourites";
                        color: AppState.context-menu-focused == 5 ? Theme.text : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center;
                    }
                }
                ta5 := TouchArea {
                    clicked => {
                        AppState.context-toggle-fav(AppState.context-menu-item-id, AppState.context-menu-is-favorite);
                        AppState.show-context-menu = false;
                    }
                    pointer-event(e) => {
                        if e.kind == PointerEventKind.move { AppState.context-menu-focused = 5; }
                    }
                }
            }

            // Row 6 — View Details
            Rectangle {
                height: 44px;
                border-radius: Theme.radius;
                background: AppState.context-menu-focused == 6 ? Theme.accent-muted : transparent;
                border-width:  (ta6.pressed || pulse6.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                pulse6 := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.context-menu-focused == 6; }
                HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 10px;
                    alignment: start;
                    Text {
                        text: "ℹ";
                        color: AppState.context-menu-focused == 6 ? Theme.accent : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center; width: 18px;
                    }
                    Text {
                        text: "View Details";
                        color: AppState.context-menu-focused == 6 ? Theme.text : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center;
                    }
                }
                ta6 := TouchArea {
                    clicked => {
                        AppState.open-detail(AppState.context-menu-item-id, AppState.context-menu-item-type);
                        AppState.show-context-menu = false;
                    }
                    pointer-event(e) => {
                        if e.kind == PointerEventKind.move { AppState.context-menu-focused = 6; }
                    }
                }
            }

            // Row 7 — Add to Playlist (music items only)
            if AppState.context-menu-item-type == "Audio" || AppState.context-menu-item-type == "MusicAlbum": Rectangle {
                height: 44px;
                border-radius: Theme.radius;
                background: AppState.context-menu-focused == 7 ? Theme.accent-muted : transparent;
                border-width:  (ta7.pressed || pulse7.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                pulse7 := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.context-menu-focused == 7; }
                HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 10px;
                    alignment: start;
                    Text {
                        text: "≡";
                        color: AppState.context-menu-focused == 7 ? Theme.accent : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center; width: 18px;
                    }
                    Text {
                        text: "Add to Playlist";
                        color: AppState.context-menu-focused == 7 ? Theme.text : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center;
                    }
                }
                ta7 := TouchArea {
                    clicked => {
                        AppState.open-playlist-picker();
                        AppState.show-context-menu = false;
                    }
                    pointer-event(e) => {
                        if e.kind == PointerEventKind.move { AppState.context-menu-focused = 7; }
                    }
                }
            }
        }
    }
}

// ── PlaylistPicker ────────────────────────────────────────────────────────────
// "Add to Playlist" modal: row 0 = ＋ New playlist… (turns into a name input),
// then the existing audio playlists. Cursor semantics: 0 = new row,
// 1..N = playlist-picker-items[cursor-1]. Keyboard handled in keys.rs
// (handle_playlist_picker); mouse clicks rows directly.
export component PlaylistPicker inherits Rectangle {
    background: #00000088;

    // Close on backdrop click
    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { AppState.show-playlist-picker = false; }
    }

    Rectangle {
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        width:         320px;
        height:        head-h + new-h + 1px + list-h + 16px;
        border-radius: Theme.radius-lg;
        background:    Theme.surface-raised;
        border-width:  1px;
        border-color:  Theme.border-strong;
        drop-shadow-blur:     20px;
        drop-shadow-color:    #000000aa;
        drop-shadow-offset-y: 6px;

        property <length> head-h: 30px;
        property <length> new-h:  44px;
        property <length> row-h:  48px;
        property <length> list-h: min(5 * row-h, AppState.playlist-picker-items.length * row-h);
        // Keep the cursor row visible (kb-y pattern — no viewport-y binding).
        property <length> kb-y: clamp(
            -(AppState.playlist-picker-cursor - 1) * row-h + list-h / 2 - row-h / 2,
            min(0px, list-h - AppState.playlist-picker-items.length * row-h),
            0px);
        changed kb-y => { fl.viewport-y = self.kb-y; }

        // Stop backdrop click from propagating through the box
        TouchArea { width: parent.width; height: parent.height; }

        VerticalLayout {
            x: 0; y: 8px;
            width: parent.width;
            padding-left:  8px;
            padding-right: 8px;

            Text {
                text:               "ADD TO PLAYLIST";
                color:              Theme.text-muted;
                font-size:          11px;
                height:             head-h;
                vertical-alignment: center;
                horizontal-alignment: center;
            }

            // Row 0 — ＋ New playlist… / name input
            Rectangle {
                height:        new-h;
                border-radius: Theme.radius;
                background:    AppState.playlist-picker-cursor == 0 ? Theme.accent-muted : (new-ta.has-hover ? Theme.surface : transparent);
                border-width:  (new-ta.pressed || new-pulse.pulsing) ? 3px : 0px;
                border-color:  Theme.accent;
                animate border-width { duration: 90ms; easing: ease-out; }
                new-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.playlist-picker-cursor == 0; }
                if !AppState.playlist-picker-naming: HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 10px;
                    alignment: start;
                    Text {
                        text: "＋";
                        color: AppState.playlist-picker-cursor == 0 ? Theme.accent : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center; width: 18px;
                    }
                    Text {
                        text: "New playlist…";
                        color: AppState.playlist-picker-cursor == 0 ? Theme.text : Theme.text-muted;
                        font-size: 14px; vertical-alignment: center;
                    }
                }
                if AppState.playlist-picker-naming: HorizontalLayout {
                    padding-left: 12px; padding-right: 12px; spacing: 8px;
                    alignment: start;
                    Text {
                        text: "Name:";
                        color: Theme.text-muted;
                        font-size: 13px; vertical-alignment: center;
                    }
                    Text {
                        text: AppState.playlist-picker-name + "▎";
                        color: Theme.text;
                        font-size: 14px; vertical-alignment: center;
                        overflow: elide;
                    }
                }
                new-ta := TouchArea {
                    clicked => {
                        AppState.playlist-picker-cursor = 0;
                        if !AppState.playlist-picker-naming {
                            AppState.playlist-picker-name   = "";
                            AppState.playlist-picker-naming = true;
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }

            fl := Flickable {
                height:          list-h;
                viewport-height: AppState.playlist-picker-items.length * row-h;
                VerticalLayout {
                    alignment: start;
                    for p[i] in AppState.playlist-picker-items: Rectangle {
                        height:        row-h;
                        border-radius: Theme.radius;
                        background:    AppState.playlist-picker-cursor == i + 1 ? Theme.accent-muted : (p-ta.has-hover ? Theme.surface : transparent);
                        border-width:  (p-ta.pressed || p-pulse.pulsing) ? 3px : 0px;
                        border-color:  Theme.accent;
                        animate border-width { duration: 90ms; easing: ease-out; }
                        p-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.playlist-picker-cursor == i + 1; }
                        p-ta := TouchArea {
                            clicked => { AppState.playlist-picker-select(i); }
                        }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px;
                            VerticalLayout {
                                alignment: center;
                                spacing:   2px;
                                Text {
                                    text:      p.title;
                                    color:     AppState.playlist-picker-cursor == i + 1 ? Theme.text : Theme.text-muted;
                                    font-size: 14px;
                                    overflow:  elide;
                                }
                                if p.subtitle != "": Text {
                                    text:      p.subtitle;
                                    color:     Theme.text-subtle;
                                    font-size: 11px;
                                    overflow:  elide;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
