// ── fjord-app · main.slint ───────────────────────────────────────────────────
//   MainWindow    window root: sync-layout, auto-advance banner, FocusScope
//   keyboard handler  single AppState.handle-key() callback → Rust keys.rs
//   bar layout    bottom of window: MusicPlayerBar (72px, is-audio-playing) stacked above
//                 MiniPlayerBar (108/56px, has-background-player && !is-playing);
//                 total-bar-h = music-bar-h + bar-h; content fills y=0 height=parent.height-total-bar-h
//   screen slots  ConnectingScreen / OfflineScreen (startup connectivity gate, checked
//                 before show-login) / LoginScreen, AppShell + HomeScreen / DashboardScreen /
//                 MusicDashboard / CollectionsDashboard / LibraryGrid (nav=1,2,3,4 with show-library) /
//                 DiscoverScreen (nav=6, Seerr, hidden unless settings-seerr-enabled)
//                 nav: 0=Home, 1=TV Shows, 2=Movies, 3=Collections, 4=Music, 5=Browse All, 6=Discover
//   overlay z-order (bottom→top)  SeriesScreen, SeasonScreen, ArtistScreen, CollectionScreen, AlbumScreen,
//                                  DetailPage, RequestDetailScreen (Seerr), PersonScreen, ContextMenu;
//                                  ConnectSeerrScreen (Seerr) layers above PlaylistPicker, below nothing else
//   video-behind-UI layer  above AppShell, only when overlay screen is open
//   loading overlay   semi-transparent #000000c0 + LoadingSpinner while app-content-loading
//   toast overlay     bottom-center error pill; auto-dismissed after 4 s by toast-timer
//   PersonScreen overlay (above Detail/Season/Series/Artist/Collection/Album; below ContextMenu)
//   QueuePanel overlay (above ContextMenu, shown when AppState.show-queue-panel)
//   LyricsView overlay (above QueuePanel, shown when show-lyrics && is-audio-playing && !show-now-playing —
//                       suppressed during Now Playing, which already embeds its own lyrics panel, CR11-8)
//   NowPlayingScreen fullscreen music view (below ContextMenu/QueuePanel/LyricsView, shown when show-now-playing && is-audio-playing)
//   ContextMenu overlay (shown when AppState.show-context-menu)
//   screen-change fade  two different mechanisms, split by whether the site is inside a
//                       shared Layout or free-floating:
//                       - FadeGate (widgets.slint), fade BOTH in and out — every free-floating
//                         direct child of MainWindow with no enclosing Layout
//                         (ConnectingScreen/OfflineScreen/LoginScreen, all 7 overlay
//                         screens series/season/artist/collection/album/detail/person, now
//                         playing, context menu, playlist picker, queue panel, lyrics,
//                         volume overlay, toast, the Up Next banner, plus Seerr's
//                         ConnectSeerrScreen and RequestDetailScreen): `gateN := FadeGate {
//                         show: <condition>; }` declared as an always-present sibling, gating
//                         `if gateN.mounted: X { opacity: gateN.fade-opacity; animate opacity
//                         {...} }` — FadeGate keeps `mounted` true for one fade-out's worth of
//                         time after `show` goes false, so Back/switching-away plays a real
//                         fade instead of Slint's `if` destroying the element the instant the
//                         condition flips.
//                       - FadeInTrigger (widgets.slint), fade IN ONLY — the AppShell
//                         `@children` sites (BrowseScreen, HomeScreen, 2×DashboardScreen,
//                         4×LibraryGrid, CollectionsDashboard, MusicDashboard,
//                         SettingsScreen, DiscoverScreen). AppShell `inherits HorizontalLayout`
//                         (layout.slint) and each of these gets `horizontal-stretch: 1` in
//                         that same content slot, which assumes exactly one is mounted at a
//                         time. FadeGate was tried here first (2026-07-13) and broke every
//                         dashboard/library switch: for the fade-out window, BOTH the
//                         outgoing and incoming screen were mounted simultaneously, and the
//                         HorizontalLayout split/squeezed space between the two
//                         horizontal-stretch:1 siblings instead of giving the whole content
//                         area to one. Reverted same day to instant-unmount + entrance-only
//                         fade, which is what a shared-layout slot requires — the two
//                         conditions must stay genuinely mutually exclusive at every instant,
//                         not just eventually.
//                       Both scale with settings-animation-speed.
//                       PlayerScreen and the two docked bars (MiniPlayerBar/
//                       MusicPlayerBar) are deliberately excluded — video start latency is
//                       too perception-sensitive, and the bars share total-bar-h with the
//                       content area's height so fading their opacity alone (without also
//                       delaying the resulting layout shift) would look like a gap
//   bundled fonts   NotoSansSymbols2-Regular.ttf + NotoSansMath-Regular.ttf (Apache-2.0,
//                   assets/fonts/) imported here purely for their compile-time side effect —
//                   Slint registers every `import "*.ttf"` found anywhere in the project as a
//                   glyph-coverage fallback for the whole app, no font-family binding needed
//                   anywhere else. Added because many of the Unicode symbol glyphs used
//                   throughout the UI (⏮︎⏭︎⋮︎🔉︎🔊︎ and others) aren't covered by every system's
//                   default font stack — confirmed live on the HTPC, which was missing them
//                   while the dev machine's fuller desktop font set happened to cover them,
//                   exactly the kind of system-dependent inconsistency this eliminates.
//                   Inter-Regular/Bold.ttf (OFL-1.1) + AdwaitaSans-Regular.ttf (OFL-1.1) are
//                   bundled the same way: Inter is Fjord's own designed-around default body
//                   font (`MainWindow.font-family`, Settings → UI → Text font can override it
//                   with any font installed on the host); Adwaita Sans supplies ♥/✓ specifically
//                   (IconCircleButton, widgets.slint) — hard-pinned regardless of which text
//                   font is active, since several candidate fonts turned out to have their own
//                   competing glyphs for common icons (confirmed via a live font-comparison
//                   pass), which would otherwise make icon appearance depend on font choice.
// ─────────────────────────────────────────────────────────────────────────────
import "../../../assets/fonts/NotoSansSymbols2-Regular.ttf";
import "../../../assets/fonts/NotoSansMath-Regular.ttf";
import "../../../assets/fonts/Inter-Regular.ttf";
import "../../../assets/fonts/Inter-Bold.ttf";
import "../../../assets/fonts/AdwaitaSans-Regular.ttf";
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, LoadingSpinner, MiniPlayerBar, MusicPlayerBar, ToastNotification, QueuePanel, LyricsView, VolumeOverlay, FadeGate, FadeInTrigger } from "widgets.slint";
import { NowPlayingScreen } from "now_playing.slint";
import { SectionRow, LibraryGrid, HomeScreen, DashboardScreen, MusicDashboard, CollectionsDashboard } from "home.slint";
import { BrowseScreen } from "browse.slint";
import { SettingsScreen } from "settings.slint";
import { LoginScreen } from "login.slint";
import { ConnectingScreen, OfflineScreen } from "connect.slint";
import { PlayerScreen } from "player.slint";
import { SeriesScreen } from "series.slint";
import { SeasonScreen } from "season.slint";
import { DetailPage } from "detail.slint";
import { AppShell } from "layout.slint";
import { PersonScreen } from "person.slint";
import { ContextMenu, PlaylistPicker } from "context_menu.slint";
import { CollectionScreen } from "collection.slint";
import { AlbumScreen } from "album.slint";
import { ArtistScreen } from "artist.slint";
import { ConnectSeerrScreen } from "connect_seerr.slint";
import { DiscoverScreen } from "discover.slint";
import { RequestDetailScreen } from "request_detail.slint";

export { AppState }

export component MainWindow inherits Window {
    title:            "FJORD";
    background:       Theme.bg;
    // Settings → UI → Text font. `default-font-family` (not `font-family` —
    // Window doesn't expose that one) is Slint's purpose-built window-wide
    // default: every Text element without its own explicit font-family uses
    // this, while the icon Text elements throughout the app (hard-pinned to
    // Adwaita Sans / Noto Sans Symbols2, see widgets.slint's IconCircleButton/
    // FjordButton) keep their own more-specific binding regardless. Set
    // synchronously from Config at launch — see apply_settings_to_window in
    // main.rs — so this never renders blank or with a placeholder font on
    // the first frame.
    default-font-family: AppState.settings-font-family;
    min-width:        900px;
    min-height:       520px;
    preferred-width:  1280px;
    preferred-height: 720px;

    callback grab-keyboard-focus;
    grab-keyboard-focus => { fs.focus(); }

    pure function grid-cols() -> int {
        if self.width < 852px  { return 3; }
        if self.width < 1011px { return 4; }
        if self.width < 1170px { return 5; }
        if self.width < 1329px { return 6; }
        if self.width < 1488px { return 7; }
        if self.width < 1647px { return 8; }
        if self.width < 1806px { return 9; }
        return 10;
    }
    pure function dash-card-w() -> length {
        if self.width < 900px  { return 115px; }
        if self.width < 1300px { return 140px; }
        if self.width < 1700px { return 165px; }
        return 190px;
    }
    pure function dash-card-h() -> length {
        if self.width < 900px  { return 184px; }
        if self.width < 1300px { return 224px; }
        if self.width < 1700px { return 264px; }
        return 304px;
    }

    function sync-layout() {
        AppState.library-cols = self.grid-cols();
        AppState.dash-cw      = self.dash-card-w();
        AppState.dash-ch      = self.dash-card-h();
    }
    init => { self.sync-layout(); }
    changed width => { self.sync-layout(); }

    // Auto-advance countdown banner — only shown outside the fullscreen player
    // (player.slint has its own banner with Play Now + Skip buttons).
    gate29 := FadeGate { show: AppState.show-next-ep-banner && !AppState.is-playing; }
    if gate29.mounted: Rectangle {
        x:             root.width  - 300px - 20px;
        y:             root.height - 110px - 20px;
        width:         300px;
        height:        110px;
        border-radius: Theme.radius-lg;
        background:    Theme.surface;
        border-width:  1px;
        border-color:  Theme.border-strong;
        drop-shadow-blur:     12px;
        drop-shadow-color:    #00000066;
        drop-shadow-offset-y: 4px;
        opacity: gate29.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; }

        VerticalLayout {
            padding: 14px;
            spacing:  8px;

            Text { text: "Up Next in \{AppState.next-ep-secs}s"; color: Theme.text-muted; font-size: 11px; }
            Text { text: AppState.next-ep-title; color: Theme.text; font-size: 13px; font-weight: 600; overflow: elide; }
            HorizontalLayout {
                alignment: end;
                FjordButton { text: "Cancel"; width: 70px; clicked => { AppState.cancel-auto-advance(); } }
            }
        }
    }

    fs := FocusScope {
        width: 0; height: 0;
        key-pressed(event) => {
            AppState.handle-key(event.text, event.modifiers.shift, event.modifiers.control, event.repeat) ? accept : reject
        }
    }

    // Height reserved for bars at the bottom (0 when not active or player is open)
    property <length> bar-h:       (AppState.has-background-player && !AppState.is-playing)
        ? (AppState.video-behind-ui ? 56px : 108px) : 0px;
    property <length> music-bar-h: AppState.is-audio-playing ? 72px : 0px;
    property <length> total-bar-h: bar-h + music-bar-h;

    // Video-behind-UI — TWO layers:
    //   Layer 1 (here, z=1): always shown below AppShell; content screens have transparent roots
    //     so the video peeks through gaps between cards on the dashboard/library.
    //   Layer 2 (after AppShell, z=3): only when an overlay screen is open; covers AppShell so
    //     the library/dashboard card elements don't ghost through the transparent overlay roots.
    if AppState.video-behind-ui && AppState.has-background-player && !AppState.is-playing: Rectangle {
        y:          0;
        height:     parent.height - total-bar-h;
        background: #000000;
        Image { source: AppState.video-frame; width: parent.width; height: parent.height; image-fit: contain; }
        Rectangle { background: #00000044; }
    }

    gate1 := FadeGate { show: AppState.show-connecting; }
    if gate1.mounted: ConnectingScreen { opacity: gate1.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }
    gate2 := FadeGate { show: AppState.show-offline; }
    if gate2.mounted: OfflineScreen { opacity: gate2.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }
    gate3 := FadeGate { show: !AppState.show-connecting && !AppState.show-offline && AppState.show-login; }
    if gate3.mounted: LoginScreen { opacity: gate3.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }

    if !AppState.show-connecting && !AppState.show-offline && !AppState.show-login: AppShell {
        y:      0;
        height: parent.height - total-bar-h;
        if AppState.show-browse: BrowseScreen {
            horizontal-stretch: 1;
            opacity: fade4.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade4 := FadeInTrigger { }
        }

        if !AppState.show-browse && AppState.active-nav == 0: HomeScreen {
            horizontal-stretch:      1;
            continue-watching:       AppState.continue-watching;
            next-up:                 AppState.next-up;
            recently-added:          AppState.recently-added;
            recently-added-movies:   AppState.recently-added-movies;
            recently-added-albums:   AppState.recently-added-albums;
            opacity: fade5.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade5 := FadeInTrigger { }
        }
        if !AppState.show-browse && AppState.active-nav == 1 && !AppState.show-library: DashboardScreen {
            horizontal-stretch: 1; screen-title: "TV Shows";
            continue-watching:  AppState.continue-watching-tv;
            next-up:            AppState.next-up;
            recently-added:     AppState.recently-added-tv;
            not-watched:        AppState.not-watched-tv;
            favorites:          AppState.favorite-series;
            opacity: fade6.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade6 := FadeInTrigger { }
        }
        if !AppState.show-browse && AppState.active-nav == 1 && AppState.show-library: LibraryGrid {
            horizontal-stretch: 1; grid-title: "All Shows";
            opacity: fade7.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade7 := FadeInTrigger { }
        }
        if !AppState.show-browse && AppState.active-nav == 2 && !AppState.show-library: DashboardScreen {
            horizontal-stretch: 1; screen-title: "Movies";
            continue-watching:  AppState.continue-watching-movies;
            recently-added:     AppState.recently-added-movies;
            not-watched:        AppState.not-watched-movies;
            favorites:          AppState.favorite-movies;
            opacity: fade8.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade8 := FadeInTrigger { }
        }
        if !AppState.show-browse && AppState.active-nav == 2 && AppState.show-library: LibraryGrid {
            horizontal-stretch: 1; grid-title: "All Movies";
            opacity: fade9.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade9 := FadeInTrigger { }
        }
        if !AppState.show-browse && AppState.active-nav == 3 && !AppState.show-library: CollectionsDashboard {
            horizontal-stretch: 1;
            recently-added:     AppState.recently-added-collections;
            unwatched:          AppState.unwatched-collections;
            opacity: fade10.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade10 := FadeInTrigger { }
        }
        if !AppState.show-browse && AppState.active-nav == 3 && AppState.show-library: LibraryGrid {
            horizontal-stretch: 1; grid-title: "Collections";
            opacity: fade11.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade11 := FadeInTrigger { }
        }
        if !AppState.show-browse && AppState.active-nav == 4 && !AppState.show-library: MusicDashboard {
            horizontal-stretch:  1;
            recently-added:      AppState.recently-added-albums;
            recently-played:     AppState.recently-played-albums;
            favorites:           AppState.favorite-albums;
            playlists:           AppState.music-playlists;
            opacity: fade12.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade12 := FadeInTrigger { }
        }
        if !AppState.show-browse && AppState.active-nav == 4 && AppState.show-library: LibraryGrid {
            horizontal-stretch: 1; grid-title: "All Artists";
            opacity: fade13.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade13 := FadeInTrigger { }
        }
        if !AppState.show-browse && AppState.active-nav == 10: SettingsScreen {
            horizontal-stretch: 1;
            opacity: fade14.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade14 := FadeInTrigger { }
        }
        // Discover (Seerr) — same horizontal-stretch:1 content-slot shape as
        // every other tab above, so it must use plain FadeInTrigger + instant
        // unmount too, never FadeGate (see CLAUDE.md's AppShell/HorizontalLayout
        // regression note: two simultaneously-mounted stretch:1 children during
        // a delayed-unmount fade squeeze the shared layout).
        if !AppState.show-browse && AppState.active-nav == 6: DiscoverScreen {
            horizontal-stretch: 1;
            opacity: fade15.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } fade15 := FadeInTrigger { }
        }
    }

    // Second video layer — declared AFTER AppShell so it covers it when an overlay is open.
    // Without this, the library/dashboard cards (solid elements inside the transparent-rooted
    // AppShell) would ghost through the transparent overlay screens. This layer acts as an
    // opaque video cover that hides AppShell content when a full-screen overlay is open.
    if AppState.video-behind-ui && AppState.has-background-player && !AppState.is-playing
       && (AppState.show-detail || AppState.show-series || AppState.show-season || AppState.show-person || AppState.show-collection || AppState.show-album || AppState.show-artist): Rectangle {
        y:          0;
        height:     parent.height - total-bar-h;
        background: #000000;
        Image { source: AppState.video-frame; width: parent.width; height: parent.height; image-fit: contain; }
        Rectangle { background: #00000044; }
    }

    // Full-screen overlays — content area only (bars remain visible at bottom).
    // PlayerScreen is exempt from the fade: total-bar-h==0 when is-playing, so it always
    // gets full height, and video start latency is too perception-sensitive for an
    // artificial opacity ramp on top of it.
    if AppState.is-playing:                          PlayerScreen  { }
    gate15 := FadeGate { show: AppState.show-series; }
    if gate15.mounted: SeriesScreen { y: 0; height: parent.height - total-bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; opacity: gate15.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }
    gate16 := FadeGate { show: AppState.show-season; }
    if gate16.mounted: SeasonScreen { y: 0; height: parent.height - total-bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; opacity: gate16.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }
    gate17 := FadeGate { show: AppState.show-artist && !AppState.is-playing; }
    if gate17.mounted: ArtistScreen { y: 0; height: parent.height - total-bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; opacity: gate17.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }
    gate18 := FadeGate { show: AppState.show-collection && !AppState.is-playing; }
    if gate18.mounted: CollectionScreen { y: 0; height: parent.height - total-bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; opacity: gate18.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }
    gate19 := FadeGate { show: AppState.show-album && !AppState.is-playing; }
    if gate19.mounted: AlbumScreen { y: 0; height: parent.height - total-bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; opacity: gate19.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }
    gate20 := FadeGate { show: AppState.show-detail && !AppState.is-playing; }
    if gate20.mounted: DetailPage { y: 0; height: parent.height - total-bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; opacity: gate20.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }
    gate21 := FadeGate { show: AppState.show-person; }
    if gate21.mounted: PersonScreen { y: 0; height: parent.height - total-bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; opacity: gate21.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }
    gate31 := FadeGate { show: AppState.show-request-detail && !AppState.is-playing; }
    if gate31.mounted: RequestDetailScreen { y: 0; height: parent.height - total-bar-h; opacity: gate31.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; } }

    // Loading overlay — covers content area only; bars remain visible at bottom
    if AppState.app-content-loading: Rectangle {
        y: 0; height: parent.height - total-bar-h;
        background: #000000c0;
        VerticalLayout {
            alignment: center;
            spacing:   28px;

            LoadingSpinner { }

            // Progress bar — 0.0 → 1.0 as milestones are hit
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width:         320px;
                    height:        6px;
                    border-radius: 3px;
                    background:    #ffffff28;
                    Rectangle {
                        x:             0;
                        width:         parent.width * AppState.app-loading-progress;
                        height:        parent.height;
                        border-radius: 3px;
                        background:    Theme.accent;
                        animate width { duration: 400ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    }
                }
            }
        }
    }

    // ── Bottom bars (video mini-player above music bar) ───────────────────────
    // MiniPlayerBar: video paused in background (above music bar)
    if AppState.has-background-player && !AppState.is-playing: MiniPlayerBar {
        y:     parent.height - bar-h - music-bar-h;
        width: parent.width;
    }
    // MusicPlayerBar: audio-only playback
    if AppState.is-audio-playing: MusicPlayerBar {
        y:     parent.height - music-bar-h;
        width: parent.width;
    }

    // Now Playing: fullscreen music view (covers the music bar). Opened by
    // clicking the bar's art/title zone, the M key, or idle auto-open.
    gate22 := FadeGate { show: AppState.show-now-playing && AppState.is-audio-playing; }
    if gate22.mounted: NowPlayingScreen {
        x: 0; y: 0;
        width:  parent.width;
        height: parent.height;
        opacity: gate22.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    }

    gate23 := FadeGate { show: AppState.show-context-menu; }
    if gate23.mounted: ContextMenu {
        opacity: gate23.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    }

    // Add-to-playlist picker (above ContextMenu — the menu closes when it opens)
    gate24 := FadeGate { show: AppState.show-playlist-picker; }
    if gate24.mounted: PlaylistPicker {
        opacity: gate24.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    }

    // Connect Seerr: reached from Settings → Integrations, layers over
    // whatever screen is currently showing (same free-floating overlay shape
    // as PlaylistPicker above).
    gate30 := FadeGate { show: AppState.show-connect-seerr; }
    if gate30.mounted: ConnectSeerrScreen {
        x: 0; y: 0;
        width:  parent.width;
        height: parent.height;
        opacity: gate30.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    }

    // Queue panel: shown above context menu when browsing with audio, or from player
    gate25 := FadeGate { show: AppState.show-queue-panel; }
    if gate25.mounted: QueuePanel {
        x: 0; y: 0;
        width:  parent.width;
        height: parent.height - total-bar-h;
        opacity: gate25.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    }

    // Lyrics overlay: shown above everything except the music bar. Suppressed
    // while Now Playing is open — it already embeds its own synced lyrics
    // panel, so this would otherwise stack a redundant popup on top (CR11-8).
    gate26 := FadeGate { show: AppState.show-lyrics && AppState.is-audio-playing && !AppState.show-now-playing; }
    if gate26.mounted: LyricsView {
        x: 0; y: 0;
        width:  parent.width;
        height: parent.height - total-bar-h;
        opacity: gate26.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    }

    // Volume overlay: shown over any screen (fullscreen player, music bar,
    // Now Playing) — was fullscreen-player-only before the music bar / Now
    // Playing volume buttons existed.
    gate27 := FadeGate { show: AppState.show-volume-overlay; }
    if gate27.mounted: VolumeOverlay {
        x: (parent.width - self.width) / 2;
        y: 24px;
        opacity: gate27.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    }

    // Toast: highest z-order, always on top.
    // Local mirror triggers changed callback; timer auto-dismisses after 4 s.
    property <bool> _toast-vis: AppState.toast-visible;
    toast-timer := Timer {
        interval: 4000ms;
        running:  false;
        triggered => {
            AppState.toast-visible = false;
            self.running = false;
        }
    }
    changed _toast-vis => {
        if _toast-vis {
            toast-timer.running = false;
            toast-timer.running = true;
        }
    }
    gate28 := FadeGate { show: AppState.toast-visible; }
    if gate28.mounted: ToastNotification {
        x:       (parent.width - self.width) / 2;
        y:       parent.height - self.height - total-bar-h - 12px;
        width:   min(460px, parent.width - 48px);
        message: AppState.toast-message;
        opacity: gate28.fade-opacity; animate opacity { duration: 150ms * AppState.settings-animation-speed; easing: ease-out-expo; }
    }
}
