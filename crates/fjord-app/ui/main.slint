// ── fjord-app · main.slint ───────────────────────────────────────────────────
//   MainWindow    window root: sync-layout, auto-advance banner, FocusScope
//   keyboard handler (inside FocusScope fs.key-pressed):
//     login guard           reject all keys while show-login
//     series screen         season tabs, episode list nav
//     detail page           scroll, Left/Right cycles buttons, Enter activates focused button
//     player mode           seek, volume, track panels, fullscreen, digit-seek
//     background player     R to resume mini-card / behind-UI player
//     library grid          2-D poster nav + search header
//     global keys           Backspace/Escape, F, Q, B, 1/2/3, S
//     settings nav          settings-focused row traversal
//     dashboard nav         Up/Down rows, Left/Right cards, I, Enter
//   screen slots  LoginScreen, AppShell + HomeScreen / DashboardScreen / LibraryGrid
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton } from "widgets.slint";
import { SectionRow, LibraryGrid, HomeScreen, DashboardScreen } from "home.slint";
import { BrowseScreen } from "browse.slint";
import { SettingsScreen } from "settings.slint";
import { LoginScreen } from "login.slint";
import { PlayerScreen } from "player.slint";
import { SeriesScreen } from "series.slint";
import { DetailPage } from "detail.slint";
import { AppShell } from "layout.slint";

export { AppState }

export component MainWindow inherits Window {
    title:            "Fjord";
    background:       Theme.bg;
    min-width:        900px;
    min-height:       520px;
    preferred-width:  1280px;
    preferred-height: 720px;

    callback grab-keyboard-focus;
    grab-keyboard-focus => { fs.focus(); }

    pure function grid-cols() -> int {
        if self.width < 852px  { return 3; }
        if self.width < 1011px { return 4; }
        if self.width < 1170px { return 5; }
        if self.width < 1329px { return 6; }
        if self.width < 1488px { return 7; }
        if self.width < 1647px { return 8; }
        if self.width < 1806px { return 9; }
        return 10;
    }
    pure function dash-card-w() -> length {
        if self.width < 900px  { return 115px; }
        if self.width < 1300px { return 140px; }
        if self.width < 1700px { return 165px; }
        return 190px;
    }
    pure function dash-card-h() -> length {
        if self.width < 900px  { return 184px; }
        if self.width < 1300px { return 224px; }
        if self.width < 1700px { return 264px; }
        return 304px;
    }

    function sync-layout() {
        AppState.library-cols = self.grid-cols();
        AppState.dash-cw      = self.dash-card-w();
        AppState.dash-ch      = self.dash-card-h();
    }
    init => { self.sync-layout(); }
    changed width => { self.sync-layout(); }

    // Auto-advance countdown banner
    if AppState.show-next-ep-banner: Rectangle {
        x:             root.width  - 300px - 20px;
        y:             root.height - 110px - 20px;
        width:         300px;
        height:        110px;
        border-radius: Theme.radius-lg;
        background:    Theme.surface;
        border-width:  1px;
        border-color:  Theme.border-strong;
        drop-shadow-blur:     12px;
        drop-shadow-color:    #00000066;
        drop-shadow-offset-y: 4px;

        VerticalLayout {
            padding: 14px;
            spacing:  8px;

            Text { text: "Up Next in \{AppState.next-ep-secs}s"; color: Theme.text-muted; font-size: 11px; }
            Text { text: AppState.next-ep-title; color: Theme.text; font-size: 13px; font-weight: 600; overflow: elide; }
            HorizontalLayout {
                alignment: end;
                FjordButton { text: "Cancel"; width: 70px; clicked => { AppState.cancel-auto-advance(); } }
            }
        }
    }

    fs := FocusScope {
        width: 0; height: 0;
        key-pressed(event) => {
            if AppState.show-login { return reject; }

            // ── Series screen ──────────────────────────────────────────────────
            if AppState.show-series {
                if event.text == Key.Escape || event.text == Key.Backspace {
                    AppState.close-series();
                    return accept;
                }
                if AppState.series-in-season-row {
                    if event.text == Key.LeftArrow {
                        if AppState.series-season-idx > 0 {
                            AppState.series-season-idx -= 1;
                            AppState.series-select-season(AppState.series-season-idx);
                            AppState.series-focused-ep = 0;
                        }
                        return accept;
                    }
                    if event.text == Key.RightArrow {
                        if AppState.series-season-idx < AppState.series-seasons.length - 1 {
                            AppState.series-season-idx += 1;
                            AppState.series-select-season(AppState.series-season-idx);
                            AppState.series-focused-ep = 0;
                        }
                        return accept;
                    }
                    if event.text == Key.DownArrow || event.text == Key.Return || event.text == " " {
                        AppState.series-in-season-row = false;
                        return accept;
                    }
                    if event.text == "f" || event.text == "F" || event.text == Key.F11 { AppState.toggle-fullscreen(); return accept; }
                    if event.text == "q" || event.text == "Q" { AppState.quit(); return accept; }
                    return reject;
                }
                if event.text == Key.UpArrow {
                    if AppState.series-focused-ep > 0 {
                        AppState.series-focused-ep -= 1;
                    } else {
                        AppState.series-in-season-row = true;
                    }
                    return accept;
                }
                if event.text == Key.DownArrow {
                    if AppState.series-focused-ep < AppState.series-episodes.length - 1 {
                        AppState.series-focused-ep += 1;
                    }
                    return accept;
                }
                if event.text == Key.Return || event.text == " " {
                    if AppState.series-episodes.length > 0 {
                        AppState.play-series-episode(AppState.series-episodes[AppState.series-focused-ep].id);
                    }
                    return accept;
                }
                if event.text == "f" || event.text == "F" || event.text == Key.F11 { AppState.toggle-fullscreen(); return accept; }
                if event.text == "q" || event.text == "Q" { AppState.quit(); return accept; }
                return reject;
            }

            // ── Detail page ────────────────────────────────────────────────────
            if AppState.show-detail {
                if event.text == Key.Escape || event.text == Key.Backspace {
                    AppState.detail-scroll      = 0px;
                    AppState.detail-focused-btn = 0;
                    AppState.close-detail();
                    return accept;
                }
                if event.text == Key.DownArrow { AppState.detail-scroll = AppState.detail-scroll + 120px; return accept; }
                if event.text == Key.UpArrow   { AppState.detail-scroll = max(0px, AppState.detail-scroll - 120px); return accept; }
                if event.text == Key.LeftArrow || event.text == Key.RightArrow {
                    if AppState.detail-can-resume {
                        AppState.detail-focused-btn = AppState.detail-focused-btn == 0 ? 1 : 0;
                    }
                    return accept;
                }
                if event.text == Key.Return || event.text == " " {
                    if AppState.detail-focused-btn == 1 && AppState.detail-can-resume {
                        AppState.resume-detail();
                    } else {
                        AppState.play-detail();
                    }
                    return accept;
                }
                if event.text == "r" || event.text == "R" {
                    if AppState.detail-can-resume { AppState.resume-detail(); }
                    return accept;
                }
                if event.text == "f" || event.text == "F" || event.text == Key.F11 { AppState.toggle-fullscreen(); return accept; }
                if event.text == "q" || event.text == "Q" { AppState.quit(); return accept; }
                return reject;
            }

            // ── Player mode ────────────────────────────────────────────────────
            if AppState.is-playing {
                AppState.show-controls();

                if event.text == Key.Escape || event.text == Key.Backspace {
                    if AppState.player-open-panel != 0 {
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                    } else {
                        AppState.stop-playback();
                    }
                    return accept;
                }

                if AppState.player-open-panel != 0 {
                    if event.text == Key.UpArrow {
                        if AppState.player-panel-cursor > 0 { AppState.player-panel-cursor -= 1; }
                        return accept;
                    }
                    if event.text == Key.DownArrow {
                        if AppState.player-open-panel == 1 {
                            if AppState.player-panel-cursor < AppState.sub-tracks.length { AppState.player-panel-cursor += 1; }
                        } else if AppState.player-open-panel == 2 {
                            if AppState.player-panel-cursor < AppState.audio-tracks.length - 1 { AppState.player-panel-cursor += 1; }
                        } else if AppState.player-open-panel == 3 {
                            if AppState.player-panel-cursor < AppState.video-tracks.length - 1 { AppState.player-panel-cursor += 1; }
                        }
                        return accept;
                    }
                    if event.text == Key.Return {
                        AppState.commit-panel-selection();
                        AppState.player-open-panel   = 0;
                        AppState.player-panel-cursor = 0;
                        return accept;
                    }
                }

                if event.text == " " || event.text == "k" || event.text == "K"
                                     || event.text == "p" || event.text == "P" {
                    AppState.pause-play-toggle(); return accept;
                }
                if event.text == Key.LeftArrow {
                    if event.modifiers.shift { AppState.seek-backward-long(); } else { AppState.seek-backward(); }
                    return accept;
                }
                if event.text == Key.RightArrow {
                    if event.modifiers.shift { AppState.seek-forward-long(); } else { AppState.seek-forward(); }
                    return accept;
                }
                if event.text == Key.UpArrow   { AppState.volume-up();   return accept; }
                if event.text == Key.DownArrow { AppState.volume-down(); return accept; }
                if event.text == "s" || event.text == "S" { AppState.player-open-panel = AppState.player-open-panel == 1 ? 0 : 1; AppState.player-panel-cursor = 0; return accept; }
                if event.text == "a" || event.text == "A" { AppState.player-open-panel = AppState.player-open-panel == 2 ? 0 : 2; AppState.player-panel-cursor = 0; return accept; }
                if event.text == "v" || event.text == "V" { AppState.player-open-panel = AppState.player-open-panel == 3 ? 0 : 3; AppState.player-panel-cursor = 0; return accept; }
                if event.text == "m" || event.text == "M" { AppState.mute-toggle();    return accept; }
                if event.text == "i" || event.text == "I" { AppState.toggle-stats();   return accept; }
                if event.text == "f" || event.text == "F" || event.text == Key.F11 { AppState.toggle-fullscreen(); return accept; }
                if event.text == "0" { AppState.seek-to(0.0); return accept; }
                if event.text == "1" { AppState.seek-to(0.1); return accept; }
                if event.text == "2" { AppState.seek-to(0.2); return accept; }
                if event.text == "3" { AppState.seek-to(0.3); return accept; }
                if event.text == "4" { AppState.seek-to(0.4); return accept; }
                if event.text == "5" { AppState.seek-to(0.5); return accept; }
                if event.text == "6" { AppState.seek-to(0.6); return accept; }
                if event.text == "7" { AppState.seek-to(0.7); return accept; }
                if event.text == "8" { AppState.seek-to(0.8); return accept; }
                if event.text == "9" { AppState.seek-to(0.9); return accept; }
                return reject;
            }

            // ── Background player ──────────────────────────────────────────────
            if AppState.has-background-player && !AppState.show-browse {
                if event.text == "r" || event.text == "R" { AppState.resume-player(); return accept; }
            }

            // ── Library grid ───────────────────────────────────────────────────
            if AppState.show-library {
                if AppState.library-searching {
                    if event.text == Key.Escape {
                        AppState.library-search-clear();
                        AppState.library-searching      = false;
                        AppState.library-header-focused = true;
                        return accept;
                    }
                    if event.text == Key.Backspace {
                        if AppState.library-query != "" {
                            AppState.library-search-backspace();
                            AppState.library-focused = 0;
                        } else {
                            AppState.library-searching      = false;
                            AppState.library-header-focused = true;
                        }
                        return accept;
                    }
                    if !event.repeat && event.text != "" {
                        AppState.library-search-append(event.text);
                        AppState.library-focused = 0;
                        return accept;
                    }
                    return reject;
                }

                if AppState.library-header-focused {
                    if event.text == Key.Return || event.text == "/" {
                        AppState.library-searching      = true;
                        AppState.library-header-focused = false;
                        AppState.library-search-clear();
                        AppState.library-focused        = 0;
                        return accept;
                    }
                    if event.text == Key.DownArrow {
                        AppState.library-header-focused = false;
                        AppState.library-focused        = 0;
                        return accept;
                    }
                    if event.text == Key.Escape || event.text == Key.Backspace {
                        AppState.show-library           = false;
                        AppState.library-header-focused = false;
                        AppState.library-searching      = false;
                        AppState.library-search-clear();
                        return accept;
                    }
                    if event.text == "f" || event.text == "F" || event.text == Key.F11 { AppState.toggle-fullscreen(); return accept; }
                    if event.text == "q" || event.text == "Q" { AppState.quit(); return accept; }
                    return reject;
                }

                if event.text == Key.Escape || event.text == Key.Backspace {
                    AppState.show-library      = false;
                    AppState.library-searching = false;
                    AppState.library-search-clear();
                    return accept;
                }
                if event.text == Key.LeftArrow {
                    if Math.mod(AppState.library-focused, AppState.library-cols) > 0 {
                        AppState.library-focused -= 1;
                    } else if !event.repeat {
                        AppState.show-library           = false;
                        AppState.library-searching      = false;
                        AppState.library-header-focused = false;
                        AppState.library-search-clear();
                        AppState.focused-section        = -1;
                    }
                    return accept;
                }
                if event.text == Key.RightArrow { if AppState.library-focused < AppState.library-display.length - 1 { AppState.library-focused += 1; } return accept; }
                if event.text == Key.UpArrow {
                    if AppState.library-focused >= AppState.library-cols {
                        AppState.library-focused -= AppState.library-cols;
                    } else {
                        AppState.library-header-focused = true;
                    }
                    return accept;
                }
                if event.text == Key.DownArrow {
                    if AppState.library-focused + AppState.library-cols < AppState.library-display.length {
                        AppState.library-focused += AppState.library-cols;
                    }
                    return accept;
                }
                if event.text == Key.Return {
                    if AppState.library-focused < AppState.library-display.length {
                        AppState.open-detail(AppState.library-display[AppState.library-focused].id);
                    }
                    return accept;
                }
                if event.text == "/" {
                    AppState.library-searching      = true;
                    AppState.library-header-focused = false;
                    AppState.library-search-clear();
                    AppState.library-focused        = 0;
                    return accept;
                }
            }

            // ── Global: Backspace/Escape ───────────────────────────────────────
            if event.text == Key.Backspace || event.text == Key.Escape {
                if AppState.show-browse {
                    AppState.current-item = -1;
                    AppState.show-browse = false;
                    fs.focus();
                    return accept;
                }
                if AppState.focused-section >= 0 { AppState.focused-section = -1; return accept; }
                return reject;
            }

            if event.text == "f" || event.text == "F" || event.text == Key.F11 { AppState.toggle-fullscreen(); return accept; }
            if event.text == "q" || event.text == "Q" { AppState.quit(); return accept; }
            if event.text == "b" || event.text == "B" {
                if AppState.active-nav < 10 { AppState.show-library = false; AppState.settings-focused = -1; AppState.show-browse = true; }
                return accept;
            }
            if event.text == "1" { AppState.show-browse = false; AppState.show-library = false; AppState.library-searching = false; AppState.library-header-focused = false; AppState.focused-section = -1; AppState.settings-focused = -1; AppState.active-nav = 0; AppState.nav-selected(0); return accept; }
            if event.text == "2" { AppState.show-browse = false; AppState.show-library = false; AppState.library-searching = false; AppState.library-header-focused = false; AppState.focused-section = -1; AppState.settings-focused = -1; AppState.active-nav = 1; AppState.nav-selected(1); return accept; }
            if event.text == "3" { AppState.show-browse = false; AppState.show-library = false; AppState.library-searching = false; AppState.library-header-focused = false; AppState.focused-section = -1; AppState.settings-focused = -1; AppState.active-nav = 2; AppState.nav-selected(2); return accept; }
            if event.text == "s" || event.text == "S" { AppState.show-browse = false; AppState.show-library = false; AppState.library-searching = false; AppState.library-header-focused = false; AppState.focused-section = -1; AppState.settings-focused = -1; AppState.active-nav = 10; AppState.nav-selected(10); return accept; }

            // ── Settings keyboard nav ──────────────────────────────────────────
            if AppState.active-nav == 10 && !AppState.show-browse && !AppState.show-series && !AppState.show-library && !AppState.is-playing {
                if event.text == Key.DownArrow && AppState.settings-focused >= 0 && AppState.settings-focused <= 17 {
                    if AppState.settings-focused < 17 {
                        AppState.settings-focused = AppState.settings-focused + 1;
                        if AppState.settings-focused == 11 && !AppState.settings-interpolation { AppState.settings-focused = 12; }
                    }
                    return accept;
                }
                if event.text == Key.UpArrow && AppState.settings-focused >= 0 {
                    if AppState.settings-focused == 0 {
                        AppState.settings-focused = -1;
                    } else {
                        AppState.settings-focused = AppState.settings-focused - 1;
                        if AppState.settings-focused == 11 && !AppState.settings-interpolation { AppState.settings-focused = 10; }
                    }
                    return accept;
                }
                if (event.text == Key.Backspace || event.text == Key.Escape) && AppState.settings-focused >= 0 {
                    AppState.settings-focused = -1; return accept;
                }
                if (event.text == Key.Return || event.text == Key.RightArrow) && AppState.settings-focused < 0 {
                    AppState.settings-focused = 0; return accept;
                }
                if AppState.settings-focused >= 0 && (event.text == Key.Return || event.text == " " || event.text == Key.LeftArrow || event.text == Key.RightArrow) {
                    if AppState.settings-focused == 0  { AppState.settings-launch-fullscreen = !AppState.settings-launch-fullscreen; AppState.settings-changed(); return accept; }
                    if AppState.settings-focused == 1  { AppState.settings-audio-spdif = !AppState.settings-audio-spdif; AppState.settings-changed(); return accept; }
                    if AppState.settings-focused == 2  { AppState.settings-vo = AppState.settings-vo == "gpu-next" ? "gpu" : "gpu-next"; AppState.settings-changed(); return accept; }
                    if AppState.settings-focused == 3  {
                        AppState.settings-gpu-api = event.text == Key.LeftArrow
                            ? (AppState.settings-gpu-api == "auto" ? "vulkan" : AppState.settings-gpu-api == "opengl" ? "auto" : "opengl")
                            : (AppState.settings-gpu-api == "auto" ? "opengl" : AppState.settings-gpu-api == "opengl" ? "vulkan" : "auto");
                        AppState.settings-changed(); return accept;
                    }
                    if AppState.settings-focused == 4  {
                        AppState.settings-hwdec = event.text == Key.LeftArrow
                            ? (AppState.settings-hwdec == "auto"       ? "none"       :
                               AppState.settings-hwdec == "vulkan-copy" ? "auto"       :
                               AppState.settings-hwdec == "nvdec-copy"  ? "vulkan-copy":
                               AppState.settings-hwdec == "vaapi-copy"  ? "nvdec-copy" :
                               AppState.settings-hwdec == "vdpau-copy"  ? "vaapi-copy" :
                               AppState.settings-hwdec == "nvdec"       ? "vdpau-copy" :
                               AppState.settings-hwdec == "vaapi"       ? "nvdec"      :
                               AppState.settings-hwdec == "vdpau"       ? "vaapi"      : "vdpau")
                            : (AppState.settings-hwdec == "auto"       ? "vulkan-copy" :
                               AppState.settings-hwdec == "vulkan-copy" ? "nvdec-copy" :
                               AppState.settings-hwdec == "nvdec-copy"  ? "vaapi-copy" :
                               AppState.settings-hwdec == "vaapi-copy"  ? "vdpau-copy" :
                               AppState.settings-hwdec == "vdpau-copy"  ? "nvdec"      :
                               AppState.settings-hwdec == "nvdec"       ? "vaapi"      :
                               AppState.settings-hwdec == "vaapi"       ? "vdpau"      :
                               AppState.settings-hwdec == "vdpau"       ? "none"       : "auto");
                        AppState.settings-changed(); return accept;
                    }
                    if AppState.settings-focused == 5  {
                        AppState.settings-hwdec-image-format = event.text == Key.LeftArrow
                            ? (AppState.settings-hwdec-image-format == ""            ? "p010"       :
                               AppState.settings-hwdec-image-format == "yuv420p"     ? ""           :
                               AppState.settings-hwdec-image-format == "yuv420p10le" ? "yuv420p"    :
                               AppState.settings-hwdec-image-format == "nv12"        ? "yuv420p10le": "nv12")
                            : (AppState.settings-hwdec-image-format == ""            ? "yuv420p"    :
                               AppState.settings-hwdec-image-format == "yuv420p"     ? "yuv420p10le":
                               AppState.settings-hwdec-image-format == "yuv420p10le" ? "nv12"       :
                               AppState.settings-hwdec-image-format == "nv12"        ? "p010"       : "");
                        AppState.settings-changed(); return accept;
                    }
                    if AppState.settings-focused == 6  {
                        AppState.settings-vf = event.text == Key.LeftArrow
                            ? (AppState.settings-vf == ""                   ? "format=p010"        :
                               AppState.settings-vf == "auto"               ? ""                   :
                               AppState.settings-vf == "format=yuv420p"     ? "auto"               :
                               AppState.settings-vf == "format=yuv420p10le" ? "format=yuv420p"     :
                               AppState.settings-vf == "format=nv12"        ? "format=yuv420p10le" : "format=nv12")
                            : (AppState.settings-vf == ""                   ? "auto"               :
                               AppState.settings-vf == "auto"               ? "format=yuv420p"     :
                               AppState.settings-vf == "format=yuv420p"     ? "format=yuv420p10le" :
                               AppState.settings-vf == "format=yuv420p10le" ? "format=nv12"        :
                               AppState.settings-vf == "format=nv12"        ? "format=p010"        : "");
                        AppState.settings-changed(); return accept;
                    }
                    if AppState.settings-focused == 7  { AppState.settings-deinterlace = !AppState.settings-deinterlace; AppState.settings-changed(); return accept; }
                    if AppState.settings-focused == 8  { AppState.settings-video-behind = !AppState.settings-video-behind; AppState.settings-changed(); return accept; }
                    if AppState.settings-focused == 9  {
                        AppState.settings-video-sync = event.text == Key.LeftArrow
                            ? (AppState.settings-video-sync == "audio"            ? "display-adrop"   :
                               AppState.settings-video-sync == "display-resample" ? "audio"           :
                               AppState.settings-video-sync == "display-vdrop"    ? "display-resample": "display-vdrop")
                            : (AppState.settings-video-sync == "audio"            ? "display-resample":
                               AppState.settings-video-sync == "display-resample" ? "display-vdrop"   :
                               AppState.settings-video-sync == "display-vdrop"    ? "display-adrop"   : "audio");
                        AppState.settings-changed(); return accept;
                    }
                    if AppState.settings-focused == 10 { AppState.settings-interpolation = !AppState.settings-interpolation; AppState.settings-changed(); return accept; }
                    if AppState.settings-focused == 11 {
                        AppState.settings-tscale = event.text == Key.LeftArrow
                            ? (AppState.settings-tscale == "oversample"  ? "bicubic"    :
                               AppState.settings-tscale == "catmull_rom" ? "oversample" :
                               AppState.settings-tscale == "mitchell"    ? "catmull_rom":
                               AppState.settings-tscale == "gaussian"    ? "mitchell"   : "gaussian")
                            : (AppState.settings-tscale == "oversample"  ? "catmull_rom":
                               AppState.settings-tscale == "catmull_rom" ? "mitchell"   :
                               AppState.settings-tscale == "mitchell"    ? "gaussian"   :
                               AppState.settings-tscale == "gaussian"    ? "bicubic"    : "oversample");
                        AppState.settings-changed(); return accept;
                    }
                    if AppState.settings-focused == 12 {
                        AppState.settings-tone-mapping = event.text == Key.LeftArrow
                            ? (AppState.settings-tone-mapping == "auto"     ? "linear"   :
                               AppState.settings-tone-mapping == "hable"    ? "auto"     :
                               AppState.settings-tone-mapping == "bt.2390"  ? "hable"    :
                               AppState.settings-tone-mapping == "reinhard" ? "bt.2390"  :
                               AppState.settings-tone-mapping == "mobius"   ? "reinhard" :
                               AppState.settings-tone-mapping == "clip"     ? "mobius"   :
                               AppState.settings-tone-mapping == "gamma"    ? "clip"     : "gamma")
                            : (AppState.settings-tone-mapping == "auto"     ? "hable"    :
                               AppState.settings-tone-mapping == "hable"    ? "bt.2390"  :
                               AppState.settings-tone-mapping == "bt.2390"  ? "reinhard" :
                               AppState.settings-tone-mapping == "reinhard" ? "mobius"   :
                               AppState.settings-tone-mapping == "mobius"   ? "clip"     :
                               AppState.settings-tone-mapping == "clip"     ? "gamma"    :
                               AppState.settings-tone-mapping == "gamma"    ? "linear"   : "auto");
                        AppState.settings-changed(); return accept;
                    }
                    if AppState.settings-focused == 13 { AppState.settings-target-colorspace-hint = !AppState.settings-target-colorspace-hint; AppState.settings-changed(); return accept; }
                    if AppState.settings-focused == 14 { AppState.settings-opengl-early-flush = !AppState.settings-opengl-early-flush; AppState.settings-changed(); return accept; }
                    if AppState.settings-focused == 15 { AppState.settings-video-latency-hacks = !AppState.settings-video-latency-hacks; AppState.settings-changed(); return accept; }
                    if AppState.settings-focused == 16 {
                        AppState.settings-cache-mb = event.text == Key.LeftArrow
                            ? (AppState.settings-cache-mb == 0   ? 1000 :
                               AppState.settings-cache-mb == 50  ? 0    :
                               AppState.settings-cache-mb == 150 ? 50   :
                               AppState.settings-cache-mb == 300 ? 150  :
                               AppState.settings-cache-mb == 500 ? 300  : 500)
                            : (AppState.settings-cache-mb == 0   ? 50   :
                               AppState.settings-cache-mb == 50  ? 150  :
                               AppState.settings-cache-mb == 150 ? 300  :
                               AppState.settings-cache-mb == 300 ? 500  :
                               AppState.settings-cache-mb == 500 ? 1000 : 0);
                        AppState.settings-changed(); return accept;
                    }
                    if AppState.settings-focused == 17 { AppState.sign-out(); return accept; }
                }
            }

            // ── Up/Down ────────────────────────────────────────────────────────
            if event.text == Key.UpArrow {
                if AppState.show-browse {
                    AppState.current-item = AppState.current-item <= 0 ? 0 : AppState.current-item - 1;
                } else if AppState.focused-section < 0 {
                    AppState.show-library      = false;
                    AppState.library-searching = false;
                    AppState.settings-focused  = -1;
                    AppState.active-nav = AppState.active-nav == 0  ? 11
                                        : AppState.active-nav == 11 ? 10
                                        : AppState.active-nav == 10 ? 2
                                        : AppState.active-nav == 2  ? 1
                                        :                             0;
                    AppState.nav-selected(AppState.active-nav);
                } else {
                    let p = AppState.find-prev-section(AppState.focused-section);
                    if p >= 0 { AppState.focused-section = p; AppState.focused-card = 0; }
                }
                return accept;
            }

            if event.text == Key.DownArrow {
                if AppState.show-browse {
                    AppState.current-item = AppState.current-item < 0 ? 0
                                          : AppState.current-item >= AppState.media-items.length - 1 ? AppState.media-items.length - 1
                                          : AppState.current-item + 1;
                } else if AppState.focused-section < 0 {
                    AppState.show-library      = false;
                    AppState.library-searching = false;
                    AppState.settings-focused  = -1;
                    AppState.active-nav = AppState.active-nav == 0  ? 1
                                        : AppState.active-nav == 1  ? 2
                                        : AppState.active-nav == 2  ? 10
                                        : AppState.active-nav == 10 ? 11
                                        :                             0;
                    AppState.nav-selected(AppState.active-nav);
                } else {
                    let n = AppState.find-next-section(AppState.focused-section);
                    if n != AppState.focused-section { AppState.focused-section = n; AppState.focused-card = 0; }
                }
                return accept;
            }

            // ── Dashboard nav: Left / Right / I / Enter ────────────────────────
            // Left: prev card; held stops at 0, single tap exits to sidebar
            if event.text == Key.LeftArrow && !AppState.show-browse && AppState.focused-section >= 0 {
                if AppState.focused-card > 0 {
                    AppState.focused-card = AppState.focused-card - 1;
                } else if !event.repeat {
                    AppState.focused-section = -1;
                }
                return accept;
            }

            // Right: enter content grid or advance card
            if event.text == Key.RightArrow && !AppState.show-browse {
                if AppState.focused-section < 0 && AppState.active-nav < 10 {
                    AppState.focused-section = AppState.find-first-section();
                    AppState.focused-card    = 0;
                } else if AppState.focused-section >= 0 {
                    if AppState.focused-card < AppState.section-len(AppState.focused-section) - 1 {
                        AppState.focused-card = AppState.focused-card + 1;
                    }
                }
                return accept;
            }

            // I: open detail
            if (event.text == "i" || event.text == "I") && AppState.focused-section >= 0 && !AppState.show-browse {
                AppState.open-detail(AppState.section-card-id(AppState.focused-section, AppState.focused-card));
                return accept;
            }

            if event.text == Key.Return {
                if AppState.show-browse && AppState.current-item >= 0 {
                    AppState.play-item(AppState.current-item); return accept;
                }
                if AppState.focused-section >= 0 && !AppState.show-browse {
                    AppState.item-play(AppState.section-card-id(AppState.focused-section, AppState.focused-card));
                    return accept;
                }
                if AppState.focused-section < 0 && AppState.active-nav == 11 {
                    AppState.quit(); return accept;
                }
                if AppState.focused-section < 0 && AppState.active-nav < 10 {
                    if AppState.active-nav == 1 || AppState.active-nav == 2 {
                        AppState.show-library    = true;
                        AppState.library-focused = 0;
                        AppState.library-search-clear();
                        AppState.open-library(AppState.active-nav);
                    } else {
                        AppState.focused-section = AppState.find-first-section();
                        AppState.focused-card    = 0;
                    }
                    return accept;
                }
                return reject;
            }

            reject
        }
    }

    // Video-behind-UI background layer
    if AppState.video-behind-ui && !AppState.is-playing: Rectangle {
        background: #000000;
        Image { source: AppState.video-frame; width: parent.width; height: parent.height; image-fit: contain; }
        Rectangle { background: #00000077; }
    }

    if AppState.show-login: LoginScreen { }

    if !AppState.show-login: AppShell {
        if AppState.show-browse: BrowseScreen { horizontal-stretch: 1; }

        if !AppState.show-browse && AppState.active-nav == 0: HomeScreen {
            horizontal-stretch:    1;
            continue-watching:     AppState.continue-watching;
            next-up:               AppState.next-up;
            recently-added:        AppState.recently-added;
            recently-added-movies: AppState.recently-added-movies;
        }
        if !AppState.show-browse && AppState.active-nav == 1 && !AppState.show-library: DashboardScreen {
            horizontal-stretch: 1; screen-title: "Movies";
            continue-watching:  AppState.continue-watching-movies;
            recently-added:     AppState.recently-added-movies;
            not-watched:        AppState.not-watched-movies;
        }
        if !AppState.show-browse && AppState.active-nav == 1 && AppState.show-library: LibraryGrid {
            horizontal-stretch: 1; grid-title: "All Movies";
        }
        if !AppState.show-browse && AppState.active-nav == 2 && !AppState.show-library: DashboardScreen {
            horizontal-stretch: 1; screen-title: "TV Shows";
            continue-watching:  AppState.continue-watching-tv;
            next-up:            AppState.next-up;
            recently-added:     AppState.recently-added-tv;
            not-watched:        AppState.not-watched-tv;
        }
        if !AppState.show-browse && AppState.active-nav == 2 && AppState.show-library: LibraryGrid {
            horizontal-stretch: 1; grid-title: "All Shows";
        }
        if !AppState.show-browse && AppState.active-nav == 10: SettingsScreen { horizontal-stretch: 1; }
    }

    if AppState.is-playing:   PlayerScreen { }
    if AppState.show-series:  SeriesScreen { }
    if AppState.show-detail:  DetailPage   { }
}
