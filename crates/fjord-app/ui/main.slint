import { LineEdit, ListView, StandardListView, ScrollView, CheckBox, ComboBox } from "std-widgets.slint";
import { Theme, HomeItem, TrackEntry, CastMember, SeasonEntry, EpisodeEntry } from "theme.slint";

// ── Accent button ─────────────────────────────────────────────────────────────
component FjordButton inherits Rectangle {
    in property <string> text;
    in property <bool>   enabled: true;
    in property <bool>   danger:  false;
    callback clicked;

    height: 38px;
    border-radius: Theme.radius;
    background: !enabled      ? Theme.surface-raised
              : ta.has-hover  ? (danger ? #c53030 : Theme.accent-hover)
              :                  (danger ? Theme.error : Theme.accent);

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
    Text {
        text:                 root.text;
        color:                root.enabled ? #ffffff : Theme.text-subtle;
        font-size:            14px;
        font-weight:          600;
        horizontal-alignment: center;
        vertical-alignment:   center;
    }
}

// ── Sidebar nav row ───────────────────────────────────────────────────────────
component NavItem inherits Rectangle {
    in property <string> label;
    in property <bool>   active: false;
    in property <bool>   kbd-focused: false;
    callback clicked;
    callback double-clicked;

    height: 40px;
    border-radius: Theme.radius;
    background: active && kbd-focused ? Theme.accent
              : active                ? Theme.accent-muted
              : ta.has-hover          ? Theme.surface-raised
              :                         #00000000;

    ta := TouchArea {
        clicked        => { root.clicked(); }
        double-clicked => { root.double-clicked(); }
    }

    HorizontalLayout {
        padding-left: 14px;
        spacing:      10px;
        alignment:    start;

        Rectangle {
            width: 6px;
            Rectangle {
                width:         6px;
                height:        6px;
                border-radius: 3px;
                y:             (parent.height - self.height) / 2;
                background:    active ? Theme.accent : Theme.text-subtle;
            }
        }
        Text {
            text:               label;
            color:              active ? Theme.text : Theme.text-muted;
            font-size:          14px;
            font-weight:        active ? 600 : 400;
            vertical-alignment: center;
        }
    }
}

// ── Browse-screen list row ────────────────────────────────────────────────────
component BrowseItem inherits Rectangle {
    in property <string> text;
    in property <bool>   selected: false;
    callback clicked;
    callback activated;

    height: 42px;
    border-radius: Theme.radius;
    background: selected      ? Theme.accent-muted
              : ta.has-hover  ? Theme.surface-raised
              :                  #00000000;

    ta := TouchArea {
        clicked        => { root.clicked(); }
        double-clicked => { root.activated(); }
    }
    HorizontalLayout {
        padding-left:  10px;
        padding-right: 12px;
        spacing:        8px;
        alignment:      start;

        Rectangle {
            width:         3px;
            height:        20px;
            y:             (parent.height - self.height) / 2;
            border-radius: 1.5px;
            background:    selected ? Theme.accent : #00000000;
        }
        Text {
            text:               root.text;
            color:              selected ? Theme.text : Theme.text-muted;
            font-size:          14px;
            overflow:           elide;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

// ── Poster card (used inside horizontal scroll rows) ──────────────────────────
component MediaCard inherits Rectangle {
    in property <HomeItem> item;
    in property <bool>     focused: false;
    callback clicked;

    width:          140px;
    height:         224px;
    border-radius:  Theme.radius;
    border-width:   focused ? 2px : 0px;
    border-color:   Theme.accent;
    background:     #00000000;

    VerticalLayout {
        spacing: 6px;

        poster-rect := Rectangle {
            height:        170px;
            border-radius: Theme.radius;
            background:    ta.has-hover ? Theme.surface-overlay : Theme.surface-raised;
            clip:          true;

            if item.has-poster: Image {
                source:    item.poster;
                width:     parent.width;
                height:    parent.height;
                image-fit: cover;
            }

            if !item.has-poster: Text {
                text:                 item.title;
                color:                Theme.text-muted;
                font-size:            11px;
                wrap:                 word-wrap;
                horizontal-alignment: center;
                vertical-alignment:   center;
                x:                    6px;
                width:                parent.width - 12px;
            }
        }

        VerticalLayout {
            spacing: 2px;

            Text {
                text:      item.title;
                color:     Theme.text;
                font-size: 12px;
                overflow:  elide;
                height:    30px;
                wrap:      word-wrap;
            }
            if item.year > 0: Text {
                text:      "\{item.year}";
                color:     Theme.text-muted;
                font-size: 10px;
            }
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// ── Horizontal-scroll content row with title ──────────────────────────────────
component SectionRow inherits Rectangle {
    in property <string>     section-title;
    in property <[HomeItem]> items;
    in property <bool>       section-focused: false;
    in property <int>        focused-card: 0;
    callback item-play(string);

    height: 280px;

    VerticalLayout {
        padding:    Theme.sp;
        spacing:    Theme.sp-sm;

        Text {
            text:        section-title;
            color:       Theme.text;
            font-size:   16px;
            font-weight: 700;
        }

        fl := Flickable {
            height:         218px;
            viewport-width: hbox.preferred-width + Theme.sp;
            viewport-x: focused-card <= 0 ? 0px
                      : clamp(
                            -(focused-card * 150px + 70px - fl.width / 2),
                            min(0px, fl.width - hbox.preferred-width - Theme.sp),
                            0px
                        );
            animate viewport-x { duration: 150ms; easing: ease-out; }

            hbox := HorizontalLayout {
                spacing:   10px;
                alignment: start;

                for itm[i] in items: MediaCard {
                    item:    itm;
                    focused: root.section-focused && i == root.focused-card;
                    clicked => { root.item-play(itm.id); }
                }
            }
        }
    }
}

// ── Library grid: all movies or all series in a 2-D poster grid ──────────────
component LibraryGrid inherits Rectangle {
    in property <[HomeItem]> items;
    in property <string>     grid-title;
    in property <int>        focused-idx: 0;
    callback item-open(string);
    callback back;

    property <int>    cols:   6;
    property <length> card-w: 145px;
    property <length> card-h: 224px;
    property <length> gap:    14px;

    background: Theme.bg;

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height:     54px;
            background: Theme.surface;
            HorizontalLayout {
                padding-left:  Theme.sp-sm;
                padding-right: Theme.sp;
                spacing:       Theme.sp-sm;
                alignment:     start;
                FjordButton {
                    text:  "← Back";
                    width: 80px;
                    clicked => { root.back(); }
                }
                Text {
                    text:               grid-title;
                    color:              Theme.text;
                    font-size:          18px;
                    font-weight:        700;
                    vertical-alignment: center;
                }
                Text {
                    text:               "\{items.length} items";
                    color:              Theme.text-muted;
                    font-size:          13px;
                    vertical-alignment: center;
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
        }

        fl := Flickable {
            vertical-stretch:   1;
            horizontal-stretch: 1;
            viewport-width:     fl.width;
            viewport-height:    max(fl.height, ((items.length + cols - 1) / cols) * (card-h + gap) + gap);
            viewport-y: clamp(
                -(focused-idx / cols) * (card-h + gap) + fl.height / 2 - card-h / 2,
                min(0px, fl.height - self.viewport-height),
                0px
            );
            animate viewport-y { duration: 150ms; easing: ease-out; }

            VerticalLayout {
                padding: gap;
                spacing: gap;

                for row-idx in (items.length + cols - 1) / cols: HorizontalLayout {
                    alignment: start;
                    spacing:   gap;
                    height:    card-h;

                    for col-idx in cols: MediaCard {
                        property <int> idx: row-idx * cols + col-idx;
                        visible: idx < items.length;
                        item:    items[idx];
                        width:   card-w;
                        focused: idx == root.focused-idx;
                        clicked => { root.item-open(items[idx].id); }
                    }
                }
            }
        }
    }
}

// ── Browse screen (virtualised flat list with search) ─────────────────────────
component BrowseScreen inherits Rectangle {
    in property <string>                 status;
    in property <[StandardListViewItem]> media-items;
    in-out property <int>                current-item: -1;
    callback filter-changed(string);
    callback play-item(int);
    callback back;

    background: Theme.bg;

    VerticalLayout {
        spacing: 0px;

        // Header: back + search
        Rectangle {
            height:     54px;
            background: Theme.surface;

            HorizontalLayout {
                padding-left:  Theme.sp-sm;
                padding-right: Theme.sp;
                spacing:       Theme.sp-sm;
                alignment:     start;

                FjordButton {
                    text:  "← Back";
                    width: 80px;
                    clicked => { root.back(); }
                }
                search-field := LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text:   "Search…";
                    edited(text) => { root.filter-changed(text); }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
        }

        list-view := ListView {
            horizontal-stretch: 1;
            vertical-stretch:   1;
            viewport-y: current-item < 0 ? 0px
                      : clamp(
                            -(current-item * 42px + 21px - list-view.visible-height / 2),
                            min(0px, list-view.visible-height - root.media-items.length * 42px),
                            0px
                        );
            animate viewport-y { duration: 150ms; easing: ease-out; }

            for item[i] in root.media-items: BrowseItem {
                width:    list-view.visible-width - 12px;
                text:     item.text;
                selected: i == root.current-item;
                clicked   => { root.current-item = i; }
                activated => { root.play-item(i); }
            }
        }

        // Footer: status + play
        Rectangle {
            height:     50px;
            background: Theme.surface;

            Rectangle { height: 1px; background: Theme.border; }

            HorizontalLayout {
                padding-left:  Theme.sp;
                padding-right: Theme.sp;
                padding-top:   Theme.sp-xs;
                spacing:       Theme.sp;
                alignment:     space-between;

                Text {
                    text:               status;
                    color:              Theme.text-muted;
                    font-size:          13px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                FjordButton {
                    text:    "▶  Play";
                    width:   100px;
                    enabled: root.current-item >= 0;
                    clicked => { root.play-item(root.current-item); }
                }
            }
        }
    }
}

// ── Home screen with curated rows ─────────────────────────────────────────────
component HomeScreen inherits Rectangle {
    in property <[HomeItem]> continue-watching;
    in property <[HomeItem]> next-up;
    in property <[HomeItem]> recently-added;
    in property <int>        kbd-section: -1;
    in property <int>        kbd-card:    0;
    callback item-play(string);
    callback browse;

    background: Theme.bg;

    VerticalLayout {
        spacing: 0px;

        // Page header
        Rectangle {
            height:     54px;
            background: Theme.surface;

            HorizontalLayout {
                padding-left:  Theme.sp-lg;
                padding-right: Theme.sp;
                spacing:       Theme.sp;
                alignment:     space-between;

                Text {
                    text:               "Home";
                    color:              Theme.text;
                    font-size:          18px;
                    font-weight:        700;
                    vertical-alignment: center;
                }
                FjordButton {
                    text:  "Browse All";
                    width: 110px;
                    clicked => { root.browse(); }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
        }

        ScrollView {
            vertical-stretch:   1;
            horizontal-stretch: 1;
            viewport-height:    rows.preferred-height;

            rows := VerticalLayout {
                padding: Theme.sp-lg;
                spacing: Theme.sp-lg;

                if continue-watching.length > 0: SectionRow {
                    section-title:  "Continue Watching";
                    items:          continue-watching;
                    section-focused: root.kbd-section == 0;
                    focused-card:   root.kbd-card;
                    item-play(id)  => { root.item-play(id); }
                }
                if next-up.length > 0: SectionRow {
                    section-title:  "Next Up";
                    items:          next-up;
                    section-focused: root.kbd-section == 1;
                    focused-card:   root.kbd-card;
                    item-play(id)  => { root.item-play(id); }
                }
                if recently-added.length > 0: SectionRow {
                    section-title:  "Recently Added";
                    items:          recently-added;
                    section-focused: root.kbd-section == 2;
                    focused-card:   root.kbd-card;
                    item-play(id)  => { root.item-play(id); }
                }
                if continue-watching.length == 0 && next-up.length == 0 && recently-added.length == 0: Rectangle {
                    height: 120px;
                    Text {
                        text:                 "Loading library…";
                        color:                Theme.text-muted;
                        font-size:            14px;
                        horizontal-alignment: center;
                        vertical-alignment:   center;
                    }
                }
            }
        }
    }
}

// ── Library screen — movies or TV shows (rows + browse button) ────────────────
component LibraryScreen inherits Rectangle {
    in property <string>     screen-title: "Library";
    in property <[HomeItem]> continue-watching;
    in property <[HomeItem]> next-up;
    in property <[HomeItem]> recently-added;
    in property <[HomeItem]> not-watched;
    in property <[HomeItem]> all-series:   [];
    in property <int>        kbd-section: -1;
    in property <int>        kbd-card:    0;
    callback item-play(string);
    callback browse;

    background: Theme.bg;

    VerticalLayout {
        spacing: 0px;

        // Page header
        Rectangle {
            height:     54px;
            background: Theme.surface;

            HorizontalLayout {
                padding-left:  Theme.sp-lg;
                padding-right: Theme.sp;
                spacing:       Theme.sp;
                alignment:     space-between;

                Text {
                    text:               screen-title;
                    color:              Theme.text;
                    font-size:          18px;
                    font-weight:        700;
                    vertical-alignment: center;
                }
                FjordButton {
                    text:  "Browse All";
                    width: 110px;
                    clicked => { root.browse(); }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
        }

        fl := Flickable {
            vertical-stretch:   1;
            horizontal-stretch: 1;
            viewport-width:     fl.width;
            viewport-height:    max(fl.height, rows.preferred-height);
            viewport-y: kbd-section < 0 ? 0px
                      : clamp(
                            fl.height / 2 - section-y(kbd-section) - 140px,
                            min(0px, fl.height - self.viewport-height),
                            0px
                        );
            animate viewport-y { duration: 150ms; easing: ease-out; }

            rows := VerticalLayout {
                padding: Theme.sp-lg;
                spacing: Theme.sp-lg;

                if continue-watching.length > 0: SectionRow {
                    section-title:   "Continue Watching";
                    items:           continue-watching;
                    section-focused: root.kbd-section == 0;
                    focused-card:    root.kbd-card;
                    item-play(id)   => { root.item-play(id); }
                }
                if next-up.length > 0: SectionRow {
                    section-title:   "Next Up";
                    items:           next-up;
                    section-focused: root.kbd-section == 1;
                    focused-card:    root.kbd-card;
                    item-play(id)   => { root.item-play(id); }
                }
                if recently-added.length > 0: SectionRow {
                    section-title:   "Recently Added";
                    items:           recently-added;
                    section-focused: root.kbd-section == 2;
                    focused-card:    root.kbd-card;
                    item-play(id)   => { root.item-play(id); }
                }
                if not-watched.length > 0: SectionRow {
                    section-title:   "Not Watched";
                    items:           not-watched;
                    section-focused: root.kbd-section == 3;
                    focused-card:    root.kbd-card;
                    item-play(id)   => { root.item-play(id); }
                }
                if all-series.length > 0: SectionRow {
                    section-title:   "All Shows";
                    items:           all-series;
                    section-focused: root.kbd-section == 4;
                    focused-card:    root.kbd-card;
                    item-play(id)   => { root.item-play(id); }
                }
                if continue-watching.length == 0 && next-up.length == 0 && recently-added.length == 0 && not-watched.length == 0: Rectangle {
                    height: 120px;
                    Text {
                        text:                 "Loading library…";
                        color:                Theme.text-muted;
                        font-size:            14px;
                        horizontal-alignment: center;
                        vertical-alignment:   center;
                    }
                }
            }
        }
    }

    pure function section-y(s: int) -> length {
        Theme.sp-lg
        + (continue-watching.length > 0 && s > 0 ? (280px + Theme.sp-lg) : 0px)
        + (next-up.length       > 0 && s > 1 ? (280px + Theme.sp-lg) : 0px)
        + (recently-added.length > 0 && s > 2 ? (280px + Theme.sp-lg) : 0px)
        + (not-watched.length   > 0 && s > 3 ? (280px + Theme.sp-lg) : 0px)
    }
}

// ── Settings screen ───────────────────────────────────────────────────────────
component SettingsScreen inherits Rectangle {
    in property     <string> server-url;
    in-out property <bool>   launch-fullscreen;
    in-out property <bool>   audio-spdif;
    in-out property <string> hwdec;
    in-out property <string> hwdec-image-format;
    in-out property <string> vf;
    in-out property <string> vo;
    in-out property <string> gpu-api;
    in-out property <string> video-sync;
    in-out property <bool>   opengl-early-flush;
    in-out property <bool>   video-latency-hacks;
    in-out property <bool>   interpolation;
    in-out property <string> tscale;
    in-out property <string> tone-mapping;
    in-out property <bool>   target-colorspace-hint;
    in-out property <bool>   deinterlace;
    in-out property <int>    cache-mb;
    in-out property <bool>   video-behind;
    callback sign-out;
    callback settings-changed;

    background: Theme.bg;

    ScrollView {
        viewport-height: card.height + Theme.sp-xl * 2;

        card := Rectangle {
            width:         min(560px, parent.width - 48px);
            height:        inner.preferred-height;
            x:             (parent.width  - self.width)  / 2;
            y:             Theme.sp-xl;
            background:    Theme.surface;
            border-radius: Theme.radius-lg;
            drop-shadow-blur:  20px;
            drop-shadow-color: #00000050;

            inner := VerticalLayout {
                padding:  Theme.sp-xl;
                spacing:  Theme.sp-lg;

                Text { text: "Settings"; color: Theme.text; font-size: 20px; font-weight: 700; }

                Rectangle { height: 1px; background: Theme.border; }

                // ── Server ────────────────────────────────────────────────────
                VerticalLayout {
                    spacing: Theme.sp-sm;
                    Text { text: "SERVER"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }
                    Text {
                        text:      server-url != "" ? server-url : "—";
                        color:     Theme.text; font-size: 14px; overflow: elide;
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── General ───────────────────────────────────────────────────
                Text { text: "GENERAL"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Launch in fullscreen"; color: Theme.text; font-size: 14px; }
                        Text { text: "Start Fjord in fullscreen mode (applies on next launch)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> root.launch-fullscreen; toggled => { root.settings-changed(); } }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── Audio ─────────────────────────────────────────────────────
                Text { text: "AUDIO"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Audio passthrough (SPDIF)"; color: Theme.text; font-size: 14px; }
                        Text { text: "Bitstream TrueHD / DTS-HD MA / AC3 to AV receiver"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox {
                        checked <=> root.audio-spdif;
                        toggled => { root.settings-changed(); }
                    }
                }

                if audio-spdif && video-sync == "display-resample": Text {
                    text:      "⚠  audio passthrough is incompatible with display-resample";
                    color:     Theme.error;
                    font-size: 12px;
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── Video ─────────────────────────────────────────────────────
                Text { text: "VIDEO"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Video output (vo)"; color: Theme.text; font-size: 14px; }
                        Text { text: "gpu-next: HDR10 / Dolby Vision  ·  gpu: legacy fallback"; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["gpu-next", "gpu"]; current-value: root.vo; width: 130px;
                        selected(v) => { root.vo = v; root.settings-changed(); }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "GPU API"; color: Theme.text; font-size: 14px; }
                        Text { text: "auto: mpv default  ·  opengl: classic (use for NVIDIA legacy)  ·  vulkan"; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["auto", "opengl", "vulkan"]; current-value: root.gpu-api; width: 130px;
                        selected(v) => { root.gpu-api = v; root.settings-changed(); }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Hardware decode (hwdec)"; color: Theme.text; font-size: 14px; }
                        Text { text: "AMD: vulkan-copy works fine. NVIDIA legacy: use nvdec-copy + set image format below."; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["auto", "vulkan-copy", "nvdec-copy", "vaapi-copy", "vdpau-copy", "nvdec", "vaapi", "vdpau", "none"];
                        current-value: root.hwdec; width: 140px;
                        selected(v) => { root.hwdec = v; root.settings-changed(); }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "HW decode image format"; color: Theme.text; font-size: 14px; }
                        Text { text: "May help on some drivers. On NVIDIA legacy EGL this has no effect — use the Video filter below instead."; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["", "yuv420p", "yuv420p10le", "nv12", "p010"];
                        current-value: root.hwdec-image-format; width: 140px;
                        selected(v) => { root.hwdec-image-format = v; root.settings-changed(); }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Video filter (vf)"; color: Theme.text; font-size: 14px; }
                        Text { text: "auto: picks nv12/p010 for nvdec or yuv420p/yuv420p10le for nvdec-copy based on detected bit depth. Fixes NVIDIA legacy stride corruption."; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["", "auto", "format=yuv420p", "format=yuv420p10le", "format=nv12", "format=p010"];
                        current-value: root.vf; width: 180px;
                        selected(v) => { root.vf = v; root.settings-changed(); }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Deinterlace"; color: Theme.text; font-size: 14px; }
                        Text { text: "Enable yadif filter (for interlaced broadcast / DVD content)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> root.deinterlace; toggled => { root.settings-changed(); } }
                }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Video in background"; color: Theme.text; font-size: 14px; }
                        Text { text: "Show video behind the interface when you press Back during playback"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> root.video-behind; toggled => { root.settings-changed(); } }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── Synchronisation ───────────────────────────────────────────
                Text { text: "SYNCHRONISATION"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Video sync"; color: Theme.text; font-size: 14px; }
                        Text { text: "display-resample: smooth sync to monitor (needs real vsync — works in Fjord)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["audio", "display-resample", "display-vdrop", "display-adrop"];
                        current-value: root.video-sync; width: 180px;
                        selected(v) => { root.video-sync = v; root.settings-changed(); }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Motion interpolation"; color: Theme.text; font-size: 14px; }
                        Text { text: "Temporal interpolation between frames (best with display-resample)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> root.interpolation; toggled => { root.settings-changed(); } }
                }

                if interpolation: HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Temporal scaler (tscale)"; color: Theme.text; font-size: 14px; }
                        Text { text: "Algorithm used for motion interpolation"; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["oversample", "catmull_rom", "mitchell", "gaussian", "bicubic"];
                        current-value: root.tscale; width: 140px;
                        selected(v) => { root.tscale = v; root.settings-changed(); }
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── HDR ───────────────────────────────────────────────────────
                Text { text: "HDR"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Tone mapping"; color: Theme.text; font-size: 14px; }
                        Text { text: "Algorithm for mapping HDR → SDR.  auto is usually correct."; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["auto", "hable", "bt.2390", "reinhard", "mobius", "clip", "gamma", "linear"];
                        current-value: root.tone-mapping; width: 130px;
                        selected(v) => { root.tone-mapping = v; root.settings-changed(); }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Target colorspace hint"; color: Theme.text; font-size: 14px; }
                        Text { text: "Pass HDR metadata to KDE 6 Plasma for native HDR output"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> root.target-colorspace-hint; toggled => { root.settings-changed(); } }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── NVIDIA Wayland ────────────────────────────────────────────
                Text { text: "NVIDIA WAYLAND"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "OpenGL early flush"; color: Theme.text; font-size: 14px; }
                        Text { text: "Flush GL commands after each frame — reduces jitter with gpu-api=opengl"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> root.opengl-early-flush; toggled => { root.settings-changed(); } }
                }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Video latency hacks"; color: Theme.text; font-size: 14px; }
                        Text { text: "Compensate for imprecise Wayland vsync timestamps (NVIDIA 5xx legacy)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> root.video-latency-hacks; toggled => { root.settings-changed(); } }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── Buffering ─────────────────────────────────────────────────
                Text { text: "BUFFERING"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Demuxer cache (MiB)"; color: Theme.text; font-size: 14px; }
                        Text { text: "0 = mpv default (~150 MiB).  Increase for slow network / large files."; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["0", "50", "150", "300", "500", "1000"];
                        current-value: root.cache-mb == 0 ? "0"
                                     : root.cache-mb == 50 ? "50"
                                     : root.cache-mb == 150 ? "150"
                                     : root.cache-mb == 300 ? "300"
                                     : root.cache-mb == 500 ? "500"
                                     : "1000";
                        width: 100px;
                        selected(v) => {
                            root.cache-mb = v == "0"    ? 0
                                          : v == "50"   ? 50
                                          : v == "150"  ? 150
                                          : v == "300"  ? 300
                                          : v == "500"  ? 500
                                          : 1000;
                            root.settings-changed();
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                FjordButton {
                    text: "Sign Out"; danger: true;
                    clicked => { root.sign-out(); }
                }
            }
        }
    }
}

// ── Stats label row (used inside StatsOverlay) ────────────────────────────────
component StatRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    height: 22px;
    HorizontalLayout {
        spacing: 10px;
        Text {
            text:               label;
            color:              #555555;
            font-size:          11px;
            font-weight:        700;
            width:              60px;
            vertical-alignment: center;
        }
        Text {
            text:               value;
            color:              #cccccc;
            font-size:          11px;
            overflow:           elide;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}


// ── Main window ───────────────────────────────────────────────────────────────
export component MainWindow inherits Window {
    title:            "Fjord";
    background:       Theme.bg;
    min-width:        900px;
    min-height:       520px;
    preferred-width:  1280px;
    preferred-height: 720px;

    // ── Existing API surface ──────────────────────────────────────────────────
    in property     <bool>                   show-login:   true;
    in property     <string>                 status:       "";
    in property     <[StandardListViewItem]> media-items:  [];
    in-out property <int>                    current-item: -1;
    in-out property <int>                    active-nav:   0;

    callback do-login(string, string, string);
    callback play-item(int);
    callback filter-changed(string);
    callback nav-selected(int);

    // ── Home-screen rows ──────────────────────────────────────────────────────
    in property <[HomeItem]> continue-watching:     [];
    in property <[HomeItem]> next-up:               [];
    in property <[HomeItem]> recently-added:        [];
    in property <[HomeItem]> continue-watching-movies: [];
    in property <[HomeItem]> recently-added-movies: [];
    in property <[HomeItem]> not-watched-movies:    [];
    in property <[HomeItem]> continue-watching-tv:  [];
    in property <[HomeItem]> recently-added-tv:     [];
    in property <[HomeItem]> not-watched-tv:        [];

    // ── Browse / settings state ───────────────────────────────────────────────
    in-out property <bool>   show-browse:      false;
    // -1 = sidebar has focus; >=0 = index of focused section in content area
    in-out property <int>    focused-section: -1;
    in-out property <int>    focused-card:     0;
    in property     <string> server-url:  "";

    // ── Player settings (kept in sync with saved config) ─────────────────────
    in-out property <bool>   settings-audio-spdif:           false;
    in-out property <string> settings-hwdec:                 "auto";
    in-out property <string> settings-hwdec-image-format:   "";
    in-out property <string> settings-vf:                   "";
    in-out property <string> settings-vo:                    "gpu-next";
    in-out property <string> settings-gpu-api:               "auto";
    in-out property <string> settings-video-sync:            "audio";
    in-out property <bool>   settings-opengl-early-flush:    false;
    in-out property <bool>   settings-video-latency-hacks:   false;
    in-out property <bool>   settings-interpolation:         false;
    in-out property <string> settings-tscale:                "oversample";
    in-out property <string> settings-tone-mapping:          "auto";
    in-out property <bool>   settings-target-colorspace-hint: false;
    in-out property <bool>   settings-deinterlace:           false;
    in-out property <int>    settings-cache-mb:              0;
    in-out property <bool>   settings-video-behind:          false;

    callback home-item-play(string);
    callback sign-out;
    callback settings-changed;
    callback toggle-fullscreen;
    callback quit;
    // Called once from Rust at startup to give keyboard focus to the nav FocusScope
    callback grab-keyboard-focus;
    grab-keyboard-focus => { fs.focus(); }

    in-out property <bool> settings-launch-fullscreen: false;

    // ── Player state ──────────────────────────────────────────────────────────
    in property     <image>  video-frame;
    in-out property <bool>   is-playing:            false;
    in-out property <bool>   has-background-player: false;
    in-out property <bool>   video-behind-ui:       false;
    in-out property <bool>   is-paused:             false;
    in-out property <string> playing-title:         "";
    in-out property <bool>   stats-visible:         false;

    in property <string> stat-vid-in:   "—";
    in property <string> stat-vid-out:  "—";
    in property <string> stat-color:    "—";
    in property <string> stat-hwdec:    "—";
    in property <string> stat-aud-in:   "—";
    in property <string> stat-aud-out:  "—";
    in property <string> stat-display:  "—";
    in property <string> stat-vsync:    "—";
    in property <string> stat-avsync:   "—";
    in property <string> stat-drop:     "—";
    in property <string> stat-bitrate:  "—";
    in property <string> stat-cache:    "—";

    // Seek bar
    in-out property <float>  playback-pos:   0;
    in-out property <string> playback-time:  "0:00";
    in-out property <string> playback-total: "0:00";

    // Track lists
    in-out property <[TrackEntry]> sub-tracks;
    in-out property <[TrackEntry]> audio-tracks;
    in-out property <[TrackEntry]> video-tracks;
    in-out property <int>          current-sub-id:   0;
    in-out property <int>          current-audio-id: 1;
    in-out property <int>          current-video-id: 1;

    // Player overlay panel: 0 = none, 1 = subtitles, 2 = audio, 3 = video
    in-out property <int> player-open-panel: 0;

    // Controls bar visibility (auto-hides after 3 s idle)
    in-out property <bool> controls-visible: true;

    callback pause-play-toggle;
    callback seek-backward;           // 10 s
    callback seek-forward;            // 10 s
    callback seek-backward-long;      // 30 s
    callback seek-forward-long;       // 30 s
    callback stop-playback;
    callback seek-to(float);          // 0.0–1.0 ratio
    callback select-sub(int);         // track id, 0 = off
    callback select-audio(int);
    callback select-video(int);
    callback commit-panel-selection;  // selects track at player-panel-cursor and closes panel
    callback mute-toggle;
    callback volume-up;
    callback volume-down;
    callback show-controls;           // resets idle timer + makes controls visible
    callback toggle-stats;

    // Cursor position inside the open track panel (Up/Down moves it, Enter commits)
    in-out property <int> player-panel-cursor: 0;
    callback minimize-player;
    callback resume-player;

    // ── Item detail page ──────────────────────────────────────────────────────
    in-out property <bool>   show-detail:         false;
    in-out property <string> detail-id:           "";
    in-out property <bool>   detail-loading:      false;
    in-out property <string> detail-title:        "";
    in-out property <string> detail-series-label: "";  // "Series S01E02" for episodes
    in-out property <string> detail-meta:         "";  // "2023 • PG-13 • 2h 14m"
    in-out property <string> detail-genres:       "";
    in-out property <string> detail-overview:     "";
    in-out property <string> detail-rating-label: "";  // "★ 8.2"
    in-out property <image>  detail-poster;
    in-out property <bool>   detail-has-poster:   false;
    in-out property <image>  detail-backdrop;
    in-out property <bool>   detail-has-backdrop: false;
    in-out property <bool>   detail-can-resume:   false;
    in-out property <string> detail-resume-label: "";  // "Resume from 1:23:45"
    in-out property <[CastMember]> detail-cast;

    callback open-detail(string);  // item id
    callback play-detail;
    callback resume-detail;
    callback close-detail;

    // ── Series drill-down ─────────────────────────────────────────────────────
    in-out property <bool>            show-series:          false;
    in-out property <string>          series-id:            "";
    in-out property <bool>            series-loading:       true;
    in-out property <string>          series-title:         "";
    in-out property <string>          series-overview:      "";
    in-out property <image>           series-poster;
    in-out property <bool>            series-has-poster:    false;
    in-out property <image>           series-backdrop;
    in-out property <bool>            series-has-backdrop:  false;
    in-out property <[SeasonEntry]>   series-seasons;
    in-out property <[EpisodeEntry]>  series-episodes;
    in-out property <int>             series-season-idx:    0;
    in-out property <int>             series-focused-ep:    0;
    in-out property <bool>            series-in-season-row: false;
    in property     <[HomeItem]>      all-movies:           [];
    in property     <[HomeItem]>      all-series:           [];
    in-out property <bool>            show-library:         false;
    in-out property <int>             library-focused:      0;
    property        <int>             library-cols:         6;

    callback open-series(string);
    callback series-select-season(int);
    callback play-series-episode(string);
    callback close-series;

    // ── Section navigation helpers ────────────────────────────────────────────
    pure function max-sections() -> int {
        active-nav == 0 ? 3 : active-nav == 2 ? 5 : 4
    }
    pure function section-len(s: int) -> int {
        if active-nav == 0 {
            return s == 0 ? continue-watching.length
                 : s == 1 ? next-up.length
                 : s == 2 ? recently-added.length
                 : 0;
        }
        if active-nav == 1 {
            return s == 0 ? continue-watching-movies.length
                 : s == 1 ? 0
                 : s == 2 ? recently-added-movies.length
                 : s == 3 ? not-watched-movies.length
                 : 0;
        }
        if active-nav == 2 {
            return s == 0 ? continue-watching-tv.length
                 : s == 1 ? next-up.length
                 : s == 2 ? recently-added-tv.length
                 : s == 3 ? not-watched-tv.length
                 : s == 4 ? all-series.length
                 : 0;
        }
        return 0;
    }
    pure function find-first-section() -> int {
        if section-len(0) > 0 { return 0; }
        if section-len(1) > 0 { return 1; }
        if section-len(2) > 0 { return 2; }
        if section-len(3) > 0 { return 3; }
        if section-len(4) > 0 { return 4; }
        return -1;
    }
    pure function find-next-section(from: int) -> int {
        if from + 1 < max-sections() && section-len(from + 1) > 0 { return from + 1; }
        if from + 2 < max-sections() && section-len(from + 2) > 0 { return from + 2; }
        if from + 3 < max-sections() && section-len(from + 3) > 0 { return from + 3; }
        return from;
    }
    // Returns -1 to signal "go back to sidebar" when already at the first section.
    pure function find-prev-section(from: int) -> int {
        if from - 1 >= 0 && section-len(from - 1) > 0 { return from - 1; }
        if from - 2 >= 0 && section-len(from - 2) > 0 { return from - 2; }
        if from - 3 >= 0 && section-len(from - 3) > 0 { return from - 3; }
        return -1;
    }
    pure function section-card-id(s: int, c: int) -> string {
        if active-nav == 0 {
            return s == 0 ? continue-watching[c].id
                 : s == 1 ? next-up[c].id
                 : s == 2 ? recently-added[c].id
                 : "";
        }
        if active-nav == 1 {
            return s == 0 ? continue-watching-movies[c].id
                 : s == 2 ? recently-added-movies[c].id
                 : s == 3 ? not-watched-movies[c].id
                 : "";
        }
        if active-nav == 2 {
            return s == 0 ? continue-watching-tv[c].id
                 : s == 1 ? next-up[c].id
                 : s == 2 ? recently-added-tv[c].id
                 : s == 3 ? not-watched-tv[c].id
                 : s == 4 ? all-series[c].id
                 : "";
        }
        return "";
    }

    // Global keyboard shortcuts — named so grab-keyboard-focus can call fs.focus()
    fs := FocusScope {
        width: 0; height: 0;
        key-pressed(event) => {
            if root.show-login { return reject; }

            // ── Series drill-down ──────────────────────────────────────────────
            if root.show-series {
                if event.text == Key.Escape || event.text == Key.Backspace {
                    root.close-series();
                    return accept;
                }
                if root.series-in-season-row {
                    if event.text == Key.LeftArrow {
                        if root.series-season-idx > 0 {
                            root.series-season-idx -= 1;
                            root.series-select-season(root.series-season-idx);
                            root.series-focused-ep = 0;
                        }
                        return accept;
                    }
                    if event.text == Key.RightArrow {
                        if root.series-season-idx < root.series-seasons.length - 1 {
                            root.series-season-idx += 1;
                            root.series-select-season(root.series-season-idx);
                            root.series-focused-ep = 0;
                        }
                        return accept;
                    }
                    if event.text == Key.DownArrow {
                        root.series-in-season-row = false;
                        return accept;
                    }
                    return reject;
                }
                // Episode list navigation
                if event.text == Key.UpArrow {
                    if root.series-focused-ep > 0 {
                        root.series-focused-ep -= 1;
                    } else {
                        root.series-in-season-row = true;
                    }
                    return accept;
                }
                if event.text == Key.DownArrow {
                    if root.series-focused-ep < root.series-episodes.length - 1 {
                        root.series-focused-ep += 1;
                    }
                    return accept;
                }
                if event.text == Key.Return || event.text == " " {
                    if root.series-episodes.length > 0 {
                        root.play-series-episode(root.series-episodes[root.series-focused-ep].id);
                    }
                    return accept;
                }
                return reject;
            }

            // ── Detail page ────────────────────────────────────────────────────
            if root.show-detail {
                if event.text == Key.Escape || event.text == Key.Backspace {
                    root.close-detail();
                    return accept;
                }
                if event.text == Key.Return || event.text == " " {
                    root.play-detail();
                    return accept;
                }
                if event.text == "r" || event.text == "R" {
                    if root.detail-can-resume { root.resume-detail(); }
                    return accept;
                }
                return reject;
            }

            // ── Player mode ────────────────────────────────────────────────────
            if root.is-playing {
                // Any key shows controls and resets idle timer
                root.show-controls();

                // Escape / Backspace: close open panel first, then stop
                if event.text == Key.Escape || event.text == Key.Backspace {
                    if root.player-open-panel != 0 {
                        root.player-open-panel = 0;
                        root.player-panel-cursor = 0;
                    } else {
                        root.stop-playback();
                    }
                    return accept;
                }

                // ── Panel navigation (when a track panel is open) ───────────────
                if root.player-open-panel != 0 {
                    if event.text == Key.UpArrow {
                        if root.player-panel-cursor > 0 {
                            root.player-panel-cursor -= 1;
                        }
                        return accept;
                    }
                    if event.text == Key.DownArrow {
                        if root.player-open-panel == 1 {
                            // Sub: 0=Off, 1..N=tracks
                            if root.player-panel-cursor < root.sub-tracks.length {
                                root.player-panel-cursor += 1;
                            }
                        } else if root.player-open-panel == 2 {
                            // Audio: 0..N-1=tracks
                            if root.player-panel-cursor < root.audio-tracks.length - 1 {
                                root.player-panel-cursor += 1;
                            }
                        } else if root.player-open-panel == 3 {
                            // Video: 0..N-1=tracks
                            if root.player-panel-cursor < root.video-tracks.length - 1 {
                                root.player-panel-cursor += 1;
                            }
                        }
                        return accept;
                    }
                    if event.text == Key.Return {
                        root.commit-panel-selection();
                        root.player-open-panel = 0;
                        root.player-panel-cursor = 0;
                        return accept;
                    }
                }

                // Space / k / p: pause/play toggle (Jellyfin/Kodi/mpv standard)
                if event.text == " " || event.text == "k" || event.text == "K"
                                     || event.text == "p" || event.text == "P" {
                    root.pause-play-toggle();
                    return accept;
                }
                // Arrow keys: seek ±10s; Shift+arrow: ±30s (Jellyfin standard)
                // Up/Down: volume ±5 when no panel is open
                if event.text == Key.LeftArrow {
                    if event.modifiers.shift { root.seek-backward-long(); }
                    else { root.seek-backward(); }
                    return accept;
                }
                if event.text == Key.RightArrow {
                    if event.modifiers.shift { root.seek-forward-long(); }
                    else { root.seek-forward(); }
                    return accept;
                }
                if event.text == Key.UpArrow {
                    root.volume-up();
                    return accept;
                }
                if event.text == Key.DownArrow {
                    root.volume-down();
                    return accept;
                }
                // S: toggle subtitle panel
                if event.text == "s" || event.text == "S" {
                    root.player-open-panel = root.player-open-panel == 1 ? 0 : 1;
                    root.player-panel-cursor = 0;
                    return accept;
                }
                // A: toggle audio panel
                if event.text == "a" || event.text == "A" {
                    root.player-open-panel = root.player-open-panel == 2 ? 0 : 2;
                    root.player-panel-cursor = 0;
                    return accept;
                }
                // V: toggle video panel
                if event.text == "v" || event.text == "V" {
                    root.player-open-panel = root.player-open-panel == 3 ? 0 : 3;
                    root.player-panel-cursor = 0;
                    return accept;
                }
                // M: mute toggle
                if event.text == "m" || event.text == "M" {
                    root.mute-toggle();
                    return accept;
                }
                // I: toggle stats overlay (like mpv's I key)
                if event.text == "i" || event.text == "I" {
                    root.toggle-stats();
                    return accept;
                }
                // F / F11: fullscreen
                if event.text == "f" || event.text == "F" || event.text == Key.F11 {
                    root.toggle-fullscreen();
                    return accept;
                }
                // 0–9: seek to 0%–90% of duration (mpv/VLC convention)
                if event.text == "0" { root.seek-to(0.0);  return accept; }
                if event.text == "1" { root.seek-to(0.1);  return accept; }
                if event.text == "2" { root.seek-to(0.2);  return accept; }
                if event.text == "3" { root.seek-to(0.3);  return accept; }
                if event.text == "4" { root.seek-to(0.4);  return accept; }
                if event.text == "5" { root.seek-to(0.5);  return accept; }
                if event.text == "6" { root.seek-to(0.6);  return accept; }
                if event.text == "7" { root.seek-to(0.7);  return accept; }
                if event.text == "8" { root.seek-to(0.8);  return accept; }
                if event.text == "9" { root.seek-to(0.9);  return accept; }
                return reject;
            }

            // Resume background player with R or Enter from sidebar
            if root.has-background-player && !root.show-browse {
                if event.text == "r" || event.text == "R" {
                    root.resume-player();
                    return accept;
                }
            }

            // Backspace / Escape: go back one level
            if event.text == Key.Backspace || event.text == Key.Escape {
                if root.show-browse {
                    root.show-browse = false;
                    fs.focus();
                    return accept;
                }
                if root.show-library {
                    root.show-library = false;
                    return accept;
                }
                if root.focused-section >= 0 {
                    root.focused-section = -1;
                    return accept;
                }
                return reject;
            }

            // f / F / F11: toggle fullscreen
            if event.text == "f" || event.text == "F" || event.text == Key.F11 {
                root.toggle-fullscreen();
                return accept;
            }

            // q / Q: quit
            if event.text == "q" || event.text == "Q" {
                root.quit();
                return accept;
            }

            // b / B: open browse list for current tab
            if event.text == "b" || event.text == "B" {
                if root.active-nav < 10 { root.show-library = false; root.show-browse = true; }
                return accept;
            }

            // 1 / 2 / 3 / s: jump to tab, return to sidebar
            if event.text == "1" { root.show-browse = false; root.show-library = false; root.focused-section = -1; root.active-nav = 0; root.nav-selected(0); return accept; }
            if event.text == "2" { root.show-browse = false; root.show-library = false; root.focused-section = -1; root.active-nav = 1; root.nav-selected(1); return accept; }
            if event.text == "3" { root.show-browse = false; root.show-library = false; root.focused-section = -1; root.active-nav = 2; root.nav-selected(2); return accept; }
            if event.text == "s" || event.text == "S" { root.show-browse = false; root.show-library = false; root.focused-section = -1; root.active-nav = 10; root.nav-selected(10); return accept; }

            // Library grid navigation (arrows + Enter consumed; other keys fall through)
            if root.show-library {
                if event.text == Key.LeftArrow {
                    if root.library-focused > 0 { root.library-focused -= 1; }
                    return accept;
                }
                if event.text == Key.RightArrow {
                    if root.library-focused < (root.active-nav == 1 ? root.all-movies.length : root.all-series.length) - 1 {
                        root.library-focused += 1;
                    }
                    return accept;
                }
                if event.text == Key.UpArrow {
                    if root.library-focused >= root.library-cols { root.library-focused -= root.library-cols; }
                    return accept;
                }
                if event.text == Key.DownArrow {
                    if root.library-focused + root.library-cols < (root.active-nav == 1 ? root.all-movies.length : root.all-series.length) {
                        root.library-focused += root.library-cols;
                    }
                    return accept;
                }
                if event.text == Key.Return {
                    if root.active-nav == 1 && root.library-focused < root.all-movies.length {
                        root.open-detail(root.all-movies[root.library-focused].id);
                    } else if root.active-nav == 2 && root.library-focused < root.all-series.length {
                        root.open-detail(root.all-series[root.library-focused].id);
                    }
                    return accept;
                }
            }

            // Up arrow
            if event.text == Key.UpArrow {
                if root.show-browse {
                    root.current-item = root.current-item <= 0 ? 0 : root.current-item - 1;
                } else if root.focused-section < 0 {
                    // Sidebar: cycle up (0→10, 1→0, 2→1, 10→2)
                    root.show-library = false;
                    root.active-nav = root.active-nav == 0 ? 10
                                    : root.active-nav == 1 ? 0
                                    : root.active-nav == 2 ? 1
                                    : 2;
                    root.nav-selected(root.active-nav);
                } else {
                    // Content: prev section; -1 means back to sidebar
                    root.focused-section = find-prev-section(root.focused-section);
                    root.focused-card = 0;
                }
                return accept;
            }

            // Down arrow
            if event.text == Key.DownArrow {
                if root.show-browse {
                    root.current-item = root.current-item < 0 ? 0
                                      : root.current-item >= root.media-items.length - 1 ? root.media-items.length - 1
                                      : root.current-item + 1;
                } else if root.focused-section < 0 {
                    // Sidebar: cycle down (0→1, 1→2, 2→10, 10→0)
                    root.show-library = false;
                    root.active-nav = root.active-nav == 0 ? 1
                                    : root.active-nav == 1 ? 2
                                    : root.active-nav == 2 ? 10
                                    : 0;
                    root.nav-selected(root.active-nav);
                } else {
                    // Content: next section (stays at last if already there)
                    root.focused-section = find-next-section(root.focused-section);
                    root.focused-card = 0;
                }
                return accept;
            }

            // Left arrow: prev card, or back to sidebar at card 0
            if event.text == Key.LeftArrow && !root.show-browse && root.focused-section >= 0 {
                if root.focused-card > 0 {
                    root.focused-card = root.focused-card - 1;
                } else {
                    root.focused-section = -1;
                }
                return accept;
            }

            // Right arrow: enter content grid from sidebar, or next card within row
            if event.text == Key.RightArrow && !root.show-browse {
                if root.focused-section < 0 && root.active-nav < 10 {
                    root.focused-section = find-first-section();
                    root.focused-card = 0;
                } else if root.focused-section >= 0 {
                    if root.focused-card < section-len(root.focused-section) - 1 {
                        root.focused-card = root.focused-card + 1;
                    }
                }
                return accept;
            }

            // Enter: open detail / enter content grid (browse list keeps direct play)
            if event.text == Key.Return {
                if root.show-browse && root.current-item >= 0 {
                    root.play-item(root.current-item);
                    return accept;
                }
                if root.focused-section >= 0 && !root.show-browse {
                    root.open-detail(section-card-id(root.focused-section, root.focused-card));
                    return accept;
                }
                if root.focused-section < 0 && root.active-nav < 10 {
                    if root.active-nav == 1 || root.active-nav == 2 {
                        root.show-library    = true;
                        root.library-focused = 0;
                    } else {
                        root.focused-section = find-first-section();
                        root.focused-card    = 0;
                    }
                    return accept;
                }
                return reject;
            }

            reject
        }
    }

    // ── Video-behind-UI background layer ─────────────────────────────────────
    if video-behind-ui && !is-playing: Rectangle {
        background: #000000;
        Image {
            source:    video-frame;
            width:     parent.width;
            height:    parent.height;
            image-fit: contain;
        }
        // Dim overlay so the UI panels are readable
        Rectangle { background: #00000077; }
    }

    // ── Login screen ──────────────────────────────────────────────────────────
    if show-login: Rectangle {
        background: Theme.bg;

        card := Rectangle {
            width:         min(420px, parent.width - 48px);
            height:        inner.preferred-height;
            x:             (parent.width  - self.width)  / 2;
            y:             (parent.height - self.height) / 2 - 24px;
            background:    Theme.surface;
            border-radius: Theme.radius-lg;
            drop-shadow-blur:  28px;
            drop-shadow-color: #00000070;

            inner := VerticalLayout {
                padding: Theme.sp-xl;
                spacing: Theme.sp;

                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text:                 "Fjord";
                        color:                Theme.accent;
                        font-size:            38px;
                        font-weight:          700;
                        horizontal-alignment: center;
                    }
                    Text {
                        text:                 "Jellyfin media player";
                        color:                Theme.text-muted;
                        font-size:            13px;
                        horizontal-alignment: center;
                    }
                }

                Rectangle { height: 6px; }

                server-input := LineEdit {
                    placeholder-text: "Server URL  (e.g. http://192.168.1.10:8096)";
                    height: 40px;
                }
                user-input := LineEdit {
                    placeholder-text: "Username";
                    height: 40px;
                }
                pass-input := LineEdit {
                    placeholder-text: "Password";
                    input-type:       password;
                    height:           40px;
                    accepted => {
                        root.do-login(server-input.text, user-input.text, pass-input.text);
                    }
                }

                FjordButton {
                    text: "Connect";
                    clicked => {
                        root.do-login(server-input.text, user-input.text, pass-input.text);
                    }
                }

                if status != "": Text {
                    text:                 status;
                    color:                Theme.text-muted;
                    font-size:            13px;
                    horizontal-alignment: center;
                    wrap:                 word-wrap;
                }
            }
        }
    }

    // ── Logged-in layout: sidebar + content ───────────────────────────────────
    if !show-login: HorizontalLayout {
        opacity: video-behind-ui ? 0.88 : 1.0;
        spacing: 0px;

        // ── Sidebar ───────────────────────────────────────────────────────────
        Rectangle {
            width:      Theme.sidebar-width;
            background: Theme.sidebar-bg;

            VerticalLayout {
                padding:     Theme.sp;
                padding-top: Theme.sp-lg;
                spacing:     3px;

                Rectangle {
                    height: 48px;
                    VerticalLayout {
                        alignment: center;
                        spacing:   2px;
                        Text { text: "Fjord";     color: Theme.accent;       font-size: 20px; font-weight: 700; }
                        Text { text: "Jellyfin";  color: Theme.text-subtle;  font-size: 11px; }
                    }
                }

                Rectangle { height: Theme.sp; }

                NavItem {
                    label: "Home";
                    active: root.active-nav == 0;
                    kbd-focused: root.focused-section < 0;
                    clicked => {
                        root.show-browse   = false;
                        root.show-library  = false;
                        root.active-nav    = 0;
                        root.nav-selected(0);
                        root.focused-section = -1;
                    }
                }
                NavItem {
                    label: "Movies";
                    active: root.active-nav == 1;
                    kbd-focused: root.focused-section < 0;
                    clicked => {
                        root.show-browse   = false;
                        root.show-library  = false;
                        root.active-nav    = 1;
                        root.nav-selected(1);
                        root.focused-section = -1;
                    }
                    double-clicked => {
                        root.active-nav       = 1;
                        root.nav-selected(1);
                        root.show-browse      = false;
                        root.show-library     = true;
                        root.library-focused  = 0;
                        root.focused-section  = -1;
                    }
                }
                NavItem {
                    label: "TV Shows";
                    active: root.active-nav == 2;
                    kbd-focused: root.focused-section < 0;
                    clicked => {
                        root.show-browse   = false;
                        root.show-library  = false;
                        root.active-nav    = 2;
                        root.nav-selected(2);
                        root.focused-section = -1;
                    }
                    double-clicked => {
                        root.active-nav       = 2;
                        root.nav-selected(2);
                        root.show-browse      = false;
                        root.show-library     = true;
                        root.library-focused  = 0;
                        root.focused-section  = -1;
                    }
                }

                Rectangle { vertical-stretch: 1; }

                // Mini player shown when video is playing in the background
                if has-background-player: Rectangle {
                    height:        video-behind-ui ? 74px : 148px;
                    background:    Theme.surface-raised;
                    border-radius: Theme.radius;
                    clip:          true;

                    VerticalLayout {
                        spacing: 0px;

                        // Thumbnail — only when video is NOT shown behind the UI
                        if !video-behind-ui: Rectangle {
                            height:     80px;
                            background: #000000;
                            clip:       true;
                            Image {
                                source:    video-frame;
                                width:     parent.width;
                                height:    parent.height;
                                image-fit: contain;
                            }
                        }

                        VerticalLayout {
                            padding:   8px;
                            spacing:   4px;
                            alignment: center;

                            Text {
                                text:        "NOW PLAYING";
                                color:       Theme.accent;
                                font-size:   9px;
                                font-weight: 700;
                            }
                            Text {
                                text:      playing-title;
                                color:     Theme.text;
                                font-size: 12px;
                                overflow:  elide;
                            }
                            FjordButton {
                                text:   "▶  Resume";
                                height: 28px;
                                clicked => { root.resume-player(); }
                            }
                        }
                    }
                }

                Rectangle { height: 4px; }

                NavItem {
                    label: "Settings";
                    active: root.active-nav == 10;
                    kbd-focused: root.focused-section < 0;
                    clicked => {
                        root.show-browse  = false;
                        root.show-library = false;
                        root.active-nav  = 10;
                        root.nav-selected(10);
                        root.focused-section = -1;
                    }
                }

                Rectangle {
                    height: 36px;
                    border-radius: Theme.radius;
                    background: ta-quit.has-hover ? #3a1a1a : #00000000;
                    ta-quit := TouchArea {
                        clicked => { root.quit(); }
                    }
                    HorizontalLayout {
                        padding-left: 14px;
                        spacing:      10px;
                        alignment:    start;
                        Rectangle {
                            width: 6px;
                            Rectangle {
                                width: 6px; height: 6px; border-radius: 3px;
                                y: (parent.height - self.height) / 2;
                                background: Theme.error;
                            }
                        }
                        Text {
                            text: "Quit";
                            color: Theme.error;
                            font-size: 14px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        Rectangle { width: 1px; background: Theme.border; }

        // ── Content: mutually-exclusive screens ───────────────────────────────

        if show-browse: BrowseScreen {
            horizontal-stretch: 1;
            status:              root.status;
            media-items:         root.media-items;
            current-item        <=> root.current-item;
            filter-changed(q)   => { root.filter-changed(q); }
            play-item(i)        => { root.play-item(i); }
            back                => { root.show-browse = false; fs.focus(); }
        }

        if !show-browse && active-nav == 0: HomeScreen {
            horizontal-stretch: 1;
            continue-watching:  root.continue-watching;
            next-up:            root.next-up;
            recently-added:     root.recently-added;
            kbd-section:        root.focused-section;
            kbd-card:           root.focused-card;
            item-play(id)       => { root.home-item-play(id); }
            browse              => { root.show-browse = true; }
        }

        if !show-browse && active-nav == 1 && !show-library: LibraryScreen {
            horizontal-stretch:  1;
            screen-title:        "Movies";
            continue-watching:   root.continue-watching-movies;
            recently-added:      root.recently-added-movies;
            not-watched:         root.not-watched-movies;
            kbd-section:         root.focused-section;
            kbd-card:            root.focused-card;
            item-play(id)        => { root.home-item-play(id); }
            browse               => { root.show-browse = true; }
        }

        if !show-browse && active-nav == 1 && show-library: LibraryGrid {
            horizontal-stretch: 1;
            grid-title:         "All Movies";
            items:              root.all-movies;
            focused-idx:        root.library-focused;
            item-open(id)       => { root.open-detail(id); }
            back                => { root.show-library = false; }
        }

        if !show-browse && active-nav == 2 && !show-library: LibraryScreen {
            horizontal-stretch:  1;
            screen-title:        "TV Shows";
            continue-watching:   root.continue-watching-tv;
            next-up:             root.next-up;
            recently-added:      root.recently-added-tv;
            not-watched:         root.not-watched-tv;
            all-series:          root.all-series;
            kbd-section:         root.focused-section;
            kbd-card:            root.focused-card;
            item-play(id)        => { root.home-item-play(id); }
            browse               => { root.show-browse = true; }
        }

        if !show-browse && active-nav == 2 && show-library: LibraryGrid {
            horizontal-stretch: 1;
            grid-title:         "All Shows";
            items:              root.all-series;
            focused-idx:        root.library-focused;
            item-open(id)       => { root.open-detail(id); }
            back                => { root.show-library = false; }
        }

        if !show-browse && active-nav == 10: SettingsScreen {
            horizontal-stretch:          1;
            server-url:                  root.server-url;
            launch-fullscreen          <=> root.settings-launch-fullscreen;
            audio-spdif                <=> root.settings-audio-spdif;
            hwdec                      <=> root.settings-hwdec;
            hwdec-image-format         <=> root.settings-hwdec-image-format;
            vf                         <=> root.settings-vf;
            vo                         <=> root.settings-vo;
            gpu-api                    <=> root.settings-gpu-api;
            video-sync                 <=> root.settings-video-sync;
            opengl-early-flush         <=> root.settings-opengl-early-flush;
            video-latency-hacks        <=> root.settings-video-latency-hacks;
            interpolation              <=> root.settings-interpolation;
            tscale                     <=> root.settings-tscale;
            tone-mapping               <=> root.settings-tone-mapping;
            target-colorspace-hint     <=> root.settings-target-colorspace-hint;
            deinterlace                <=> root.settings-deinterlace;
            cache-mb                   <=> root.settings-cache-mb;
            video-behind               <=> root.settings-video-behind;
            sign-out                    => { root.sign-out(); }
            settings-changed            => { root.settings-changed(); }
        }
    }

    // ── Player screen (covers the full window when playing) ───────────────────
    if is-playing: Rectangle {
        background: #000000;

        // Video frame — filled by the GL rendering notifier each frame
        Image {
            source:     video-frame;
            width:      parent.width;
            height:     parent.height;
            image-fit:  contain;
        }

        // Mouse activity detector — click to pause/play, move to show controls
        // Sits above the image but below the ctrl-bar (z-order = declaration order)
        TouchArea {
            width:        parent.width;
            height:       parent.height;
            mouse-cursor: root.controls-visible ? MouseCursor.default : MouseCursor.none;
            clicked => {
                root.pause-play-toggle();
                root.show-controls();
            }
            moved => { root.show-controls(); }
        }

        // Semi-transparent controls bar at the bottom
        ctrl-bar := Rectangle {
            y:          parent.height - self.height;
            height:     158px;
            background: #000000dd;
            opacity:    root.controls-visible ? 1.0 : 0.0;
            animate opacity { duration: 300ms; }

            VerticalLayout {
                padding:   12px;
                spacing:   9px;
                alignment: center;

                // Title
                Text {
                    text:                 playing-title;
                    color:                #ffffff;
                    font-size:            13px;
                    overflow:             elide;
                    horizontal-alignment: center;
                }

                // Seek bar row
                HorizontalLayout {
                    spacing: 10px;
                    alignment: center;

                    seek-track := Rectangle {
                        height:           6px;
                        horizontal-stretch: 1;
                        background:       #444444;
                        border-radius:    3px;

                        // Filled progress
                        Rectangle {
                            x:            0;
                            width:        playback-pos * parent.width;
                            height:       parent.height;
                            background:   Theme.accent;
                            border-radius: 3px;
                        }
                        // Scrub handle
                        Rectangle {
                            x:            playback-pos * parent.width - 7px;
                            y:            -5px;
                            width:        14px;
                            height:       14px;
                            border-radius: 7px;
                            background:   #ffffff;
                        }
                        // Click-to-seek touch area
                        seek-ta := TouchArea {
                            clicked => {
                                root.seek-to(max(0, min(1, seek-ta.mouse-x / seek-track.width)));
                            }
                            moved => {
                                if seek-ta.pressed {
                                    root.seek-to(max(0, min(1, seek-ta.mouse-x / seek-track.width)));
                                }
                            }
                        }
                    }

                    Text {
                        text:      playback-time + " / " + playback-total;
                        color:     #bbbbbb;
                        font-size: 12px;
                        width:     108px;
                    }
                }

                // Buttons row
                HorizontalLayout {
                    alignment: center;
                    spacing:   8px;

                    FjordButton { text: "← Back";  width: 76px;  clicked => { root.minimize-player(); } }
                    FjordButton { text: "◀◀ 30s";  width: 80px;  clicked => { root.seek-backward-long(); } }
                    FjordButton {
                        text:  is-paused ? "▶ Play" : "⏸ Pause";
                        width: 80px;
                        clicked => { root.pause-play-toggle(); }
                    }
                    FjordButton { text: "30s ▶▶";  width: 80px;  clicked => { root.seek-forward-long(); } }
                    FjordButton { text: "■ Stop";   width: 72px;  danger: true; clicked => { root.stop-playback(); } }

                    // Track selector buttons
                    FjordButton {
                        text:  "Sub ▾";
                        width: 68px;
                        clicked => { root.player-open-panel = root.player-open-panel == 1 ? 0 : 1; root.player-panel-cursor = 0; }
                    }
                    FjordButton {
                        text:  "Audio ▾";
                        width: 76px;
                        clicked => { root.player-open-panel = root.player-open-panel == 2 ? 0 : 2; root.player-panel-cursor = 0; }
                    }
                    FjordButton {
                        text:  "Video ▾";
                        width: 76px;
                        clicked => { root.player-open-panel = root.player-open-panel == 3 ? 0 : 3; root.player-panel-cursor = 0; }
                    }
                    FjordButton {
                        text:  stats-visible ? "Hide Stats" : "Stats";
                        width: 82px;
                        clicked => { root.toggle-stats(); }
                    }
                }
            }
        }

        // Inline stats overlay — top-right corner, no separate window
        if stats-visible: Rectangle {
            x:             parent.width - self.width - 16px;
            y:             16px;
            width:         420px;
            height:        stats-inner.preferred-height;
            background:    #0d0d0dcc;
            border-radius: Theme.radius;

            stats-inner := VerticalLayout {
                padding:   16px;
                spacing:   0px;

                Text {
                    text:        "Playback Stats";
                    color:       Theme.accent;
                    font-size:   12px;
                    font-weight: 700;
                    height:      22px;
                }
                Rectangle { height: 1px; background: #2a2a2a; }
                Rectangle { height: 8px; }

                StatRow { label: "VID IN";   value: stat-vid-in;  }
                StatRow { label: "VID OUT";  value: stat-vid-out; }
                StatRow { label: "COLOR";    value: stat-color;   }
                StatRow { label: "HWDEC";    value: stat-hwdec;   }

                Rectangle { height: 6px; }
                Rectangle { height: 1px; background: #1f1f1f; }
                Rectangle { height: 6px; }

                StatRow { label: "AUD IN";   value: stat-aud-in;  }
                StatRow { label: "AUD OUT";  value: stat-aud-out; }

                Rectangle { height: 6px; }
                Rectangle { height: 1px; background: #1f1f1f; }
                Rectangle { height: 6px; }

                StatRow { label: "DISPLAY";  value: stat-display; }
                StatRow { label: "VSYNC";    value: stat-vsync;   }
                StatRow { label: "A/V";      value: stat-avsync;  }
                StatRow { label: "DROP";     value: stat-drop;    }
                StatRow { label: "BITRATE";  value: stat-bitrate; }
                StatRow { label: "CACHE";    value: stat-cache;   }
            }
        }

        // ── Subtitle track panel ──────────────────────────────────────────────
        if root.player-open-panel == 1: Rectangle {
            y:             parent.height - ctrl-bar.height - sub-panel-inner.preferred-height - 24px;
            x:             parent.width - self.width - 16px;
            width:         220px;
            height:        sub-panel-inner.preferred-height + 16px;
            background:    #0e0e0eee;
            border-radius: Theme.radius-lg;

            sub-panel-inner := VerticalLayout {
                padding: 8px;
                spacing: 2px;

                Text {
                    text:        "Subtitles";
                    color:       Theme.accent;
                    font-size:   11px;
                    font-weight: 700;
                    height:      24px;
                }

                // "Off" entry — cursor index 0
                Rectangle {
                    height:        32px;
                    border-radius: Theme.radius;
                    background:    root.player-panel-cursor == 0
                                   ? Theme.surface-overlay
                                   : (current-sub-id == 0 ? Theme.accent-muted : transparent);
                    HorizontalLayout {
                        padding-left: 10px; padding-right: 10px;
                        alignment: center;
                        Text {
                            text:  "Off";
                            color: current-sub-id == 0 ? Theme.accent : Theme.text;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        clicked => {
                            root.select-sub(0);
                            root.current-sub-id = 0;
                            root.player-open-panel = 0;
                            root.player-panel-cursor = 0;
                        }
                    }
                }

                // Tracks — cursor index i+1
                for t[i] in sub-tracks: Rectangle {
                    height:        32px;
                    border-radius: Theme.radius;
                    background:    root.player-panel-cursor == i + 1
                                   ? Theme.surface-overlay
                                   : (current-sub-id == t.id ? Theme.accent-muted : transparent);
                    HorizontalLayout {
                        padding-left: 10px; padding-right: 10px;
                        alignment: center;
                        Text {
                            text:  t.label;
                            color: current-sub-id == t.id ? Theme.accent : Theme.text;
                            font-size: 12px;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        clicked => {
                            root.select-sub(t.id);
                            root.current-sub-id = t.id;
                            root.player-open-panel = 0;
                            root.player-panel-cursor = 0;
                        }
                    }
                }
            }
        }

        // ── Audio track panel ─────────────────────────────────────────────────
        if root.player-open-panel == 2: Rectangle {
            y:             parent.height - ctrl-bar.height - aud-panel-inner.preferred-height - 24px;
            x:             parent.width - self.width - 16px;
            width:         220px;
            height:        aud-panel-inner.preferred-height + 16px;
            background:    #0e0e0eee;
            border-radius: Theme.radius-lg;

            aud-panel-inner := VerticalLayout {
                padding: 8px;
                spacing: 2px;

                Text {
                    text:        "Audio";
                    color:       Theme.accent;
                    font-size:   11px;
                    font-weight: 700;
                    height:      24px;
                }

                // Tracks — cursor index i
                for t[i] in audio-tracks: Rectangle {
                    height:        32px;
                    border-radius: Theme.radius;
                    background:    root.player-panel-cursor == i
                                   ? Theme.surface-overlay
                                   : (current-audio-id == t.id ? Theme.accent-muted : transparent);
                    HorizontalLayout {
                        padding-left: 10px; padding-right: 10px;
                        alignment: center;
                        Text {
                            text:  t.label;
                            color: current-audio-id == t.id ? Theme.accent : Theme.text;
                            font-size: 12px;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        clicked => {
                            root.select-audio(t.id);
                            root.current-audio-id = t.id;
                            root.player-open-panel = 0;
                            root.player-panel-cursor = 0;
                        }
                    }
                }
            }
        }

        // ── Video track panel ─────────────────────────────────────────────────
        if root.player-open-panel == 3: Rectangle {
            y:             parent.height - ctrl-bar.height - vid-panel-inner.preferred-height - 24px;
            x:             parent.width - self.width - 16px;
            width:         220px;
            height:        vid-panel-inner.preferred-height + 16px;
            background:    #0e0e0eee;
            border-radius: Theme.radius-lg;

            vid-panel-inner := VerticalLayout {
                padding: 8px;
                spacing: 2px;

                Text {
                    text:        "Video";
                    color:       Theme.accent;
                    font-size:   11px;
                    font-weight: 700;
                    height:      24px;
                }

                for t[i] in video-tracks: Rectangle {
                    height:        32px;
                    border-radius: Theme.radius;
                    background:    root.player-panel-cursor == i
                                   ? Theme.surface-overlay
                                   : (current-video-id == t.id ? Theme.accent-muted : transparent);
                    HorizontalLayout {
                        padding-left: 10px; padding-right: 10px;
                        alignment: center;
                        Text {
                            text:  t.label;
                            color: current-video-id == t.id ? Theme.accent : Theme.text;
                            font-size: 12px;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        clicked => {
                            root.select-video(t.id);
                            root.current-video-id = t.id;
                            root.player-open-panel = 0;
                            root.player-panel-cursor = 0;
                        }
                    }
                }
            }
        }
    }

    // ── Series drill-down screen ──────────────────────────────────────────────
    if show-series: Rectangle {
        background: Theme.bg;

        VerticalLayout {

            // Backdrop strip
            if series-has-backdrop: Rectangle {
                height: 260px;
                clip:   true;
                Image {
                    source:    series-backdrop;
                    width:     parent.width;
                    height:    parent.height;
                    image-fit: cover;
                }
                Rectangle {
                    background: @linear-gradient(180deg, transparent 20%, Theme.bg 100%);
                }
            }

            // Hero: poster + title + overview
            HorizontalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-top:    series-has-backdrop ? 0px : 36px;
                padding-bottom: 16px;
                spacing:        28px;
                alignment:      start;

                if series-has-poster: Image {
                    source:    series-poster;
                    width:     130px;
                    height:    195px;
                    image-fit: cover;
                }

                VerticalLayout {
                    spacing:          8px;
                    alignment:        start;
                    horizontal-stretch: 1;

                    Text {
                        text:        series-title;
                        color:       Theme.text;
                        font-size:   28px;
                        font-weight: 700;
                        wrap:        no-wrap;
                        overflow:    elide;
                    }

                    if series-overview != "": Text {
                        text:     series-overview;
                        color:    Theme.text-muted;
                        font-size: 13px;
                        wrap:     word-wrap;
                        overflow: elide;
                    }
                }
            }

            // Season tabs
            if series-seasons.length > 0: Rectangle {
                height:     44px;
                background: series-in-season-row ? Theme.surface-raised : #00000000;

                Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }

                Flickable {
                    width:          parent.width;
                    viewport-width: season-tabs.preferred-width + 48px;
                    season-tabs := HorizontalLayout {
                        padding-left:  48px;
                        padding-right: 48px;
                        spacing:       8px;
                        alignment:     start;

                        for s[i] in series-seasons: Rectangle {
                            width:         max(80px, lbl.preferred-width + 24px);
                            height:        32px;
                            y:             6px;
                            border-radius: Theme.radius;
                            background:    i == series-season-idx ? Theme.accent : Theme.surface;

                            lbl := Text {
                                text:                 s.name;
                                color:                i == series-season-idx ? #ffffff : Theme.text-muted;
                                font-size:            13px;
                                font-weight:          i == series-season-idx ? 700 : 400;
                                horizontal-alignment: center;
                                vertical-alignment:   center;
                            }

                            TouchArea {
                                clicked => {
                                    root.series-season-idx = i;
                                    root.series-select-season(i);
                                    root.series-focused-ep = 0;
                                    root.series-in-season-row = false;
                                }
                            }
                        }
                    }
                }
            }

            // Loading indicator (must be outside ListView — ListView allows only one for-child)
            if series-loading && series-episodes.length == 0: Rectangle {
                height: 60px;
                Text {
                    text:                 "Loading episodes…";
                    color:                Theme.text-muted;
                    font-size:            14px;
                    horizontal-alignment: center;
                    vertical-alignment:   center;
                }
            }

            // Episode list
            ep-list := ListView {
                vertical-stretch: 1;
                viewport-y: series-focused-ep <= 0 ? 0px
                          : clamp(
                                -(series-focused-ep * 72px + 36px - ep-list.visible-height / 2),
                                min(0px, ep-list.visible-height - series-episodes.length * 72px),
                                0px
                            );
                animate viewport-y { duration: 150ms; easing: ease-out; }

                for ep[i] in series-episodes: Rectangle {
                    height:     72px;
                    background: i == series-focused-ep && !series-in-season-row
                              ? Theme.surface-raised : #00000000;

                    HorizontalLayout {
                        spacing:   0px;
                        alignment: start;

                        // Left accent bar
                        Rectangle {
                            width:      3px;
                            height:     parent.height;
                            background: i == series-focused-ep && !series-in-season-row
                                      ? Theme.accent : #00000000;
                        }

                        HorizontalLayout {
                        padding-left:  13px;
                        padding-right: 16px;
                        spacing:       12px;
                        alignment:     start;

                        // Thumbnail or placeholder
                        Rectangle {
                            width:         120px;
                            height:        68px;
                            y:             2px;
                            border-radius: Theme.radius;
                            background:    Theme.surface;
                            clip:          true;

                            if ep.has-thumb: Image {
                                source:    ep.thumb;
                                width:     parent.width;
                                height:    parent.height;
                                image-fit: cover;
                            }

                            // Watched overlay
                            if ep.has-played: Rectangle {
                                background: #00000099;
                                Text {
                                    text:                 "✓";
                                    color:                Theme.accent;
                                    font-size:            20px;
                                    horizontal-alignment: center;
                                    vertical-alignment:   center;
                                }
                            }
                        }

                        // Episode info
                        VerticalLayout {
                            spacing:    3px;
                            alignment:  center;
                            vertical-stretch: 1;

                            HorizontalLayout {
                                spacing:   8px;
                                alignment: start;

                                Text {
                                    text:        "S\{ep.season-num < 10 ? "0" : ""}\{ep.season-num}E\{ep.ep-num < 10 ? "0" : ""}\{ep.ep-num}";
                                    color:       Theme.accent;
                                    font-size:   12px;
                                    font-weight: 600;
                                }
                                Text {
                                    text:       ep.runtime;
                                    color:      Theme.text-muted;
                                    font-size:  12px;
                                }
                            }

                            Text {
                                text:      ep.title;
                                color:     Theme.text;
                                font-size: 14px;
                                font-weight: 500;
                                overflow:  elide;
                            }

                            if ep.overview != "": Text {
                                text:      ep.overview;
                                color:     Theme.text-muted;
                                font-size: 12px;
                                overflow:  elide;
                            }

                            // Resume progress bar
                            if ep.resume-pct > 0: Rectangle {
                                height:        3px;
                                border-radius: 1.5px;
                                background:    Theme.surface-overlay;
                                max-width:     300px;

                                Rectangle {
                                    width:         parent.width * ep.resume-pct;
                                    height:        parent.height;
                                    border-radius: parent.border-radius;
                                    background:    Theme.accent;
                                }
                            }
                        }

                        TouchArea {
                            clicked => { root.play-series-episode(ep.id); }
                        }
                    }  // inner HorizontalLayout
                    }  // outer HorizontalLayout
                }
            }
        }

        // Back button
        FjordButton {
            x:       16px;
            y:       16px;
            text:    "← Back";
            width:   88px;
            clicked => { root.close-series(); }
        }
    }

    // ── Item detail page ──────────────────────────────────────────────────────
    if show-detail: Rectangle {
        background: Theme.bg;

        ScrollView {
            width:  parent.width;
            height: parent.height;

            VerticalLayout {

                // Backdrop strip
                if detail-has-backdrop: Rectangle {
                    height: 300px;
                    clip:   true;
                    Image {
                        source:    detail-backdrop;
                        width:     parent.width;
                        height:    parent.height;
                        image-fit: cover;
                    }
                    Rectangle {
                        background: @linear-gradient(180deg, transparent 20%, Theme.bg 100%);
                    }
                }

                // Hero: poster + info
                HorizontalLayout {
                    padding-left:   48px;
                    padding-right:  48px;
                    padding-top:    detail-has-backdrop ? 0px : 48px;
                    padding-bottom: 24px;
                    spacing:        32px;
                    alignment:      start;

                    if detail-has-poster: Image {
                        source:    detail-poster;
                        width:     160px;
                        height:    240px;
                        image-fit: cover;
                    }

                    VerticalLayout {
                        spacing:   8px;
                        alignment: start;

                        Text {
                            text:        detail-title;
                            color:       Theme.text;
                            font-size:   28px;
                            font-weight: 700;
                            wrap:        word-wrap;
                        }

                        if detail-series-label != "": Text {
                            text:      detail-series-label;
                            color:     Theme.accent;
                            font-size: 14px;
                        }

                        HorizontalLayout {
                            spacing:   16px;
                            alignment: start;
                            Text { text: detail-meta;         color: Theme.text-muted; font-size: 14px; }
                            if detail-rating-label != "": Text { text: detail-rating-label; color: #f5c518; font-size: 14px; }
                        }

                        if detail-genres != "": Text {
                            text:      detail-genres;
                            color:     Theme.text-muted;
                            font-size: 13px;
                        }

                        Rectangle { height: 12px; }

                        if detail-overview != "": Text {
                            text:      detail-overview;
                            color:     Theme.text;
                            font-size: 14px;
                            wrap:      word-wrap;
                            max-width: 640px;
                        }

                        Rectangle { height: 20px; }

                        HorizontalLayout {
                            spacing:   12px;
                            alignment: start;
                            if detail-loading: Text {
                                text:               "Loading…";
                                color:              Theme.text-muted;
                                font-size:          14px;
                                vertical-alignment: center;
                            }
                            if !detail-loading: FjordButton {
                                text:    "▶  Play";
                                width:   110px;
                                clicked => { root.play-detail(); }
                            }
                            if !detail-loading && detail-can-resume: FjordButton {
                                text:    "⏩  " + detail-resume-label;
                                clicked => { root.resume-detail(); }
                            }
                        }
                    }
                }

                // Cast section
                if detail-cast.length > 0: VerticalLayout {
                    padding-left:   48px;
                    padding-right:  48px;
                    padding-bottom: 40px;
                    spacing:        12px;

                    Rectangle { height: 1px; background: Theme.border; }

                    Text { text: "Cast"; color: Theme.text; font-size: 16px; font-weight: 700; }

                    HorizontalLayout {
                        spacing:   24px;
                        alignment: start;
                        for c in detail-cast: VerticalLayout {
                            width:   120px;
                            spacing: 2px;
                            Text { text: c.name; color: Theme.text;       font-size: 13px; font-weight: 600; overflow: elide; }
                            Text { text: c.role; color: Theme.text-muted; font-size: 12px; overflow: elide; }
                        }
                    }
                }
            }
        }

        // Back button — always on top of scroll content
        FjordButton {
            x:       16px;
            y:       16px;
            text:    "← Back";
            width:   88px;
            clicked => { root.close-detail(); }
        }
    }
}

