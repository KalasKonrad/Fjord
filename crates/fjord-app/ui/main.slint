// ── fjord-app · main.slint ───────────────────────────────────────────────────
//   MainWindow    window root: sync-layout, auto-advance banner, FocusScope
//   keyboard handler  single AppState.handle-key() callback → Rust keys.rs
//   MiniPlayerBar top bar when has-background-player && !is-playing; offsets AppShell by bar-h
//   screen slots  LoginScreen, AppShell + HomeScreen / DashboardScreen / LibraryGrid
//   video-behind-UI layer  above AppShell, only when overlay screen is open (detail/series/season/person)
//                          so video does NOT show through dashboard/library but DOES show through overlays
//   loading overlay   semi-transparent #00000088 + LoadingSpinner while app-content-loading
//   PersonScreen overlay (above Detail/Season/Series; below ContextMenu)
//   ContextMenu overlay (highest z-order, shown when AppState.show-context-menu)
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, LoadingSpinner, MiniPlayerBar } from "widgets.slint";
import { SectionRow, LibraryGrid, HomeScreen, DashboardScreen } from "home.slint";
import { BrowseScreen } from "browse.slint";
import { SettingsScreen } from "settings.slint";
import { LoginScreen } from "login.slint";
import { PlayerScreen } from "player.slint";
import { SeriesScreen } from "series.slint";
import { SeasonScreen } from "season.slint";
import { DetailPage } from "detail.slint";
import { AppShell } from "layout.slint";
import { PersonScreen } from "person.slint";
import { ContextMenu } from "context_menu.slint";

export { AppState }

export component MainWindow inherits Window {
    title:            "Fjord";
    background:       Theme.bg;
    min-width:        900px;
    min-height:       520px;
    preferred-width:  1280px;
    preferred-height: 720px;

    callback grab-keyboard-focus;
    grab-keyboard-focus => { fs.focus(); }

    pure function grid-cols() -> int {
        if self.width < 852px  { return 3; }
        if self.width < 1011px { return 4; }
        if self.width < 1170px { return 5; }
        if self.width < 1329px { return 6; }
        if self.width < 1488px { return 7; }
        if self.width < 1647px { return 8; }
        if self.width < 1806px { return 9; }
        return 10;
    }
    pure function dash-card-w() -> length {
        if self.width < 900px  { return 115px; }
        if self.width < 1300px { return 140px; }
        if self.width < 1700px { return 165px; }
        return 190px;
    }
    pure function dash-card-h() -> length {
        if self.width < 900px  { return 184px; }
        if self.width < 1300px { return 224px; }
        if self.width < 1700px { return 264px; }
        return 304px;
    }

    function sync-layout() {
        AppState.library-cols = self.grid-cols();
        AppState.dash-cw      = self.dash-card-w();
        AppState.dash-ch      = self.dash-card-h();
    }
    init => { self.sync-layout(); }
    changed width => { self.sync-layout(); }

    // Auto-advance countdown banner — only shown outside the fullscreen player
    // (player.slint has its own banner with Play Now + Skip buttons).
    if AppState.show-next-ep-banner && !AppState.is-playing: Rectangle {
        x:             root.width  - 300px - 20px;
        y:             root.height - 110px - 20px;
        width:         300px;
        height:        110px;
        border-radius: Theme.radius-lg;
        background:    Theme.surface;
        border-width:  1px;
        border-color:  Theme.border-strong;
        drop-shadow-blur:     12px;
        drop-shadow-color:    #00000066;
        drop-shadow-offset-y: 4px;

        VerticalLayout {
            padding: 14px;
            spacing:  8px;

            Text { text: "Up Next in \{AppState.next-ep-secs}s"; color: Theme.text-muted; font-size: 11px; }
            Text { text: AppState.next-ep-title; color: Theme.text; font-size: 13px; font-weight: 600; overflow: elide; }
            HorizontalLayout {
                alignment: end;
                FjordButton { text: "Cancel"; width: 70px; clicked => { AppState.cancel-auto-advance(); } }
            }
        }
    }

    fs := FocusScope {
        width: 0; height: 0;
        key-pressed(event) => {
            AppState.handle-key(event.text, event.modifiers.shift, event.modifiers.control, event.repeat) ? accept : reject
        }
    }

    // Height reserved for the mini-player bar (0 when not active or player is open)
    property <length> bar-h: (AppState.has-background-player && !AppState.is-playing)
        ? (AppState.video-behind-ui ? 56px : 108px) : 0px;

    // Video-behind-UI layer — declared first so it sits at the very bottom of the z-stack.
    // Content screens (HomeScreen, DashboardScreen, etc.) have transparent backgrounds in this
    // mode so the video shows through the gaps between UI elements on every screen, including
    // the dashboard and library. Overlay screens (detail/series/season/person) chain through
    // their transparent roots → transparent AppShell content → video.
    if AppState.video-behind-ui && AppState.has-background-player && !AppState.is-playing: Rectangle {
        y:          bar-h;
        height:     parent.height - bar-h;
        background: #000000;
        Image { source: AppState.video-frame; width: parent.width; height: parent.height; image-fit: contain; }
        Rectangle { background: #00000044; }
    }

    // Mini-player bar — full width, docked at top, pushes AppShell down
    if AppState.has-background-player && !AppState.is-playing: MiniPlayerBar {
        y:     0;
        width: parent.width;
    }

    if AppState.show-login: LoginScreen { }

    if !AppState.show-login: AppShell {
        y:      bar-h;
        height: parent.height - bar-h;
        if AppState.show-browse: BrowseScreen { horizontal-stretch: 1; }

        if !AppState.show-browse && AppState.active-nav == 0: HomeScreen {
            horizontal-stretch:    1;
            continue-watching:     AppState.continue-watching;
            next-up:               AppState.next-up;
            recently-added:        AppState.recently-added;
            recently-added-movies: AppState.recently-added-movies;
        }
        if !AppState.show-browse && AppState.active-nav == 1 && !AppState.show-library: DashboardScreen {
            horizontal-stretch: 1; screen-title: "Movies";
            continue-watching:  AppState.continue-watching-movies;
            recently-added:     AppState.recently-added-movies;
            not-watched:        AppState.not-watched-movies;
        }
        if !AppState.show-browse && AppState.active-nav == 1 && AppState.show-library: LibraryGrid {
            horizontal-stretch: 1; grid-title: "All Movies";
        }
        if !AppState.show-browse && AppState.active-nav == 2 && !AppState.show-library: DashboardScreen {
            horizontal-stretch: 1; screen-title: "TV Shows";
            continue-watching:  AppState.continue-watching-tv;
            next-up:            AppState.next-up;
            recently-added:     AppState.recently-added-tv;
            not-watched:        AppState.not-watched-tv;
        }
        if !AppState.show-browse && AppState.active-nav == 2 && AppState.show-library: LibraryGrid {
            horizontal-stretch: 1; grid-title: "All Shows";
        }
        if !AppState.show-browse && AppState.active-nav == 10: SettingsScreen { horizontal-stretch: 1; }
    }

    // Full-screen overlays all start at bar-h so the mini-player bar remains visible above them.
    // PlayerScreen is exempt: bar-h==0 when is-playing, so it always gets full height.
    if AppState.is-playing:                          PlayerScreen  { }
    if AppState.show-series:                         SeriesScreen  { y: bar-h; height: parent.height - bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; }
    if AppState.show-season:                         SeasonScreen  { y: bar-h; height: parent.height - bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; }
    if AppState.show-detail && !AppState.is-playing: DetailPage    { y: bar-h; height: parent.height - bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; }
    if AppState.show-person:                         PersonScreen  { y: bar-h; height: parent.height - bar-h; background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg; }

    // Loading overlay — offset by bar-h so bar stays visible while content loads
    if AppState.app-content-loading: Rectangle {
        y: bar-h; height: parent.height - bar-h;
        background: #00000088;
        VerticalLayout {
            alignment: center;
            spacing:   20px;

            LoadingSpinner { }

            // Progress bar — 0.0 → 1.0 as milestones are hit
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width:         240px;
                    height:        4px;
                    border-radius: 2px;
                    background:    #ffffff22;
                    Rectangle {
                        x:             0;
                        width:         parent.width * AppState.app-loading-progress;
                        height:        parent.height;
                        border-radius: 2px;
                        background:    Theme.accent;
                        animate width { duration: 400ms; easing: ease-out; }
                    }
                }
            }
        }
    }

    if AppState.show-context-menu:                   ContextMenu  { }
}
