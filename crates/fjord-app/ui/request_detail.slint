// ── fjord-app · request_detail.slint ─────────────────────────────────────────
//   RequestDetailScreen    Seerr movie/TV detail: rating badge, collapsible
//                          StorylineSection overview, Cast & Crew row (CastRow,
//                          TMDB photos), Request button. Free-floating overlay
//                          (FadeGate at the main.slint mount site, not owned
//                          here — see connect_seerr.slint's header comment for
//                          why). Header matches the universal detail-screen
//                          pattern used by DetailPage/SeasonScreen/
//                          CollectionScreen: full-bleed backdrop Image + dark
//                          gradient overlay behind the poster+title content,
//                          plus a floating "← Back" FjordButton overlaid
//                          top-left — not a copy of DetailPage (different data
//                          source and action set: Request, not Play; no
//                          Jellyfin item id; no resume/watched state).
//                          Keyboard flow: request-detail-back-focused (top) ->
//                          request-detail-zone (0=button row, 1=storyline,
//                          2=cast row — see existing_zones()/
//                          handle_key_request_detail in discover.rs).
//   RequestOptionsOverlay  Modal opened by the Request button: Quality
//                          (2K/4K pair), quality profile (radio-select chip
//                          strip, if any configured — Radarr/Sonarr's own
//                          named profiles, e.g. "WEB-1080p"/"Remux-2160p"),
//                          tag chips, season cards, Cancel/Request confirm
//                          row — the actual request settings, kept off the
//                          main page and out of the way until the user
//                          decides to request. Same dim-backdrop-plus-
//                          centered-box shape as PlaylistPicker
//                          (context_menu.slint); tag chip / season card /
//                          profile chip Flickable strips are the same
//                          horizontal kb-x idiom as CastRow.
//                          Keyboard flow: request-options-zone (0=Quality
//                          row, 1=profile row, 2=tags row, 3=seasons row,
//                          4=confirm row — see existing_option_zones()/
//                          handle_key_request_options in discover.rs).
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, PosterBlock, MetaLine, PressPulse, CastRow, StorylineSection } from "widgets.slint";

export component RequestDetailScreen inherits Rectangle {
    background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

    property <bool> has-cast: AppState.request-detail-cast.length > 0;

    fl := Flickable {
        width:           parent.width;
        height:          parent.height;
        viewport-height: content.preferred-height;
        viewport-width:  self.width;
        animate viewport-y { duration: 200ms * AppState.settings-scroll-speed; easing: ease-in-out; }

        content := VerticalLayout {

            // ── Header: backdrop image fills entire poster+text block ─────────
            // Same full-bleed-Image + gradient-overlay pattern as DetailPage/
            // SeasonScreen/CollectionScreen (see file header comment) —
            // deliberately NOT BackdropHero, which put the backdrop in its
            // own separate 300px band above plain background content.
            Rectangle {
                background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

                if AppState.request-detail-has-backdrop: Image {
                    x: 0; y: 0;
                    width:     parent.width;
                    height:    parent.height;
                    image-fit: cover;
                    source:    AppState.request-detail-backdrop;
                }
                if AppState.request-detail-has-backdrop: Rectangle {
                    x: 0; y: 0;
                    width:      parent.width;
                    height:     parent.height;
                    background: @linear-gradient(180deg, #00000080 0%, #000000cc 100%);
                }

                VerticalLayout {
                HorizontalLayout {
                    padding-left:   48px;
                    padding-right:  48px;
                    padding-top:    68px;
                    padding-bottom: 24px;
                    spacing:        32px;
                    alignment:      start;

                    PosterBlock { source: AppState.request-detail-poster; has-image: AppState.request-detail-has-poster; }

                    VerticalLayout {
                        spacing:   8px;
                        alignment: start;

                        Text {
                            text:        AppState.request-detail-title;
                            color:       Theme.text;
                            font-size:   28px;
                            font-weight: 700;
                            wrap:        word-wrap;
                        }
                        MetaLine { meta: AppState.request-detail-meta; rating-label: AppState.request-detail-rating; }

                        Rectangle { height: 20px; }

                        // ── Status / Request button ──────────────────────────
                        // Request opens the Request Options modal (4K/tags/
                        // seasons configured there — see RequestOptionsOverlay
                        // below) rather than submitting directly or exposing
                        // every picker inline on this page.
                        req-row := HorizontalLayout {
                            alignment: start;
                            spacing: 12px;
                            if AppState.request-detail-status == "": FjordButton {
                                text:        AppState.request-detail-requesting ? "Requesting…" : "Request";
                                enabled:     !AppState.request-detail-requesting;
                                kbd-focused: !AppState.request-detail-back-focused && AppState.request-detail-zone == 0;
                                clicked => { AppState.open-request-options(); }
                            }
                            if AppState.request-detail-status != "": Rectangle {
                                height: 32px;
                                width: status-txt.preferred-width + 20px;
                                border-radius: Theme.radius;
                                background: AppState.request-detail-status == "available" ? Theme.accent : Theme.surface-overlay;
                                status-txt := Text {
                                    text: AppState.request-detail-status == "requested"  ? "Requested"
                                        : AppState.request-detail-status == "processing" ? "Processing"
                                        : AppState.request-detail-status == "partial"    ? "Partially Available"
                                        : AppState.request-detail-status == "available"  ? "In Library"
                                        : "";
                                    color: #ffffff;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                    }
                }
                if AppState.request-detail-overview != "": StorylineSection {
                    text:        AppState.request-detail-overview;
                    expanded <=> AppState.request-detail-overview-expanded;
                    kbd-focused: AppState.request-detail-zone == 1 && !AppState.request-detail-back-focused;
                }
                }
            }

            // ── Cast & Crew (director/writer/top-billed cast, TMDB photos) ──
            if has-cast: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 24px;

                Rectangle { height: 1px; background: Theme.border; }
                Rectangle { height: 12px; }

                CastRow {
                    cast:        AppState.request-detail-cast;
                    focused-idx: AppState.request-detail-zone == 2 ? AppState.request-detail-focused-cast : -1;
                    // item-selected left unbound — there's no TMDB-person
                    // detail screen to open, unlike Jellyfin's person.rs.
                }
            }

            Rectangle { height: Theme.sp-lg; }
        }
    }

    FjordButton {
        x:           16px;
        y:           16px;
        text:        "← Back";
        width:       88px;
        kbd-focused: AppState.request-detail-back-focused;
        clicked => { AppState.show-request-detail = false; }
    }
}

// ── Request Options modal ─────────────────────────────────────────────────────
// 4K toggle + tag chips + season cards + Cancel/Request confirm row — the
// actual request settings, opened from RequestDetailScreen's Request button
// instead of sitting inline on the page. Same dim-backdrop-plus-centered-box
// shape as PlaylistPicker (context_menu.slint); tag chip / season card
// Flickable strips are the tag/season strips that used to live on the page
// itself, unchanged apart from the fixed dialog-w width (see dialog-w below).
export component RequestOptionsOverlay inherits Rectangle {
    background: #00000088;

    property <bool>   has-profiles: AppState.request-detail-profiles.length > 0;
    property <bool>   has-tags:     AppState.request-detail-tags.length > 0;
    property <bool>   has-seasons:  AppState.request-detail-media-type == "tv" && AppState.request-detail-seasons.length > 0;
    // Fixed, non-conditional width for the dialog's content — read by the
    // tag/season Flickables below instead of an unset/layout-derived width,
    // same "Recursion detected" avoidance as the page's own root.width
    // remedy (see CLAUDE.md) — root here is this component's own top-level
    // Rectangle (the full-screen backdrop), never itself conditional.
    property <length> dialog-w: 480px;

    // Close on backdrop click (Cancel, same as Escape/Back)
    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { AppState.show-request-options = false; }
    }

    Rectangle {
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        width:         root.dialog-w;
        height:        dialog-content.preferred-height + 32px;
        border-radius: Theme.radius-lg;
        background:    Theme.surface-raised;
        border-width:  1px;
        border-color:  Theme.border-strong;
        drop-shadow-blur:     20px;
        drop-shadow-color:    #000000aa;
        drop-shadow-offset-y: 6px;

        // Stop backdrop click from propagating through the box
        TouchArea { width: parent.width; height: parent.height; }

        dialog-content := VerticalLayout {
            x: 20px; y: 20px;
            width:   parent.width - 40px;
            spacing: 20px;

            Text {
                text:                 "Request Options";
                color:                Theme.text;
                font-size:            17px;
                font-weight:          700;
                horizontal-alignment: center;
            }

            // ── Quality (2K / 4K) ─────────────────────────────────────────────
            // A pair, not a single on/off toggle — "off" reading ambiguously
            // as "no quality chosen" was the original design's weak point;
            // exactly one of the two is always the visibly selected one.
            // Left/Right directly set the value (no separate cursor state to
            // track — the selected button already IS the keyboard position).
            VerticalLayout {
                spacing: 8px;
                Text { text: "Quality"; color: Theme.text; font-size: 14px; font-weight: 700; horizontal-alignment: center; }
                HorizontalLayout {
                    alignment: center;
                    spacing: 10px;
                    twok-btn := Rectangle {
                        width:         90px;
                        height:        40px;
                        border-radius: Theme.radius;
                        background:    !AppState.request-detail-want-4k ? Theme.accent : Theme.surface-overlay;
                        border-width:  (twok-ta.pressed || twok-pulse.pulsing) ? 4px
                                     : (AppState.request-options-zone == 0 && !AppState.request-detail-want-4k ? 2px : 1px);
                        border-color:  !AppState.request-detail-want-4k ? #ffffff99 : Theme.border-strong;
                        animate border-width, background { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                        twok-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.request-options-zone == 0 && !AppState.request-detail-want-4k; }
                        twok-ta := TouchArea {
                            clicked => {
                                AppState.request-options-zone = 0;
                                AppState.request-detail-set-quality(false);
                            }
                        }
                        Text {
                            text:                 "2K";
                            color:                !AppState.request-detail-want-4k ? #ffffff : Theme.text-muted;
                            font-size:            14px;
                            font-weight:          700;
                            horizontal-alignment: center;
                            vertical-alignment:   center;
                        }
                    }
                    fourk-btn := Rectangle {
                        width:         90px;
                        height:        40px;
                        border-radius: Theme.radius;
                        background:    AppState.request-detail-want-4k ? Theme.accent : Theme.surface-overlay;
                        border-width:  (fourk-ta.pressed || fourk-pulse.pulsing) ? 4px
                                     : (AppState.request-options-zone == 0 && AppState.request-detail-want-4k ? 2px : 1px);
                        border-color:  AppState.request-detail-want-4k ? #ffffff99 : Theme.border-strong;
                        animate border-width, background { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                        fourk-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.request-options-zone == 0 && AppState.request-detail-want-4k; }
                        fourk-ta := TouchArea {
                            clicked => {
                                AppState.request-options-zone = 0;
                                AppState.request-detail-set-quality(true);
                            }
                        }
                        Text {
                            text:                 "4K";
                            color:                AppState.request-detail-want-4k ? #ffffff : Theme.text-muted;
                            font-size:            14px;
                            font-weight:          700;
                            horizontal-alignment: center;
                            vertical-alignment:   center;
                        }
                    }
                }
            }

            // ── Quality profile (Radarr/Sonarr, radio-select) ────────────────
            // Same horizontal Flickable/kb-x shape as Tags below, but exactly
            // one chip is ever selected (clicking one replaces the previous
            // choice, rather than toggling independently) — row 0 is always
            // the synthetic "Default" entry Rust prepends, so there's always
            // an explicit way back to "no override" without a separate button.
            if has-profiles: VerticalLayout {
                spacing: 8px;

                Text { text: "Profile"; color: Theme.text; font-size: 14px; font-weight: 700; }

                property <length> kb-profile-x: AppState.request-detail-focused-profile <= 0 ? 0px
                    : clamp(-(AppState.request-detail-focused-profile * 146px + 65px - profile-fl.width / 2),
                            min(0px, profile-fl.width - profile-hbox.preferred-width), 0px);
                changed kb-profile-x => { profile-fl.viewport-x = kb-profile-x; }

                profile-fl := Flickable {
                    width:          root.dialog-w - 64px;
                    height:         44px;
                    viewport-width: profile-hbox.preferred-width;
                    animate viewport-x { duration: 150ms * AppState.settings-scroll-speed; easing: ease-out-expo; }

                    profile-hbox := HorizontalLayout {
                        spacing:   16px;
                        alignment: start;

                        for p[i] in AppState.request-detail-profiles: Rectangle {
                            width:         130px;
                            height:        36px;
                            border-radius: self.height / 2;
                            background:    p.id == AppState.request-detail-selected-profile-id ? Theme.accent : Theme.surface-overlay;
                            border-width:  (profile-ta.pressed || profile-pulse.pulsing) ? 4px
                                         : (AppState.request-options-zone == 1 && AppState.request-detail-focused-profile == i ? 2px : 1px);
                            border-color:  p.id == AppState.request-detail-selected-profile-id ? #ffffff99 : Theme.border-strong;
                            animate border-width, background { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                            profile-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.request-options-zone == 1 && AppState.request-detail-focused-profile == i; }

                            profile-ta := TouchArea {
                                clicked => {
                                    AppState.request-options-zone = 1;
                                    AppState.request-detail-focused-profile = i;
                                    AppState.request-detail-selected-profile-id = p.id;
                                }
                            }

                            Text {
                                text:                 p.name;
                                color:                p.id == AppState.request-detail-selected-profile-id ? #ffffff : Theme.text-muted;
                                font-size:            13px;
                                font-weight:          600;
                                overflow:             elide;
                                horizontal-alignment: center;
                                vertical-alignment:   center;
                                width:                parent.width - 16px;
                                x:                    8px;
                            }
                        }
                    }
                }
            }

            // ── Tags (Radarr/Sonarr default-server tags, movie or TV) ────────
            // Horizontal Flickable strip of fixed-width chips, same kb-x
            // scroll idiom as CastRow (fixed width chosen deliberately over
            // size-to-content — a variable-width chip breaks the fixed-stride
            // kb-x math every scrollable row in this app relies on; long
            // labels elide instead).
            if has-tags: VerticalLayout {
                spacing: 8px;

                Text { text: "Tags"; color: Theme.text; font-size: 14px; font-weight: 700; }

                property <length> kb-tag-x: AppState.request-detail-focused-tag <= 0 ? 0px
                    : clamp(-(AppState.request-detail-focused-tag * 126px + 55px - tag-fl.width / 2),
                            min(0px, tag-fl.width - tag-hbox.preferred-width), 0px);
                changed kb-tag-x => { tag-fl.viewport-x = kb-tag-x; }

                tag-fl := Flickable {
                    width:          root.dialog-w - 64px;
                    height:         44px;
                    viewport-width: tag-hbox.preferred-width;
                    animate viewport-x { duration: 150ms * AppState.settings-scroll-speed; easing: ease-out-expo; }

                    tag-hbox := HorizontalLayout {
                        spacing:   16px;
                        alignment: start;

                        // Pill shape (border-radius = height/2, not Theme.radius)
                        // and an always-visible border (subtle when unselected,
                        // accent when selected/focused) — the original flat
                        // rectangles with no border when idle read as plain
                        // gray blobs rather than chips.
                        for t[i] in AppState.request-detail-tags: Rectangle {
                            width:         110px;
                            height:        36px;
                            border-radius: self.height / 2;
                            background:    t.selected ? Theme.accent : Theme.surface-overlay;
                            border-width:  (tag-ta.pressed || tag-pulse.pulsing) ? 4px
                                         : (AppState.request-options-zone == 2 && AppState.request-detail-focused-tag == i ? 2px : 1px);
                            border-color:  t.selected ? #ffffff99 : Theme.border-strong;
                            animate border-width, background { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                            tag-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.request-options-zone == 2 && AppState.request-detail-focused-tag == i; }

                            tag-ta := TouchArea {
                                clicked => {
                                    AppState.request-options-zone = 1;
                                    AppState.request-detail-focused-tag = i;
                                    AppState.request-detail-toggle-tag(i);
                                }
                            }

                            HorizontalLayout {
                                padding-left:  10px;
                                padding-right: 10px;
                                alignment:     center;
                                spacing:       4px;
                                if t.selected: Text { text: "✓︎"; font-family: "Adwaita Sans"; color: #ffffff; font-size: 12px; vertical-alignment: center; }
                                Text {
                                    text:                 t.label;
                                    color:                t.selected ? #ffffff : Theme.text-muted;
                                    font-size:            13px;
                                    font-weight:          600;
                                    overflow:             elide;
                                    vertical-alignment:   center;
                                    horizontal-stretch:   1;
                                }
                            }
                        }
                    }
                }
            }

            // ── Seasons (TV only) ─────────────────────────────────────────────
            // Horizontal Flickable strip of season cards (poster + name +
            // episode count + ✓ badge when selected) — same fixed-width
            // kb-x idiom as the tag strip and CastRow, just with a poster
            // instead of a chip label.
            if has-seasons: VerticalLayout {
                spacing: 8px;

                Text { text: "Seasons"; color: Theme.text; font-size: 14px; font-weight: 700; }

                property <length> kb-season-x: AppState.request-detail-focused-season <= 0 ? 0px
                    : clamp(-(AppState.request-detail-focused-season * 158px + 55px - season-fl.width / 2),
                            min(0px, season-fl.width - season-hbox.preferred-width), 0px);
                changed kb-season-x => { season-fl.viewport-x = kb-season-x; }

                season-fl := Flickable {
                    width:          root.dialog-w - 64px;
                    height:         210px;
                    viewport-width: season-hbox.preferred-width;
                    animate viewport-x { duration: 150ms * AppState.settings-scroll-speed; easing: ease-out-expo; }

                    season-hbox := HorizontalLayout {
                        spacing:   16px;
                        alignment: start;

                        for s[i] in AppState.request-detail-seasons: VerticalLayout {
                            width:   110px;
                            spacing: 4px;

                            Rectangle {
                                height:        165px;
                                border-radius: Theme.radius;
                                clip:          true;
                                background:    Theme.surface-overlay;
                                border-width:  (season-ta.pressed || season-pulse.pulsing) ? 4px
                                             : (AppState.request-options-zone == 3 && AppState.request-detail-focused-season == i ? 2px : 0px);
                                border-color:  Theme.accent;
                                animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                                season-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.request-options-zone == 3 && AppState.request-detail-focused-season == i; }

                                if s.has-poster: Image { source: s.poster; width: parent.width; height: parent.height; image-fit: cover; }
                                if !s.has-poster: Text {
                                    text:                 s.season-number;
                                    color:                Theme.text-muted;
                                    font-size:            28px;
                                    font-weight:          700;
                                    horizontal-alignment: center;
                                    vertical-alignment:   center;
                                    width:                parent.width;
                                    height:               parent.height;
                                }

                                // ✓ selected badge (top-right), same idiom as PosterBlock's played badge
                                if s.selected: Rectangle {
                                    x: parent.width - 26px; y: 6px;
                                    width: 20px; height: 20px;
                                    border-radius: 10px;
                                    background: Theme.accent;
                                    Text { text: "✓︎"; font-family: "Adwaita Sans"; color: white; font-size: 10px; font-weight: 700;
                                           horizontal-alignment: center; vertical-alignment: center;
                                           width: parent.width; height: parent.height; }
                                }

                                season-ta := TouchArea {
                                    clicked => {
                                        AppState.request-options-zone = 2;
                                        AppState.request-detail-focused-season = i;
                                        AppState.request-detail-toggle-season(i);
                                    }
                                }
                            }

                            Text { text: s.name; color: Theme.text; font-size: 12px; font-weight: 600; overflow: elide; }
                            Text { text: "\{s.episode-count} episodes"; color: Theme.text-muted; font-size: 11px; }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }

            // ── Confirm row ───────────────────────────────────────────────────
            // Cancel is deliberately NOT a FjordButton — that widget always
            // renders filled accent blue, which made Cancel look just as
            // "primary" as Request with no visual hint of which one is the
            // safe/reversible action. A plain outlined ("ghost") button reads
            // as secondary next to Request's solid fill, the standard
            // primary/secondary confirm-dialog convention.
            HorizontalLayout {
                spacing:   12px;
                alignment: center;
                cancel-btn := Rectangle {
                    width:         100px;
                    height:        38px;
                    border-radius: Theme.radius;
                    background:    transparent;
                    border-width:  (cancel-ta.pressed || cancel-pulse.pulsing) ? 4px
                                 : (AppState.request-options-zone == 4 && AppState.request-options-confirm-focused == 0 ? 2px : 1px);
                    border-color:  AppState.request-options-zone == 4 && AppState.request-options-confirm-focused == 0 ? Theme.accent : Theme.border-strong;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    cancel-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.request-options-zone == 4 && AppState.request-options-confirm-focused == 0; }
                    cancel-ta := TouchArea {
                        clicked => {
                            AppState.request-options-zone = 3;
                            AppState.request-options-confirm-focused = 0;
                            AppState.show-request-options = false;
                        }
                    }
                    Text {
                        text:                 "Cancel";
                        color:                Theme.text;
                        font-size:            14px;
                        font-weight:          600;
                        horizontal-alignment: center;
                        vertical-alignment:   center;
                    }
                }
                FjordButton {
                    text:        AppState.request-detail-requesting ? "Requesting…" : "Request";
                    enabled:     !AppState.request-detail-requesting;
                    width:       100px;
                    kbd-focused: AppState.request-options-zone == 4 && AppState.request-options-confirm-focused == 1;
                    clicked => {
                        AppState.request-options-zone = 3;
                        AppState.request-options-confirm-focused = 1;
                        AppState.show-request-options = false;
                        AppState.request-detail-request();
                    }
                }
            }
        }
    }
}
