// ── fjord-app · request_detail.slint ─────────────────────────────────────────
//   RequestDetailScreen  Seerr movie/TV detail + Request action. Free-floating
//                        overlay (FadeGate at the main.slint mount site, not
//                        owned here — see connect_seerr.slint's header comment
//                        for why). Header now matches the universal detail-
//                        screen pattern used by DetailPage/SeasonScreen/
//                        CollectionScreen: full-bleed backdrop Image + dark
//                        gradient overlay behind the poster+title content
//                        (not the separate BackdropHero band this screen used
//                        before — BackdropHero turned out to be unused by
//                        every other detail-style screen despite being
//                        documented as a shared atom, which is exactly why
//                        this screen looked inconsistent with the rest of
//                        the app), plus a floating "← Back" FjordButton
//                        overlaid top-left instead of an inline chip in the
//                        scrolling content. Still reuses PosterBlock/MetaLine
//                        (genuinely shared atoms) — not a copy of DetailPage
//                        (different data source and action set: Request, not
//                        Play; no Jellyfin item id; no resume/watched state).
//                        Redesigned (2026-07-16) to match Detail/Season's
//                        content depth, not just chrome: MetaLine now carries
//                        a TMDB rating badge, the overview is a collapsible
//                        StorylineSection, a Cast & Crew row (CastRow, TMDB
//                        profile photos) sits below the header, and the tag/
//                        season pickers are horizontal card/chip Flickable
//                        strips (same kb-x idiom as CastRow) instead of
//                        vertical checkbox lists — Slint has no flex-wrap
//                        layout, so this keeps the "chips" look from the
//                        design mockup without inventing wrap machinery.
//                        Keyboard flow: request-detail-back-focused (top) ->
//                        request-detail-zone (0=button row Request/4K,
//                        1=storyline, 2=cast row, 3=tags row, 4=seasons row —
//                        see existing_zones()/handle_key_request_detail in
//                        discover.rs for which zones exist for a given item).
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, PosterBlock, MetaLine, PressPulse, CastRow, StorylineSection } from "widgets.slint";

export component RequestDetailScreen inherits Rectangle {
    background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

    property <bool> has-seasons: AppState.request-detail-media-type == "tv" && AppState.request-detail-seasons.length > 0;
    property <bool> has-tags: AppState.request-detail-tags.length > 0;
    property <bool> has-cast: AppState.request-detail-cast.length > 0;

    fl := Flickable {
        width:           parent.width;
        height:          parent.height;
        viewport-height: content.preferred-height;
        viewport-width:  self.width;
        animate viewport-y { duration: 200ms * AppState.settings-scroll-speed; easing: ease-in-out; }

        content := VerticalLayout {

            // ── Header: backdrop image fills entire poster+text block ─────────
            // Same full-bleed-Image + gradient-overlay pattern as DetailPage/
            // SeasonScreen/CollectionScreen (see file header comment) —
            // deliberately NOT BackdropHero, which put the backdrop in its
            // own separate 300px band above plain background content.
            Rectangle {
                background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

                if AppState.request-detail-has-backdrop: Image {
                    x: 0; y: 0;
                    width:     parent.width;
                    height:    parent.height;
                    image-fit: cover;
                    source:    AppState.request-detail-backdrop;
                }
                if AppState.request-detail-has-backdrop: Rectangle {
                    x: 0; y: 0;
                    width:      parent.width;
                    height:     parent.height;
                    background: @linear-gradient(180deg, #00000080 0%, #000000cc 100%);
                }

                VerticalLayout {
                HorizontalLayout {
                    padding-left:   48px;
                    padding-right:  48px;
                    padding-top:    68px;
                    padding-bottom: 24px;
                    spacing:        32px;
                    alignment:      start;

                    PosterBlock { source: AppState.request-detail-poster; has-image: AppState.request-detail-has-poster; }

                    VerticalLayout {
                        spacing:   8px;
                        alignment: start;

                        Text {
                            text:        AppState.request-detail-title;
                            color:       Theme.text;
                            font-size:   28px;
                            font-weight: 700;
                            wrap:        word-wrap;
                        }
                        MetaLine { meta: AppState.request-detail-meta; rating-label: AppState.request-detail-rating; }

                        Rectangle { height: 20px; }

                        // ── Status / Request button + 4K toggle ─────────────
                        property <bool> row-active: !AppState.request-detail-back-focused && AppState.request-detail-zone == 0;
                        req-row := HorizontalLayout {
                            alignment: start;
                            spacing: 12px;
                            if AppState.request-detail-status == "": FjordButton {
                                text:        AppState.request-detail-requesting ? "Requesting…" : "Request";
                                enabled:     !AppState.request-detail-requesting;
                                kbd-focused: row-active && AppState.request-detail-btn-focused == 0;
                                clicked => { AppState.request-detail-btn-focused = 0; AppState.request-detail-request(); }
                            }
                            // 4K toggle chip — only while still requestable (nothing
                            // left to toggle once requested/available). Maps to
                            // POST /request's `is4k` field; only succeeds if the
                            // Seerr admin has a 4K server configured.
                            if AppState.request-detail-status == "": fourk-btn := Rectangle {
                                width: fourk-txt.preferred-width + 20px;
                                height: 38px;
                                border-radius: Theme.radius;
                                background: AppState.request-detail-want-4k ? Theme.accent
                                          : (row-active && AppState.request-detail-btn-focused == 1 ? Theme.surface-overlay : Theme.surface-raised);
                                border-width: (fourk-ta.pressed || fourk-pulse.pulsing) ? 4px : (row-active && AppState.request-detail-btn-focused == 1 ? 2px : 0px);
                                border-color: #ffffff99;
                                animate border-width, background { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                                fourk-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: row-active && AppState.request-detail-btn-focused == 1; }
                                fourk-ta := TouchArea {
                                    clicked => {
                                        AppState.request-detail-btn-focused = 1;
                                        AppState.request-detail-want-4k = !AppState.request-detail-want-4k;
                                    }
                                }
                                fourk-txt := Text {
                                    text: "4K";
                                    color: AppState.request-detail-want-4k ? #ffffff : Theme.text-muted;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            if AppState.request-detail-status != "": Rectangle {
                                height: 32px;
                                width: status-txt.preferred-width + 20px;
                                border-radius: Theme.radius;
                                background: AppState.request-detail-status == "available" ? Theme.accent : Theme.surface-overlay;
                                status-txt := Text {
                                    text: AppState.request-detail-status == "requested"  ? "Requested"
                                        : AppState.request-detail-status == "processing" ? "Processing"
                                        : AppState.request-detail-status == "partial"    ? "Partially Available"
                                        : AppState.request-detail-status == "available"  ? "In Library"
                                        : "";
                                    color: #ffffff;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                    }
                }
                if AppState.request-detail-overview != "": StorylineSection {
                    text:        AppState.request-detail-overview;
                    expanded <=> AppState.request-detail-overview-expanded;
                    kbd-focused: AppState.request-detail-zone == 1 && !AppState.request-detail-back-focused;
                }
                }
            }

            // ── Cast & Crew (director/writer/top-billed cast, TMDB photos) ──
            if has-cast: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 24px;

                Rectangle { height: 1px; background: Theme.border; }
                Rectangle { height: 12px; }

                CastRow {
                    cast:        AppState.request-detail-cast;
                    focused-idx: AppState.request-detail-zone == 2 ? AppState.request-detail-focused-cast : -1;
                    // item-selected left unbound — there's no TMDB-person
                    // detail screen to open, unlike Jellyfin's person.rs.
                }
            }

            // ── Tags (Radarr/Sonarr default-server tags, movie or TV) ────────
            // Horizontal Flickable strip of fixed-width chips, same kb-x
            // scroll idiom as CastRow above (fixed width chosen deliberately
            // over size-to-content — a variable-width chip breaks the fixed-
            // stride kb-x math every other scrollable row in this app relies
            // on; long labels elide instead, matching CastRow's own cards).
            if has-tags: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 24px;
                spacing:        8px;

                Text { text: "Tags"; color: Theme.text; font-size: 16px; font-weight: 700; }

                // tag-fl gets an explicit root-derived width rather than
                // stretching to its (conditionally-mounted) parent layout —
                // kb-tag-x reads tag-fl.width, and reading a layout-derived
                // width from a property on the same conditional element
                // risks the "Recursion detected" gotcha (see CLAUDE.md);
                // root.width is a different, already-resolved layout pass
                // (AppShell's outer layout), same remedy discover.slint's
                // fl-container/landing-container used.
                property <length> kb-tag-x: AppState.request-detail-focused-tag <= 0 ? 0px
                    : clamp(-(AppState.request-detail-focused-tag * 126px + 55px - tag-fl.width / 2),
                            min(0px, tag-fl.width - tag-hbox.preferred-width), 0px);
                changed kb-tag-x => { tag-fl.viewport-x = kb-tag-x; }

                tag-fl := Flickable {
                    width:          root.width - 96px;
                    height:         44px;
                    viewport-width: tag-hbox.preferred-width;
                    animate viewport-x { duration: 150ms * AppState.settings-scroll-speed; easing: ease-out-expo; }

                    tag-hbox := HorizontalLayout {
                        spacing:   16px;
                        alignment: start;

                        for t[i] in AppState.request-detail-tags: Rectangle {
                            width:         110px;
                            height:        36px;
                            border-radius: Theme.radius;
                            background:    t.selected ? Theme.accent : Theme.surface-raised;
                            border-width:  (tag-ta.pressed || tag-pulse.pulsing) ? 4px
                                         : (AppState.request-detail-zone == 3 && AppState.request-detail-focused-tag == i ? 2px : 0px);
                            border-color:  #ffffff99;
                            animate border-width, background { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                            tag-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.request-detail-zone == 3 && AppState.request-detail-focused-tag == i; }

                            tag-ta := TouchArea {
                                clicked => {
                                    AppState.request-detail-zone = 3;
                                    AppState.request-detail-focused-tag = i;
                                    AppState.request-detail-toggle-tag(i);
                                }
                            }

                            HorizontalLayout {
                                padding-left:  10px;
                                padding-right: 10px;
                                alignment:     center;
                                spacing:       4px;
                                if t.selected: Text { text: "✓︎"; font-family: "Adwaita Sans"; color: #ffffff; font-size: 12px; vertical-alignment: center; }
                                Text {
                                    text:                 t.label;
                                    color:                t.selected ? #ffffff : Theme.text;
                                    font-size:            13px;
                                    font-weight:          600;
                                    overflow:             elide;
                                    vertical-alignment:   center;
                                    horizontal-stretch:   1;
                                }
                            }
                        }
                    }
                }
            }

            // ── Seasons (TV only) ─────────────────────────────────────────────
            // Horizontal Flickable strip of season cards (poster + name +
            // episode count + ✓ badge when selected) — same fixed-width
            // kb-x idiom as the tag strip and CastRow, just with a poster
            // instead of a chip label.
            if has-seasons: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-bottom: 24px;
                spacing:        8px;

                Text { text: "Seasons"; color: Theme.text; font-size: 16px; font-weight: 700; }

                // Same root-derived-width remedy as tag-fl above, same reason.
                property <length> kb-season-x: AppState.request-detail-focused-season <= 0 ? 0px
                    : clamp(-(AppState.request-detail-focused-season * 158px + 55px - season-fl.width / 2),
                            min(0px, season-fl.width - season-hbox.preferred-width), 0px);
                changed kb-season-x => { season-fl.viewport-x = kb-season-x; }

                season-fl := Flickable {
                    width:          root.width - 96px;
                    height:         210px;
                    viewport-width: season-hbox.preferred-width;
                    animate viewport-x { duration: 150ms * AppState.settings-scroll-speed; easing: ease-out-expo; }

                    season-hbox := HorizontalLayout {
                        spacing:   16px;
                        alignment: start;

                        for s[i] in AppState.request-detail-seasons: VerticalLayout {
                            width:   110px;
                            spacing: 4px;

                            Rectangle {
                                height:        165px;
                                border-radius: Theme.radius;
                                clip:          true;
                                background:    Theme.surface-raised;
                                border-width:  (season-ta.pressed || season-pulse.pulsing) ? 4px
                                             : (AppState.request-detail-zone == 4 && AppState.request-detail-focused-season == i ? 2px : 0px);
                                border-color:  Theme.accent;
                                animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                                season-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.request-detail-zone == 4 && AppState.request-detail-focused-season == i; }

                                if s.has-poster: Image { source: s.poster; width: parent.width; height: parent.height; image-fit: cover; }
                                if !s.has-poster: Text {
                                    text:                 s.season-number;
                                    color:                Theme.text-muted;
                                    font-size:            28px;
                                    font-weight:          700;
                                    horizontal-alignment: center;
                                    vertical-alignment:   center;
                                    width:                parent.width;
                                    height:               parent.height;
                                }

                                // ✓ selected badge (top-right), same idiom as PosterBlock's played badge
                                if s.selected: Rectangle {
                                    x: parent.width - 26px; y: 6px;
                                    width: 20px; height: 20px;
                                    border-radius: 10px;
                                    background: Theme.accent;
                                    Text { text: "✓︎"; font-family: "Adwaita Sans"; color: white; font-size: 10px; font-weight: 700;
                                           horizontal-alignment: center; vertical-alignment: center;
                                           width: parent.width; height: parent.height; }
                                }

                                season-ta := TouchArea {
                                    clicked => {
                                        AppState.request-detail-zone = 4;
                                        AppState.request-detail-focused-season = i;
                                        AppState.request-detail-toggle-season(i);
                                    }
                                }
                            }

                            Text { text: s.name; color: Theme.text; font-size: 12px; font-weight: 600; overflow: elide; }
                            Text { text: "\{s.episode-count} episodes"; color: Theme.text-muted; font-size: 11px; }
                        }
                    }
                }
            }

            Rectangle { height: Theme.sp-lg; }
        }
    }

    FjordButton {
        x:           16px;
        y:           16px;
        text:        "← Back";
        width:       88px;
        kbd-focused: AppState.request-detail-back-focused;
        clicked => { AppState.show-request-detail = false; }
    }
}
