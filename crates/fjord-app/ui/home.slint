                    font-weight:        700;
                    vertical-alignment: center;
                }
                FjordButton {
                    text:  "Browse All";
                    width: 110px;
                    clicked => { root.browse(); }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
        }

        fl := Flickable {
            vertical-stretch:   1;
            horizontal-stretch: 1;
            viewport-width:     fl.width;
            viewport-height:    max(fl.height, rows.preferred-height);
            viewport-y: kbd-section < 0 ? 0px
                      : clamp(
                            fl.height / 2 - section-y(kbd-section) - (card-h + 56px) / 2,
                            min(0px, fl.height - self.viewport-height),
                            0px
                        );
            animate viewport-y { duration: 150ms; easing: ease-out; }

            rows := VerticalLayout {
                padding: Theme.sp-lg;
                spacing: Theme.sp-lg;

                if continue-watching.length > 0: SectionRow {
                    section-title:   "Continue Watching";
                    items:           continue-watching;
                    section-focused: root.kbd-section == 0;
                    focused-card:    root.kbd-card;
                    card-w:          root.card-w;
                    card-h:          root.card-h;
                    item-play(id)   => { root.item-play(id); }
                }
                if next-up.length > 0: SectionRow {
                    section-title:   "Next Up";
                    items:           next-up;
                    section-focused: root.kbd-section == 1;
                    focused-card:    root.kbd-card;
                    card-w:          root.card-w;
                    card-h:          root.card-h;
                    item-play(id)   => { root.item-play(id); }
                }
                if recently-added.length > 0: SectionRow {
                    section-title:   "Recently Added";
                    items:           recently-added;
                    section-focused: root.kbd-section == 2;
                    focused-card:    root.kbd-card;
                    card-w:          root.card-w;
                    card-h:          root.card-h;
                    item-play(id)   => { root.item-play(id); }
                }
                if not-watched.length > 0: SectionRow {
                    section-title:   "Not Watched";
                    items:           not-watched;
                    section-focused: root.kbd-section == 3;
                    focused-card:    root.kbd-card;
                    card-w:          root.card-w;
                    card-h:          root.card-h;
                    item-play(id)   => { root.item-play(id); }
                }
                if continue-watching.length == 0 && next-up.length == 0 && recently-added.length == 0 && not-watched.length == 0: LoadingSpinner {
                    height: 120px;
                }
            }
        }
    }

    pure function section-y(s: int) -> length {
        Theme.sp-lg
        + (continue-watching.length > 0 && s > 0 ? (card-h + 56px + Theme.sp-lg) : 0px)
        + (next-up.length           > 0 && s > 1 ? (card-h + 56px + Theme.sp-lg) : 0px)
        + (recently-added.length    > 0 && s > 2 ? (card-h + 56px + Theme.sp-lg) : 0px)
        + (not-watched.length       > 0 && s > 3 ? (card-h + 56px + Theme.sp-lg) : 0px)
    }
}
