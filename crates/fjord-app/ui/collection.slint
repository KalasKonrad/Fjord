// ── fjord-app · collection.slint ─────────────────────────────────────────────
//   CollectionScreen  BoxSet detail: backdrop hero + Back button + title +
//                     overview + ♥︎/✓︎ buttons + member grid
//                     Opened when Enter is pressed on a BoxSet in the Collections library.
//                     collection-focused: int (focused card index); collection-back-focused: bool
//                     Enter on card → open-detail; C → context menu; Back → close
//                     Title column is a plain Rectangle fixed at height:240px (matching
//                     PosterBlock) with two independently-positioned children — title/item-
//                     count/overview at its top, the ♥︎/✓︎ row pinned via explicit
//                     y: parent.height - 38px (2026-07-18; corrected same day from an earlier
//                     vertical-stretch:1-spacer version that didn't reliably hold up live —
//                     see detail.slint's identical fix).
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, MediaCard, PosterBlock, IconCircleButton } from "widgets.slint";

export component CollectionScreen inherits Rectangle {
    property <length> card-w: 145px;
    property <length> card-h: 224px;
    property <length> gap:    14px;
    property <length> grid-content-height:
        ((AppState.collection-items.length + AppState.library-cols - 1) / AppState.library-cols)
        * (card-h + gap) + gap;

    property <length> kb-y: clamp(
        -(AppState.collection-focused / AppState.library-cols) * (card-h + gap) + fl-container.height / 2 - card-h / 2,
        min(0px, fl-container.height - grid-content-height),
        0px
    );
    changed kb-y => { coll-fl.viewport-y = kb-y; }

    fl := Flickable {
        width:           parent.width;
        height:          parent.height;
        viewport-height: coll-content.preferred-height;
        viewport-width:  self.width;
        animate viewport-y { duration: 200ms * AppState.settings-scroll-speed; easing: ease-in-out; }

        coll-content := VerticalLayout {

            // ── Header: backdrop + title block ────────────────────────────────
            Rectangle {
                background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

                if AppState.collection-has-backdrop: Image {
                    x: 0; y: 0;
                    width:     parent.width;
                    height:    parent.height;
                    image-fit: cover;
                    source:    AppState.collection-backdrop;
                }
                if AppState.collection-has-backdrop: Rectangle {
                    x: 0; y: 0;
                    width:      parent.width;
                    height:     parent.height;
                    background: @linear-gradient(180deg, #00000080 0%, #000000cc 100%);
                }

                VerticalLayout {
                    HorizontalLayout {
                        padding-left:   48px;
                        padding-right:  48px;
                        padding-top:    68px;
                        padding-bottom: 24px;
                        spacing:        32px;
                        alignment:      start;

                        if AppState.collection-has-poster: PosterBlock {
                            source:    AppState.collection-poster;
                            has-image: true;
                        }

                        // Deterministic fixed-position fix (2026-07-18,
                        // replaces an earlier height:240px+spacer version
                        // that didn't reliably hold up live — see
                        // detail.slint's identical fix for the full "why").
                        // Plain Rectangle fixed at 240px (matching
                        // PosterBlock); title/item-count/overview sit at
                        // its top in their own VerticalLayout, the ♥︎/✓︎ row
                        // is pinned via explicit `y: parent.height - 38px`
                        // (IconCircleButton is a hard-coded 38px in
                        // widgets.slint) — neither child's position
                        // depends on the other's size.
                        Rectangle {
                            height: 240px;

                            VerticalLayout {
                                x: 0; y: 0;
                                width:     parent.width;
                                spacing:   12px;
                                alignment: start;

                                Text {
                                    text:        AppState.collection-title;
                                    color:       Theme.text;
                                    font-size:   28px;
                                    font-weight: 700;
                                    wrap:        word-wrap;
                                }

                                if AppState.collection-items.length > 0: Text {
                                    text:      AppState.collection-items.length + " items";
                                    color:     AppState.collection-has-backdrop ? #cccccc : Theme.text-muted;
                                    font-size: 14px;
                                }

                                if AppState.collection-overview != "": Text {
                                    text:      AppState.collection-overview;
                                    color:     AppState.collection-has-backdrop ? #cccccc : Theme.text-muted;
                                    font-size: 13px;
                                    wrap:      word-wrap;
                                    max-width: 620px;
                                }
                            }

                            HorizontalLayout {
                                x: 0;
                                y: parent.height - 38px;
                                spacing:   10px;
                                alignment: start;
                                IconCircleButton {
                                    icon:        "❤︎";
                                    active:      AppState.collection-is-favorite;
                                    kbd-focused: AppState.collection-btn-focused == 0;
                                    clicked => { AppState.toggle-collection-fav(); }
                                }
                                IconCircleButton {
                                    icon:        "✓︎";
                                    active:      AppState.collection-has-played;
                                    kbd-focused: AppState.collection-btn-focused == 1;
                                    clicked => { AppState.toggle-collection-played(); }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }

            // ── Member grid ───────────────────────────────────────────────────
            fl-container := Rectangle {
                height:             grid-content-height;
                horizontal-stretch: 1;

                coll-fl := Flickable {
                    viewport-width:  fl-container.width;
                    viewport-height: max(fl-container.height, grid-content-height);
                    animate viewport-y { duration: 150ms * AppState.settings-scroll-speed; easing: ease-out-expo; }

                    VerticalLayout {
                        padding: gap;
                        spacing: gap;

                        for row-idx in (AppState.collection-items.length + AppState.library-cols - 1) / AppState.library-cols: HorizontalLayout {
                            alignment: start;
                            spacing:   gap;
                            height:    card-h;

                            for col-idx in AppState.library-cols: MediaCard {
                                property <int> idx: row-idx * AppState.library-cols + col-idx;
                                visible: idx < AppState.collection-items.length;
                                item:    AppState.collection-items[idx];
                                width:   card-w;
                                focused: idx == AppState.collection-focused && !AppState.collection-back-focused && AppState.collection-btn-focused < 0;
                                clicked => {
                                    AppState.collection-focused     = idx;
                                    AppState.collection-back-focused = false;
                                    AppState.collection-btn-focused  = -1;
                                    let c = AppState.collection-items[idx];
                                    AppState.open-detail(c.id, c.item-type);
                                }
                                right-clicked => {
                                    let c = AppState.collection-items[idx];
                                    AppState.context-menu-title = c.title;
                                    AppState.open-context-menu(c.id, c.has-played, c.is-favorite, c.resume-pct, c.item-type, c.series-id);
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { height: gap; }
        }
    }

    // Floating Back button — same position as detail.slint, overlaid on the backdrop
    FjordButton {
        x:           16px;
        y:           16px;
        text:        "← Back";
        width:       88px;
        kbd-focused: AppState.collection-back-focused;
        clicked => { AppState.show-collection = false; }
    }
}
