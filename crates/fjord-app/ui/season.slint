// ── fjord-app · season.slint ──────────────────────────────────────────────────
//   SeasonScreen  scrollable page: backdrop · poster/title/meta/overview ·
//                 episode SectionRow (reuses AppState.series-episode-cards) ·
//                 CastRow (season-specific people)
//   Keyboard scroll: kb-y property on fl; cast-anchor tracks cast section Y.
//   Episodes reuse series-episode-cards from AppState (already loaded for the
//   selected season); season-focused-ep tracks focus independently.
//   Title column is a plain Rectangle fixed at height:195px, width: root.width - 254px
//   (NOT parent.width — compile-time binding loop, see the Slint gotchas section)
//   (matching this screen's own 130x195 poster) with the ♥︎/✓︎ row pinned via explicit
//   y: parent.height - 38px (2026-07-18, three-attempt fix — see detail.slint's
//   identical structure, confirmed live-working there, for the full story).
// ─────────────────────────────────────────────────────────────────────────────
import { Theme, CardItem } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, IconCircleButton, CastRow, StorylineSection } from "widgets.slint";
import { SectionRow } from "home.slint";

export component SeasonScreen inherits Rectangle {
    background: Theme.bg;

    fl := Flickable {
        width:           parent.width;
        height:          parent.height;
        viewport-height: content.preferred-height;
        viewport-width:  self.width;
        animate viewport-y { duration: 200ms * AppState.settings-scroll-speed; easing: ease-in-out; }

        // Keyboard scroll — cast-anchor tracks cast section Y; when in episodes
        // (cast-focused < 0) scroll to ep-anchor.  Mouse-wheel still works
        // natively because viewport-y is NOT bound to an expression.
        property <length> kb-y:
            AppState.season-cast-focused >= 0 ?
                clamp(root.height / 2 - cast-anchor.y, min(0px, root.height - content.preferred-height), 0px) :
                clamp(root.height / 3 - ep-anchor.y,   min(0px, root.height - content.preferred-height), 0px);
        changed kb-y => { self.viewport-y = kb-y; }

        content := VerticalLayout {

            // ── Header: backdrop fills behind poster+title block ─────────────
            Rectangle {
                background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

                if AppState.season-has-backdrop: Image {
                    x: 0; y: 0;
                    width:     parent.width;
                    height:    parent.height;
                    image-fit: cover;
                    source:    AppState.season-backdrop;
                }
                if AppState.season-has-backdrop: Rectangle {
                    x: 0; y: 0;
                    width:      parent.width;
                    height:     parent.height;
                    background: @linear-gradient(180deg, #00000080 0%, #000000cc 100%);
                }

                VerticalLayout {
                HorizontalLayout {
                    padding-left:   48px;
                    padding-right:  48px;
                    padding-top:    68px;
                    padding-bottom: 20px;
                    spacing:        28px;
                    alignment:      start;

                    if AppState.season-has-poster: Rectangle {
                        width:         130px;
                        height:        195px;
                        border-radius: Theme.radius;
                        clip:          true;
                        Image {
                            source:    AppState.season-poster;
                            width:     parent.width;
                            height:    parent.height;
                            image-fit: cover;
                        }
                    }

                    // Deterministic fixed-position fix (2026-07-18, replaces
                    // an earlier height:195px+spacer version that didn't
                    // reliably hold up live — see detail.slint's identical
                    // fix for the full "why"). Plain Rectangle fixed at
                    // 195px matching this screen's own 130x195 poster (not
                    // 240px — that's PosterBlock's size, used on Detail/
                    // Collection/RequestDetail, not here). Title/meta sit
                    // at its top in their own VerticalLayout, the ♥︎/✓︎ row
                    // is pinned via explicit `y: parent.height - 38px`
                    // (IconCircleButton is a hard-coded 38px in
                    // widgets.slint) — neither child's position depends on
                    // the other's size.
                    Rectangle {
                        height: 195px;
                        // Explicit computed width off root.width — see
                        // detail.slint's identical fix for the full three-
                        // attempt "why" (horizontal-stretch:1 confirmed live
                        // not to work on a plain Rectangle; parent.width
                        // caused a genuine compile-time binding loop, since
                        // a HorizontalLayout's own width can't depend on a
                        // child reading it back). This screen's Rectangle
                        // had inherited horizontal-stretch:1 from the
                        // VerticalLayout it replaced and had the same latent
                        // bug, just not yet live-tested/reported. root.width
                        // minus the HorizontalLayout's own padding-left/
                        // padding-right (48+48), this screen's own 130px
                        // poster, and the 28px spacing between them
                        // (season.slint uses 28px here, not the 32px
                        // Detail/Collection/RequestDetail use).
                        width: root.width - 48px - 48px - 130px - 28px;

                        VerticalLayout {
                            x: 0; y: 0;
                            width:     parent.width;
                            spacing:   8px;
                            alignment: start;

                            Text {
                                text:        AppState.season-title;
                                color:       Theme.text;
                                font-size:   28px;
                                font-weight: 700;
                                wrap:        no-wrap;
                                overflow:    elide;
                            }

                            if AppState.season-meta != "": Text {
                                text:      AppState.season-meta;
                                color:     AppState.season-has-backdrop ? #ffffff : Theme.text-muted;
                                font-size: 13px;
                            }
                        }

                        HorizontalLayout {
                            x: 0;
                            y: parent.height - 38px;
                            spacing:   12px;
                            alignment: start;
                            IconCircleButton {
                                icon:        "❤︎";
                                active:      AppState.season-is-favorite;
                                kbd-focused: AppState.season-focused-btn == 1;
                                clicked => { AppState.toggle-season-fav(); }
                            }
                            IconCircleButton {
                                icon:        "✓︎";
                                active:      AppState.season-has-played;
                                kbd-focused: AppState.season-focused-btn == 2;
                                clicked => { AppState.toggle-season-played(); }
                            }
                        }
                    }
                }
                if AppState.season-overview != "": StorylineSection {
                    text:        AppState.season-overview;
                    expanded <=> AppState.season-overview-expanded;
                    kbd-focused: AppState.season-focused-btn == 3;
                }
                }
            }

            // ── Episode anchor (scroll target) ────────────────────────────────
            ep-anchor := Rectangle { height: 0px; }

            // ── Loading ───────────────────────────────────────────────────────
            if AppState.season-loading && AppState.series-episode-cards.length == 0: Rectangle {
                height: 60px;
                Text {
                    text:                 "Loading episodes…";
                    color:                Theme.text-muted;
                    font-size:            14px;
                    horizontal-alignment: center;
                    vertical-alignment:   center;
                }
            }

            // ── Episode row (reuses series-episode-cards) ─────────────────────
            if AppState.series-episode-cards.length > 0: VerticalLayout {
                padding-left:  48px;
                padding-right: 48px;
                SectionRow {
                    section-title:   "Episodes";
                    items:           AppState.series-episode-cards;
                    section-focused: AppState.season-cast-focused < 0
                                     && AppState.season-focused-btn < 0;
                    focused-card:    AppState.season-focused-ep;
                    item-play(id, _) => { AppState.play-series-episode(id); }
                    item-context(id, played, fav, rpct, itype, sid) => {
                        AppState.open-context-menu(id, played, fav, rpct, itype, sid);
                    }
                }
            }

            // ── Cast anchor (scroll target) ───────────────────────────────────
            cast-anchor := Rectangle { height: 0px; }

            // ── Cast & Crew ───────────────────────────────────────────────────
            if AppState.season-cast.length > 0: VerticalLayout {
                padding-left:   48px;
                padding-right:  48px;
                padding-top:    4px;
                padding-bottom: 40px;

                Rectangle { height: 1px; background: Theme.border; }
                Rectangle { height: 12px; }

                CastRow {
                    cast:        AppState.season-cast;
                    focused-idx: AppState.season-cast-focused;
                    item-selected(idx) => {
                        AppState.open-person(AppState.season-cast[idx].id, AppState.season-cast[idx].name);
                    }
                }
            }
        }
    }

    FjordButton {
        x:           16px;
        y:           16px;
        text:        "← Back";
        width:       88px;
        kbd-focused: AppState.season-focused-btn == 0;
        clicked => { AppState.close-season-detail(); }
    }
}
