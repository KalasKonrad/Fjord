// ── fjord-app · artist.slint ──────────────────────────────────────────────────
//   ArtistScreen  MusicArtist detail: portrait + meta + album grid
//                 artist-focused: int (focused album card flat index)
//                 artist-back-focused: bool (Back button has focus)
//                 artist-btn-focused: int (-1=none, 0=▶︎ Play All, 1=♥︎, 2=bio)
//                 artist-overview-expanded: bool (collapsible bio below header)
//                 Enter on card → open-album; C → context menu; Back → close-artist
//                 ▶︎ Play All → play-artist-all; ♥︎ → toggle-artist-fav
//                 Title column: height:160px (matching the circular portrait) +
//                 vertical-stretch:1 spacer before the button row, alignment:start
//                 instead of the previous alignment:center (2026-07-18) — trades the
//                 old vertically-centered title+meta+buttons group (which re-centered
//                 whenever the meta line appeared/disappeared) for a fixed bottom-
//                 pinned button row, matching Detail/Collection/Season/RequestDetail.
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, MediaCard, IconCircleButton, StorylineSection } from "widgets.slint";

export component ArtistScreen inherits Rectangle {
    property <length> card-w: 145px;
    property <length> card-h: 224px;
    property <length> gap:    14px;
    property <length> grid-content-height:
        ((AppState.artist-albums.length + AppState.library-cols - 1) / AppState.library-cols)
        * (card-h + gap) + gap;

    property <length> kb-y: clamp(
        -(AppState.artist-focused / AppState.library-cols) * (card-h + gap) + fl-container.height / 2 - card-h / 2,
        min(0px, fl-container.height - grid-content-height),
        0px
    );
    changed kb-y => { art-fl.viewport-y = kb-y; }

    fl := Flickable {
        width:           parent.width;
        height:          parent.height;
        viewport-height: art-content.preferred-height;
        viewport-width:  self.width;
        animate viewport-y { duration: 200ms * AppState.settings-scroll-speed; easing: ease-in-out; }

        art-content := VerticalLayout {

            // ── Header block ──────────────────────────────────────────────────
            Rectangle {
                background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

                VerticalLayout {
                    HorizontalLayout {
                        padding-left:   48px;
                        padding-right:  48px;
                        padding-top:    68px;
                        padding-bottom: 24px;
                        spacing:        32px;
                        alignment:      start;

                        // Portrait / placeholder
                        Rectangle {
                            width:         160px;
                            height:        160px;
                            border-radius: 80px;  // circle
                            background:    Theme.surface-overlay;
                            clip:          true;
                            if AppState.artist-has-portrait: Image {
                                width:     parent.width;
                                height:    parent.height;
                                image-fit: cover;
                                source:    AppState.artist-portrait;
                            }
                            if !AppState.artist-has-portrait: Text {
                                text:                 "♪︎";
                                    font-family:          "Noto Sans Symbols 2";
                                color:                Theme.text-subtle;
                                font-size:            64px;
                                vertical-alignment:   center;
                                horizontal-alignment: center;
                                width:                parent.width;
                                height:               parent.height;
                            }
                        }

                        VerticalLayout {
                            // height:160px + vertical-stretch:1 spacer,
                            // matching the circular portrait above — same
                            // fixed-button-position fix as Detail/Collection/
                            // Season/RequestDetail (2026-07-18). This
                            // deliberately trades the previous alignment:
                            // center (title+meta+buttons floating as a
                            // vertically-centered group, re-centering
                            // whenever the optional meta line appears/
                            // disappears) for alignment:start + a bottom-
                            // pinned button row, for the same reason those
                            // other screens changed: a fixed button position
                            // over one that drifts with content.
                            height:    160px;
                            spacing:   12px;
                            alignment: start;

                            Text {
                                text:        AppState.artist-title;
                                color:       Theme.text;
                                font-size:   28px;
                                font-weight: 700;
                                wrap:        word-wrap;
                            }
                            if AppState.artist-meta != "": Text {
                                text:      AppState.artist-meta;
                                color:     Theme.text-muted;
                                font-size: 14px;
                            }

                            Rectangle { vertical-stretch: 1; }

                            // ▶︎ Play All + ♥︎ action buttons
                            HorizontalLayout {
                                spacing:   10px;
                                alignment: start;
                                FjordButton {
                                    icon-left:   "▶︎";
                                    text:        "Play All";
                                    height:      34px;
                                    width:       110px;
                                    kbd-focused: AppState.artist-btn-focused == 0;
                                    clicked => { AppState.play-artist-all(); }
                                }
                                IconCircleButton {
                                    icon:        "❤︎";
                                    active:      AppState.artist-is-favorite;
                                    kbd-focused: AppState.artist-btn-focused == 1;
                                    clicked => { AppState.toggle-artist-fav(); }
                                }
                            }
                        }
                    }
                }
            }

            // ── Overview / bio (collapsible) ──────────────────────────────────
            if AppState.artist-overview != "": StorylineSection {
                text:        AppState.artist-overview;
                expanded <=> AppState.artist-overview-expanded;
                kbd-focused: AppState.artist-btn-focused == 2;
            }

            Rectangle { height: 1px; background: Theme.border; }

            // ── Album grid ────────────────────────────────────────────────────
            fl-container := Rectangle {
                height:             grid-content-height;
                horizontal-stretch: 1;

                art-fl := Flickable {
                    viewport-width:  fl-container.width;
                    viewport-height: max(fl-container.height, grid-content-height);
                    animate viewport-y { duration: 150ms * AppState.settings-scroll-speed; easing: ease-out-expo; }

                    VerticalLayout {
                        padding: gap;
                        spacing: gap;

                        for row-idx in (AppState.artist-albums.length + AppState.library-cols - 1) / AppState.library-cols: HorizontalLayout {
                            alignment: start;
                            spacing:   gap;
                            height:    card-h;

                            for col-idx in AppState.library-cols: MediaCard {
                                property <int> idx: row-idx * AppState.library-cols + col-idx;
                                visible: idx < AppState.artist-albums.length;
                                item:    AppState.artist-albums[idx];
                                width:   card-w;
                                focused: idx == AppState.artist-focused && !AppState.artist-back-focused;
                                clicked => {
                                    // Single click opens (grid-wide convention);
                                    // focus syncs so Back returns the cursor here.
                                    AppState.artist-focused      = idx;
                                    AppState.artist-back-focused = false;
                                    AppState.artist-btn-focused  = -1;
                                    let c = AppState.artist-albums[idx];
                                    AppState.open-album(c.id, c.title);
                                }
                                right-clicked => {
                                    let c = AppState.artist-albums[idx];
                                    AppState.context-menu-title = c.title;
                                    AppState.open-context-menu(c.id, c.has-played, c.is-favorite, c.resume-pct, c.item-type, c.series-id);
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { height: gap; }
        }
    }

    // Floating Back button
    FjordButton {
        x:           16px;
        y:           16px;
        text:        "← Back";
        width:       88px;
        kbd-focused: AppState.artist-back-focused;
        clicked => { AppState.close-artist(); }
    }
}
