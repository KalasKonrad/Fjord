// ── fjord-app · connect.slint ────────────────────────────────────────────────
//   ConnectingScreen  shown at startup while the saved-session auth probe is in
//                     flight — replaces the old behavior of showing cached
//                     dashboard content before connectivity is confirmed
//   OfflineScreen     shown when the probe can't reach the server at all (not a
//                     definite 401 — that still routes to LoginScreen); three
//                     buttons (offline-focused 0/1/2, Left/Right + Enter from
//                     keys.rs): Retry (AppState.retry-connection), Change Server
//                     (AppState.sign-out — clears the saved session so the
//                     user can enter a fresh URL, for a permanent failure like
//                     a decommissioned server), Quit (AppState.quit)
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, LoadingSpinner } from "widgets.slint";

export component ConnectingScreen inherits Rectangle {
    background: Theme.bg;
    VerticalLayout {
        alignment: center;
        spacing: Theme.sp;
        LoadingSpinner { }
        Text {
            text:                 "Connecting to server…";
            color:                Theme.text-muted;
            font-size:            14px;
            horizontal-alignment: center;
        }
    }
}

export component OfflineScreen inherits Rectangle {
    background: Theme.bg;

    card := Rectangle {
        width:         min(420px, parent.width - 48px);
        height:        inner.preferred-height;
        x:             (parent.width  - self.width)  / 2;
        y:             (parent.height - self.height) / 2 - 24px;
        background:    Theme.surface;
        border-radius: Theme.radius-lg;
        drop-shadow-blur:  28px;
        drop-shadow-color: #00000070;

        inner := VerticalLayout {
            padding: Theme.sp-xl;
            spacing: Theme.sp;

            Text {
                text:                 "Can't reach server";
                color:                Theme.text;
                font-size:            22px;
                font-weight:          700;
                horizontal-alignment: center;
            }
            if AppState.status != "": Text {
                text:                 AppState.status;
                color:                Theme.text-muted;
                font-size:            13px;
                horizontal-alignment: center;
                wrap:                 word-wrap;
            }

            Rectangle { height: 4px; }

            HorizontalLayout {
                spacing: Theme.sp-sm;
                FjordButton {
                    text:        "Retry";
                    kbd-focused: AppState.offline-focused == 0;
                    clicked => { AppState.retry-connection(); }
                }
                FjordButton {
                    text:        "Change Server";
                    kbd-focused: AppState.offline-focused == 1;
                    clicked => { AppState.sign-out(); }
                }
                FjordButton {
                    text:        "Quit";
                    kbd-focused: AppState.offline-focused == 2;
                    clicked => { AppState.quit(); }
                }
            }
        }
    }
}
