// ── fjord-app · browse.slint ─────────────────────────────────────────────────
//   BrowseScreen  search bar + scrollable ListView of all library items
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, BrowseItem } from "widgets.slint";
import { LineEdit, ListView } from "std-widgets.slint";

export component BrowseScreen inherits Rectangle {
    background: Theme.bg;

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height:     54px;
            background: Theme.surface;

            HorizontalLayout {
                padding-left:  Theme.sp-sm;
                padding-right: Theme.sp;
                spacing:       Theme.sp-sm;
                alignment:     start;

                FjordButton {
                    text:  "← Back";
                    width: 80px;
                    clicked => { AppState.current-item = -1; AppState.show-browse = false; }
                }
                search-field := LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text:   "Search…";
                    edited(text) => { AppState.filter-changed(text); }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
        }

        list-view := ListView {
            horizontal-stretch: 1;
            vertical-stretch:   1;
            viewport-y: AppState.current-item < 0 ? 0px
                      : clamp(
                            -(AppState.current-item * 42px + 21px - list-view.visible-height / 2),
                            min(0px, list-view.visible-height - AppState.media-items.length * 42px),
                            0px
                        );
            animate viewport-y { duration: 150ms; easing: ease-out; }

            for item[i] in AppState.media-items: BrowseItem {
                width:    list-view.visible-width - 12px;
                text:     item.text;
                selected: i == AppState.current-item;
                clicked   => { AppState.current-item = i; }
                activated => { AppState.play-item(i); }
            }
        }

        Rectangle {
            height:     50px;
            background: Theme.surface;

            Rectangle { height: 1px; background: Theme.border; }

            HorizontalLayout {
                padding-left:  Theme.sp;
                padding-right: Theme.sp;
                padding-top:   Theme.sp-xs;
                spacing:       Theme.sp;
                alignment:     space-between;

                Text {
                    text:               AppState.status;
                    color:              Theme.text-muted;
                    font-size:          13px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                FjordButton {
                    text:    "▶  Play";
                    width:   100px;
                    enabled: AppState.current-item >= 0;
                    clicked => { AppState.play-item(AppState.current-item); }
                }
            }
        }
    }
}
