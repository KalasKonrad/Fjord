// ── fjord-app · browse.slint ─────────────────────────────────────────────────
//   BrowseScreen  keyboard-driven search bar (browse-query) + scrollable ListView
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, BrowseItem } from "widgets.slint";

export component BrowseScreen inherits Rectangle {
    background: Theme.bg;

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height:     54px;
            background: Theme.surface;

            HorizontalLayout {
                padding-left:  Theme.sp-sm;
                padding-right: Theme.sp;
                spacing:       Theme.sp-sm;
                alignment:     start;

                FjordButton {
                    text:  "← Back";
                    width: 80px;
                    clicked => {
                        AppState.browse-header-focused = false;
                        AppState.current-item = -1;
                        AppState.show-browse  = false;
                        AppState.browse-search-clear();
                        if AppState.active-nav == 3 { AppState.active-nav = 0; }
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    height:             36px;
                    border-radius:      Theme.radius;
                    border-width:       AppState.browse-header-focused ? 2px : 1px;
                    border-color:       AppState.browse-header-focused ? Theme.accent : Theme.border;
                    background:         Theme.bg;

                    HorizontalLayout {
                        padding-left:  12px;
                        padding-right: 12px;
                        spacing:       8px;
                        alignment:     start;

                        Text {
                            text:               "⌕";
                            color:              AppState.browse-header-focused ? Theme.accent : Theme.text-muted;
                            font-size:          17px;
                            vertical-alignment: center;
                            width:              22px;
                        }
                        Text {
                            text: AppState.browse-header-focused
                                ? (AppState.browse-query != "" ? AppState.browse-query + "▌" : "▌")
                                : AppState.browse-query != "" ? AppState.browse-query
                                : "Search…";
                            color: AppState.browse-query != "" ? Theme.text
                                 : AppState.browse-header-focused ? Theme.text-muted
                                 : Theme.text-subtle;
                            font-size:          14px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        if AppState.browse-query != "" && !AppState.browse-header-focused: Text {
                            text:               "Esc to clear";
                            color:              Theme.text-subtle;
                            font-size:          12px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
        }

        list-flick := Flickable {
            horizontal-stretch: 1;
            vertical-stretch:   1;
            interactive:        false;
            viewport-height: AppState.media-items.length * 42px;
            viewport-y: AppState.current-item < 0 ? 0px
                      : clamp(
                            -(AppState.current-item * 42px + 21px - list-flick.height / 2),
                            min(0px, list-flick.height - AppState.media-items.length * 42px),
                            0px
                        );
            animate viewport-y { duration: 150ms; easing: ease-out; }

            VerticalLayout {
                for item[i] in AppState.media-items: BrowseItem {
                    text:     item.text;
                    selected: i == AppState.current-item;
                    clicked   => { AppState.current-item = i; }
                    activated => { AppState.play-item(i); }
                }
            }
        }

        Rectangle {
            height:     50px;
            background: Theme.surface;

            Rectangle { height: 1px; background: Theme.border; }

            HorizontalLayout {
                padding-left:  Theme.sp;
                padding-right: Theme.sp;
                padding-top:   Theme.sp-xs;
                spacing:       Theme.sp;
                alignment:     space-between;

                Text {
                    text:               AppState.status;
                    color:              Theme.text-muted;
                    font-size:          13px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                FjordButton {
                    text:    "▶  Play";
                    width:   100px;
                    enabled: AppState.current-item >= 0;
                    clicked => { AppState.play-item(AppState.current-item); }
                }
            }
        }
    }
}
