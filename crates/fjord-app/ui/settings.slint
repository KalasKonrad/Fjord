// ── fjord-app · settings.slint ───────────────────────────────────────────────
//   SettingsScreen   two-pane layout: left section list, right scrollable content
//     Left pane      "General" / "Video" / "Audio" / "Player" / "Key Bindings" / "UI" /
//                    "Integrations" (each appended last, not inserted earlier — every row
//                    below hardcodes a literal section: N with no symbolic const reference,
//                    so inserting a section anywhere but the end means renumbering every
//                    row that follows); below the section list, a vertical-stretch:1
//                    spacer pins a SERVER/CLIENT/SEERR info block to the bottom of the
//                    pane — SEERR only rendered when AppState.seerr-connected
//     Right pane     Flickable; shows section content based on settings-section
//       General      launch-in-fullscreen (row 0), video-behind (row 1), log-level (row 2),
//                    prewarm-metadata (row 3), prewarm-images (row 4), sign-out (row 5)
//       Video        hwdec (0), vf (1), deinterlace (2),
//                    video-sync (3), interpolation (4), tscale (5 virtual),
//                    tone-mapping (6), target-colorspace (7),
//                    opengl-early-flush (8), video-latency-hacks (9)
//       Audio        audio-device (0), audio-channels (1), SPDIF (2), AC3 (3), EAC3 (4),
//                    DTS (5), DTS-HD (6), TrueHD (7), passthrough-device (8, hidden when
//                    SPDIF off), alsa-irq-scheduling (9 virtual, hidden when SPDIF off or
//                    non-PipeWire device), audio-lang (10), gapless-audio (11 toggle),
//                    now-playing-auto-open (12 toggle)
//       Player       sub-enabled (0), sub-lang (1, hidden when disabled),
//                    sub-lang2 (2, hidden when disabled), sub-type (3, hidden when disabled),
//                    sub-scale (4), sub-pos (5), sub-respect-ass-styling (6, always visible —
//                    scale/pos always apply to ASS subtitles per mpv's own default, so only
//                    this toggle is unconditional), sub-color (7 virtual, only when !respect-ass),
//                    sub-background (8 virtual, only when !respect-ass) — rows 4-8 all hidden
//                    when sub disabled, same as 1-3; cache-mb (9);
//                    INTRO SKIPPER: intro-mode (10), intro-secs (11 virtual),
//                    recap-mode (12), recap-secs (13 virtual),
//                    preview-mode (14), preview-secs (15 virtual),
//                    commercial-mode (16), commercial-secs (17 virtual),
//                    CREDITS: credits-mode (18), credits-secs (19 virtual);
//                    SEEKING: seek-step (20), seek-step-long (21) — appended at the end,
//                    always visible, no natural "home" section within Player
//       Key Bindings keybinding-focused 0..N rows, Reset button
//       UI           scroll-speed (0), animation-speed (1) — both always visible, no
//                    virtual rows; percentage multipliers driving ~119 animate blocks +
//                    LoadingSpinner's cycle Timer across all other .slint files, see
//                    settings-scroll-speed/settings-animation-speed in app_state.slint;
//                    text-font (2, dynamic dropdown — fc-list at startup, same shape as
//                    Audio → audio-device — "Inter (Fjord default)" + "System default" +
//                    every installed font family; bound to MainWindow.default-font-family)
//       Integrations seerr-enabled (0, toggle — gates the Discover sidebar tab only, independent
//                    of connection state), seerr-connect (1, bespoke Rectangle like Sign Out —
//                    "Connect Seerr"/"Disconnect" depending on AppState.seerr-connected, opens
//                    ConnectSeerrScreen or calls seerr-disconnect())
//   Row highlight    handled by SettingsRow component (TouchArea lower z, children higher z)
//   Scroll           viewport-y tracks settings-focused (≈64px/row for Video/Audio);
//                    keybinding scroll ≈base + index*44px
//   kb-row-y(i)      approximate: i*44px + 22px  (used for scroll only)
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, ToggleSwitch, SectionHeader, SettingsDropdown, SettingsRow, PressPulse } from "widgets.slint";

export component SettingsScreen inherits Rectangle {
    background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

    pure function kb-row-y(i: int) -> length {
        i * 44px + 22px
    }

    HorizontalLayout {
        // ── Left pane ─────────────────────────────────────────────────────────
        left-pane := Rectangle {
            background: Theme.surface;
            width: 220px;

            VerticalLayout {
                padding: Theme.sp-xl;
                spacing: Theme.sp-sm;
                alignment: start;

                Text {
                    text: "Settings";
                    color: Theme.text;
                    font-size: 20px;
                    font-weight: 700;
                }

                Rectangle { height: 1px; background: Theme.border; }

                // Section list — General (0), Video (1), Audio (2), Player (3), Key Bindings (4)
                for sect[i] in ["General", "Video", "Audio", "Player", "Key Bindings", "UI", "Integrations"]: Rectangle {
                    height: 44px;
                    border-radius: Theme.radius;
                    background: {
                        let hov = sect-ta.has-hover;
                        AppState.settings-section == i
                            ? (i == 4
                                ? (AppState.keybinding-focused < 0 ? Theme.accent : Theme.accent-muted)
                                : (AppState.settings-focused < 0 ? Theme.accent : Theme.accent-muted))
                            : (hov ? Theme.surface-raised : transparent)
                    };
                    border-width:  (sect-ta.pressed || sect-pulse.pulsing) ? 3px : 0px;
                    border-color:  Theme.accent;
                    animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                    sect-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.settings-section == i; }
                    sect-ta := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            AppState.settings-section = i;
                            AppState.settings-focused = -1;
                            AppState.refocus();
                        }
                    }
                    HorizontalLayout {
                        padding-left: 12px;
                        alignment: start;
                        Text {
                            text: sect;
                            color: Theme.text;
                            font-size: 14px;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle { vertical-stretch: 1; }

                // ── Server / Seerr / Client info block — pinned to the bottom.
                // Seerr sits right after Server (both are "servers" Fjord
                // connects to), before Client (Fjord itself) — moved here
                // per explicit request, was originally after Client.
                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "SERVER"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }
                Text {
                    text:      AppState.server-name != "" ? AppState.server-name : "—";
                    color:     Theme.text;
                    font-size: 13px;
                    font-weight: 600;
                    overflow:  elide;
                }
                Text {
                    text:      AppState.server-version != "" ? AppState.server-version : "";
                    color:     Theme.text-muted;
                    font-size: 11px;
                    overflow:  elide;
                }

                if AppState.seerr-connected: Text { text: "SEERR"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }
                if AppState.seerr-connected: Text {
                    text:      AppState.seerr-connected-label;
                    color:     Theme.text;
                    font-size: 13px;
                    font-weight: 600;
                    wrap:      word-wrap;
                }
                // Deliberately NOT Theme.text-muted, unlike every other
                // version line here — explicit request.
                if AppState.seerr-connected && AppState.seerr-version != "": Text {
                    text:      AppState.seerr-version;
                    color:     Theme.text;
                    font-size: 11px;
                    overflow:  elide;
                }

                Text { text: "CLIENT"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }
                Text {
                    text:      "FJORD";
                    color:     Theme.text;
                    font-size: 13px;
                    font-weight: 600;
                    overflow:  elide;
                }
                Text {
                    text:      AppState.client-version != "" ? AppState.client-version : "—";
                    color:     Theme.text-muted;
                    font-size: 11px;
                    overflow:  elide;
                }
            }
        }

        Rectangle { width: 1px; background: Theme.border; }

        // ── Right pane ────────────────────────────────────────────────────────
        right-pane := Rectangle {
            horizontal-stretch: 1;
            property <length> right-vp-h: right-inner.preferred-height + Theme.sp-xl * 2;
            property <length> kb-y: AppState.keybinding-focused >= 0
                ? clamp(-(kb-row-y(AppState.keybinding-focused) - self.height / 2),
                         min(0px, self.height - right-vp-h), 0px)
                : AppState.settings-focused < 0 ? 0px
                : clamp(-(Theme.sp-xl + 30px + AppState.settings-focused * 64px + 28px
                          - self.height / 2),
                         min(0px, self.height - right-vp-h), 0px);
            changed kb-y => { right-fl.viewport-y = kb-y; }

            // ── Keyboard dropdown overlay props ───────────────────────────────
            property <length> kbdd-content-h: AppState.settings-dropdown-model.length * 32px + 8px;
            property <length> kbdd-h:         min(kbdd-content-h, 320px);
            property <length> kbdd-w:         min(max(300px, kbdd-vl.preferred-width + 8px), self.width - Theme.sp-xl * 2);

            right-fl := Flickable {
                viewport-height: right-pane.right-vp-h;

            right-inner := VerticalLayout {
                y: Theme.sp-xl;
                width: parent.width - Theme.sp-xl * 2;
                x: Theme.sp-xl;

                // ── General section ───────────────────────────────────────────
                if AppState.settings-section == 0: VerticalLayout {
                    spacing: Theme.sp-sm;

                    SectionHeader { text: "GENERAL"; }

                    // Row 0 — Launch in fullscreen
                    SettingsRow { row-index: 0; section: 0; title: "Launch in fullscreen"; subtitle: "Start Fjord in fullscreen mode";
                        ToggleSwitch { checked <=> AppState.settings-launch-fullscreen; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 1 — Video in background
                    SettingsRow { row-index: 1; section: 0; title: "Video in background"; subtitle: "Show video behind the UI when you press Back during playback";
                        ToggleSwitch { checked <=> AppState.settings-video-behind; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 2 — Log level
                    SettingsRow { row-index: 2; section: 0; title: "Log level"; subtitle: "Verbosity of ~/.cache/fjord/fjord.log — applies on next launch";
                        SettingsDropdown {
                            model: ["error","warn","info","debug"];
                            current-value: AppState.settings-log-level;
                            selected(v) => { AppState.settings-log-level = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 3 — Prewarm library metadata
                    SettingsRow { row-index: 3; section: 0; title: "Prewarm library metadata";
                        subtitle: AppState.prewarm-metadata-running
                            ? "Running… \{AppState.prewarm-metadata-done} of \{AppState.prewarm-metadata-total}"
                            : (AppState.prewarm-metadata-summary != "" ? AppState.prewarm-metadata-summary
                               : "Fetch detail/cast/related-items for your whole library once, so opening anything is instant");
                        FjordButton {
                            width: 100px;
                            text: AppState.prewarm-metadata-running ? "Running…" : "Prewarm";
                            enabled: !AppState.prewarm-metadata-running;
                            clicked => { AppState.prewarm-metadata(); }
                        }
                    }

                    // Row 4 — Prewarm library images
                    SettingsRow { row-index: 4; section: 0; title: "Prewarm library images";
                        subtitle: AppState.prewarm-image-running
                            ? "Running… \{AppState.prewarm-image-done} of \{AppState.prewarm-image-total}"
                            : (AppState.prewarm-image-summary != "" ? AppState.prewarm-image-summary
                               : "Fetch backdrops + cast portraits for whatever's already in the metadata cache");
                        FjordButton {
                            width: 100px;
                            text: AppState.prewarm-image-running ? "Running…" : "Prewarm";
                            enabled: !AppState.prewarm-image-running;
                            clicked => { AppState.prewarm-images(); }
                        }
                    }

                    Rectangle { height: 1px; background: Theme.border; }

                    // Row 5 — Sign Out
                    Rectangle {
                        border-radius: Theme.radius;
                        background: AppState.settings-focused == 5 ? Theme.accent-muted
                                  : (g2.has-hover ? Theme.surface : transparent);
                        height: 48px;
                        border-width:  (g2.pressed || signout-pulse.pulsing) ? 3px : 0px;
                        border-color:  Theme.accent;
                        animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                        signout-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.settings-focused == 5; }
                        g2 := TouchArea {
                            clicked => { AppState.sign-out(); }
                        }
                        HorizontalLayout {
                            padding-left: 12px;
                            alignment: start;
                            Text {
                                text: "Sign Out";
                                color: Theme.error;
                                font-size: 14px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── Video section ─────────────────────────────────────────────
                if AppState.settings-section == 1: VerticalLayout {
                    spacing: Theme.sp-sm;

                    SectionHeader { text: "DECODE"; }

                    // Row 0 — hwdec
                    SettingsRow { row-index: 0; section: 1; title: "Hardware decode (hwdec)"; subtitle: "AMD: vulkan (native) or vulkan-copy · NVIDIA legacy: nvdec-copy + set vf below";
                        SettingsDropdown {
                            model: ["auto","vulkan","vulkan-copy","nvdec","nvdec-copy","vaapi","vaapi-copy","vdpau","vdpau-copy","none"];
                            current-value: AppState.settings-hwdec;


                            selected(v) => { AppState.settings-hwdec = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 1 — vf
                    SettingsRow { row-index: 1; section: 1; title: "Video filter (vf)"; subtitle: "auto: applies stride fix only when nvdec is active, safe for all GPUs · yuv420p/yuv420p10le: force 8-bit/10-bit fix";
                        SettingsDropdown {
                            model: ["","auto","format=yuv420p","format=yuv420p10le","format=nv12","format=p010"];
                            current-value: AppState.settings-vf;


                            selected(v) => { AppState.settings-vf = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 2 — Deinterlace
                    SettingsRow { row-index: 2; section: 1; title: "Deinterlace"; subtitle: "auto: only deinterlaces content flagged as interlaced · yes: always on (DVD / broadcast)";
                        SettingsDropdown {
                            model: ["no","auto","yes"];
                            current-value: AppState.settings-deinterlace;
                            selected(v) => { AppState.settings-deinterlace = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    SectionHeader { text: "SYNCHRONISATION"; }

                    // Row 3 — Video sync
                    SettingsRow { row-index: 3; section: 1; title: "Video sync"; subtitle: "display-resample: smooth sync · desync: no A/V correction (debug)";
                        SettingsDropdown {
                            model: ["audio","display-resample","display-vdrop","display-adrop","desync"];
                            current-value: AppState.settings-video-sync;


                            selected(v) => { AppState.settings-video-sync = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }
                    if AppState.settings-audio-spdif && AppState.settings-video-sync == "display-resample" && (AppState.settings-spdif-ac3 || AppState.settings-spdif-eac3 || AppState.settings-spdif-dts || AppState.settings-spdif-dts-hd || AppState.settings-spdif-truehd): Rectangle {
                        height: 24px;
                        HorizontalLayout {
                            x: 12px; y: 0px; height: parent.height;
                            spacing: 4px; alignment: start;
                            Text {
                                text: "⚠︎";
                                font-family: "Noto Sans Symbols 2";
                                color: Theme.error; font-size: 12px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "passthrough active — display-resample falls back to 'audio' sync (no display sync correction)";
                                color: Theme.error; font-size: 12px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Row 4 — Motion interpolation
                    SettingsRow { row-index: 4; section: 1; title: "Motion interpolation"; subtitle: "Temporal interpolation between frames (best with display-resample)";
                        ToggleSwitch { checked <=> AppState.settings-interpolation; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 5 — tscale (virtual: only shown when interpolation is on)
                    if AppState.settings-interpolation: SettingsRow { row-index: 5; section: 1; title: "Temporal scaler (tscale)"; subtitle: "Algorithm used for motion interpolation";
                        SettingsDropdown {
                            model: ["oversample","catmull_rom","mitchell","gaussian","bicubic"];
                            current-value: AppState.settings-tscale;


                            selected(v) => { AppState.settings-tscale = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    SectionHeader { text: "HDR"; }

                    // Row 6 — HDR passthrough
                    SettingsRow { row-index: 6; section: 1; title: "HDR passthrough"; subtitle: "Pass HDR metadata to compositor for native HDR output (compositor handles tone mapping)";
                        ToggleSwitch { checked <=> AppState.settings-target-colorspace-hint; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 7 — Tone mapping (hidden when HDR passthrough is on)
                    if !AppState.settings-target-colorspace-hint: SettingsRow { row-index: 7; section: 1; title: "Tone mapping"; subtitle: "HDR → SDR algorithm — auto is usually correct"; indent: true;
                        SettingsDropdown {
                            model: ["auto","hable","bt.2390","reinhard","mobius","clip","gamma","linear"];
                            current-value: AppState.settings-tone-mapping;
                            selected(v) => { AppState.settings-tone-mapping = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    SectionHeader { text: "NVIDIA WAYLAND"; }

                    // Row 8 — OpenGL early flush
                    SettingsRow { row-index: 8; section: 1; title: "OpenGL early flush"; subtitle: "Flush GL after each frame — may reduce jitter on NVIDIA Wayland";
                        ToggleSwitch { checked <=> AppState.settings-opengl-early-flush; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 9 — Video latency hacks (only relevant with display-resample)
                    if AppState.settings-video-sync == "display-resample": SettingsRow { row-index: 9; section: 1; title: "Video latency hacks"; subtitle: "Compensate for imprecise Wayland vsync timestamps (NVIDIA 5xx legacy)"; indent: true;
                        ToggleSwitch { checked <=> AppState.settings-video-latency-hacks; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }
                }

                // ── Audio section ─────────────────────────────────────────────
                if AppState.settings-section == 2: VerticalLayout {
                    spacing: Theme.sp-sm;

                    SectionHeader { text: "OUTPUT"; }

                    // Row 0 — Audio output device
                    SettingsRow { row-index: 0; section: 2; title: "Audio output"; subtitle: "mpv audio device — auto lets the system choose";
                        SettingsDropdown {
                            model <=> AppState.settings-audio-device-display;
                            current-value: AppState.settings-audio-device-desc != "" ? AppState.settings-audio-device-desc : "Autoselect device";
                            selected(v) => { AppState.audio-device-selected(v); AppState.refocus(); }
                        }
                    }

                    // Row 1 — Audio channels (mpv --audio-channels)
                    SettingsRow { row-index: 1; section: 2; title: "Audio channels"; subtitle: "'auto-safe' may downmix 5.1 PCM to stereo on direct ALSA devices — '7.1,5.1,stereo' negotiates the best layout";
                        SettingsDropdown {
                            model: ["auto-safe","auto","stereo","5.1","7.1","7.1,5.1,stereo"];
                            current-value: AppState.settings-audio-channels;
                            selected(v) => { AppState.settings-audio-channels = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    SectionHeader { text: "PASSTHROUGH"; }

                    // Row 2 — Audio SPDIF master toggle
                    SettingsRow { row-index: 2; section: 2; title: "Audio passthrough (SPDIF)"; subtitle: "Bitstream audio to AV receiver — select formats below";
                        ToggleSwitch { checked <=> AppState.settings-audio-spdif; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Rows 3–9 — Per-format toggles + passthrough device + PipeWire fix (hidden when SPDIF is off)
                    if AppState.settings-audio-spdif: VerticalLayout {
                        SettingsRow { row-index: 3; section: 2; title: "AC3 (Dolby Digital)";         subtitle: "Standard Dolby 5.1"; indent: true;
                            ToggleSwitch { checked <=> AppState.settings-spdif-ac3;    toggled => { AppState.settings-changed(); AppState.refocus(); } }
                        }
                        SettingsRow { row-index: 4; section: 2; title: "EAC3 (Dolby Digital Plus)";   subtitle: "DD+ used on streaming and Blu-ray"; indent: true;
                            ToggleSwitch { checked <=> AppState.settings-spdif-eac3;   toggled => { AppState.settings-changed(); AppState.refocus(); } }
                        }
                        SettingsRow { row-index: 5; section: 2; title: "DTS";                         subtitle: "DTS core"; indent: true;
                            ToggleSwitch { checked <=> AppState.settings-spdif-dts;    toggled => { AppState.settings-changed(); AppState.refocus(); } }
                        }
                        SettingsRow { row-index: 6; section: 2; title: "DTS-HD MA";                   subtitle: "DTS lossless / DTS:X"; indent: true;
                            ToggleSwitch { checked <=> AppState.settings-spdif-dts-hd; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                        }
                        SettingsRow { row-index: 7; section: 2; title: "TrueHD / Atmos";              subtitle: "Dolby lossless / Atmos object audio"; indent: true;
                            ToggleSwitch { checked <=> AppState.settings-spdif-truehd; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                        }
                        // Row 8 — Passthrough output device (video playback only)
                        SettingsRow { row-index: 8; section: 2; indent: true;
                            title: "Passthrough output";
                            subtitle: "Device used for video while SPDIF is on — music always keeps the normal output";
                            SettingsDropdown {
                                model <=> AppState.settings-audio-device-display;
                                current-value: AppState.settings-passthrough-device-desc != "" ? AppState.settings-passthrough-device-desc : "Same as audio output";
                                selected(v) => { AppState.passthrough-device-selected(v); AppState.refocus(); }
                            }
                        }
                        // Row 9 — PipeWire IRQ scheduling; hidden when a direct ALSA/JACK/OSS device is selected
                        if AppState.settings-device-is-pipewire: SettingsRow { row-index: 9; section: 2; indent: true;
                            title: "PipeWire IRQ scheduling";
                            subtitle: "Use hardware IRQ wakeups instead of software timers — fixes passthrough dropout under GPU load";
                            ToggleSwitch { checked <=> AppState.settings-alsa-irq-scheduling; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                        }
                    }

                    if AppState.settings-audio-spdif && AppState.settings-video-sync == "display-resample" && (AppState.settings-spdif-ac3 || AppState.settings-spdif-eac3 || AppState.settings-spdif-dts || AppState.settings-spdif-dts-hd || AppState.settings-spdif-truehd): Rectangle {
                        height: 24px;
                        HorizontalLayout {
                            x: 12px; y: 0px; height: parent.height;
                            spacing: 4px; alignment: start;
                            Text {
                                text: "⚠︎";
                                font-family: "Noto Sans Symbols 2";
                                color: Theme.error; font-size: 12px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "passthrough active — display-resample falls back to 'audio' sync (no display sync correction)";
                                color: Theme.error; font-size: 12px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    SectionHeader { text: "LANGUAGE"; }

                    // Row 10 — Preferred audio language
                    SettingsRow { row-index: 10; section: 2; title: "Preferred audio language"; subtitle: "Auto-select matching audio track when the video has multiple audio tracks";
                        SettingsDropdown {
                            model: ["Off","English","German","French","Japanese","Spanish","Italian","Portuguese","Russian","Korean","Chinese","Dutch","Swedish","Polish","Czech","Arabic","Turkish","Finnish","Danish","Norwegian"];
                            current-value: AppState.settings-audio-lang == "" ? "Off" : AppState.settings-audio-lang;


                            selected(v) => { AppState.settings-audio-lang = v == "Off" ? "" : v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    SectionHeader { text: "MUSIC"; }

                    // Row 11 — Gapless music playback
                    SettingsRow { row-index: 11; section: 2; title: "Gapless music playback"; subtitle: "Preload the next track into the running player — album transitions without a gap";
                        ToggleSwitch { checked <=> AppState.settings-gapless-audio; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 12 — Auto-open Now Playing after idle
                    SettingsRow { row-index: 12; section: 2; title: "Auto-open Now Playing"; subtitle: "Show the fullscreen music screen after ~30s idle while music plays";
                        ToggleSwitch { checked <=> AppState.settings-now-playing-auto-open; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }
                }

                // ── Player section ────────────────────────────────────────────
                if AppState.settings-section == 3: VerticalLayout {
                    spacing: Theme.sp-sm;

                    SectionHeader { text: "SUBTITLES"; }

                    // Row 0 — Subtitle on/off
                    SettingsRow { row-index: 0; section: 3; title: "Enable subtitles"; subtitle: "Off always disables subtitles regardless of language settings";
                        ToggleSwitch { checked <=> AppState.settings-sub-enabled; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 1 — Primary subtitle language (hidden when subs disabled)
                    if AppState.settings-sub-enabled: SettingsRow { row-index: 1; section: 3; indent: true; title: "Primary language"; subtitle: "Auto-select first matching track; no preference = use video default";
                        SettingsDropdown {
                            model: ["Off","English","German","French","Japanese","Spanish","Italian","Portuguese","Russian","Korean","Chinese","Dutch","Swedish","Polish","Czech","Arabic","Turkish","Finnish","Danish","Norwegian"];
                            current-value: AppState.settings-sub-lang == "" ? "Off" : AppState.settings-sub-lang;


                            selected(v) => { AppState.settings-sub-lang = v == "Off" ? "" : v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 2 — Fallback subtitle language (hidden when subs disabled)
                    if AppState.settings-sub-enabled: SettingsRow { row-index: 2; section: 3; indent: true; title: "Fallback language"; subtitle: "Used when no primary language track is found";
                        SettingsDropdown {
                            model: ["Off","English","German","French","Japanese","Spanish","Italian","Portuguese","Russian","Korean","Chinese","Dutch","Swedish","Polish","Czech","Arabic","Turkish","Finnish","Danish","Norwegian"];
                            current-value: AppState.settings-sub-lang2 == "" ? "Off" : AppState.settings-sub-lang2;


                            selected(v) => { AppState.settings-sub-lang2 = v == "Off" ? "" : v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 3 — Subtitle type preference (hidden when subs disabled)
                    if AppState.settings-sub-enabled: SettingsRow { row-index: 3; section: 3; indent: true; title: "Subtitle type"; subtitle: "Prefer Normal (no tags), Forced (foreign lines only), or Hearing Impaired (SDH)";
                        SettingsDropdown {
                            model: ["Any","Normal","Forced","Hearing Impaired"];
                            current-value: AppState.settings-sub-type == "" ? "Any" : AppState.settings-sub-type;
                            selected(v) => { AppState.settings-sub-type = v == "Any" ? "" : v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 4 — Subtitle size (hidden when subs disabled). Always
                    // applies regardless of the ASS-styling toggle below — mpv
                    // applies sub-scale to ASS subtitles too at its own default.
                    if AppState.settings-sub-enabled: SettingsRow { row-index: 4; section: 3; indent: true; title: "Subtitle size"; subtitle: "Applies to both plain and styled (ASS) subtitles";
                        SettingsDropdown {
                            model: ["50","75","100","125","150","175","200"];
                            current-value: AppState.settings-sub-scale-pct == 50  ? "50"
                                         : AppState.settings-sub-scale-pct == 75  ? "75"
                                         : AppState.settings-sub-scale-pct == 125 ? "125"
                                         : AppState.settings-sub-scale-pct == 150 ? "150"
                                         : AppState.settings-sub-scale-pct == 175 ? "175"
                                         : AppState.settings-sub-scale-pct == 200 ? "200" : "100";
                            selected(v) => {
                                AppState.settings-sub-scale-pct = v == "50"  ? 50
                                                                 : v == "75"  ? 75
                                                                 : v == "125" ? 125
                                                                 : v == "150" ? 150
                                                                 : v == "175" ? 175
                                                                 : v == "200" ? 200 : 100;
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 5 — Subtitle vertical position (hidden when subs
                    // disabled). Also always applies regardless of the
                    // ASS-styling toggle — mpv documents sub-pos as affecting
                    // ASS subtitles unconditionally.
                    if AppState.settings-sub-enabled: SettingsRow { row-index: 5; section: 3; indent: true; title: "Subtitle position"; subtitle: "100 = bottom of screen; lower values move it up";
                        SettingsDropdown {
                            model: ["50","60","70","80","90","95","100"];
                            current-value: AppState.settings-sub-pos-pct == 50 ? "50"
                                         : AppState.settings-sub-pos-pct == 60 ? "60"
                                         : AppState.settings-sub-pos-pct == 70 ? "70"
                                         : AppState.settings-sub-pos-pct == 80 ? "80"
                                         : AppState.settings-sub-pos-pct == 90 ? "90"
                                         : AppState.settings-sub-pos-pct == 95 ? "95" : "100";
                            selected(v) => {
                                AppState.settings-sub-pos-pct = v == "50" ? 50
                                                               : v == "60" ? 60
                                                               : v == "70" ? 70
                                                               : v == "80" ? 80
                                                               : v == "90" ? 90
                                                               : v == "95" ? 95 : 100;
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 6 — Respect subtitle's own styling (ASS). Only this
                    // toggle is always visible; Color/Background below are
                    // hidden while it's on, since those two settings are the
                    // ones that silently do nothing to ASS-styled subtitles
                    // otherwise (per mpv's sub-ass-override, default "scale").
                    if AppState.settings-sub-enabled: SettingsRow { row-index: 6; section: 3; indent: true; title: "Respect subtitle's own styling (ASS)"; subtitle: "Off lets Color/Background below also apply to styled subtitles — may render some files incorrectly";
                        ToggleSwitch { checked <=> AppState.settings-sub-respect-ass-styling; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 7 — Subtitle color (virtual: only when Row 6 is off)
                    if AppState.settings-sub-enabled && !AppState.settings-sub-respect-ass-styling: SettingsRow { row-index: 7; section: 3; indent: true; title: "Subtitle color"; subtitle: "Only affects plain subtitles unless styling above is not respected";
                        SettingsDropdown {
                            model: ["Default","White","Yellow","Cyan","Green"];
                            current-value: AppState.settings-sub-color == "" ? "Default" : AppState.settings-sub-color;
                            selected(v) => { AppState.settings-sub-color = v == "Default" ? "" : v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 8 — Subtitle background box (virtual: only when Row 6 is off)
                    if AppState.settings-sub-enabled && !AppState.settings-sub-respect-ass-styling: SettingsRow { row-index: 8; section: 3; indent: true; title: "Subtitle background box"; subtitle: "Draw a solid box behind subtitle text";
                        ToggleSwitch { checked <=> AppState.settings-sub-background; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    SectionHeader { text: "BUFFERING"; }

                    // Row 9 — Demuxer cache
                    SettingsRow { row-index: 9; section: 3; title: "Demuxer cache (MiB)"; subtitle: "0 = mpv default (~150 MiB). Increase for slow network / large files.";
                        SettingsDropdown {
                            model: ["0","50","150","300","500","1000"];
                            current-value: AppState.settings-cache-mb == 0   ? "0"
                                         : AppState.settings-cache-mb == 50  ? "50"
                                         : AppState.settings-cache-mb == 150 ? "150"
                                         : AppState.settings-cache-mb == 300 ? "300"
                                         : AppState.settings-cache-mb == 500 ? "500" : "1000";


                            selected(v) => {
                                AppState.settings-cache-mb = v == "0"   ? 0
                                                           : v == "50"  ? 50
                                                           : v == "150" ? 150
                                                           : v == "300" ? 300
                                                           : v == "500" ? 500 : 1000;
                                AppState.settings-changed();
                                AppState.refocus();
                            }
                        }
                    }

                    SectionHeader { text: "INTRO SKIPPER"; }

                    // Row 10 — Intro skip mode
                    SettingsRow { row-index: 10; section: 3; title: "Intro"; subtitle: "What to do when an intro segment is detected";
                        SettingsDropdown {
                            model: ["Always skip", "Ask", "Ask (timed)", "Never skip"];
                            current-value: AppState.settings-skip-intro-mode == "always-skip" ? "Always skip"
                                         : AppState.settings-skip-intro-mode == "ask-timed"   ? "Ask (timed)"
                                         : AppState.settings-skip-intro-mode == "never-skip"  ? "Never skip" : "Ask";
                            selected(v) => {
                                AppState.settings-skip-intro-mode = v == "Always skip" ? "always-skip"
                                                                  : v == "Ask (timed)" ? "ask-timed"
                                                                  : v == "Never skip"  ? "never-skip" : "ask";
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 11 — Intro auto-skip timer (virtual: only when ask-timed)
                    if AppState.settings-skip-intro-mode == "ask-timed": SettingsRow { row-index: 11; section: 3; indent: true; title: "Auto-skip after"; subtitle: "Seconds before the intro is skipped automatically";
                        SettingsDropdown {
                            model: ["3","5","8","10","15","20","30"];
                            current-value: AppState.settings-skip-intro-secs == 3  ? "3"
                                         : AppState.settings-skip-intro-secs == 5  ? "5"
                                         : AppState.settings-skip-intro-secs == 10 ? "10"
                                         : AppState.settings-skip-intro-secs == 15 ? "15"
                                         : AppState.settings-skip-intro-secs == 20 ? "20"
                                         : AppState.settings-skip-intro-secs == 30 ? "30" : "8";
                            selected(v) => {
                                AppState.settings-skip-intro-secs = v == "3"  ? 3 : v == "5"  ? 5
                                    : v == "10" ? 10 : v == "15" ? 15 : v == "20" ? 20 : v == "30" ? 30 : 8;
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 12 — Recap skip mode
                    SettingsRow { row-index: 12; section: 3; title: "Recap"; subtitle: "What to do when a recap segment is detected";
                        SettingsDropdown {
                            model: ["Always skip", "Ask", "Ask (timed)", "Never skip"];
                            current-value: AppState.settings-skip-recap-mode == "always-skip" ? "Always skip"
                                         : AppState.settings-skip-recap-mode == "ask-timed"   ? "Ask (timed)"
                                         : AppState.settings-skip-recap-mode == "never-skip"  ? "Never skip" : "Ask";
                            selected(v) => {
                                AppState.settings-skip-recap-mode = v == "Always skip" ? "always-skip"
                                                                  : v == "Ask (timed)" ? "ask-timed"
                                                                  : v == "Never skip"  ? "never-skip" : "ask";
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 13 — Recap auto-skip timer (virtual)
                    if AppState.settings-skip-recap-mode == "ask-timed": SettingsRow { row-index: 13; section: 3; indent: true; title: "Auto-skip after"; subtitle: "Seconds before the recap is skipped automatically";
                        SettingsDropdown {
                            model: ["3","5","8","10","15","20","30"];
                            current-value: AppState.settings-skip-recap-secs == 3  ? "3"
                                         : AppState.settings-skip-recap-secs == 5  ? "5"
                                         : AppState.settings-skip-recap-secs == 10 ? "10"
                                         : AppState.settings-skip-recap-secs == 15 ? "15"
                                         : AppState.settings-skip-recap-secs == 20 ? "20"
                                         : AppState.settings-skip-recap-secs == 30 ? "30" : "8";
                            selected(v) => {
                                AppState.settings-skip-recap-secs = v == "3"  ? 3 : v == "5"  ? 5
                                    : v == "10" ? 10 : v == "15" ? 15 : v == "20" ? 20 : v == "30" ? 30 : 8;
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 14 — Preview skip mode
                    SettingsRow { row-index: 14; section: 3; title: "Preview"; subtitle: "What to do when a preview segment is detected";
                        SettingsDropdown {
                            model: ["Always skip", "Ask", "Ask (timed)", "Never skip"];
                            current-value: AppState.settings-skip-preview-mode == "always-skip" ? "Always skip"
                                         : AppState.settings-skip-preview-mode == "ask-timed"   ? "Ask (timed)"
                                         : AppState.settings-skip-preview-mode == "never-skip"  ? "Never skip" : "Ask";
                            selected(v) => {
                                AppState.settings-skip-preview-mode = v == "Always skip" ? "always-skip"
                                                                    : v == "Ask (timed)" ? "ask-timed"
                                                                    : v == "Never skip"  ? "never-skip" : "ask";
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 15 — Preview auto-skip timer (virtual)
                    if AppState.settings-skip-preview-mode == "ask-timed": SettingsRow { row-index: 15; section: 3; indent: true; title: "Auto-skip after"; subtitle: "Seconds before the preview is skipped automatically";
                        SettingsDropdown {
                            model: ["3","5","8","10","15","20","30"];
                            current-value: AppState.settings-skip-preview-secs == 3  ? "3"
                                         : AppState.settings-skip-preview-secs == 5  ? "5"
                                         : AppState.settings-skip-preview-secs == 10 ? "10"
                                         : AppState.settings-skip-preview-secs == 15 ? "15"
                                         : AppState.settings-skip-preview-secs == 20 ? "20"
                                         : AppState.settings-skip-preview-secs == 30 ? "30" : "8";
                            selected(v) => {
                                AppState.settings-skip-preview-secs = v == "3"  ? 3 : v == "5"  ? 5
                                    : v == "10" ? 10 : v == "15" ? 15 : v == "20" ? 20 : v == "30" ? 30 : 8;
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 16 — Commercial skip mode
                    SettingsRow { row-index: 16; section: 3; title: "Commercial"; subtitle: "What to do when a commercial segment is detected";
                        SettingsDropdown {
                            model: ["Always skip", "Ask", "Ask (timed)", "Never skip"];
                            current-value: AppState.settings-skip-commercial-mode == "always-skip" ? "Always skip"
                                         : AppState.settings-skip-commercial-mode == "ask-timed"   ? "Ask (timed)"
                                         : AppState.settings-skip-commercial-mode == "never-skip"  ? "Never skip" : "Ask";
                            selected(v) => {
                                AppState.settings-skip-commercial-mode = v == "Always skip" ? "always-skip"
                                                                       : v == "Ask (timed)" ? "ask-timed"
                                                                       : v == "Never skip"  ? "never-skip" : "ask";
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 17 — Commercial auto-skip timer (virtual)
                    if AppState.settings-skip-commercial-mode == "ask-timed": SettingsRow { row-index: 17; section: 3; indent: true; title: "Auto-skip after"; subtitle: "Seconds before the commercial is skipped automatically";
                        SettingsDropdown {
                            model: ["3","5","8","10","15","20","30"];
                            current-value: AppState.settings-skip-commercial-secs == 3  ? "3"
                                         : AppState.settings-skip-commercial-secs == 5  ? "5"
                                         : AppState.settings-skip-commercial-secs == 10 ? "10"
                                         : AppState.settings-skip-commercial-secs == 15 ? "15"
                                         : AppState.settings-skip-commercial-secs == 20 ? "20"
                                         : AppState.settings-skip-commercial-secs == 30 ? "30" : "8";
                            selected(v) => {
                                AppState.settings-skip-commercial-secs = v == "3"  ? 3 : v == "5"  ? 5
                                    : v == "10" ? 10 : v == "15" ? 15 : v == "20" ? 20 : v == "30" ? 30 : 8;
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    SectionHeader { text: "CREDITS / UP NEXT"; }

                    // Row 18 — Credits (Up Next banner) mode
                    SettingsRow { row-index: 18; section: 3; title: "Credits / Up Next"; subtitle: "What to do when credits start; controls the Up Next auto-advance banner";
                        SettingsDropdown {
                            model: ["Always skip", "Ask", "Never skip"];
                            current-value: AppState.settings-skip-credits-mode == "always-skip" ? "Always skip"
                                         : AppState.settings-skip-credits-mode == "never-skip"  ? "Never skip" : "Ask";
                            selected(v) => {
                                AppState.settings-skip-credits-mode = v == "Always skip" ? "always-skip"
                                                                    : v == "Never skip"  ? "never-skip" : "ask";
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 19 — Up Next countdown duration (virtual: only when credits = ask)
                    if AppState.settings-skip-credits-mode == "ask": SettingsRow { row-index: 19; section: 3; indent: true; title: "Countdown"; subtitle: "Seconds shown on the Up Next banner before auto-advancing";
                        SettingsDropdown {
                            model: ["10","15","20","30","45","60"];
                            current-value: AppState.settings-skip-credits-secs == 10 ? "10"
                                         : AppState.settings-skip-credits-secs == 15 ? "15"
                                         : AppState.settings-skip-credits-secs == 20 ? "20"
                                         : AppState.settings-skip-credits-secs == 45 ? "45"
                                         : AppState.settings-skip-credits-secs == 60 ? "60" : "30";
                            selected(v) => {
                                AppState.settings-skip-credits-secs = v == "10" ? 10 : v == "15" ? 15
                                    : v == "20" ? 20 : v == "45" ? 45 : v == "60" ? 60 : 30;
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    SectionHeader { text: "SEEKING"; }

                    // Row 20 — Seek step (Left/Right, and the on-screen skip buttons)
                    SettingsRow { row-index: 20; section: 3; title: "Seek step"; subtitle: "Left/Right arrow seek amount during playback";
                        SettingsDropdown {
                            model: ["5","10","15","20","30"];
                            current-value: AppState.settings-seek-step-secs == 5  ? "5"
                                         : AppState.settings-seek-step-secs == 15 ? "15"
                                         : AppState.settings-seek-step-secs == 20 ? "20"
                                         : AppState.settings-seek-step-secs == 30 ? "30" : "10";
                            selected(v) => {
                                AppState.settings-seek-step-secs = v == "5"  ? 5
                                                                  : v == "15" ? 15
                                                                  : v == "20" ? 20
                                                                  : v == "30" ? 30 : 10;
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }

                    // Row 21 — Long seek step (Shift+Left/Right, and the long skip buttons)
                    SettingsRow { row-index: 21; section: 3; title: "Long seek step"; subtitle: "Shift+Left/Right arrow seek amount during playback";
                        SettingsDropdown {
                            model: ["15","30","45","60","120"];
                            current-value: AppState.settings-seek-step-long-secs == 15  ? "15"
                                         : AppState.settings-seek-step-long-secs == 45  ? "45"
                                         : AppState.settings-seek-step-long-secs == 60  ? "60"
                                         : AppState.settings-seek-step-long-secs == 120 ? "120" : "30";
                            selected(v) => {
                                AppState.settings-seek-step-long-secs = v == "15"  ? 15
                                                                       : v == "45"  ? 45
                                                                       : v == "60"  ? 60
                                                                       : v == "120" ? 120 : 30;
                                AppState.settings-changed(); AppState.refocus();
                            }
                        }
                    }
                }

                // ── Key Bindings section ──────────────────────────────────────
                if AppState.settings-section == 4: VerticalLayout {
                    spacing: 0;

                    SectionHeader { text: "NAVIGATION & GLOBAL"; }

                    for kb[i] in AppState.keybinding-normal: Rectangle {
                        height: 44px;
                        border-radius: Theme.radius;
                        background: AppState.keybinding-focused == i
                                    ? (AppState.keybinding-rebinding ? Theme.accent : Theme.accent-muted)
                                    : (kb-ta.has-hover ? Theme.surface : transparent);
                        border-width:  (kb-ta.pressed || kb-pulse.pulsing) ? 3px : 0px;
                        border-color:  Theme.accent;
                        animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                        kb-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.keybinding-focused == i; }
                        kb-ta := TouchArea {
                            clicked => { AppState.keybinding-focused = i; }
                        }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px;
                            alignment: space-between;
                            Text { text: kb.action; color: Theme.text; font-size: 13px; vertical-alignment: center; }
                            Text {
                                text: AppState.keybinding-focused == i && AppState.keybinding-rebinding
                                      ? "Press a key…" : kb.key;
                                color: AppState.keybinding-focused == i && AppState.keybinding-rebinding
                                       ? Theme.bg : Theme.text-muted;
                                font-size: 12px; vertical-alignment: center;
                            }
                        }
                    }

                    SectionHeader { text: "PLAYER"; }

                    for kb[i] in AppState.keybinding-player: Rectangle {
                        height: 44px;
                        border-radius: Theme.radius;
                        background: AppState.keybinding-focused == i + AppState.keybinding-normal.length
                                    ? (AppState.keybinding-rebinding ? Theme.accent : Theme.accent-muted)
                                    : (kb-player-ta.has-hover ? Theme.surface : transparent);
                        border-width:  (kb-player-ta.pressed || kb-player-pulse.pulsing) ? 3px : 0px;
                        border-color:  Theme.accent;
                        animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                        kb-player-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.keybinding-focused == i + AppState.keybinding-normal.length; }
                        kb-player-ta := TouchArea {
                            clicked => { AppState.keybinding-focused = i + AppState.keybinding-normal.length; }
                        }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px;
                            alignment: space-between;
                            Text { text: kb.action; color: Theme.text; font-size: 13px; vertical-alignment: center; }
                            Text {
                                text: AppState.keybinding-focused == i + AppState.keybinding-normal.length
                                      && AppState.keybinding-rebinding ? "Press a key…" : kb.key;
                                color: AppState.keybinding-focused == i + AppState.keybinding-normal.length
                                       && AppState.keybinding-rebinding ? Theme.bg : Theme.text-muted;
                                font-size: 12px; vertical-alignment: center;
                            }
                        }
                    }

                    FjordButton {
                        text: "Reset to Defaults";
                        clicked => { AppState.keybinding-reset-defaults(); AppState.refocus(); }
                    }
                }

                // ── UI section ──────────────────────────────────────────────────
                if AppState.settings-section == 5: VerticalLayout {
                    spacing: Theme.sp-sm;

                    SectionHeader { text: "UI"; }

                    // Row 0 — Scroll speed. The value is a DURATION multiplier, not a
                    // rate — bigger % = longer transition = slower, smaller % = faster.
                    // Opposite of what "speed" suggests at a glance, so the subtitle
                    // spells it out.
                    SettingsRow { row-index: 0; section: 5; title: "Scroll speed"; subtitle: "Speed of list/page scrolling with the keyboard — lower % is faster, higher % is slower";
                        SettingsDropdown {
                            model: ["0","25","50","75","100","150","200","300","400","500"];
                            current-value: AppState.settings-scroll-speed-pct == 0   ? "0"
                                         : AppState.settings-scroll-speed-pct == 25  ? "25"
                                         : AppState.settings-scroll-speed-pct == 50  ? "50"
                                         : AppState.settings-scroll-speed-pct == 75  ? "75"
                                         : AppState.settings-scroll-speed-pct == 150 ? "150"
                                         : AppState.settings-scroll-speed-pct == 200 ? "200"
                                         : AppState.settings-scroll-speed-pct == 300 ? "300"
                                         : AppState.settings-scroll-speed-pct == 400 ? "400"
                                         : AppState.settings-scroll-speed-pct == 500 ? "500" : "100";
                            selected(v) => {
                                AppState.settings-scroll-speed-pct = v == "0"   ? 0
                                                                    : v == "25"  ? 25
                                                                    : v == "50"  ? 50
                                                                    : v == "75"  ? 75
                                                                    : v == "150" ? 150
                                                                    : v == "200" ? 200
                                                                    : v == "300" ? 300
                                                                    : v == "400" ? 400
                                                                    : v == "500" ? 500 : 100;
                                AppState.settings-scroll-speed = (v == "0"   ? 0.0
                                                                 : v == "25"  ? 0.25
                                                                 : v == "50"  ? 0.5
                                                                 : v == "75"  ? 0.75
                                                                 : v == "150" ? 1.5
                                                                 : v == "200" ? 2.0
                                                                 : v == "300" ? 3.0
                                                                 : v == "400" ? 4.0
                                                                 : v == "500" ? 5.0 : 1.0);
                                AppState.settings-changed();
                                AppState.refocus();
                            }
                        }
                    }

                    // Row 1 — Animation speed (same duration-multiplier caveat as above)
                    SettingsRow { row-index: 1; section: 5; title: "Animation speed"; subtitle: "Speed of press feedback, fades, and other UI transitions — lower % is faster, higher % is slower, 0% = instant";
                        SettingsDropdown {
                            model: ["0","25","50","75","100","150","200","300","400","500"];
                            current-value: AppState.settings-animation-speed-pct == 0   ? "0"
                                         : AppState.settings-animation-speed-pct == 25  ? "25"
                                         : AppState.settings-animation-speed-pct == 50  ? "50"
                                         : AppState.settings-animation-speed-pct == 75  ? "75"
                                         : AppState.settings-animation-speed-pct == 150 ? "150"
                                         : AppState.settings-animation-speed-pct == 200 ? "200"
                                         : AppState.settings-animation-speed-pct == 300 ? "300"
                                         : AppState.settings-animation-speed-pct == 400 ? "400"
                                         : AppState.settings-animation-speed-pct == 500 ? "500" : "100";
                            selected(v) => {
                                AppState.settings-animation-speed-pct = v == "0"   ? 0
                                                                       : v == "25"  ? 25
                                                                       : v == "50"  ? 50
                                                                       : v == "75"  ? 75
                                                                       : v == "150" ? 150
                                                                       : v == "200" ? 200
                                                                       : v == "300" ? 300
                                                                       : v == "400" ? 400
                                                                       : v == "500" ? 500 : 100;
                                AppState.settings-animation-speed = (v == "0"   ? 0.0
                                                                    : v == "25"  ? 0.25
                                                                    : v == "50"  ? 0.5
                                                                    : v == "75"  ? 0.75
                                                                    : v == "150" ? 1.5
                                                                    : v == "200" ? 2.0
                                                                    : v == "300" ? 3.0
                                                                    : v == "400" ? 4.0
                                                                    : v == "500" ? 5.0 : 1.0);
                                AppState.settings-changed();
                                AppState.refocus();
                            }
                        }
                    }

                    // Row 2 — Text font (dynamic dropdown, same shape as Audio
                    // output above — fetched at startup via fc-list, main.rs)
                    SettingsRow { row-index: 2; section: 5; title: "Text font"; subtitle: "Inter is Fjord's own designed-around default — pick any font installed on this system to override it";
                        SettingsDropdown {
                            model <=> AppState.settings-font-family-display;
                            current-value: AppState.settings-font-family-desc != "" ? AppState.settings-font-family-desc : "Inter (Fjord default)";
                            selected(v) => { AppState.font-family-selected(v); AppState.refocus(); }
                        }
                    }
                }

                // ── Integrations section ────────────────────────────────────
                if AppState.settings-section == 6: VerticalLayout {
                    spacing: Theme.sp-sm;

                    SectionHeader { text: "INTEGRATIONS"; }

                    // Row 0 — Enable Seerr (only gates the Discover sidebar tab;
                    // independent of connection state — see the property doc
                    // comment in app_state.slint)
                    SettingsRow { row-index: 0; section: 6; title: "Seerr"; subtitle: "Search and request movies/shows not yet in your library";
                        ToggleSwitch { checked <=> AppState.settings-seerr-enabled; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 1 — Connect / Disconnect (bespoke Rectangle, same
                    // pattern as the General section's Sign Out row — a plain
                    // action row, not a SettingsRow + control pair)
                    Rectangle {
                        border-radius: Theme.radius;
                        background: AppState.settings-focused == 1 ? Theme.accent-muted
                                  : (int-connect-ta.has-hover ? Theme.surface : transparent);
                        height: 48px;
                        border-width:  (int-connect-ta.pressed || int-connect-pulse.pulsing) ? 3px : 0px;
                        border-color:  Theme.accent;
                        animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                        int-connect-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: AppState.settings-focused == 1; }
                        int-connect-ta := TouchArea {
                            clicked => {
                                if AppState.seerr-connected { AppState.seerr-disconnect(); } else { AppState.open-connect-seerr(); }
                            }
                        }
                        HorizontalLayout {
                            padding-left: 12px;
                            alignment: start;
                            spacing: 2px;
                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                Text {
                                    text: AppState.seerr-connected ? "Disconnect" : "Connect Seerr";
                                    color: AppState.seerr-connected ? Theme.error : Theme.text;
                                    font-size: 14px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: AppState.seerr-connected-label;
                                    color: Theme.text-muted;
                                    font-size: 12px;
                                }
                            }
                        }
                    }

                    // Row 2 — Streaming Region (dynamic dropdown, same shape
                    // as Text font above — fetched from Seerr instead of
                    // fc-list, once per connection rather than at startup;
                    // only reachable/rendered while connected, since it has
                    // nothing to show otherwise)
                    if AppState.seerr-connected: SettingsRow { row-index: 2; section: 6; title: "Streaming Region"; subtitle: "Which region's providers show in \"Currently Streaming On\" on Discover";
                        SettingsDropdown {
                            model <=> AppState.settings-streaming-region-display;
                            current-value: AppState.settings-streaming-region-desc != "" ? AppState.settings-streaming-region-desc : "United States (US)";
                            selected(v) => { AppState.streaming-region-selected(v); AppState.refocus(); }
                        }
                    }
                }
            }
            }

            // ── Keyboard dropdown overlay ─────────────────────────────────────
            // Shown when a dropdown row is opened via Enter. The FocusScope keeps
            // focus so Rust continues to receive all key events. Up/Down move the
            // cursor; Enter confirms; Escape/Left closes without changing.
            // Always in tree (visible: not if:) so kbdd-vl.preferred-width is readable for kbdd-w.
            Rectangle {
                visible:       AppState.settings-dropdown-open;
                z:             20;
                width:         right-pane.kbdd-w;
                height:        right-pane.kbdd-h;
                x:             right-pane.width - self.width - Theme.sp-xl;
                y:             Theme.sp-xl;
                background:    Theme.surface-raised;
                border-radius: 8px;
                border-width:  1px;
                border-color:  Theme.border;
                drop-shadow-blur:  12px;
                drop-shadow-color: #00000080;
                clip:          true;

                kbdd-fl := Flickable {
                    viewport-height: right-pane.kbdd-content-h;

                    // Scroll to keep cursor centred in the overlay panel.
                    property <length> kbdd-scroll: AppState.settings-dropdown-cursor >= 0
                        ? clamp(-(AppState.settings-dropdown-cursor * 32px + 16px - right-pane.kbdd-h / 2),
                                min(0px, right-pane.kbdd-h - right-pane.kbdd-content-h), 0px)
                        : 0px;
                    changed kbdd-scroll => { kbdd-fl.viewport-y = kbdd-scroll; }
                    init    => { kbdd-fl.viewport-y = kbdd-scroll; }

                    kbdd-vl := VerticalLayout {
                        padding: 4px;
                        for opt[i] in AppState.settings-dropdown-model: Rectangle {
                            height:          32px;
                            border-radius:   4px;
                            preferred-width: kbdd-txt.preferred-width + 24px;
                            background:      i == AppState.settings-dropdown-cursor
                                             ? Theme.accent-muted
                                             : (kbdd-item-ta.has-hover ? Theme.surface-overlay : transparent);
                            border-width:  (kbdd-item-ta.pressed || kbdd-pulse.pulsing) ? 3px : 0px;
                            border-color:  Theme.accent;
                            animate border-width { duration: 90ms * AppState.settings-animation-speed; easing: ease-out-expo; }
                            kbdd-pulse := PressPulse { trigger: AppState.kb-activate-pulse; active: i == AppState.settings-dropdown-cursor; }
                            kbdd-txt := Text {
                                x:                  12px;
                                text:               opt;
                                color:              opt == AppState.settings-dropdown-display
                                                    ? Theme.accent : Theme.text;
                                font-size:          13px;
                                font-weight:        opt == AppState.settings-dropdown-display ? 600 : 400;
                                vertical-alignment: center;
                                overflow:           elide;
                            }
                            kbdd-item-ta := TouchArea {
                                clicked => {
                                    AppState.settings-dropdown-cursor = i;
                                    AppState.dropdown-pick();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
