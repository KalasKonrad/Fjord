// ── fjord-app · settings.slint ───────────────────────────────────────────────
//   SettingsScreen   two-pane layout: left section list, right scrollable content
//     Left pane      "General" / "Player" / "Key Bindings" section items
//     Right pane     Flickable; shows section content based on settings-section
//       General      launch-in-fullscreen (row 0), video-behind (row 1), sign-out (row 2)
//       Player       SPDIF (0), hwdec (1), vf (2), deinterlace (3),
//                    video-sync (4, options: audio/display-resample/vdrop/adrop/desync), interpolation (5), tscale (6 virtual),
//                    tone-mapping (7), target-colorspace (8), opengl-early-flush (9),
//                    video-latency-hacks (10), sub-enabled (11), sub-lang (12), sub-lang2 (13), cache-mb (14)
//       Key Bindings keybinding-focused 0..N rows, Reset button
//   Row highlight    handled by SettingsRow component (TouchArea lower z, children higher z)
//   Scroll           viewport-y tracks settings-focused (≈64px/row for Player);
//                    keybinding scroll ≈base + index*44px
//   kb-row-y(i)      approximate: i*44px + 22px  (used for scroll only)
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton, ToggleSwitch, SectionHeader, SettingsDropdown, SettingsRow } from "widgets.slint";

export component SettingsScreen inherits Rectangle {
    background: Theme.bg;

    pure function kb-row-y(i: int) -> length {
        i * 44px + 22px
    }

    HorizontalLayout {
        // ── Left pane ─────────────────────────────────────────────────────────
        left-pane := Rectangle {
            background: Theme.surface;
            width: 220px;

            VerticalLayout {
                padding: Theme.sp-xl;
                spacing: Theme.sp-sm;
                alignment: start;

                Text {
                    text: "Settings";
                    color: Theme.text;
                    font-size: 20px;
                    font-weight: 700;
                }

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "SERVER"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }
                Text {
                    text:      AppState.server-name != "" ? AppState.server-name : "—";
                    color:     Theme.text;
                    font-size: 13px;
                    font-weight: 600;
                    overflow:  elide;
                }
                Text {
                    text:      AppState.server-version != "" ? AppState.server-version : "";
                    color:     Theme.text-muted;
                    font-size: 11px;
                    overflow:  elide;
                }

                Rectangle { height: 1px; background: Theme.border; }

                // Section list — General (0), Player (1), Key Bindings (2)
                for sect[i] in ["General", "Player", "Key Bindings"]: Rectangle {
                    height: 44px;
                    border-radius: Theme.radius;
                    background: {
                        let hov = sect-ta.has-hover;
                        AppState.settings-section == i
                            ? (i == 2
                                ? (AppState.keybinding-focused < 0 ? Theme.accent : Theme.accent-muted)
                                : (AppState.settings-focused < 0 ? Theme.accent : Theme.accent-muted))
                            : (hov ? Theme.surface-raised : transparent)
                    };
                    sect-ta := TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            AppState.settings-section = i;
                            AppState.settings-focused = -1;
                            AppState.refocus();
                        }
                    }
                    HorizontalLayout {
                        padding-left: 12px;
                        alignment: start;
                        Text {
                            text: sect;
                            color: Theme.text;
                            font-size: 14px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        Rectangle { width: 1px; background: Theme.border; }

        // ── Right pane ────────────────────────────────────────────────────────
        right-pane := Rectangle {
            horizontal-stretch: 1;
            property <length> right-vp-h: right-inner.preferred-height + Theme.sp-xl * 2;
            property <length> kb-y: AppState.keybinding-focused >= 0
                ? clamp(-(kb-row-y(AppState.keybinding-focused) - self.height / 2),
                         min(0px, self.height - right-vp-h), 0px)
                : AppState.settings-focused < 0 ? 0px
                : AppState.settings-section == 1
                  ? clamp(-(Theme.sp-xl + 30px + AppState.settings-focused * 64px + 28px
                            - self.height / 2),
                           min(0px, self.height - right-vp-h), 0px)
                  : 0px;
            changed kb-y => { right-fl.viewport-y = kb-y; }

            right-fl := Flickable {
                viewport-height: right-pane.right-vp-h;

            right-inner := VerticalLayout {
                y: Theme.sp-xl;
                width: parent.width - Theme.sp-xl * 2;
                x: Theme.sp-xl;

                // ── General section ───────────────────────────────────────────
                if AppState.settings-section == 0: VerticalLayout {
                    spacing: Theme.sp-sm;

                    SectionHeader { text: "GENERAL"; }

                    // Row 0 — Launch in fullscreen
                    SettingsRow { row-index: 0; section: 0; title: "Launch in fullscreen"; subtitle: "Start Fjord in fullscreen mode";
                        ToggleSwitch { checked <=> AppState.settings-launch-fullscreen; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 1 — Video in background
                    SettingsRow { row-index: 1; section: 0; title: "Video in background"; subtitle: "Show video behind the UI when you press Back during playback";
                        ToggleSwitch { checked <=> AppState.settings-video-behind; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    Rectangle { height: 1px; background: Theme.border; }

                    // Row 2 — Sign Out
                    Rectangle {
                        border-radius: Theme.radius;
                        background: AppState.settings-focused == 2 ? Theme.accent-muted
                                  : (g2.has-hover ? Theme.surface : transparent);
                        height: 48px;
                        g2 := TouchArea {
                            clicked => { AppState.sign-out(); }
                        }
                        HorizontalLayout {
                            padding-left: 12px;
                            alignment: start;
                            Text {
                                text: "Sign Out";
                                color: Theme.error;
                                font-size: 14px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── Player section ────────────────────────────────────────────
                if AppState.settings-section == 1: VerticalLayout {
                    spacing: Theme.sp-sm;

                    SectionHeader { text: "PLAYER"; }

                    // Row 0 — Audio SPDIF
                    SettingsRow { row-index: 0; title: "Audio passthrough (SPDIF)"; subtitle: "Bitstream TrueHD / DTS-HD MA / AC3 to AV receiver";
                        ToggleSwitch { checked <=> AppState.settings-audio-spdif; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }
                    if AppState.settings-audio-spdif && AppState.settings-video-sync == "display-resample": Text {
                        text: "⚠  audio passthrough is incompatible with display-resample";
                        color: Theme.error; font-size: 12px;
                    }

                    // Row 1 — hwdec
                    SettingsRow { row-index: 1; title: "Hardware decode (hwdec)"; subtitle: "AMD: vulkan (native) or vulkan-copy · NVIDIA legacy: nvdec-copy + set vf below";
                        SettingsDropdown {
                            model: ["auto","vulkan","vulkan-copy","nvdec","nvdec-copy","vaapi","vaapi-copy","vdpau","vdpau-copy","none"];
                            current-value: AppState.settings-hwdec;
                            selected(v) => { AppState.settings-hwdec = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 2 — vf
                    SettingsRow { row-index: 2; title: "Video filter (vf)"; subtitle: "NVIDIA legacy: format=yuv420p fixes stride corruption · auto detects hwdec at runtime";
                        SettingsDropdown {
                            model: ["","auto","format=yuv420p","format=yuv420p10le","format=nv12","format=p010"];
                            current-value: AppState.settings-vf;
                            selected(v) => { AppState.settings-vf = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 3 — Deinterlace
                    SettingsRow { row-index: 3; title: "Deinterlace"; subtitle: "Enable yadif filter (interlaced broadcast / DVD content)";
                        ToggleSwitch { checked <=> AppState.settings-deinterlace; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    SectionHeader { text: "SYNCHRONISATION"; }

                    // Row 4 — Video sync
                    SettingsRow { row-index: 4; title: "Video sync"; subtitle: "display-resample: smooth sync · desync: no A/V correction (debug)";
                        SettingsDropdown {
                            model: ["audio","display-resample","display-vdrop","display-adrop","desync"];
                            current-value: AppState.settings-video-sync;
                            selected(v) => { AppState.settings-video-sync = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 5 — Motion interpolation
                    SettingsRow { row-index: 5; title: "Motion interpolation"; subtitle: "Temporal interpolation between frames (best with display-resample)";
                        ToggleSwitch { checked <=> AppState.settings-interpolation; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 6 — tscale (virtual: only shown when interpolation is on)
                    if AppState.settings-interpolation: SettingsRow { row-index: 6; title: "Temporal scaler (tscale)"; subtitle: "Algorithm used for motion interpolation";
                        SettingsDropdown {
                            model: ["oversample","catmull_rom","mitchell","gaussian","bicubic"];
                            current-value: AppState.settings-tscale;
                            selected(v) => { AppState.settings-tscale = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    SectionHeader { text: "HDR"; }

                    // Row 7 — Tone mapping
                    SettingsRow { row-index: 7; title: "Tone mapping"; subtitle: "HDR → SDR algorithm. auto is usually correct.";
                        SettingsDropdown {
                            model: ["auto","hable","bt.2390","reinhard","mobius","clip","gamma","linear"];
                            current-value: AppState.settings-tone-mapping;
                            selected(v) => { AppState.settings-tone-mapping = v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 8 — Target colorspace
                    SettingsRow { row-index: 8; title: "Target colorspace hint"; subtitle: "Pass HDR metadata to KDE 6 Plasma for native HDR output";
                        ToggleSwitch { checked <=> AppState.settings-target-colorspace-hint; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    SectionHeader { text: "NVIDIA WAYLAND"; }

                    // Row 9 — OpenGL early flush
                    SettingsRow { row-index: 9; title: "OpenGL early flush"; subtitle: "Flush GL after each frame — may reduce jitter on NVIDIA Wayland";
                        ToggleSwitch { checked <=> AppState.settings-opengl-early-flush; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 10 — Video latency hacks
                    SettingsRow { row-index: 10; title: "Video latency hacks"; subtitle: "Compensate for imprecise Wayland vsync timestamps (NVIDIA 5xx legacy)";
                        ToggleSwitch { checked <=> AppState.settings-video-latency-hacks; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    SectionHeader { text: "SUBTITLES"; }

                    // Row 11 — Subtitle on/off
                    SettingsRow { row-index: 11; title: "Enable subtitles"; subtitle: "Off always disables subtitles regardless of language settings";
                        ToggleSwitch { checked <=> AppState.settings-sub-enabled; toggled => { AppState.settings-changed(); AppState.refocus(); } }
                    }

                    // Row 12 — Primary subtitle language
                    SettingsRow { row-index: 12; title: "Primary subtitle language"; subtitle: "Auto-select first matching track; no preference = use video default";
                        SettingsDropdown {
                            model: ["Off","English","German","French","Japanese","Spanish","Italian","Portuguese","Russian","Korean","Chinese","Dutch","Swedish","Polish","Czech","Arabic","Turkish","Finnish","Danish","Norwegian"];
                            current-value: AppState.settings-sub-lang == "" ? "Off" : AppState.settings-sub-lang;
                            selected(v) => { AppState.settings-sub-lang = v == "Off" ? "" : v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    // Row 13 — Fallback subtitle language
                    SettingsRow { row-index: 13; title: "Fallback subtitle language"; subtitle: "Used when no primary language track is found";
                        SettingsDropdown {
                            model: ["Off","English","German","French","Japanese","Spanish","Italian","Portuguese","Russian","Korean","Chinese","Dutch","Swedish","Polish","Czech","Arabic","Turkish","Finnish","Danish","Norwegian"];
                            current-value: AppState.settings-sub-lang2 == "" ? "Off" : AppState.settings-sub-lang2;
                            selected(v) => { AppState.settings-sub-lang2 = v == "Off" ? "" : v; AppState.settings-changed(); AppState.refocus(); }
                        }
                    }

                    SectionHeader { text: "BUFFERING"; }

                    // Row 14 — Demuxer cache
                    SettingsRow { row-index: 14; title: "Demuxer cache (MiB)"; subtitle: "0 = mpv default (~150 MiB). Increase for slow network / large files.";
                        SettingsDropdown {
                            model: ["0","50","150","300","500","1000"];
                            current-value: AppState.settings-cache-mb == 0   ? "0"
                                         : AppState.settings-cache-mb == 50  ? "50"
                                         : AppState.settings-cache-mb == 150 ? "150"
                                         : AppState.settings-cache-mb == 300 ? "300"
                                         : AppState.settings-cache-mb == 500 ? "500" : "1000";
                            selected(v) => {
                                AppState.settings-cache-mb = v == "0"   ? 0
                                                           : v == "50"  ? 50
                                                           : v == "150" ? 150
                                                           : v == "300" ? 300
                                                           : v == "500" ? 500 : 1000;
                                AppState.settings-changed();
                                AppState.refocus();
                            }
                        }
                    }
                }

                // ── Key Bindings section ──────────────────────────────────────
                if AppState.settings-section == 2: VerticalLayout {
                    spacing: 0;

                    SectionHeader { text: "NAVIGATION & GLOBAL"; }

                    for kb[i] in AppState.keybinding-normal: Rectangle {
                        height: 44px;
                        border-radius: Theme.radius;
                        background: AppState.keybinding-focused == i
                                    ? (AppState.keybinding-rebinding ? Theme.accent : Theme.accent-muted)
                                    : (kb-ta.has-hover ? Theme.surface : transparent);
                        kb-ta := TouchArea {
                            clicked => { AppState.keybinding-focused = i; }
                        }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px;
                            alignment: space-between;
                            Text { text: kb.action; color: Theme.text; font-size: 13px; vertical-alignment: center; }
                            Text {
                                text: AppState.keybinding-focused == i && AppState.keybinding-rebinding
                                      ? "Press a key…" : kb.key;
                                color: AppState.keybinding-focused == i && AppState.keybinding-rebinding
                                       ? Theme.bg : Theme.text-muted;
                                font-size: 12px; vertical-alignment: center;
                            }
                        }
                    }

                    SectionHeader { text: "PLAYER"; }

                    for kb[i] in AppState.keybinding-player: Rectangle {
                        height: 44px;
                        border-radius: Theme.radius;
                        background: AppState.keybinding-focused == i + AppState.keybinding-normal.length
                                    ? (AppState.keybinding-rebinding ? Theme.accent : Theme.accent-muted)
                                    : (kb-player-ta.has-hover ? Theme.surface : transparent);
                        kb-player-ta := TouchArea {
                            clicked => { AppState.keybinding-focused = i + AppState.keybinding-normal.length; }
                        }
                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px;
                            alignment: space-between;
                            Text { text: kb.action; color: Theme.text; font-size: 13px; vertical-alignment: center; }
                            Text {
                                text: AppState.keybinding-focused == i + AppState.keybinding-normal.length
                                      && AppState.keybinding-rebinding ? "Press a key…" : kb.key;
                                color: AppState.keybinding-focused == i + AppState.keybinding-normal.length
                                       && AppState.keybinding-rebinding ? Theme.bg : Theme.text-muted;
                                font-size: 12px; vertical-alignment: center;
                            }
                        }
                    }

                    FjordButton {
                        text: "Reset to Defaults";
                        clicked => { AppState.keybinding-reset-defaults(); AppState.refocus(); }
                    }
                }
            }
            }
        }
    }
}
