// ── fjord-app · settings.slint ───────────────────────────────────────────────
//   SettingsScreen  scrollable settings card with keyboard-scroll (row-y / kb-row-y)
//     SERVER        server URL display
//     GENERAL       launch-in-fullscreen                       row0
//     AUDIO         SPDIF passthrough                          row1
//     VIDEO         GPU API, hwdec, vf, deinterlace,           rows 2–5
//                   video-behind                               row6
//     SYNCHRONISATION  video-sync, interpolation, tscale       rows 7–9
//     HDR           tone-mapping, target-colorspace-hint       rows 10–11
//     NVIDIA WAYLAND   opengl-early-flush, video-latency       rows 12–13
//     BUFFERING     demuxer cache MiB                          row14
//     sign out      danger button → AppState.sign-out()        row15
//     KEY BINDINGS  normal rows (keybinding-focused 0..16)
//                   player rows (keybinding-focused 17..28)
//                   Reset to Defaults button (keybinding-focused 29)
//   row-y(r)     maps settings-focused index → centre Y (card-relative)
//   kb-row-y(i)  maps keybinding-focused index → centre Y (card-relative)
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { FjordButton } from "widgets.slint";
import { CheckBox, ComboBox } from "std-widgets.slint";

// Height of each keybinding row (kept as a constant via pure function).
// 44px gives comfortable touch-target size and matches the focus highlight height.


export component SettingsScreen inherits Rectangle {
    // Centre Y of a settings-focused row (r), in card-relative coordinates.
    // Row 11 (tscale) is conditional — derive its centre from row10/row12.
    pure function row-y(r: int) -> length {
        r == 0  ? row0.y  + row0.height  / 2 :
        r == 1  ? row1.y  + row1.height  / 2 :
        r == 2  ? row2.y  + row2.height  / 2 :
        r == 3  ? row3.y  + row3.height  / 2 :
        r == 4  ? row4.y  + row4.height  / 2 :
        r == 5  ? row5.y  + row5.height  / 2 :
        r == 6  ? row6.y  + row6.height  / 2 :
        r == 7  ? row7.y  + row7.height  / 2 :
        r == 8  ? row8.y  + row8.height  / 2 :
        r == 9  ? (row8.y + row8.height + row10.y) / 2 :
        r == 10 ? row10.y + row10.height / 2 :
        r == 11 ? row11.y + row11.height / 2 :
        r == 12 ? row12.y + row12.height / 2 :
        r == 13 ? row13.y + row13.height / 2 :
        r == 14 ? row14.y + row14.height / 2 :
                  row15.y + row15.height / 2
    }

    // Centre Y of a keybinding-focused row (i), in card-relative coordinates.
    // Rows are 44px each with no spacing; the Reset button is a full-height element.
    pure function kb-row-y(i: int) -> length {
        i < AppState.keybinding-normal.length
        ? kb-normal-section.y + i * 44px + 22px
        : i < AppState.keybinding-normal.length + AppState.keybinding-player.length
        ? kb-player-section.y + (i - AppState.keybinding-normal.length) * 44px + 22px
        : kb-reset-row.y + kb-reset-row.height / 2
    }

    background: Theme.bg;

    Flickable {
        viewport-height: card.height + Theme.sp-xl * 2;
        viewport-y: AppState.keybinding-focused >= 0
                  ? clamp(-(card.y + kb-row-y(AppState.keybinding-focused) - self.height / 2),
                           min(0px, self.height - self.viewport-height), 0px)
                  : AppState.settings-focused < 0 ? 0px
                  : clamp(-(card.y + row-y(AppState.settings-focused) - self.height / 2),
                           min(0px, self.height - self.viewport-height), 0px);

        card := Rectangle {
            width:         min(560px, parent.width - 48px);
            height:        inner.preferred-height;
            x:             (parent.width  - self.width)  / 2;
            y:             Theme.sp-xl;
            background:    Theme.surface;
            border-radius: Theme.radius-lg;
            drop-shadow-blur:  20px;
            drop-shadow-color: #00000050;

            if AppState.settings-focused >= 0: Rectangle {
                y:             row-y(AppState.settings-focused) - 28px;
                height:        56px;
                x:             Theme.sp;
                width:         parent.width - Theme.sp * 2;
                background:    Theme.accent-muted;
                border-radius: Theme.radius;
            }

            inner := VerticalLayout {
                padding:  Theme.sp-xl;
                spacing:  Theme.sp-lg;

                Text { text: "Settings"; color: Theme.text; font-size: 20px; font-weight: 700; }

                Rectangle { height: 1px; background: Theme.border; }

                VerticalLayout {
                    spacing: Theme.sp-sm;
                    Text { text: "SERVER"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }
                    Text {
                        text:      AppState.server-url != "" ? AppState.server-url : "—";
                        color:     Theme.text; font-size: 14px; overflow: elide;
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "GENERAL"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                row0 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Launch in fullscreen"; color: Theme.text; font-size: 14px; }
                        Text { text: "Start Fjord in fullscreen mode (applies on next launch)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> AppState.settings-launch-fullscreen; toggled => { AppState.settings-changed(); } }
                }

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "AUDIO"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                row1 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Audio passthrough (SPDIF)"; color: Theme.text; font-size: 14px; }
                        Text { text: "Bitstream TrueHD / DTS-HD MA / AC3 to AV receiver"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> AppState.settings-audio-spdif; toggled => { AppState.settings-changed(); } }
                }

                if AppState.settings-audio-spdif && AppState.settings-video-sync == "display-resample": Text {
                    text:      "⚠  audio passthrough is incompatible with display-resample";
                    color:     Theme.error;
                    font-size: 12px;
                }

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "VIDEO"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                row2 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "GPU API"; color: Theme.text; font-size: 14px; }
                        Text { text: "auto: mpv default  ·  opengl: classic (use for NVIDIA legacy)  ·  vulkan"; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["auto", "opengl", "vulkan"]; current-value: AppState.settings-gpu-api; width: 130px;
                        selected(v) => { AppState.settings-gpu-api = v; AppState.settings-changed(); }
                    }
                }

                row3 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Hardware decode (hwdec)"; color: Theme.text; font-size: 14px; }
                        Text { text: "AMD: vulkan-copy works fine. NVIDIA legacy: use nvdec-copy + set image format below."; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["auto", "vulkan-copy", "nvdec-copy", "vaapi-copy", "vdpau-copy", "nvdec", "vaapi", "vdpau", "none"];
                        current-value: AppState.settings-hwdec; width: 140px;
                        selected(v) => { AppState.settings-hwdec = v; AppState.settings-changed(); }
                    }
                }

                row4 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Video filter (vf)"; color: Theme.text; font-size: 14px; }
                        Text { text: "NVIDIA legacy: use format=yuv420p (with nvdec-copy) to fix stride corruption. auto detects hwdec and bit depth at runtime."; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["", "auto", "format=yuv420p", "format=yuv420p10le", "format=nv12", "format=p010"];
                        current-value: AppState.settings-vf; width: 180px;
                        selected(v) => { AppState.settings-vf = v; AppState.settings-changed(); }
                    }
                }

                row5 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Deinterlace"; color: Theme.text; font-size: 14px; }
                        Text { text: "Enable yadif filter (for interlaced broadcast / DVD content)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> AppState.settings-deinterlace; toggled => { AppState.settings-changed(); } }
                }

                row6 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Video in background"; color: Theme.text; font-size: 14px; }
                        Text { text: "Show video behind the interface when you press Back during playback"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> AppState.settings-video-behind; toggled => { AppState.settings-changed(); } }
                }

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "SYNCHRONISATION"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                row7 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Video sync"; color: Theme.text; font-size: 14px; }
                        Text { text: "display-resample: smooth sync to monitor (needs real vsync — works in Fjord)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["audio", "display-resample", "display-vdrop", "display-adrop"];
                        current-value: AppState.settings-video-sync; width: 180px;
                        selected(v) => { AppState.settings-video-sync = v; AppState.settings-changed(); }
                    }
                }

                row8 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Motion interpolation"; color: Theme.text; font-size: 14px; }
                        Text { text: "Temporal interpolation between frames (best with display-resample)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> AppState.settings-interpolation; toggled => { AppState.settings-changed(); } }
                }

                if AppState.settings-interpolation: HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Temporal scaler (tscale)"; color: Theme.text; font-size: 14px; }
                        Text { text: "Algorithm used for motion interpolation"; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["oversample", "catmull_rom", "mitchell", "gaussian", "bicubic"];
                        current-value: AppState.settings-tscale; width: 140px;
                        selected(v) => { AppState.settings-tscale = v; AppState.settings-changed(); }
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "HDR"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                row10 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Tone mapping"; color: Theme.text; font-size: 14px; }
                        Text { text: "Algorithm for mapping HDR → SDR.  auto is usually correct."; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["auto", "hable", "bt.2390", "reinhard", "mobius", "clip", "gamma", "linear"];
                        current-value: AppState.settings-tone-mapping; width: 130px;
                        selected(v) => { AppState.settings-tone-mapping = v; AppState.settings-changed(); }
                    }
                }

                row11 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Target colorspace hint"; color: Theme.text; font-size: 14px; }
                        Text { text: "Pass HDR metadata to KDE 6 Plasma for native HDR output"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> AppState.settings-target-colorspace-hint; toggled => { AppState.settings-changed(); } }
                }

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "NVIDIA WAYLAND"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                row12 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "OpenGL early flush"; color: Theme.text; font-size: 14px; }
                        Text { text: "Flush GL commands after each frame — reduces jitter with gpu-api=opengl"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> AppState.settings-opengl-early-flush; toggled => { AppState.settings-changed(); } }
                }

                row13 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Video latency hacks"; color: Theme.text; font-size: 14px; }
                        Text { text: "Compensate for imprecise Wayland vsync timestamps (NVIDIA 5xx legacy)"; color: Theme.text-muted; font-size: 12px; }
                    }
                    CheckBox { checked <=> AppState.settings-video-latency-hacks; toggled => { AppState.settings-changed(); } }
                }

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "BUFFERING"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                row14 := HorizontalLayout {
                    spacing: Theme.sp; alignment: space-between;
                    VerticalLayout {
                        spacing: 3px; horizontal-stretch: 1;
                        Text { text: "Demuxer cache (MiB)"; color: Theme.text; font-size: 14px; }
                        Text { text: "0 = mpv default (~150 MiB).  Increase for slow network / large files."; color: Theme.text-muted; font-size: 12px; }
                    }
                    ComboBox {
                        model: ["0", "50", "150", "300", "500", "1000"];
                        current-value: AppState.settings-cache-mb == 0   ? "0"
                                     : AppState.settings-cache-mb == 50  ? "50"
                                     : AppState.settings-cache-mb == 150 ? "150"
                                     : AppState.settings-cache-mb == 300 ? "300"
                                     : AppState.settings-cache-mb == 500 ? "500"
                                     : "1000";
                        width: 100px;
                        selected(v) => {
                            AppState.settings-cache-mb = v == "0"   ? 0
                                                       : v == "50"  ? 50
                                                       : v == "150" ? 150
                                                       : v == "300" ? 300
                                                       : v == "500" ? 500
                                                       : 1000;
                            AppState.settings-changed();
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                row15 := FjordButton {
                    text: "Sign Out"; danger: true;
                    clicked => { AppState.sign-out(); }
                }

                Rectangle { height: 1px; background: Theme.border; }

                Text { text: "KEY BINDINGS"; color: Theme.text-muted; font-size: 10px; font-weight: 700; }

                Text { text: "NAVIGATION & GLOBAL"; color: Theme.text-muted; font-size: 9px; }

                kb-normal-section := VerticalLayout {
                    spacing: 0;
                    for kb[i] in AppState.keybinding-normal: Rectangle {
                        height: 44px;
                        border-radius: Theme.radius;
                        background: AppState.keybinding-focused == i
                                    ? (AppState.keybinding-rebinding ? Theme.accent : Theme.accent-muted)
                                    : transparent;
                        HorizontalLayout {
                            padding-left:  12px;
                            padding-right: 12px;
                            alignment: space-between;
                            Text {
                                text: kb.action;
                                color: Theme.text;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: AppState.keybinding-focused == i && AppState.keybinding-rebinding
                                      ? "Press a key…"
                                      : kb.key;
                                color: AppState.keybinding-focused == i && AppState.keybinding-rebinding
                                       ? Theme.bg : Theme.text-muted;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                Text { text: "PLAYER"; color: Theme.text-muted; font-size: 9px; }

                kb-player-section := VerticalLayout {
                    spacing: 0;
                    for kb[i] in AppState.keybinding-player: Rectangle {
                        height: 44px;
                        border-radius: Theme.radius;
                        background: AppState.keybinding-focused == i + AppState.keybinding-normal.length
                                    ? (AppState.keybinding-rebinding ? Theme.accent : Theme.accent-muted)
                                    : transparent;
                        HorizontalLayout {
                            padding-left:  12px;
                            padding-right: 12px;
                            alignment: space-between;
                            Text {
                                text: kb.action;
                                color: Theme.text;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                            Text {
                                text: AppState.keybinding-focused == i + AppState.keybinding-normal.length
                                      && AppState.keybinding-rebinding
                                      ? "Press a key…"
                                      : kb.key;
                                color: AppState.keybinding-focused == i + AppState.keybinding-normal.length
                                       && AppState.keybinding-rebinding
                                       ? Theme.bg : Theme.text-muted;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                kb-reset-row := FjordButton {
                    text: "Reset to Defaults";
                    clicked => { AppState.keybinding-reset-defaults(); }
                }
            }
        }
    }
}
