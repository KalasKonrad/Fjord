// ── fjord-app · theme.slint ──────────────────────────────────────────────────
//   Theme           global design tokens: colors, spacing, radius, font sizes
//   TrackEntry      audio / video / subtitle track row for track-panel lists
//   TrackItem       one row in an album tracklist (id, title, artist, duration, track-number, played, is-favorite)
//   CastMember      name + role + id + portrait photo for the detail-page cast row
//   SeasonEntry     season id + display name for series season tabs
//   CardItem        universal poster card data (id, series-id, item-type, title, year, played, resume, is-favorite, unplayed-count)
//   KeyBindingEntry one row in the key-binding editor (action label + current key string)
// ─────────────────────────────────────────────────────────────────────────────
// Fjord default theme — Jellyfin-inspired dark palette.
// Swap this file (or override properties at runtime) to change the whole UI.
export global Theme {
    // ── Backgrounds ───────────────────────────────────────────────────────────
    out property <color> bg:              #0d0d0d;
    out property <color> surface:         #1a1a1c;
    out property <color> surface-raised:  #242426;
    out property <color> surface-overlay: #2c2c2e;
    out property <color> sidebar-bg:      #111113;

    // ── Accent (Jellyfin blue) ────────────────────────────────────────────────
    out property <color> accent:          #00a4dc;
    out property <color> accent-hover:    #0090c4;
    out property <color> accent-muted:    #00a4dc40;  // ~25 % alpha

    // ── Text ─────────────────────────────────────────────────────────────────
    out property <color> text:            #f2f2f7;
    out property <color> text-muted:      #8e8e93;
    out property <color> text-subtle:     #48484a;

    // ── Borders / separators ─────────────────────────────────────────────────
    out property <color> border:          #2c2c2e;
    out property <color> border-strong:   #3a3a3c;

    // ── Feedback ─────────────────────────────────────────────────────────────
    out property <color> error:           #ff453a;

    // ── Layout ───────────────────────────────────────────────────────────────
    out property <length> sidebar-width:  200px;
    out property <length> radius:         6px;
    out property <length> radius-lg:      12px;
    out property <length> sp-xs:          4px;
    out property <length> sp-sm:          8px;
    out property <length> sp:             14px;
    out property <length> sp-lg:          20px;
    out property <length> sp-xl:          32px;
}

// A single entry in a track-selection list (audio / subtitle / video).
export struct TrackEntry {
    id:    int,
    label: string,
}

// One row in an album tracklist.
export struct TrackItem {
    id:           string,
    title:        string,
    artist:       string,
    duration:     string,   // "3:45"
    track-number: int,
    has-played:   bool,
    is-favorite:  bool,
    resume-pct:   float,
}

// A cast member shown on the detail page.
export struct CastMember {
    id:        string,
    name:      string,
    role:      string,
    photo:     image,
    has-photo: bool,
}

// A season entry in the series drill-down.
export struct SeasonEntry {
    id:   string,
    name: string,
}

// One row in the key-binding editor (action display name + current key label).
export struct KeyBindingEntry {
    action: string,
    key:    string,
}

// Passed from Rust for every poster card on any screen.
export struct CardItem {
    id:             string,
    series-id:      string,   // series ID for Episode cards; empty for movies/series
    item-type:      string,
    title:          string,
    year:           int,
    has-played:     bool,
    is-favorite:    bool,
    resume-pct:     float,
    has-poster:     bool,
    poster:         image,
    unplayed-count: int,
}
