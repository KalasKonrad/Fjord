// ── fjord-app · theme.slint ──────────────────────────────────────────────────
//   Theme           global design tokens: colors, spacing, radius, font sizes
//   TrackEntry      audio / video / subtitle track row for track-panel lists
//   TrackItem       one row in an album/playlist tracklist (id, title, artist, duration, track-number,
//                   played, is-favorite, entry-id (playlist entry, for removal), album-id (music-bar art))
//   CastMember      name + role + id + portrait photo for the detail-page cast row
//   SeasonEntry     season id + display name for series season tabs
//   CardItem        universal poster card data (id, series-id, item-type, title, subtitle, year, played, resume,
//                   is-favorite, unplayed-count, availability — Discover/Seerr cards only, "" elsewhere;
//                   requested-4k/other-tier-available — Discover "Requested" row only, false elsewhere,
//                   2026-07-18, drives MediaCard's tier-prefixed availability pill + cross-tier badge)
//   SeasonItem      one TV season card for the Discover request-detail season strip (number, name, episode-count, selected, poster, has-poster)
//   TagItem         one Radarr/Sonarr tag row for the Discover request-detail tag picker (id, label, selected)
//   ProfileItem     one Radarr/Sonarr quality profile row for the Discover request-detail profile
//                   picker (id, name) — radio-select via request-detail-selected-profile-id, not
//                   a per-row bool; row 0 is a synthetic "Default" entry prepended in Rust
//   KeyBindingEntry one row in the key-binding editor (action label + current key string)
//   QueueEntry      one row in the queue panel (id, index, title, artist, is-current, is-queued, poster-id, has-poster, poster)
//   LyricEntry      one lyric line (text, start-ms); start-ms=0 means no timestamps
// ─────────────────────────────────────────────────────────────────────────────
// Fjord default theme — Jellyfin-inspired dark palette.
// Swap this file (or override properties at runtime) to change the whole UI.
export global Theme {
    // ── Backgrounds ───────────────────────────────────────────────────────────
    out property <color> bg:              #0d0d0d;
    out property <color> surface:         #1a1a1c;
    out property <color> surface-raised:  #242426;
    out property <color> surface-overlay: #2c2c2e;
    out property <color> sidebar-bg:      #111113;

    // ── Accent (Jellyfin blue) ────────────────────────────────────────────────
    out property <color> accent:          #00a4dc;
    out property <color> accent-hover:    #0090c4;
    out property <color> accent-muted:    #00a4dc40;  // ~25 % alpha

    // ── Text ─────────────────────────────────────────────────────────────────
    out property <color> text:            #f2f2f7;
    out property <color> text-muted:      #8e8e93;
    out property <color> text-subtle:     #48484a;

    // ── Borders / separators ─────────────────────────────────────────────────
    out property <color> border:          #2c2c2e;
    out property <color> border-strong:   #3a3a3c;

    // ── Feedback ─────────────────────────────────────────────────────────────
    out property <color> error:           #ff453a;

    // ── Layout ───────────────────────────────────────────────────────────────
    out property <length> sidebar-width:  200px;
    out property <length> radius:         6px;
    out property <length> radius-lg:      12px;
    out property <length> sp-xs:          4px;
    out property <length> sp-sm:          8px;
    out property <length> sp:             14px;
    out property <length> sp-lg:          20px;
    out property <length> sp-xl:          32px;
}

// A single entry in a track-selection list (audio / subtitle / video).
export struct TrackEntry {
    id:    int,
    label: string,
}

// One row in an album or playlist tracklist.
export struct TrackItem {
    id:           string,
    title:        string,
    artist:       string,
    duration:     string,   // "3:45"
    track-number: int,
    has-played:   bool,
    is-favorite:  bool,
    resume-pct:   float,
    entry-id:     string,   // PlaylistItemId — set for playlist rows, "" for album rows
    album-id:     string,   // owning album id — music-bar art for playlist rows
}

// A cast member shown on the detail page.
export struct CastMember {
    id:        string,
    name:      string,
    role:      string,
    photo:     image,
    has-photo: bool,
}

// A season entry in the series drill-down.
export struct SeasonEntry {
    id:   string,
    name: string,
}

// One row in the key-binding editor (action display name + current key label).
export struct KeyBindingEntry {
    action: string,
    key:    string,
}

// Passed from Rust for every poster card on any screen.
export struct CardItem {
    id:             string,
    series-id:      string,   // series ID for Episode cards; empty for movies/series
    item-type:      string,
    title:          string,
    subtitle:       string,   // second card row: "S1:E3 - Title" / "2019 - Present" / artist / year
    year:           int,      // numeric year kept for library sorting
    has-played:     bool,
    is-favorite:    bool,
    resume-pct:     float,
    has-poster:     bool,
    poster:         image,
    unplayed-count: int,
    // Discover (Seerr) results only — "" on every Jellyfin-sourced card
    // (every existing construction site leaves this at its Default::default()
    // "", zero risk to the other ~25 CardItem models). One more badge pill in
    // MediaCard, same additive/conditional shape as the four above:
    // "requested" | "processing" | "partial" | "available" | "" (none —
    // requestable, no badge).
    availability:   string,
    // Discover "Requested" row only (2026-07-18) — false/false on every
    // other card by construction, same zero-risk-elsewhere reasoning as
    // `availability` above. `requested-4k` tags the main availability pill
    // with the requested tier ("4K Requested" vs plain "Requested") since
    // Seerr tracks 2K/4K fulfillment as two genuinely independent statuses
    // (see fjord_seerr::MediaInfo's own doc comment) — a request can be
    // fully served in one tier while still pending in the other.
    // `other-tier-available` drives a second small badge ("Available in
    // 2K"/"Available in 4K") when the OTHER (non-requested) tier is
    // already available, so the user isn't left thinking nothing is
    // watchable yet. `other-tier-requested` drives the same badge slot
    // with "Also requested in 2K"/"Also requested in 4K" instead, for the
    // rarer case where BOTH tiers were requested and neither is available
    // yet — a genuinely different situation from "available" that used to
    // be silently indistinguishable from "not requested at all" (real
    // report, 2026-07-18: user read "Also in 2K" and assumed it meant
    // "also requested", which it never did — this field is what makes
    // that actual state exist). `other-tier-available` wins when both
    // would apply (better news); `other-tier-requested` only applies once
    // its own tier's request is still active and unfulfilled.
    requested-4k:          bool,
    other-tier-available:  bool,
    other-tier-requested:  bool,
    // Discover "Requested" row only (2026-07-18) — the underlying Seerr
    // MediaRequest's own id (NOT the tmdb id, which stays in `id` above and
    // is load-bearing for open-discover-item). "" on every other card,
    // including every non-Requested-row Discover card. Drives the Discover
    // context menu's Edit/Cancel/Approve/Decline actions.
    request-id: string,
    // request-pending: MediaRequest.status == Pending (the request's own
    // approval-workflow state — a DIFFERENT thing from `availability`
    // above, which reflects the media's fulfillment status; a request can
    // be Approved but still Processing, for example). request-mine:
    // requested_by == the connected account (true by construction unless
    // this is a multi-user Seerr instance where this account can also see
    // others' requests, i.e. has REQUEST_VIEW/MANAGE_REQUESTS). Both false
    // on every non-Requested-row card. Together with `seerr-is-admin`
    // (AppState) these pick which row family the Discover context menu
    // shows for a Requested-row card — see context_menu.slint's own doc
    // comment for the exact matrix.
    request-pending: bool,
    request-mine:    bool,
}

// Discover (Seerr) request-detail screen only — one row per TV season.
export struct SeasonItem {
    season-number: int,
    name:          string,
    episode-count: int,
    selected:      bool,
    poster:        image,
    has-poster:    bool,
}

// Discover (Seerr) request-detail screen only — one row per available
// Radarr/Sonarr tag on the default server (empty list when none configured).
export struct TagItem {
    id:       int,
    label:    string,
    selected: bool,
}

// A Radarr/Sonarr quality profile row for the request-detail Profile picker
// — radio-select (exactly one, via request-detail-selected-profile-id), not
// one bool per row like TagItem's multi-select. Row 0 is always a synthetic
// "Default" entry (id: 0) prepended in Rust, not fetched from the server.
export struct ProfileItem {
    id:   int,
    name: string,
}

// Discover request-detail screen's "Currently Streaming On" row — one entry
// per flatrate (subscription) provider for the resolved streaming region
// (Seerr's own streamingRegion setting, see discover.rs's
// resolve_streaming_region). TMDB logo, small icon-sized fetch.
export struct StreamingProvider {
    id:        int,
    name:      string,
    logo:      image,
    has-logo:  bool,
}

export struct QueueEntry {
    id:         string,
    index:      int,       // UNDERLYING position for queue-jump/-remove (playlist idx;
                           // playlist.len()+i for queued rows; -1 = synthetic now-playing row)
    title:      string,
    artist:     string,    // album artist or series name; empty for video
    is-current: bool,      // true when this is the currently playing item
    is-queued:  bool,      // true for context-menu queue rows (play after the playlist)
    poster-id:  string,    // ID used for poster fetch (album_art_id for audio, item id for video)
    has-poster: bool,
    poster:     image,
}

export struct LyricEntry {
    text:     string,
    start-ms: int,   // milliseconds from track start; 0 means no timestamp info
}
