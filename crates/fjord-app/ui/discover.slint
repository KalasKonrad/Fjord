// ── fjord-app · discover.slint ───────────────────────────────────────────────
//   DiscoverScreen  Seerr search + results grid, or (no query) 6 landing
//                   SectionRows — Trending/Popular Movies/Popular TV/Upcoming
//                   Movies/Upcoming TV/Requested (still-pending requests,
//                   posters resolved via per-item detail fetch — see
//                   discover.rs's fetch_requested_row), reusing home.slint's
//                   SectionRow component and section-y/kb-y scroll idiom verbatim.
//                   AppShell content slot at active-nav == 6, same tier as
//                   Home/Movies/TV dashboards — no Back button (it IS the
//                   base screen for that tab, not an overlay). Search field
//                   mirrors LibraryGrid's (hand-drawn cursor,
//                   discover-header-focused state); grid reuses the same
//                   Flickable+kb-y scroll idiom and MediaCard component.
//                   Empty states: not-connected/no-rows-yet, no results.
// ─────────────────────────────────────────────────────────────────────────────
import { Theme } from "theme.slint";
import { AppState } from "app_state.slint";
import { MediaCard, LoadingSpinner } from "widgets.slint";
import { SectionRow } from "home.slint";

export component DiscoverScreen inherits Rectangle {
    property <length> card-w: 145px;
    property <length> card-h: 224px;
    property <length> gap:    14px;
    property <length> grid-content-height: ((AppState.discover-results.length + AppState.library-cols - 1) / AppState.library-cols) * (card-h + gap) + gap;
    // Both fl-container (grid) and landing-container (rows) below are
    // conditionally mounted inside the outer VerticalLayout — reading their
    // own self.height in a changed-tracked property from there is the
    // documented "Recursion detected" crash pattern (Slint gotcha in
    // CLAUDE.md: a conditional VerticalLayout child's self.width/height reads
    // the parent layout cache mid-evaluation). Fixed the same documented way:
    // root.height instead of self.height — root (DiscoverScreen itself) gets
    // its height from AppShell's own HorizontalLayout, a different layout
    // pass than the inner VerticalLayout doing the conditional mounting, so
    // it's not part of the same re-entrant cache computation. 106px = 54px
    // top bar + 52px search bar, the two fixed-height siblings above whichever
    // of the two flex regions is showing.
    property <length> content-h: root.height - 106px;
    property <bool> has-landing-rows:
        AppState.discover-trending.length        > 0
        || AppState.discover-popular-movies.length  > 0
        || AppState.discover-popular-tv.length      > 0
        || AppState.discover-upcoming-movies.length > 0
        || AppState.discover-upcoming-tv.length     > 0
        || AppState.discover-requested.length       > 0;

    background: (AppState.video-behind-ui && AppState.has-background-player) ? transparent : Theme.bg;

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height:     54px;
            background: Theme.surface;
            HorizontalLayout {
                padding-left:  Theme.sp-sm;
                padding-right: Theme.sp;
                spacing:       Theme.sp-sm;
                alignment:     start;
                Text {
                    text:               "Discover";
                    color:              Theme.text;
                    font-size:          18px;
                    font-weight:        700;
                    vertical-alignment: center;
                }
                if AppState.discover-query != "": Text {
                    text:               "\{AppState.discover-results.length} results";
                    color:              Theme.accent;
                    font-size:          13px;
                    vertical-alignment: center;
                }
                if AppState.discover-searching: LoadingSpinner { width: 60px; }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
        }

        // ── Search field (mirrors LibraryGrid's — hand-drawn cursor, no native LineEdit) ──
        Rectangle {
            height:     52px;
            background: Theme.surface;

            Rectangle {
                x:             Theme.sp;
                y:             8px;
                width:         parent.width - Theme.sp * 2;
                height:        36px;
                border-radius: Theme.radius;
                border-width:  AppState.discover-header-focused ? 2px : 1px;
                border-color:  AppState.discover-header-focused ? Theme.accent : Theme.border;
                background:    Theme.bg;

                TouchArea {
                    clicked => { AppState.discover-header-focused = true; }
                }

                HorizontalLayout {
                    padding-left:  12px;
                    padding-right: 12px;
                    spacing:       8px;
                    alignment:     start;

                    Text {
                        text:               "⌕︎";
                        font-family:        "Noto Sans Symbols 2";
                        color:              AppState.discover-header-focused ? Theme.accent : Theme.text-muted;
                        font-size:          17px;
                        vertical-alignment: center;
                        width:              22px;
                    }
                    Text {
                        text: AppState.discover-header-focused
                            ? (AppState.discover-query != "" ? AppState.discover-query + "▌" : "▌")
                            : AppState.discover-query != "" ? AppState.discover-query
                            : "Search for movies and TV shows not in your library…";
                        color: AppState.discover-query != "" ? Theme.text
                             : AppState.discover-header-focused ? Theme.text-muted
                             : Theme.text-subtle;
                        font-size:          14px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    if AppState.discover-query != "" && !AppState.discover-header-focused: Text {
                        text:               "Esc to clear";
                        color:              Theme.text-subtle;
                        font-size:          12px;
                        vertical-alignment: center;
                    }
                }
            }
            Rectangle { y: parent.height - 1px; height: 1px; background: Theme.border; }
        }

        if AppState.discover-query == "" && !has-landing-rows: Rectangle {
            vertical-stretch: 1;
            Text {
                text:                 AppState.seerr-connected
                    ? "Loading Seerr's trending picks…"
                    : "Type to search, or connect Seerr in Settings to see Trending, Popular, and Upcoming rows here.";
                color:                Theme.text-muted;
                font-size:            14px;
                horizontal-alignment: center;
                y:                    parent.height / 3;
                width:                parent.width;
                wrap:                 word-wrap;
            }
        }

        // ── Landing rows (no query) — mirrors HomeScreen's section-y/kb-y idiom ──
        if AppState.discover-query == "" && has-landing-rows: landing-container := Rectangle {
            vertical-stretch:   1;
            horizontal-stretch: 1;

            pure function row-y(s: int) -> length {
                Theme.sp-lg
                + (AppState.discover-trending.length        > 0 && s > 0 ? (AppState.dash-ch + 56px + Theme.sp-lg) : 0px)
                + (AppState.discover-popular-movies.length   > 0 && s > 1 ? (AppState.dash-ch + 56px + Theme.sp-lg) : 0px)
                + (AppState.discover-popular-tv.length       > 0 && s > 2 ? (AppState.dash-ch + 56px + Theme.sp-lg) : 0px)
                + (AppState.discover-upcoming-movies.length  > 0 && s > 3 ? (AppState.dash-ch + 56px + Theme.sp-lg) : 0px)
                + (AppState.discover-upcoming-tv.length      > 0 && s > 4 ? (AppState.dash-ch + 56px + Theme.sp-lg) : 0px)
            }

            // root.content-h, not self/own height — see the doc comment on
            // content-h up top for why this container being conditionally
            // mounted makes that unsafe here specifically.
            property <length> kb-y: AppState.focused-section < 0 ? 0px
                : clamp(
                      root.content-h / 2 - row-y(AppState.focused-section) - (AppState.dash-ch + 56px) / 2,
                      min(0px, root.content-h - landing-content.preferred-height),
                      0px
                  );
            changed kb-y => { landing-fl.viewport-y = kb-y; }

            landing-fl := Flickable {
                width:            parent.width;
                height:           parent.height;
                viewport-width:   self.width;
                viewport-height:  landing-content.preferred-height;
                animate viewport-y { duration: 200ms * AppState.settings-scroll-speed; easing: ease-in-out; }

                landing-content := VerticalLayout {
                    if AppState.discover-trending.length > 0: SectionRow {
                        section-title:   "Trending";
                        items:           AppState.discover-trending;
                        section-focused: AppState.focused-section == 0;
                        focused-card:    AppState.discover-landing-card;
                        card-w:          AppState.dash-cw;
                        card-h:          AppState.dash-ch;
                        item-play(id, it) => { AppState.open-discover-item(it == "DiscoverMovie" ? "movie" : "tv", id); }
                    }
                    if AppState.discover-popular-movies.length > 0: SectionRow {
                        section-title:   "Popular Movies";
                        items:           AppState.discover-popular-movies;
                        section-focused: AppState.focused-section == 1;
                        focused-card:    AppState.discover-landing-card;
                        card-w:          AppState.dash-cw;
                        card-h:          AppState.dash-ch;
                        item-play(id, it) => { AppState.open-discover-item(it == "DiscoverMovie" ? "movie" : "tv", id); }
                    }
                    if AppState.discover-popular-tv.length > 0: SectionRow {
                        section-title:   "Popular TV Shows";
                        items:           AppState.discover-popular-tv;
                        section-focused: AppState.focused-section == 2;
                        focused-card:    AppState.discover-landing-card;
                        card-w:          AppState.dash-cw;
                        card-h:          AppState.dash-ch;
                        item-play(id, it) => { AppState.open-discover-item(it == "DiscoverMovie" ? "movie" : "tv", id); }
                    }
                    if AppState.discover-upcoming-movies.length > 0: SectionRow {
                        section-title:   "Upcoming Movies";
                        items:           AppState.discover-upcoming-movies;
                        section-focused: AppState.focused-section == 3;
                        focused-card:    AppState.discover-landing-card;
                        card-w:          AppState.dash-cw;
                        card-h:          AppState.dash-ch;
                        item-play(id, it) => { AppState.open-discover-item(it == "DiscoverMovie" ? "movie" : "tv", id); }
                    }
                    if AppState.discover-upcoming-tv.length > 0: SectionRow {
                        section-title:   "Upcoming TV Shows";
                        items:           AppState.discover-upcoming-tv;
                        section-focused: AppState.focused-section == 4;
                        focused-card:    AppState.discover-landing-card;
                        card-w:          AppState.dash-cw;
                        card-h:          AppState.dash-ch;
                        item-play(id, it) => { AppState.open-discover-item(it == "DiscoverMovie" ? "movie" : "tv", id); }
                    }
                    if AppState.discover-requested.length > 0: SectionRow {
                        section-title:   "Requested";
                        items:           AppState.discover-requested;
                        section-focused: AppState.focused-section == 5;
                        focused-card:    AppState.discover-landing-card;
                        card-w:          AppState.dash-cw;
                        card-h:          AppState.dash-ch;
                        item-play(id, it) => { AppState.open-discover-item(it == "DiscoverMovie" ? "movie" : "tv", id); }
                    }
                }
            }
        }

        if AppState.discover-query != "" && AppState.discover-results.length == 0 && !AppState.discover-searching: Rectangle {
            vertical-stretch: 1;
            Text {
                text:                 "No results for \"\{AppState.discover-query}\".";
                color:                Theme.text-muted;
                font-size:            14px;
                horizontal-alignment: center;
                y:                    parent.height / 3;
                width:                parent.width;
            }
        }

        if AppState.discover-results.length > 0: fl-container := Rectangle {
            vertical-stretch:   1;
            horizontal-stretch: 1;
            // root.height (content-h), not self.height — see the doc comment
            // on content-h up top for why this container being conditionally
            // mounted makes self.height unsafe here specifically.
            property <length> kb-y: clamp(
                -AppState.discover-focused-row * (card-h + gap) + root.content-h / 2 - card-h / 2,
                min(0px, root.content-h - root.grid-content-height),
                0px
            );
            changed kb-y => { fl.viewport-y = kb-y; }

            fl := Flickable {
                viewport-width:  fl-container.width;
                viewport-height: max(fl-container.height, root.grid-content-height);
                animate viewport-y { duration: 150ms * AppState.settings-scroll-speed; easing: ease-out-expo; }

                VerticalLayout {
                    padding: gap;
                    spacing: gap;

                    for row-idx in (AppState.discover-results.length + AppState.library-cols - 1) / AppState.library-cols: HorizontalLayout {
                        alignment: start;
                        spacing:   gap;
                        height:    card-h;

                        for col-idx in AppState.library-cols: MediaCard {
                            property <int> idx: row-idx * AppState.library-cols + col-idx;
                            visible: idx < AppState.discover-results.length;
                            item:    AppState.discover-results[idx];
                            width:   card-w;
                            focused: AppState.focused-section == 0 && !AppState.discover-header-focused && idx == AppState.discover-focused;
                            clicked => {
                                AppState.focused-section      = 0;
                                AppState.discover-focused     = idx;
                                AppState.discover-focused-row = row-idx;
                                AppState.discover-header-focused = false;
                                let c = AppState.discover-results[idx];
                                AppState.open-discover-item(c.item-type == "DiscoverMovie" ? "movie" : "tv", c.id);
                            }
                        }
                    }
                }
            }
        }
    }
}
